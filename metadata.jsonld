  "@id": "https://data.riik.ee/dataset/estonian-legal-ontology",
  "@type": "dcat:Dataset",
  "dcterms:title": [
    {
      "@value": "Estonian Legal Ontology",
      "@language": "en"
    },
    {
      "@value": "Eesti oigusontoloogia",
      "@language": "et"
    }
  ],
  "dcterms:description": [
    {
      "@value": "A comprehensive, machine-readable ontology of Estonian and EU legislation in JSON-LD format. Maps 615 enacted laws, 22,832 draft legislation items, 12,137 Supreme Court decisions, 33,242 EU legal acts, and 22,290 EU court decisions into a semantic knowledge graph with 120,000+ semantic nodes. Includes 14 integration layers: cross-law references, court decision links, EU directive transposition mapping, EuroVoc taxonomy, amendment history, legal concept graph, deontic classification, institutional competence, sanction index, semantic similarity, and temporal validity.",
      "@language": "en"
    },
    {
      "@value": "Terviklik masinloetav Eesti ja EL oigusaktide ontoloogia JSON-LD formaadis. Kaardistab 615 kehtivat seadust, 22 832 eelnou, 12 137 Riigikohtu lahendit, 33 242 EL oigusakti ja 22 290 EL kohtulahendit semantilisse teadmusgraafi, mis sisaldab ule 120 000 semantilise soelme. Sisaldab 14 integratsioonikihti: ristviited seaduste vahel, kohtuotsuste seosed, EL direktiivide ulevotukaardistus, EuroVoc taksonoomia, muudatuste ajalugu, oigusmoistete graaf, deontiline klassifikatsioon, institutsioonide padevus, sanktsioonide indeks, semantiline sarnasus ja ajaline kehtivus.",
      "@language": "et"
    }
  ],
  "dcterms:creator": {
