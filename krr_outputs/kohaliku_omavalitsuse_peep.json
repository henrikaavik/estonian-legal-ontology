      "estleg:paragrahv": "§ 22",
      "rdfs:label": "§ 22. Volikogu ainupädevus",
      "estleg:requestedCluster": "local_government_bodies",
      "estleg:summary": "Sätestab küsimused, mida saab otsustada üksnes volikogu (nt eelarve, arengukava, kohalike õigusaktide vastuvõtmine).",
      "estleg:sourceAct": "Kohaliku omavalitsuse korralduse seadus",
