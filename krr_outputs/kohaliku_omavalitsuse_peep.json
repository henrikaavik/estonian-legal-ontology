      "estleg:paragrahv": "§ 50",
      "rdfs:label": "§ 50. Vallavanem/linnapea",
      "estleg:requestedCluster": "local_government_bodies",
      "estleg:summary": "Reguleerib vallavanema või linnapea staatust, valimist/määramist ning juhtimisrolli.",
      "estleg:sourceAct": "Kohaliku omavalitsuse korralduse seadus"
