      ],
      "estleg:paragrahv": "§ 30",
      "rdfs:label": "§ 30. Vallavalitsuse/linnavalitsuse pädevus",
      "estleg:requestedCluster": "local_government_bodies",
      "estleg:summary": "Kirjeldab täitevorgani ülesandeid volikogu otsuste elluviimisel ja igapäevase halduse korraldamisel.",
      "estleg:sourceAct": "Kohaliku omavalitsuse korralduse seadus"
    },
