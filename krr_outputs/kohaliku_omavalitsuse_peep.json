      "rdfs:label": "§ 49. Vallavalitsus/linnavalitsus",
      "estleg:requestedCluster": "local_government_bodies",
      "estleg:summary": "Määratleb valitsuse kui omavalitsusüksuse kollegiaalse täitevorgani.",
      "estleg:sourceAct": "Kohaliku omavalitsuse korralduse seadus"
