      ],
      "estleg:paragrahv": "§ 47",
      "rdfs:label": "§ 47. Volikogu komisjonid",
      "estleg:requestedCluster": "local_government_bodies",
      "estleg:summary": "Reguleerib volikogu komisjonide moodustamist ja rolli otsuste ettevalmistamisel.",
      "estleg:sourceAct": "Kohaliku omavalitsuse korralduse seadus"
    },
    {
