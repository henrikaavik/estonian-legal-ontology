      "estleg:paragrahv": "§ 48",
      "rdfs:label": "§ 48. Revisjonikomisjon",
      "estleg:requestedCluster": "local_government_bodies",
      "estleg:summary": "Sätestab revisjonikomisjoni kontrollifunktsiooni omavalitsuse vara ja eelarve kasutamise üle.",
      "estleg:sourceAct": "Kohaliku omavalitsuse korralduse seadus"
    },
    {
