      "rdfs:label": "Äriühingute restruktureerimine",
      "estleg:requestedCluster": "umberkujundamine_ja_lopetamine",
      "estleg:summary": "Reguleerib ühinemise ja jagunemise menetlust, õiguste-kohustuste üleminekut ning osanike/võlausaldajate kaitsemehhanisme.",
      "estleg:sourceAct": "Äriseadustik"
    },
    {
      "@id": "estleg:ARIS_Norm_062",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_ariseadustik"
      ],
      "estleg:paragrahv": "Ümberkujundamine",
      "rdfs:label": "Äriühingu õigusliku vormi muutmine",
      "estleg:requestedCluster": "umberkujundamine_ja_lopetamine",
      "estleg:summary": "Võimaldab ühingu õigusliku vormi muutmist, säilitades juriidilise järjepidevuse ja järgides kaitsenõudeid.",
      "estleg:sourceAct": "Äriseadustik"
    },
    {
      "@id": "estleg:ARIS_Norm_063",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_ariseadustik"
      ],
      "estleg:paragrahv": "Lõpetamine ja likvideerimine",
      "rdfs:label": "Ühingu lõpetamise alused",
      "estleg:requestedCluster": "umberkujundamine_ja_lopetamine",
