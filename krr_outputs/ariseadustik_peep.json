      "estleg:sourceAct": "Äriseadustik"
    },
    {
      "@id": "estleg:ARIS_Norm_043",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_ariseadustik"
      ],
      "estleg:paragrahv": "Osaühing",
      "rdfs:label": "Osanike otsused ja hääleõigus",
      "estleg:requestedCluster": "osa_uhing",
      "estleg:summary": "Reguleerib osanike pädevust, üldkoosoleku läbiviimist, otsuste vastuvõtmise kvoorumit ja vaidlustamise võimalusi.",
      "estleg:sourceAct": "Äriseadustik"
    },
    {
      "@id": "estleg:ARIS_Norm_044",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_ariseadustik"
      ],
      "estleg:paragrahv": "Osaühing",
      "rdfs:label": "Juhatuse liikme kohustused ja vastutus",
      "estleg:requestedCluster": "osa_uhing",
      "estleg:summary": "Juhatus peab tegutsema korraliku ettevõtja hoolsusega; kohustuste rikkumisel võib järgneda isiklik vastutus ühingu ees.",
      "estleg:sourceAct": "Äriseadustik",
      "estleg:normativeType": [
        {
          "@id": "estleg:NormType_Obligation"
        }
      ],
      "estleg:dutyHolder": "Juhatus"
    },
    {
      "@id": "estleg:ARIS_Norm_045",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_ariseadustik"
      ],
      "estleg:paragrahv": "Osaühing",
      "rdfs:label": "Kasumi jaotamine",
      "estleg:requestedCluster": "osa_uhing",
