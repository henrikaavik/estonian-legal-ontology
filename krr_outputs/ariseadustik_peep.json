    {
      "@id": "estleg:ARIS_Norm_001",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_ariseadustik"
      ],
      "estleg:paragrahv": "Üldsätted (algusosa)",
      "rdfs:label": "Äriseadustiku kohaldamisala",
      "estleg:requestedCluster": "ettevotja_ja_ariregister",
      "estleg:summary": "Määratleb ettevõtja mõiste, ettevõtluse korraldamise põhivormid ning seaduse üldise kohaldamisala äritegevusele.",
      "estleg:sourceAct": "Äriseadustik"
    },
    {
      "@id": "estleg:ARIS_Norm_002",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_ariseadustik"
      ],
      "estleg:paragrahv": "Üldsätted (algusosa)",
      "rdfs:label": "Äriregistrisse kandmise põhimõte",
      "estleg:requestedCluster": "ettevotja_ja_ariregister",
      "estleg:summary": "Ettevõtja andmed, muudatused ja õiguslikult olulised asjaolud tehakse avalikuks registrikande kaudu; register toetab õiguskindlust kolmandate isikute suhtes.",
      "estleg:sourceAct": "Äriseadustik"
    },
    {
      "@id": "estleg:ARIS_Norm_003",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_ariseadustik"
      ],
      "estleg:paragrahv": "Üldsätted (algusosa)",
      "rdfs:label": "Äriregistri avalikkus ja usaldatavus",
      "estleg:requestedCluster": "ettevotja_ja_ariregister",
      "estleg:summary": "Registriandmete avalikkus võimaldab kolmandatel isikutel tugineda registrikannetele; kandmata või avaldamata andmetele tuginemine võib olla piiratud.",
      "estleg:sourceAct": "Äriseadustik",
      "estleg:normativeType": [
        {
          "@id": "estleg:NormType_Right"
        }
      ]
    },
    {
      "@id": "estleg:ARIS_Norm_004",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_ariseadustik"
      ],
      "estleg:paragrahv": "Üldsätted (algusosa)",
      "rdfs:label": "Ärinime nõuded",
      "estleg:requestedCluster": "arinimi_ja_esindus",
      "estleg:summary": "Ärinimi peab vastama seaduse nõuetele, olema eristatav ja mitte eksitav; teatud tähiste kasutamine võib olla piiratud.",
      "estleg:sourceAct": "Äriseadustik",
      "estleg:normativeType": [
        {
          "@id": "estleg:NormType_Obligation"
        }
      ],
      "estleg:dutyHolder": "Ärinimi"
    },
    {
      "@id": "estleg:ARIS_Norm_005",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_ariseadustik"
      ],
      "estleg:paragrahv": "Üldsätted (algusosa)",
      "rdfs:label": "Ettevõtja asukoht ja aadress",
      "estleg:requestedCluster": "arinimi_ja_esindus",
      "estleg:summary": "Ettevõtjal peab olema registris kajastatud asukoht ja kontaktandmed, mis tagavad õigusliku suhtluse kättesaadavuse.",
      "estleg:sourceAct": "Äriseadustik",
      "estleg:normativeType": [
        {
          "@id": "estleg:NormType_Obligation"
        }
      ],
      "estleg:dutyHolder": "Ettevõtjal"
    },
    {
      "@id": "estleg:ARIS_Norm_006",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_ariseadustik"
      ],
      "estleg:paragrahv": "Üldsätted (algusosa)",
      "rdfs:label": "Esindusõigus ja esinduse piirangud",
      "estleg:requestedCluster": "arinimi_ja_esindus",
      "estleg:summary": "Juriidilise isiku esindusõigus tekib seaduse ja registrikande alusel; sisemised piirangud ei pruugi kolmandate isikute suhtes kehtida.",
      "estleg:sourceAct": "Äriseadustik"
    },
    {
      "@id": "estleg:ARIS_Norm_010",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_ariseadustik"
      ],
      "estleg:paragrahv": "Filiaal",
      "rdfs:label": "Välisühingu filiaali registreerimine",
      "estleg:requestedCluster": "valis_uhing",
      "estleg:summary": "Välisriigi äriühingu filiaal Eestis peab olema registrisse kantud ning avaldama andmed emaühingu, esindajate ja tegevuskoha kohta.",
      "estleg:sourceAct": "Äriseadustik",
      "estleg:normativeType": [
        {
          "@id": "estleg:NormType_Obligation"
        }
      ],
      "estleg:dutyHolder": "Eestis"
    },
    {
      "@id": "estleg:ARIS_Norm_011",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_ariseadustik"
      ],
      "estleg:paragrahv": "Filiaal",
      "rdfs:label": "Filiaali vastutus ja teabeandmine",
      "estleg:requestedCluster": "valis_uhing",
      "estleg:summary": "Filiaal tegutseb emaühingu nimel; avalikkusele tuleb anda selge teave filiaali staatusest ning välisühingu vastutusest.",
      "estleg:sourceAct": "Äriseadustik",
      "estleg:normativeType": [
        {
          "@id": "estleg:NormType_Obligation"
        }
      ]
    },
    {
      "@id": "estleg:ARIS_Norm_020",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_ariseadustik"
      ],
      "estleg:paragrahv": "Täisühing",
      "rdfs:label": "Täisühingu asutamine",
      "estleg:requestedCluster": "tais_uhing",
      "estleg:summary": "Täisühing tekib osanike lepingu ja registrikande alusel; osanikud osalevad juhtimises ning vastutavad üldjuhul isiklikult.",
      "estleg:sourceAct": "Äriseadustik"
    },
    {
      "@id": "estleg:ARIS_Norm_021",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_ariseadustik"
      ],
      "estleg:paragrahv": "Täisühing",
      "rdfs:label": "Täisosanike solidaarne vastutus",
      "estleg:requestedCluster": "tais_uhing",
      "estleg:summary": "Täisosanike vastutus ühingu kohustuste eest on üldjuhul solidaarne ja piiramatu, kui seadus ei sätesta teisiti.",
      "estleg:sourceAct": "Äriseadustik"
    },
    {
      "@id": "estleg:ARIS_Norm_030",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_ariseadustik"
      ],
      "estleg:paragrahv": "Usaldusühing",
      "rdfs:label": "Usaldusühingu osanike liigid",
      "estleg:requestedCluster": "usaldus_uhing",
      "estleg:summary": "Usaldusühingus eristatakse täisosanikku ja usaldusosanikku; nende juhtimisõigus ning vastutus ulatuvad erinevalt.",
      "estleg:sourceAct": "Äriseadustik"
    },
    {
      "@id": "estleg:ARIS_Norm_031",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_ariseadustik"
      ],
      "estleg:paragrahv": "Usaldusühing",
      "rdfs:label": "Usaldusosaniku vastutuse piirid",
      "estleg:requestedCluster": "usaldus_uhing",
      "estleg:summary": "Usaldusosaniku vastutus on seotud sissemakse ulatusega, kuid teatud juhtudel võib vastutus laieneda, kui usaldusosanik tegutseb täisosaniku rollis.",
      "estleg:sourceAct": "Äriseadustik",
      "estleg:normativeType": [
        {
          "@id": "estleg:NormType_Right"
        }
      ]
    },
    {
      "@id": "estleg:ARIS_Norm_040",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_ariseadustik"
      ],
      "estleg:paragrahv": "Osaühing",
      "rdfs:label": "Osaühingu asutamine ja põhikiri",
      "estleg:requestedCluster": "osa_uhing",
      "estleg:summary": "Osaühing luuakse asutamisotsuse, põhikirja ja registrikande alusel; sätestatakse osakapital, osade jaotus ning juhtorganid.",
      "estleg:sourceAct": "Äriseadustik"
    },
    {
      "@id": "estleg:ARIS_Norm_041",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_ariseadustik"
      ],
      "estleg:paragrahv": "Osaühing",
      "rdfs:label": "Osakapital ja sissemaksed",
      "estleg:requestedCluster": "osa_uhing",
      "estleg:summary": "Reguleerib osakapitali moodustamist, sissemaksete tingimusi ja vajadusel mitterahaliste sissemaksete hindamist.",
      "estleg:sourceAct": "Äriseadustik"
    },
    {
      "@id": "estleg:ARIS_Norm_042",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_ariseadustik"
      ],
      "estleg:paragrahv": "Osaühing",
      "rdfs:label": "Osa võõrandamine ja pantimine",
      "estleg:requestedCluster": "osa_uhing",
