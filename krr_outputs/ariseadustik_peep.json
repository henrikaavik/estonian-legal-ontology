      "estleg:paragrahv": "Aktsiaselts",
      "rdfs:label": "Aktsiaseltsi asutamine",
      "estleg:requestedCluster": "aktsia_selts",
      "estleg:summary": "Aktsiaseltsi loomisel määratakse aktsiakapital, aktsiate liigid ja juhtimismudel; ühing tekib registrikandega.",
      "estleg:sourceAct": "Äriseadustik"
    },
    {
      "@id": "estleg:ARIS_Norm_051",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_ariseadustik"
