    {
      "@id": "estleg:RRKU_Par_1",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_RRKU"
      ],
      "estleg:paragrahv": "§ 1.",
      "rdfs:label": "§ 1. Konventsiooniga ühinemine",
      "estleg:sourceAct": "Rahvusvahelise raudteeveo konventsiooniga ühinemise seadus",
      "estleg:summary": "Ühineda rahvusvahelise raudteeveo konventsiooniga ./755199 (COTIF, edaspidi konventsioon), mis on koostatud 1980. aasta 9. mail Bernis ja mida on muudetud 1999. aasta 3. juunil Vilniuses koostatud protokolliga. RT II 2008 15 39 12980419 2008-07-14+03:00 Ühineda (COTIF, edaspidi konventsioon), mis on koostatud 1980. aasta 9. mail Bernis ja mida on muudetud 1999. aasta 3. juunil Vilniuses koostatud protokolliga."
    },
    {
      "@id": "estleg:RRKU_Par_2",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_RRKU"
      ],
      "estleg:paragrahv": "§ 2.",
      "rdfs:label": "§ 2. Reservatsioonid",
      "estleg:sourceAct": "Rahvusvahelise raudteeveo konventsiooniga ühinemise seadus",
      "estleg:summary": "Kooskõlas konventsiooni artikliga 42 teeb Eesti Vabariik järgmised reservatsioonid: 1 1) konventsiooni lisa A «Reisijate rahvusvahelise raudteeveo lepingu ühtsed eeskirjad» (CIV) artikli 2 lõike 1 alusel kasutab Eesti Vabariik õigust jätta kohaldamata lisa A artikkel 30, milles käsitletakse raudtee-ettevõtja vastutust Eesti territooriumil toimunud õnnetusjuhtumis kannatanud reisija surma või vigastuste korral, kui nimetatud reisija on Eesti Vabariigi kodanik või kui reisija alaline elukoht on Ee"
    },
    {
      "@id": "estleg:RRKU_Par_3",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_RRKU"
      ],
      "estleg:paragrahv": "§ 3.",
      "rdfs:label": "§ 3. Deklaratsioonid",
      "estleg:sourceAct": "Rahvusvahelise raudteeveo konventsiooniga ühinemise seadus",
      "estleg:summary": "Eesti Vabariik teeb järgmised deklaratsioonid: 1 1) konventsiooni artikli 24 ja lisa A «Reisijate rahvusvahelise raudteeveo lepingu ühtsed eeskirjad» (CIV) artikli 1 lõike 6 alusel kohaldab Eesti Vabariik konventsiooni lisa A ainult Tallinna–Tapa–Valga liini mõlemal suunal toimuvale reisijate rahvusvahelisele raudteeveole; RT II 2008 15 39 12980419 2008-07-14+03:00 2 2) konventsiooni artiklite 3 ja 24 ning lisa B «Kaupade rahvusvahelise raudteeveo lepingu ühtsed eeskirjad» (CIM) artikli 1 lõike "
    }
  ]
