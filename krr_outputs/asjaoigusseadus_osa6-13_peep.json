    },
    {
      "@id": "estleg:AOS_Par_141",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_AOS_osa6_13"
      ],
      "estleg:paragrahv": "§ 141",
      "rdfs:label": "Kitsenduste kehtivus",
      "estleg:requestedCluster": "osa6_asjaoiguste_vahendamine",
      "estleg:summary": "Kinnisasja kasutamisel tuleb arvestada seadusest ja eraõigussuhetest tulenevate kitsendustega; kitsendused kehtivad õigusjärglaste suhtes.",
      "estleg:sourceAct": "Asjaõigusseadus",
      "estleg:normativeType": [
        {
          "@id": "estleg:NormType_Obligation"
        }
      ],
      "estleg:dutyHolder": "Kinnisasja kasutamisel"
    },
    {
      "@id": "estleg:AOS_Par_143",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_AOS_osa6_13"
      ],
      "estleg:paragrahv": "§ 143",
      "rdfs:label": "Kahjulikud mõjutused",
      "estleg:requestedCluster": "osa6_asjaoiguste_vahendamine",
      "estleg:summary": "Naaberkinnisasja omanik peab hoiduma sellistest mõjutustest, mis ületavad tavapärase talumiskohustuse; rikkumise korral saab nõuda mõjutuse lõpetamist.",
      "estleg:sourceAct": "Asjaõigusseadus",
      "estleg:normativeType": [
        {
          "@id": "estleg:NormType_Obligation"
        }
      ],
      "estleg:dutyHolder": "Naaberkinnisasja omanik",
      "estleg:referencedBy": [
        {
          "@id": "estleg:KORTER_Par_31"
        },
        {
          "@id": "estleg:TeeS_Par_21"
        }
      ]
    },
    {
      "@id": "estleg:AOS_Par_145",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_AOS_osa6_13"
      ],
      "estleg:paragrahv": "§ 145",
      "rdfs:label": "Varisemisohtlik ehitis",
      "estleg:requestedCluster": "osa6_asjaoiguste_vahendamine",
      "estleg:summary": "Kui ehitis või rajatis ohustab naaberkinnisasja, võib naaber nõuda ohu kõrvaldamist ja vajalikke kaitsemeetmeid.",
      "estleg:sourceAct": "Asjaõigusseadus",
      "estleg:normativeType": [
        {
          "@id": "estleg:NormType_Right"
        }
      ],
      "estleg:referencedBy": [
        {
          "@id": "estleg:TeeS_Par_21"
        }
      ]
    },
    {
      "@id": "estleg:AOS_Par_172",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_AOS_osa6_13"
      ],
      "estleg:paragrahv": "§ 172",
      "rdfs:label": "Reaalservituudi mõiste",
      "estleg:requestedCluster": "osa7_servituut",
      "estleg:summary": "Reaalservituut koormab üht kinnisasja teise kinnisasja kasuks, andes valitseva kinnisasja omanikule kindla kasutusõiguse või keelates teatud tegevused teenival kinnisasjal.",
      "estleg:sourceAct": "Asjaõigusseadus"
    },
    {
      "@id": "estleg:AOS_Par_173",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_AOS_osa6_13"
      ],
      "estleg:paragrahv": "§ 173",
      "rdfs:label": "Reaalservituudi tekkimine",
      "estleg:requestedCluster": "osa7_servituut",
      "estleg:summary": "Reaalservituut tekib asjaõiguslepingu ja kinnistusraamatu kandega, kui seadus ei sätesta teisiti.",
      "estleg:sourceAct": "Asjaõigusseadus"
    },
    {
      "@id": "estleg:AOS_Par_180",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_AOS_osa6_13"
      ],
      "estleg:paragrahv": "§ 180",
      "rdfs:label": "Reaalservituudi teostamise viisi muutmine",
      "estleg:requestedCluster": "osa7_servituut",
      "estleg:summary": "Servituudi teostamise viisi saab kohandada, kui see on vajalik poolte huvide tasakaalustamiseks ja ei muuda õiguse tuuma.",
      "estleg:sourceAct": "Asjaõigusseadus"
    },
    {
      "@id": "estleg:AOS_Par_229",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_AOS_osa6_13"
      ],
      "estleg:paragrahv": "§ 229",
      "rdfs:label": "Reaalkoormatise mõiste",
      "estleg:requestedCluster": "osa8_reaalservituut",
      "estleg:summary": "Reaalkoormatis seob kinnisasja omaniku kohustusega teha perioodilisi sooritusi õigustatud isikule.",
      "estleg:sourceAct": "Asjaõigusseadus"
    },
    {
      "@id": "estleg:AOS_Par_231",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_AOS_osa6_13"
      ],
      "estleg:paragrahv": "§ 231",
      "rdfs:label": "Reaalkoormatise tekkimine",
      "estleg:requestedCluster": "osa8_reaalservituut",
      "estleg:summary": "Reaalkoormatis tekib kokkuleppe alusel ja kinnistusraamatu kandega.",
      "estleg:sourceAct": "Asjaõigusseadus"
    },
    {
      "@id": "estleg:AOS_Par_233",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_AOS_osa6_13"
      ],
      "estleg:paragrahv": "§ 233",
      "rdfs:label": "Reaalkoormatise lõpetamine õigustatud isiku nõudel",
      "estleg:requestedCluster": "osa8_reaalservituut",
      "estleg:summary": "Õigustatud isik võib teatud tingimustel nõuda reaalkoormatise lõpetamist ning vastava kande kustutamist.",
      "estleg:sourceAct": "Asjaõigusseadus",
      "estleg:normativeType": [
        {
          "@id": "estleg:NormType_Right"
        }
      ]
    },
    {
      "@id": "estleg:AOS_Par_225",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_AOS_osa6_13"
      ],
      "estleg:paragrahv": "§ 225",
      "rdfs:label": "Isikliku kasutusõiguse mõiste",
      "estleg:requestedCluster": "osa9_kasutusoigus",
      "estleg:summary": "Isiklik kasutusõigus annab õigustatud isikule õiguse kasutada kinnisasja kokkulepitud ulatuses.",
      "estleg:sourceAct": "Asjaõigusseadus"
    },
    {
      "@id": "estleg:AOS_Par_226",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_AOS_osa6_13"
      ],
      "estleg:paragrahv": "§ 226",
      "rdfs:label": "Isikliku kasutusõiguse üleandmine",
      "estleg:requestedCluster": "osa9_kasutusoigus",
      "estleg:summary": "Isiklik kasutusõigus on üldjuhul isikuga seotud; üleandmine on piiratud seaduse või kokkuleppe alusel.",
      "estleg:sourceAct": "Asjaõigusseadus"
    },
    {
      "@id": "estleg:AOS_Par_228",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_AOS_osa6_13"
      ],
      "estleg:paragrahv": "§ 228",
      "rdfs:label": "Reaalservituudi ja kasutusvalduse sätete kohaldamine",
      "estleg:requestedCluster": "osa9_kasutusoigus",
      "estleg:summary": "Isiklikule kasutusõigusele kohaldatakse täiendavalt reaalservituudi ja kasutusvalduse norme, kui see sobib õiguse olemusega.",
      "estleg:sourceAct": "Asjaõigusseadus"
    },
    {
      "@id": "estleg:AOS_Par_244_asjaoigusseadus_osa6_13",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_AOS_osa6_13"
      ],
      "estleg:paragrahv": "§ 244",
      "rdfs:label": "Hoonestusõiguse lõpetamine kokkuleppel",
      "estleg:requestedCluster": "osa10_hoonestusoiguse_lopetamine",
      "estleg:summary": "Hoonestusõigus saab lõppeda poolte kokkuleppel ning kinnistusraamatu vastava kande kustutamisel.",
      "estleg:sourceAct": "Asjaõigusseadus"
    },
    {
      "@id": "estleg:AOS_Par_245_asjaoigusseadus_osa6_13",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_AOS_osa6_13"
      ],
      "estleg:paragrahv": "§ 245",
      "rdfs:label": "Hoonestusõiguse lõpetamine selle omandamisel kinnisasja omaniku poolt",
      "estleg:requestedCluster": "osa10_hoonestusoiguse_lopetamine",
      "estleg:summary": "Kui kinnisasja omanik omandab hoonestusõiguse, lõpeb hoonestusõigus ühinemise tõttu.",
      "estleg:sourceAct": "Asjaõigusseadus"
    },
    {
      "@id": "estleg:AOS_Par_253_asjaoigusseadus_osa6_13",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_AOS_osa6_13"
      ],
      "estleg:paragrahv": "§ 253",
      "rdfs:label": "Hüvitis hoonestusõiguse tähtaja möödumisel",
      "estleg:requestedCluster": "osa10_hoonestusoiguse_lopetamine",
      "estleg:summary": "Hoonestusõiguse tähtaja lõppemisel reguleerib seadus ehitise saatust ja hüvitise maksmise aluseid.",
      "estleg:sourceAct": "Asjaõigusseadus"
    },
    {
      "@id": "estleg:AOS_Par_238",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_AOS_osa6_13"
      ],
      "estleg:paragrahv": "§ 238",
      "rdfs:label": "Reaalkoormatise üleantavus",
      "estleg:requestedCluster": "osa11_parimisoigus",
      "estleg:summary": "Õigus ja kohustus reaalkoormatise suhtes järgib kinnisasja õigusjärglust ning läheb üle koos õigussuhete järjepidevusega.",
      "estleg:sourceAct": "Asjaõigusseadus"
    },
    {
      "@id": "estleg:AOS_Par_249_asjaoigusseadus_osa6_13",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_AOS_osa6_13"
      ],
      "estleg:paragrahv": "§ 249",
      "rdfs:label": "Hoonestusõiguse käsutamine",
      "estleg:requestedCluster": "osa11_parimisoigus",
      "estleg:summary": "Hoonestusõiguse käsutamine ning selle üleminek õigusjärglastele toimub asjaõiguslike käsutuste üldreeglite järgi.",
      "estleg:sourceAct": "Asjaõigusseadus"
    },
    {
      "@id": "estleg:AOS_Par_260",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_AOS_osa6_13"
      ],
      "estleg:paragrahv": "§ 260",
      "rdfs:label": "Ostueesõiguse üleandmise piirangud",
      "estleg:requestedCluster": "osa11_parimisoigus",
      "estleg:summary": "Ostueesõiguse üleminek on piiratud; pärimise ja muu õigusjärgluse küsimused alluvad seaduses sätestatud tingimustele.",
      "estleg:sourceAct": "Asjaõigusseadus"
    },
    {
      "@id": "estleg:AOS_Par_80_asjaoigusseadus_osa6_13",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_AOS_osa6_13"
      ],
      "estleg:paragrahv": "§ 80",
      "rdfs:label": "Asja väljanõudmine ebaseaduslikust valdusest",
      "estleg:requestedCluster": "osa12_asjaoiguste_kaitse",
      "estleg:summary": "Omanikul on õigus nõuda asja tagastamist isikult, kes valdab seda õigusliku aluseta.",
      "estleg:sourceAct": "Asjaõigusseadus",
      "estleg:normativeType": [
        {
          "@id": "estleg:NormType_Right"
        }
      ]
    },
    {
      "@id": "estleg:AOS_Par_89_asjaoigusseadus_osa6_13",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_AOS_osa6_13"
      ],
      "estleg:paragrahv": "§ 89",
      "rdfs:label": "Omandi kaitse valduse kaotusega mitteseotud rikkumise korral",
      "estleg:requestedCluster": "osa12_asjaoiguste_kaitse",
      "estleg:summary": "Omanik võib nõuda rikkumise lõpetamist ja edasise rikkumise vältimist ka siis, kui valdus ei ole ära võetud.",
      "estleg:sourceAct": "Asjaõigusseadus",
      "estleg:normativeType": [
        {
          "@id": "estleg:NormType_Right"
        }
      ]
    },
    {
      "@id": "estleg:AOS_Par_90_asjaoigusseadus_osa6_13",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_AOS_osa6_13"
      ],
      "estleg:paragrahv": "§ 90",
      "rdfs:label": "Valdaja omandi eeldus",
      "estleg:requestedCluster": "osa12_asjaoiguste_kaitse",
      "estleg:summary": "Valduse olemasolu tekitab omandi eelduse, mida saab ümber lükata vastupidise tõendamisega.",
      "estleg:sourceAct": "Asjaõigusseadus"
    },
    {
      "@id": "estleg:AOS_Par_255",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_AOS_osa6_13"
      ],
      "estleg:paragrahv": "§ 255",
      "rdfs:label": "Maksud ja koormatised",
      "estleg:requestedCluster": "osa13_rakendamine",
      "estleg:summary": "Rakendamisel täpsustatakse maksude, tasude ja kinnisasjaga seotud koormatiste kandmise põhimõtteid.",
      "estleg:sourceAct": "Asjaõigusseadus"
    },
    {
      "@id": "estleg:AOS_Par_256",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_AOS_osa6_13"
      ],
      "estleg:paragrahv": "§ 256",
      "rdfs:label": "Ostueesõiguse mõiste",
      "estleg:requestedCluster": "osa13_rakendamine",
      "estleg:summary": "Säte määratleb ostueesõiguse kui õiguse astuda müügilepingusse ostja asemele seaduses sätestatud korras.",
      "estleg:sourceAct": "Asjaõigusseadus"
    },
    {
      "@id": "estleg:AOS_Par_257",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_AOS_osa6_13"
      ],
      "estleg:paragrahv": "§ 257",
      "rdfs:label": "Ostueesõiguse seadmine ja tähendus",
      "estleg:requestedCluster": "osa13_rakendamine",
      "estleg:summary": "Ostueesõiguse tekkimine eeldab vastavat seadmist ning annab õigustatud isikule prioriteedi asja omandamisel.",
      "estleg:sourceAct": "Asjaõigusseadus",
      "estleg:interpretedBy": [
        {
          "@id": "estleg:RK_3_4_1_1_06"
        }
      ]
    },
    {
      "@id": "estleg:AOS_Par_260_dup2",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_AOS_osa6_13"
      ],
      "estleg:paragrahv": "§ 260",
      "rdfs:label": "Ostueesõiguse üleandmise piirangud",
      "estleg:requestedCluster": "osa13_rakendamine",
      "estleg:summary": "Norm piirab ostueesõiguse loovutamist ja sätestab ülemineku eeldused.",
      "estleg:sourceAct": "Asjaõigusseadus"
    },
    {
      "@id": "estleg:AOS_Par_261",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_AOS_osa6_13"
      ],
      "estleg:paragrahv": "§ 261",
      "rdfs:label": "Ostueesõiguse teostamise tagajärjed",
      "estleg:requestedCluster": "osa13_rakendamine",
      "estleg:summary": "Paragrahv reguleerib ostueesõiguse teostamisel ostja ja õigustatud isiku vaheliste õiguste ning kohustuste ümberjaotust.",
      "estleg:sourceAct": "Asjaõigusseadus"
    },
    {
      "@id": "estleg:AOS_Par_262",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_AOS_osa6_13"
      ],
      "estleg:paragrahv": "§ 262",
      "rdfs:label": "Ostueesõiguse sisu täpsustused",
      "estleg:requestedCluster": "osa13_rakendamine",
      "estleg:summary": "Säte täpsustab ostueesõiguse sisulisi ja menetluslikke piiranguid kinnisasja võõrandamisel.",
      "estleg:sourceAct": "Asjaõigusseadus"
    },
    {
      "@id": "estleg:AOS_Par_263",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_AOS_osa6_13"
      ],
      "estleg:paragrahv": "§ 263",
      "rdfs:label": "Rakendussäte",
      "estleg:requestedCluster": "osa13_rakendamine",
      "estleg:summary": "Rakendussäte tähistab üleminekureeglite koondpunkti Osa 13 lõpetamisel (ajaloolistes redaktsioonides käsitletud ulatuses).",
      "estleg:sourceAct": "Asjaõigusseadus"
    }
  ]
}
