      "rdfs:label": "Vara jagamine (division of property)"
    },
    {
      "@id": "estleg:AOS_Osa11_Par_70",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_asjaoigusseadus_osa11"
      ],
      "estleg:paragrahv": "§ 70",
      "rdfs:label": "Ühisomandi mõiste ja suhe kaasomandiga",
      "estleg:requestedCluster": "community_property",
      "estleg:summary": "Määratleb ühisomandi kui ühise õiguse liigi, kus osad ei ole kindlaks määratud, ning eristab seda kaasomandist.",
      "estleg:sourceAct": "Asjaõigusseadus"
    },
    {
      "@id": "estleg:AOS_Osa11_Par_71",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_asjaoigusseadus_osa11"
      ],
      "estleg:paragrahv": "§ 71",
      "rdfs:label": "Ühisomanike ühine teostamine",
      "estleg:requestedCluster": "community_property",
      "estleg:summary": "Ühisomandis oleva asja valdamine, kasutamine ja käsutamine toimub ühiselt, kui seadus või õigussuhte laad ei näe ette teisiti.",
      "estleg:sourceAct": "Asjaõigusseadus"
    },
    {
      "@id": "estleg:AOS_Osa11_Par_72",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_asjaoigusseadus_osa11"
      ],
      "estleg:paragrahv": "§ 72",
      "rdfs:label": "Ühisomandi valitsemine",
      "estleg:requestedCluster": "community_property",
      "estleg:summary": "Kehtestab ühisomandi valitsemise üldise raami, sh otsuste tegemise ja majandamise põhimõtted.",
      "estleg:sourceAct": "Asjaõigusseadus"
    },
    {
      "@id": "estleg:AOS_Par_70_Lg6",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_asjaoigusseadus_osa11"
      ],
      "estleg:paragrahv": "§ 70 lg 6",
      "rdfs:label": "Abikaasade ühisvara seos ühisomandi regulatsiooniga",
      "estleg:requestedCluster": "spouses_property",
      "estleg:summary": "Abikaasade ühisvarale kohaldatakse ühisomandi põhimõtteid ulatuses, milles perekonnaõiguslikud erinormid ei sätesta teisiti.",
      "estleg:sourceAct": "Asjaõigusseadus"
    },
    {
      "@id": "estleg:AOS_Par_73_Context",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_asjaoigusseadus_osa11"
      ],
      "estleg:paragrahv": "§ 73 (süsteemne kontekst)",
      "rdfs:label": "Mõttelise osa käsutamise piirid võrreldes ühisvaraga",
      "estleg:requestedCluster": "spouses_property",
      "estleg:summary": "Kaasomandi osa käsutamise norm rõhutab erinevust ühisvarast: abikaasade ühisomandis ei ole kumbalgi eelnevalt määratletud mõttelist osa vaba käsutamiseks.",
      "estleg:sourceAct": "Asjaõigusseadus"
    },
    {
      "@id": "estleg:AOS_Osa11_Par_76",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_asjaoigusseadus_osa11"
      ],
      "estleg:paragrahv": "§ 76",
      "rdfs:label": "Ühisomandi lõpetamise nõue",
      "estleg:requestedCluster": "division_of_property",
      "estleg:summary": "Annab aluse ühisomandi lõpetamise nõudeks; see on keskne lähtepunkt ühisvara jagamisel juhul, kui eriseadus ei välista lõpetamist.",
      "estleg:sourceAct": "Asjaõigusseadus"
    },
    {
      "@id": "estleg:AOS_Osa11_Par_77",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_asjaoigusseadus_osa11"
      ],
      "estleg:paragrahv": "§ 77",
      "rdfs:label": "Kaasomandi lõpetamise viisid",
      "estleg:requestedCluster": "division_of_property",
      "estleg:summary": "Kirjeldab lõpetamise viise (jagamine, hüvitus, müük), mida kasutatakse analoogiana ka ühisvara jagamise tehniliste lahenduste hindamisel.",
      "estleg:sourceAct": "Asjaõigusseadus"
    },
    {
      "@id": "estleg:AOS_Par_78_79",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_asjaoigusseadus_osa11"
      ],
      "estleg:paragrahv": "§ 78–79",
      "rdfs:label": "Asja jagamine või müük jagamisel",
      "estleg:requestedCluster": "division_of_property",
      "estleg:summary": "Sätestab jaotusmehhanismid olukordadeks, kus asi jagatakse naturaalselt või võõrandatakse ning väärtus jaotatakse osaliste vahel.",
      "estleg:sourceAct": "Asjaõigusseadus"
    },
    {
      "@id": "estleg:Concept_CommunityProperty",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "rdfs:label": "Ühisomandi tuum",
      "skos:definition": "Ühisomand tähendab ühist õigust ilma eelnevalt määratud mõtteliste osadeta; õiguste teostamine toimub reeglina ühiselt.",
      "estleg:belongsToCluster": "community_property"
    },
    {
      "@id": "estleg:Concept_SpousesPropertyRegimeLink",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "rdfs:label": "Abieluvara ja asjaõiguse seos",
      "skos:definition": "Abikaasade ühisvara asjaõiguslik raamistik tugineb ühisomandi normidele ning suhestub perekonnaõiguslike erireeglitega.",
      "estleg:belongsToCluster": "spouses_property"
    },
    {
      "@id": "estleg:Concept_PropertyDivisionMechanics",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "rdfs:label": "Vara jagamise mehhanismid",
      "skos:definition": "Vara jagamisel eelistatakse õiglast ja majanduslikult põhjendatud lahendust: jagamine esemeliselt, hüvitise määramine või müük ja tulu jaotus.",
      "estleg:belongsToCluster": "division_of_property"
    }
  ]
