    {
      "@id": "estleg:TsUS_Par_142",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_tsiviilseadustik_osa4"
      ],
      "estleg:paragrahv": "§142",
      "rdfs:label": "Aegumise mõiste",
      "estleg:requestedCluster": "limitation_periods_142_157",
      "estleg:summary": "Määratleb nõude aegumise, aegumistähtaja ja tagajärje: kohustatud isik võib pärast aegumist täitmisest keelduda; erandina võivad mõned nõuded mitte aeguda.",
      "estleg:relatesToConcept": "estleg:Concept_LimitationPeriodCore",
      "estleg:sourceAct": "Tsiviilseadustiku üldosa seadus"
    },
    {
      "@id": "estleg:TsUS_Par_143",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_tsiviilseadustik_osa4"
      ],
      "estleg:paragrahv": "§143",
      "rdfs:label": "Aegumise arvestamine kohtu poolt",
      "estleg:requestedCluster": "limitation_periods_142_157",
      "estleg:summary": "Kohus arvestab aegumist üksnes kohustatud isiku vastava taotluse alusel.",
      "estleg:relatesToConcept": "estleg:Concept_LimitationPeriodCore",
      "estleg:sourceAct": "Tsiviilseadustiku üldosa seadus"
    },
    {
      "@id": "estleg:TsUS_Par_144",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_tsiviilseadustik_osa4"
      ],
      "estleg:paragrahv": "§144",
      "rdfs:label": "Kõrvalkohustusest tuleneva nõude aegumine",
      "estleg:requestedCluster": "limitation_periods_142_157",
      "estleg:summary": "Põhinõude aegumisega aegub ka kõrvalkohustusest tulenev nõue.",
      "estleg:relatesToConcept": "estleg:Concept_LimitationPeriodCore",
      "estleg:sourceAct": "Tsiviilseadustiku üldosa seadus"
    },
    {
      "@id": "estleg:TsUS_Par_145",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_tsiviilseadustik_osa4"
      ],
      "estleg:paragrahv": "§145",
      "rdfs:label": "Kokkulepe aegumise kohta",
      "estleg:requestedCluster": "limitation_periods_142_157",
      "estleg:summary": "Pooltel on piiratud ulatuses õigus aegumise tingimusi kergendada või tähtaega pikendada; aegumise kohaldamisest etteulatuv loobumine on tühine.",
      "estleg:relatesToConcept": "estleg:Concept_LimitationPeriodCore",
      "estleg:sourceAct": "Tsiviilseadustiku üldosa seadus"
    },
    {
      "@id": "estleg:TsUS_Par_145b1",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_tsiviilseadustik_osa4"
      ],
      "estleg:paragrahv": "§145¹",
      "rdfs:label": "Aegumise tagajärjed tagatisele",
      "estleg:requestedCluster": "limitation_periods_142_157",
      "estleg:summary": "Nõude aegumine ei võta teatud juhtudel tagatise realiseerimise õigust (nt pant, omandireservatsioon).",
      "estleg:relatesToConcept": "estleg:Concept_LimitationPeriodCore",
      "estleg:sourceAct": "Tsiviilseadustiku üldosa seadus"
    },
    {
      "@id": "estleg:TsUS_Par_146",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_tsiviilseadustik_osa4"
      ],
      "estleg:paragrahv": "§146",
      "rdfs:label": "Tehingust tuleneva nõude aegumistähtaeg",
      "estleg:requestedCluster": "limitation_periods_142_157",
      "estleg:summary": "Sätestab tehinguliste nõuete üld- ja eritähtajad (3, 5 ja 10 aastat olenevalt nõudest ja rikkumisest).",
      "estleg:relatesToConcept": "estleg:Concept_LimitationPeriodTypes",
      "estleg:sourceAct": "Tsiviilseadustiku üldosa seadus"
    },
    {
      "@id": "estleg:TsUS_Par_147",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_tsiviilseadustik_osa4"
      ],
      "estleg:paragrahv": "§147",
      "rdfs:label": "Aegumistähtaja algus",
      "estleg:requestedCluster": "calculation_147_152",
      "estleg:summary": "Sätestab aegumistähtaja algusmomendi reeglid nõude sissenõutavaks muutumise ja hoidumiskohustuse rikkumise korral.",
      "estleg:relatesToConcept": "estleg:Concept_CalculationOfLimitation",
      "estleg:sourceAct": "Tsiviilseadustiku üldosa seadus"
    },
    {
      "@id": "estleg:TsUS_Par_148",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_tsiviilseadustik_osa4"
      ],
      "estleg:paragrahv": "§148",
      "rdfs:label": "Lepingueelsetest läbirääkimistest tuleneva nõude aegumine",
      "estleg:requestedCluster": "limitation_periods_142_157",
      "estleg:summary": "Tehinguliste nõuete aegumise reegleid kohaldatakse ka lepingueelsete läbirääkimiste rikkumisest tulenevatele nõuetele.",
      "estleg:relatesToConcept": "estleg:Concept_LimitationPeriodTypes",
      "estleg:sourceAct": "Tsiviilseadustiku üldosa seadus"
    },
    {
      "@id": "estleg:TsUS_Par_149",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_tsiviilseadustik_osa4"
      ],
      "estleg:paragrahv": "§149",
      "rdfs:label": "Seadusest tuleneva nõude aegumistähtaeg",
      "estleg:requestedCluster": "limitation_periods_142_157",
      "estleg:summary": "Seadusest tuleneva nõude üldine aegumistähtaeg on 10 aastat nõude sissenõutavaks muutumisest.",
      "estleg:relatesToConcept": "estleg:Concept_LimitationPeriodTypes",
      "estleg:sourceAct": "Tsiviilseadustiku üldosa seadus"
    },
    {
      "@id": "estleg:TsUS_Par_150",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_tsiviilseadustik_osa4"
      ],
      "estleg:paragrahv": "§150",
      "rdfs:label": "Kahju õigusvastasest tekitamisest tuleneva nõude aegumistähtaeg",
      "estleg:requestedCluster": "limitation_periods_142_157",
      "estleg:summary": "Deliktiõigusliku kahjunõude suhtes kehtib 3-aastane subjektiivne ja 10-aastane objektiivne aegumistähtaeg.",
      "estleg:relatesToConcept": "estleg:Concept_LimitationPeriodTypes",
      "estleg:sourceAct": "Tsiviilseadustiku üldosa seadus"
    },
    {
      "@id": "estleg:TsUS_Par_151",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_tsiviilseadustik_osa4"
      ],
      "estleg:paragrahv": "§151",
      "rdfs:label": "Alusetust rikastumisest tuleneva nõude aegumistähtaeg",
      "estleg:requestedCluster": "limitation_periods_142_157",
      "estleg:summary": "Alusetu rikastumise nõudele kehtib 3-aastane subjektiivne ja 10-aastane objektiivne aegumistähtaeg.",
      "estleg:relatesToConcept": "estleg:Concept_LimitationPeriodTypes",
      "estleg:sourceAct": "Tsiviilseadustiku üldosa seadus"
    },
    {
      "@id": "estleg:TsUS_Par_152",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_tsiviilseadustik_osa4"
      ],
      "estleg:paragrahv": "§152",
      "rdfs:label": "Aegumine nõuete konkurentsi korral",
      "estleg:requestedCluster": "calculation_147_152",
      "estleg:summary": "Nõuete konkurentsi korral suunab norm aegumise kohaldamise aluse valikut ning eristab erijuhte.",
      "estleg:relatesToConcept": "estleg:Concept_CalculationOfLimitation",
      "estleg:sourceAct": "Tsiviilseadustiku üldosa seadus"
    },
    {
      "@id": "estleg:TsUS_Par_153",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_tsiviilseadustik_osa4"
      ],
      "estleg:paragrahv": "§153",
      "rdfs:label": "Surma põhjustamisest, kehavigastuse tekitamisest, tervise kahjustamisest või vabaduse võtmisest tuleneva nõude aegumine",
      "estleg:requestedCluster": "limitation_periods_142_157",
      "estleg:summary": "Isikukahju nõuetele kehtib 3-aastane subjektiivne ja 30-aastane objektiivne tähtaeg sõltumata nõude õiguslikust alusest.",
      "estleg:relatesToConcept": "estleg:Concept_LimitationSpecialCases",
      "estleg:sourceAct": "Tsiviilseadustiku üldosa seadus"
    },
    {
      "@id": "estleg:TsUS_Par_154",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_tsiviilseadustik_osa4"
      ],
      "estleg:paragrahv": "§154",
      "rdfs:label": "Korduvate kohustuste täitmisele suunatud nõude aegumine",
      "estleg:requestedCluster": "limitation_periods_142_157",
      "estleg:summary": "Korduvate kohustuste ja ülalpidamisnõuete aegumine toimub iga üksiku kohustuse kohta eraldi, üldjuhul 3-aastaselt.",
      "estleg:relatesToConcept": "estleg:Concept_LimitationSpecialCases",
      "estleg:sourceAct": "Tsiviilseadustiku üldosa seadus"
    },
    {
      "@id": "estleg:TsUS_Par_155",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_tsiviilseadustik_osa4"
      ],
      "estleg:paragrahv": "§155",
      "rdfs:label": "Omandiõigusest tuleneva väljaandmisnõude ning perekonna- ja pärimisõigusest tuleneva nõude aegumine",
      "estleg:requestedCluster": "limitation_periods_142_157",
      "estleg:summary": "Sätestab 30-aastase tähtaja ning omavolilise valdaja vastu suunatud väljaandmisnõude mitteaegumise.",
      "estleg:relatesToConcept": "estleg:Concept_LimitationSpecialCases",
      "estleg:sourceAct": "Tsiviilseadustiku üldosa seadus"
    },
    {
      "@id": "estleg:TsUS_Par_156",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_tsiviilseadustik_osa4"
      ],
      "estleg:paragrahv": "§156",
      "rdfs:label": "Aegumine õigusjärgluse korral",
      "estleg:requestedCluster": "limitation_periods_142_157",
      "estleg:summary": "Valduse üleminek õigusjärgluse tõttu ei mõjuta teatud asjaõiguslike nõuete aegumist.",
      "estleg:relatesToConcept": "estleg:Concept_LimitationSpecialCases",
      "estleg:sourceAct": "Tsiviilseadustiku üldosa seadus"
    },
    {
      "@id": "estleg:TsUS_Par_157",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_tsiviilseadustik_osa4"
      ],
      "estleg:paragrahv": "§157",
      "rdfs:label": "Jõustunud kohtuotsusega tunnustatud nõude aegumine",
      "estleg:requestedCluster": "limitation_periods_142_157",
      "estleg:summary": "Täitedokumendist tulenevatele nõuetele kehtib üldjuhul 10-aastane aegumistähtaeg koos erisätetega.",
      "estleg:relatesToConcept": "estleg:Concept_LimitationSpecialCases",
      "estleg:sourceAct": "Tsiviilseadustiku üldosa seadus"
    },
    {
      "@id": "estleg:TsUS_Par_158",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_tsiviilseadustik_osa4"
      ],
      "estleg:paragrahv": "§158",
      "rdfs:label": "Aegumise katkemine nõude tunnustamisega",
      "estleg:requestedCluster": "suspension_and_interruption_158_169",
      "estleg:summary": "Nõude tunnustamine katkestab aegumise ja paneb uue tähtaja kulgema.",
      "estleg:relatesToConcept": "estleg:Concept_InterruptionAndSuspension",
      "estleg:sourceAct": "Tsiviilseadustiku üldosa seadus"
    },
    {
      "@id": "estleg:TsUS_Par_159",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_tsiviilseadustik_osa4"
      ],
      "estleg:paragrahv": "§159",
      "rdfs:label": "Aegumise katkemine täitetoimingu puhul",
      "estleg:requestedCluster": "suspension_and_interruption_158_169",
      "estleg:summary": "Täitedokumendi esitamine katkestab aegumise, kuid seadus sätestab olukorrad, kus katkestust ei loeta toimunuks.",
      "estleg:relatesToConcept": "estleg:Concept_InterruptionAndSuspension",
      "estleg:sourceAct": "Tsiviilseadustiku üldosa seadus"
    },
    {
      "@id": "estleg:TsUS_Par_160",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_tsiviilseadustik_osa4"
      ],
      "estleg:paragrahv": "§160",
      "rdfs:label": "Aegumise peatumine hagi esitamisega",
      "estleg:requestedCluster": "suspension_and_interruption_158_169",
      "estleg:summary": "Hagi ja mitmed sellega võrdsustatud menetlustoimingud peatavad aegumise menetluse kestel.",
      "estleg:relatesToConcept": "estleg:Concept_Suspension",
      "estleg:sourceAct": "Tsiviilseadustiku üldosa seadus"
    },
    {
      "@id": "estleg:TsUS_Par_161",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_tsiviilseadustik_osa4"
      ],
      "estleg:paragrahv": "§161",
      "rdfs:label": "Aegumise peatumine vahekohtumenetluse korral",
      "estleg:requestedCluster": "suspension_and_interruption_158_169",
      "estleg:summary": "Arbitraažimenetluses kohaldatakse peatumise reegleid analoogselt kohtumenetlusega.",
      "estleg:relatesToConcept": "estleg:Concept_Suspension",
      "estleg:sourceAct": "Tsiviilseadustiku üldosa seadus"
    },
    {
      "@id": "estleg:TsUS_Par_162",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_tsiviilseadustik_osa4"
      ],
      "estleg:paragrahv": "§162",
      "rdfs:label": "Aegumise peatumine kohustuse täitmisest keeldumise õiguse puhul",
      "estleg:requestedCluster": "suspension_and_interruption_158_169",
      "estleg:summary": "Aegumine peatub ajaks, mil kohustatud isikul on kokkuleppeline õigus täitmisest ajutiselt keelduda.",
      "estleg:relatesToConcept": "estleg:Concept_Suspension",
      "estleg:sourceAct": "Tsiviilseadustiku üldosa seadus"
    },
    {
      "@id": "estleg:TsUS_Par_163",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_tsiviilseadustik_osa4"
      ],
      "estleg:paragrahv": "§163",
      "rdfs:label": "Aegumise peatumine vääramatu jõu tõttu",
      "estleg:requestedCluster": "suspension_and_interruption_158_169",
      "estleg:summary": "Vääramatu jõu korral peatub aegumine, kui õiguste kaitse ei ole tähtaja viimase kuue kuu jooksul võimalik.",
      "estleg:relatesToConcept": "estleg:Concept_Suspension",
      "estleg:sourceAct": "Tsiviilseadustiku üldosa seadus"
    },
    {
      "@id": "estleg:TsUS_Par_164",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_tsiviilseadustik_osa4"
      ],
      "estleg:paragrahv": "§164",
      "rdfs:label": "Aegumise peatumine perekondlikul põhjusel või eestkoste ajal",
      "estleg:requestedCluster": "suspension_and_interruption_158_169",
      "estleg:summary": "Perekondlikes ja eestkostesuhetes peatub aegumine seaduses nimetatud perioodideks.",
      "estleg:relatesToConcept": "estleg:Concept_Suspension",
      "estleg:sourceAct": "Tsiviilseadustiku üldosa seadus"
    },
    {
      "@id": "estleg:TsUS_Par_165",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_tsiviilseadustik_osa4"
      ],
      "estleg:paragrahv": "§165",
      "rdfs:label": "Aegumise peatumine piiratud teovõimega isiku puhul",
      "estleg:requestedCluster": "suspension_and_interruption_158_169",
      "estleg:summary": "Seadusliku esindaja puudumisel peatub aegumine ning nõue ei aegu enne kuue kuu möödumist esindaja määramisest või teovõime taastumisest.",
      "estleg:relatesToConcept": "estleg:Concept_Suspension",
      "estleg:sourceAct": "Tsiviilseadustiku üldosa seadus"
    },
    {
      "@id": "estleg:TsUS_Par_166",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_tsiviilseadustik_osa4"
      ],
      "estleg:paragrahv": "§166",
      "rdfs:label": "Aegumise peatumine pärimise korral",
      "estleg:requestedCluster": "suspension_and_interruption_158_169",
      "estleg:summary": "Pärandvaraga seotud nõuete aegumine peatub kuni pärandi vastuvõtuni või muu seaduses nimetatud sündmuseni.",
      "estleg:relatesToConcept": "estleg:Concept_Suspension",
      "estleg:sourceAct": "Tsiviilseadustiku üldosa seadus"
    },
    {
      "@id": "estleg:TsUS_Par_167",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_tsiviilseadustik_osa4"
      ],
      "estleg:paragrahv": "§167",
      "rdfs:label": "Aegumise peatumine läbirääkimiste korral",
      "estleg:requestedCluster": "suspension_and_interruption_158_169",
      "estleg:summary": "Läbirääkimised, täiendava tähtaja andmine ning kokkulepitud ekspertiis või lepitus peatavad aegumise.",
      "estleg:relatesToConcept": "estleg:Concept_Suspension",
      "estleg:sourceAct": "Tsiviilseadustiku üldosa seadus"
    },
    {
      "@id": "estleg:TsUS_Par_168",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_tsiviilseadustik_osa4"
      ],
      "estleg:paragrahv": "§168",
      "rdfs:label": "Peatumise toime",
      "estleg:requestedCluster": "suspension_and_interruption_158_169",
      "estleg:summary": "Peatumise aeg ei lähe aegumistähtaja hulka ning pärast peatumise lõppu kehtib minimaalse jäägi kaitse.",
      "estleg:relatesToConcept": "estleg:Concept_CalculationOfLimitation",
      "estleg:sourceAct": "Tsiviilseadustiku üldosa seadus"
    },
    {
      "@id": "estleg:TsUS_Par_169",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_tsiviilseadustik_osa4"
      ],
      "estleg:paragrahv": "§169",
      "rdfs:label": "Aegumise peatumine nõuete konkurentsi korral",
      "estleg:requestedCluster": "suspension_and_interruption_158_169",
      "estleg:summary": "Kui samasisulisel nõudel on nii seaduslik kui tehinguline alus, kandub peatumise/katkemise mõju mõlemale alusele.",
      "estleg:relatesToConcept": "estleg:Concept_InterruptionAndSuspension",
