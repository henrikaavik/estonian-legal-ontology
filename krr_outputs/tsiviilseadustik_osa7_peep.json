      "original_data": {
        "source": "Tsiviilseadustiku üldosa seadus (TsÜS)",
        "sourceActId": "RT I, 13.03.2014, 104 (redaktsioon jõust. 01.01.2018)",
        "draftVersion": "peep-v1",
        "scope": "TsÜS Osa 7/Final provisions mapping (lõppsätted): jõustumine ja kehtetuks tunnistamise käsitlus",
        "sections": [
          {
            "section": "Final provisions (lõppsätted)",
            "paragraphs": [
              "Osa 8 pealkiri: Seaduse rakendamine",
              "§170"
            ],
            "concepts": [
              {
                "Concept": "FinalProvisionsBlock",
                "IRI": "FinalProvisionsBlock",
                "Definition": "TsÜS lõppsätete plokk kehtivas terviktekstis, mis koondub seaduse rakendamise ja jõustumise reeglile.",
                "Rule": [
                  "Kehtivas TsÜS terviktekstis on lõppsätete sisuline norm §170 (Seaduse jõustumine).",
                  "Lõppsätete funktsioon on siduda TsÜS jõustumine eraldi rakendusseadusega.",
                  "TsÜS normatiivne lõppstruktuur ei sisalda kehtivas redaktsioonis eraldi sisemist repeali-paragrahvi."
                ],
                "Categories": [
                  "FinalProvisions",
                  "ApplicationLink",
                  "CodificationClosure"
                ]
              }
            ],
            "coreRelations": [
              "TsUS_FinalPart --contains--> Par170",
              "FinalProvisionsBlock --centersOn--> EntryIntoForceRule",
              "TsUS --isAppliedThrough--> ImplementationAct"
            ]
          },
          {
            "section": "Entry into force (jõustumine)",
            "paragraphs": [
              "§170 lg 1"
            ],
            "concepts": [
              {
                "Concept": "EntryIntoForceByImplementationAct",
                "IRI": "EntryIntoForceByImplementationAct",
                "Definition": "TsÜS jõustumise aja määrab rakendamise seadus, mitte TsÜS-s fikseeritud kalendrikuupäev.",
                "Rule": [
                  "§170 lg 1: 'Käesolev seadus jõustub selle rakendamise seaduses sätestatud ajast.'",
                  "Jõustumisreegel on viitenorm, mis delegeerib jõustumise ajamääratluse rakendamisseadusele.",
                  "Intertemporaalne tõlgendus tuleb teha koos TsÜS rakendamisseadusega (VÕSRS)."
                ],
                "Categories": [
                  "EntryIntoForceRule",
                  "ReferenceNorm",
                  "IntertemporalLink"
                ]
              }
            ],
            "coreRelations": [
              "Par170_1 --defines--> EntryIntoForceByImplementationAct",
              "EntryIntoForceByImplementationAct --references--> VOSRS",
              "TsUS --entryIntoForceDeterminedBy--> ImplementationLaw"
            ]
          },
          {
            "section": "Repealed provisions (kehtetuks tunnistamine)",
            "paragraphs": [
              "TsÜS kehtiv terviktekst: explicit repeal norm not present in final part",
              "Repeal architecture handled through implementation/reform legislation"
            ],
            "concepts": [
              {
                "Concept": "ExternalRepealArchitecture",
                "IRI": "ExternalRepealArchitecture",
                "Definition": "TsÜS enda lõpposas puudub kehtivas redaktsioonis autonoomne kehtetuks tunnistamise norm; repeali mõju realiseerub reformipaketi ja rakendusseaduste kaudu.",
                "Rule": [
                  "Kehtiv TsÜS tekst ei sisalda lõpposas eraldi kehtetuks tunnistamise paragrahvi.",
                  "Õigusajalooline repeali ulatus tuleb tuletada seotud reformiaktidest ja ajaloolistest redaktsioonidest.",
                  "Süsteemse analüüsi korral tuleb TsÜS repeali käsitleda koos rakendamise seadusmaterjaliga."
                ],
                "Categories": [
                  "RepealHandling",
                  "HistoricalRedactionDependency",
                  "ImplementationFramework"
                ]
              }
            ],
            "coreRelations": [
              "TsUS_CurrentText --doesNotContain--> InternalRepealParagraph",
              "RepealEffects --areTracedVia--> HistoricalAndImplementationActs",
              "ExternalRepealArchitecture --requires--> RedactionChronologyAnalysis"
            ]
          }
        ]
