        {
          "@id": "https://data.riik.ee/ontology/estleg#Par227"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par228"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par229"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par230"
        }
      ]
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par230_2",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 230<sup>1</sup>. Karistamine käesolevas peatükis sätestatud süüteo eest",
      "estleg:sectionNumber": "230",
      "estleg:legalText": "Kui käesolevas peatükis sätestatud süüteo objektiks oli riigisaladus või salastatud välisteave, ei vabane süüteo toime pannud isik vastutusest, kui pärast sellise süüteo toimepanemist teabe salastatus kustub, välja arvatud juhul, kui teabe salastamiseks puudus õiguslik alus. RT I 2007 16 77 12791615 2008-01-01"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Division15_1",
      "@type": [
        "estleg:Division",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "1. jagu – Üldsätted",
      "estleg:hasSection": [
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par230"
        }
      ]
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par231",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 231. Eesti Vabariigi vastu suunatud vägivaldne tegevus",
      "estleg:sectionNumber": "231",
      "estleg:legalText": "1 (1) Tegevuse eest, mis on suunatud Eesti Vabariigi iseseisvuse ja sõltumatuse vägivaldsele muutmisele, territoriaalse terviklikkuse vägivaldsele rikkumisele, vägivaldsele võimuhaaramisele või muul viisil Eesti põhiseadusliku korra vägivaldsele muutmisele, –karistatakse kuue- kuni kahekümneaastase või eluaegse vangistusega. 2 (2) Kohus kohaldab käesolevas paragrahvis sätestatud kuriteo eest kuriteoga saadud vara laiendatud konfiskeerimist vastavalt käesoleva seadustiku §-s 832 sätestatule. RT I"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par232",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 232. Riigireetmine",
      "estleg:sectionNumber": "232",
      "estleg:legalText": "1 (1) Eesti Vabariigi kodaniku poolt välisriigi, välisriigi organisatsiooni, välismaalase või välisriigi ülesandel tegutseva isiku abistamise eest Eesti Vabariigi iseseisvuse ja sõltumatuse või territoriaalse terviklikkuse vastu suunatud vägivallata tegevuses või riigisaladuse või salastatud välisteabe kogumise eest selle edastamise eesmärgil või selle edastamise eest välisriigile, välisriigi organisatsioonile, välismaalasele või välisriigi ülesandel tegutsevale isikule –karistatakse kuue- kuni "
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par233",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 233. Välismaalase poolt toimepandud Eesti Vabariigi vastu suunatud vägivallata tegevus",
      "estleg:sectionNumber": "233",
      "estleg:legalText": "Välismaalase poolt Eesti Vabariigi iseseisvuse ja sõltumatuse või territoriaalse terviklikkuse vastu suunatud vägivallata tegevuse eest, kui puudub käesoleva seadustiku §-s 231 või 234 sätestatud süüteokoosseis, –karistatakse kahe- kuni viieteistaastase vangistusega. RT I 2009 51 347 13230387 2009-11-15"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par234",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 234. Salakuulamine",
      "estleg:sectionNumber": "234",
      "estleg:legalText": "1 (1) Välismaalase poolt riigisaladuse või salastatud välisteabe kogumise eest selle edastamise eesmärgil või selle edastamise eest välisriigile, välisriigi organisatsioonile, välismaalasele või välisriigi ülesandel tegutsevale isikule –karistatakse kolme- kuni viieteistaastase vangistusega. RT I 2009 51 347 13230387 2009-11-15 2 (2) Kohus kohaldab käesolevas paragrahvis sätestatud kuriteo eest kuriteoga saadud vara laiendatud konfiskeerimist vastavalt käesoleva seadustiku §-s 832 sätestatule. R"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par234_2",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 234<sup>1</sup>. Eesti Vabariigi vastase sõja või okupatsiooni toetamine",
      "estleg:sectionNumber": "234",
      "estleg:legalText": "Eesti Vabariigi vastase sõja või Eesti okupeerimise ajal Eesti Vabariigi kodaniku poolt vaenlase relvajõududega liitumise, Eesti Vabariigi vastases sõjategevuses osalemise või selliste sõjaliste või juhtivate tsiviilülesannete täitmise eest, mis toetavad Eesti Vabariigi vastast sõjategevust või Eesti Vabariigi okupeerimist, –karistatakse kuue- kuni kahekümneaastase või eluaegse vangistusega. RT I 2009 51 347 13230387 2009-11-15"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par235",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 235. Eesti Vabariigi põhiseadusliku korra vastane ühendus",
      "estleg:sectionNumber": "235",
      "estleg:legalText": "1 (1) Eesti Vabariigi vastu suunatud vägivaldse tegevuse eesmärgil loodud kolmest või enamast isikust koosnevasse püsivasse ja isikutevahelise ülesannete jaotusega ühendusse kuulumise, samuti sellise ühenduse loomise, juhtimise või sellesse liikmete värbamise eest –karistatakse kuni kuueaastase vangistusega. RT I 2009 51 347 13230387 2009-11-15 2 (2) Käesoleva paragrahvi lõikes 1 sätestatud teo eest, kui selle on toime pannud juriidiline isik, –karistatakse rahalise karistuse või sundlõpetamiseg"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par235_2",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 235<sup>1</sup>. Eesti Vabariigi vastane vandenõu",
      "estleg:sectionNumber": "235",
      "estleg:legalText": "Eesti Vabariigi kodaniku poolt suhte loomise või pidamise eest välisriigiga, välisriigi organisatsiooni või välisriigi ülesandel tegutseva isikuga eesmärgiga panna toime käesoleva seadustiku §-s 232 sätestatud kuritegu –karistatakse kuni kuueaastase vangistusega. RT I 2009 51 347 13230387 2009-11-15"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par235_3",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 235<sup>2</sup>. Eesti Vabariigi vastane võltsimine",
      "estleg:sectionNumber": "235",
      "estleg:legalText": "Ametliku dokumendi võltsimise, sellise dokumendi levitamise või selles sisalduvate andmete levitamise eest eesmärgiga kahjustada Eesti Vabariigi iseseisvust ja sõltumatust või territoriaalset terviklikkust või kui sellega kaasnes oht Eesti Vabariigi iseseisvusele ja sõltumatusele või territoriaalsele terviklikkusele –karistatakse kuni kuueaastase vangistusega. RT I 2009 51 347 13230387 2009-11-15"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par235_4",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 235<sup>3</sup>. Politseiametniku ja tegevväelase riigivastane mõjutamine",
      "estleg:sectionNumber": "235",
      "estleg:legalText": "Politseiametniku või tegevväelase süstemaatilise mõjutamise eest teenistuskohustuste täitmata jätmisele eesmärgiga kahjustada Eesti Vabariigi iseseisvust ja sõltumatust või territoriaalset terviklikkust –karistatakse rahalise karistuse või kuni kolmeaastase vangistusega. RT I 2012-07-10 2 110072012002 2013-04-01"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par236",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 236. Üleskutse kuriteo toimepanemisele Eesti Vabariigi vastu",
      "estleg:sectionNumber": "236",
      "estleg:legalText": "Käesolevas jaos sätestatud kuriteo toimepanemisele avaliku üleskutsumise eest –karistatakse rahalise karistuse või kuni kolmeaastase vangistusega."
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Division15_2",
      "@type": [
        "estleg:Division",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "2. jagu – Süüteod Eesti Vabariigi vastu",
      "estleg:hasSection": [
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par231"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par232"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par233"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par234"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par234"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par235"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par235"
