    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par451",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 451. Karistusseadustiku kehtestamine",
      "estleg:sectionNumber": "451",
      "estleg:legalText": "Karistusseadustik kehtestatakse eraldi seadusega."
    },
    {
