      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 402<sup>2</sup>. Erakonnale tehtava annetuse vastuvõtmise keelu rikkumine",
      "estleg:sectionNumber": "402",
      "estleg:legalText": ""
    },
    {
