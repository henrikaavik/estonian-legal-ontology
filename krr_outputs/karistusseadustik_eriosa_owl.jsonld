        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par147"
        }
      ]
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par148",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 148. Laibarüvetamine",
      "estleg:sectionNumber": "148",
      "estleg:legalText": "Inimese laiba tükeldamise, matmata jätmise või muu üldtunnustatud tavadele mittevastava kohtlemise või laiba varguse eest –karistatakse rahalise karistuse või kuni üheaastase vangistusega."
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par149",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 149. Surnu mälestuse teotamine",
      "estleg:sectionNumber": "149",
      "estleg:legalText": "Matuse- või muu surnu mälestamise tseremoonia takistamise, haua või muu viimseks puhkepaigaks tunnistatud koha või surnule püstitatud mälestusmärgi rüüstamise või nimetatud kohtadest eseme varguse eest –karistatakse rahalise karistuse või kuni üheaastase vangistusega."
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par150",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 150. Ebaseaduslik siirdematerjali võtmine laibalt",
      "estleg:sectionNumber": "150",
      "estleg:legalText": "Inimese laibalt siirdamise eesmärgil elundi või koe eraldamise eest selleks õigustatud isiku poolt, kui inimene on selle oma eluajal keelanud, –karistatakse rahalise karistusega."
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Division9_8",
      "@type": [
        "estleg:Division",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "8. jagu – Surnuvastased süüteod",
      "estleg:hasSection": [
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par148"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par149"
        },
