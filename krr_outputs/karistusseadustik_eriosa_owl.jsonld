    {
      "@id": "https://data.riik.ee/ontology/estleg#Chapter21",
      "@type": [
        "estleg:Chapter",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "21. peatükk – MAJANDUSALASED SÜÜTEOD",
      "estleg:hasDivision": [
