        }
      ]
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par399",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 399. Turgu valitseva ettevõtja seisundi kuritarvitamine",
      "estleg:sectionNumber": "399",
      "estleg:legalText": "1 (1) Ebaõiglaste äritingimuste kehtestamise, ostjate kahjuks tootmise või teenindamise või kaubaturu, tehnilise arengu või investeeringute piiramise, samuti muu tegevuse eest, millega on kaasnenud ettevõtja turgu valitseva seisundi kuritarvitamine kaubaturul, kui süüdlasele on sama teo eest kohaldatud väärteokaristust, –karistatakse rahalise karistuse või kuni kolmeaastase vangistusega. RT I 2007 13 69 12789872 2007-03-15 1 (1<sup>1</sup>) Vee-, soojus-, elektri- või gaasiettevõtja teenuse müüg"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par400",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 400. Konkurentsi kahjustav kokkulepe, otsus ja kooskõlastatud tegevus",
      "estleg:sectionNumber": "400",
      "estleg:legalText": "1 (1) Konkurentsi kahjustava eesmärgi või tagajärjega ettevõtjatevahelise kokkuleppe, otsuse või kooskõlastatud tegevuse eest –karistatakse rahalise karistuse või kuni üheaastase vangistusega. RT I 2013-07-05 1 105072013001 2013-07-15 2 (2) Konkurentidevahelise kokkuleppe, otsuse või kooskõlastatud tegevuse eest, sealhulgas riigihankes osalemisel, kui sellega: 1 1) määratakse otseselt või kaudselt kolmandate isikute suhtes kindlaks hind või muud kauplemistingimused; 2 2) piiratakse tootmist, tee"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par401",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 401. Koondumise jõustamine koondumiseks loa puudumisel ja konkurentsi kahjustav koondumine",
      "estleg:sectionNumber": "401",
      "estleg:legalText": "1 (1) Koondumise jõustamise eest, kui koondumiseks puudub luba, samuti koondumise keelu või koondumise loa tingimuste rikkumise eest, kui süüdlasele on sama teo eest kohaldatud väärteokaristust, –karistatakse rahalise karistuse või kuni kolmeaastase vangistusega. RT I 2013-07-05 1 105072013001 2013-07-15 2 (2) Sama teo eest, kui selle on toime pannud juriidiline isik, –karistatakse rahalise karistusega."
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par402",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 402. Olulist vahendit omava ettevõtja kohustuste täitmata jätmine",
      "estleg:sectionNumber": "402",
      "estleg:legalText": "1 (1) Teisele ettevõtjale mõistlikel ja mittediskrimineerivatel tingimustel võrgustikule, infrastruktuurile või muule olulisele vahendile juurdepääsu mittelubamise eest, samuti muu tegevuse eest, millega on kaasnenud olulist vahendit omava ettevõtja seaduses sätestatud kohustuste rikkumine, kui süüdlasele on sama teo eest kohaldatud väärteokaristust, –karistatakse rahalise karistuse või kuni kolmeaastase vangistusega. 2 (2) Sama teo eest, kui selle on toime pannud juriidiline isik, –karistatakse"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Division21_7",
      "@type": [
        "estleg:Division",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "7. jagu – Konkurentsialased süüteod",
      "estleg:hasSection": [
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par399"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par400"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par401"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par402"
        }
      ]
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par402_2",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 402<sup>1</sup>. Keelatud annetuse tegemine ja vastuvõtmine suures ulatuses",
      "estleg:sectionNumber": "402",
      "estleg:legalText": "1 (1) Keelatud annetuse tegemise või selle vastuvõtmise eest suures ulatuses –karistatakse rahalise karistusega. 2 (2) Sama teo eest, kui selle on toime pannud juriidiline isik, –karistatakse rahalise karistusega. RT I 2014-02-05 1 105022014001 2014-04-01"
    },
    {
