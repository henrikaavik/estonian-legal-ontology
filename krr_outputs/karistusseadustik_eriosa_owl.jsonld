        {
          "@id": "https://data.riik.ee/ontology/estleg#Par297"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par298"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par298"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par299"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par300"
