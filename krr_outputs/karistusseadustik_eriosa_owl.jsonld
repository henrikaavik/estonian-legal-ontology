        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Division9_8"
        }
      ]
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par151",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 151. Vaenu õhutamine",
      "estleg:sectionNumber": "151",
      "estleg:legalText": "1 (1) Tegevuse eest, millega avalikult on kutsutud üles vihkamisele, vägivallale või diskrimineerimisele seoses rahvuse, rassi, nahavärvi, soo, keele, päritolu, usutunnistuse, seksuaalse sättumuse, poliitiliste veendumuste või varalise või sotsiaalse seisundiga, kui sellega on põhjustatud oht isiku elule, tervisele või varale, –karistatakse rahatrahviga kuni kolmsada trahviühikut või arestiga. 2 (2) Sama teo eest, kui 1 1) sellega on põhjustatud inimese surm või tekitatud tervisekahjustus või mu"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par152",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 152. Võrdõiguslikkuse rikkumine",
      "estleg:sectionNumber": "152",
      "estleg:legalText": "1 (1) Inimese õiguste ebaseadusliku piiramise või inimesele ebaseaduslike eeliste andmise eest tema rahvuse, rassi, nahavärvi, soo, keele, päritolu, usutunnistuse, seksuaalse sättumuse, poliitiliste veendumuste, varalise või sotsiaalse seisundi alusel –karistatakse rahatrahviga kuni kolmsada trahviühikut või arestiga. 2 (2) Sama teo eest, kui see on toime pandud: 1 1) vähemalt teist korda või 2 2) kui sellega on tekitatud oluline kahju teise isiku seadusega kaitstud õigustele või huvidele või av"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par153",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 153. Diskrimineerimine pärilikkusriskide alusel",
      "estleg:sectionNumber": "153",
      "estleg:legalText": "1 (1) Inimese õiguste ebaseadusliku piiramise või inimesele ebaseaduslike eeliste andmise eest tema pärilikkusriskide alusel –karistatakse rahatrahviga kuni kolmsada trahviühikut või arestiga. 2 (2) Sama teo eest, kui see on toime pandud: 1 1) vähemalt teist korda või 2 2) kui sellega on tekitatud oluline kahju teise isiku seadusega kaitstud õigustele või huvidele või avalikele huvidele, –karistatakse rahalise karistuse või kuni üheaastase vangistusega. RT I 2004 46 329 765405 2004-07-01"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Division10_1",
      "@type": [
        "estleg:Division",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "1. jagu – Süüteod võrdõiguslikkuse vastu",
      "estleg:hasSection": [
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par151"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par152"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par153"
        }
      ]
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par154",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 154. Usuvabaduse rikkumine",
      "estleg:sectionNumber": "154",
      "estleg:legalText": "Usulisse ühendusse kuulumise või usutalituse täitmise takistamise eest, välja arvatud juhul, kui usulisse ühendusse kuulumine või usutalituse täitmine kahjustab kõlblust, teiste inimeste õigusi või tervist või rikub avalikku korda, –karistatakse rahalise karistuse või kuni üheaastase vangistusega."
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par155",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 155. Usulisse ühendusse või erakonda astuma ja selle liikmeks olema sundimine",
      "estleg:sectionNumber": "155",
      "estleg:legalText": "1 (1) Usulisse ühendusse või erakonda astuma või selle liikmeks olema sundimise eest –karistatakse rahalise karistuse või kuni üheaastase vangistusega. RT I 2010-12-10 1 110122010001 2011-04-01 2 (2) Sama teo eest, kui selle on toime pannud juriidiline isik, –karistatakse rahalise karistusega. RT I 2010-12-10 1 110122010001 2011-04-01"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par156",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 156. Sõnumisaladuse rikkumine",
      "estleg:sectionNumber": "156",
      "estleg:legalText": "1 (1) Kirjavahetuse ja sidevahendi abil edastatud sõnumi saladuse rikkumise eest –karistatakse rahalise karistusega. 2 (2) Sama teo eest isiku poolt, kes pääses sõnumi juurde oma tööülesannete tõttu, –karistatakse rahalise karistuse või kuni üheaastase vangistusega."
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par157",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 157. Kutse- ja ametitegevuses teatavaks saanud saladuse hoidmise kohustuse rikkumine",
      "estleg:sectionNumber": "157",
      "estleg:legalText": "Kutse- või ametitegevuses teatavaks saanud teise isiku tervist, eraelu või äritegevust puudutava teabe avaldamise eest isiku poolt, kellel on seadusest tulenev kohustus hoida sellist teavet saladuses, –karistatakse rahalise karistusega või kuni kolmeaastase vangistusega. RT I 2011-02-23 1 123022011001 2011-09-01"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par157_2",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 157<sup>1</sup>. Delikaatsete isikuandmete ebaseaduslik avaldamine",
      "estleg:sectionNumber": "157",
      "estleg:legalText": "Delikaatsete isikuandmete ebaseadusliku avalikustamise, andmetele juurdepääsu võimaldamise või andmete edastamise eest omakasu eesmärgil või kui sellega on tekitatud oluline kahju teise isiku seadusega kaitstud õigustele või huvidele –karistatakse rahalise karistuse või kuni üheaastase vangistusega. RT I 2007 13 69 12789872 2007-03-15"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par157_3",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 157<sup>2</sup>. Teise isiku identiteedi ebaseaduslik kasutamine",
      "estleg:sectionNumber": "157",
      "estleg:legalText": "Teist isikut tuvastavate või tuvastada võimaldavate isikuandmete tema nõusolekuta edastamise, nendele juurdepääsu võimaldamise või nende kasutamise eest eesmärgiga luua teise isikuna esinemise teel temast teadvalt ebaõige ettekujutus, kui sellega on tekitatud kahju teise isiku seadusega kaitstud õigustele või huvidele, või varjata kuritegu –karistatakse rahalise karistuse või kuni kolmeaastase vangistusega. RT I 2009 51 348 13230375 2009-11-15"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par158",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 158. Seaduslikult korraldatud avaliku koosoleku takistamine ja selle laialiajamine vägivallaga",
      "estleg:sectionNumber": "158",
      "estleg:legalText": "Seaduslikult korraldatud avaliku koosoleku takistamise või selle vägivaldse laialiajamise eest –karistatakse rahalise karistuse või kuni üheaastase vangistusega."
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par159",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 159. Ühinemisvabaduse rikkumine",
      "estleg:sectionNumber": "159",
      "estleg:legalText": "Mittetulundusühingu loomise, sellesse astumise või selle liikmeks olemise takistamise eest, kui ühingu loomine ja tegevus ei rikkunud riigi ja ühiskonna julgeoleku, avaliku korra, kõlbluse või teiste inimeste õiguste kaitse huvides seaduses sätestatud tingimusi ja piiranguid ning ühingusse astumine või selle liikmeks olemine ei rikkunud avalikus teenistuses olevatele isikutele seaduses sätestatud tingimusi ja piiranguid, –karistatakse rahatrahviga kuni kolmsada trahviühikut või arestiga."
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Division10_2",
      "@type": [
        "estleg:Division",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "2. jagu – Põhivabaduste rikkumised",
      "estleg:hasSection": [
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par154"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par155"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par156"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par157"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par157"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par157"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par158"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par159"
        }
      ]
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par160",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 160. Valimise mõiste",
      "estleg:sectionNumber": "160",
      "estleg:legalText": "Valimine käesoleva jao tähenduses on Riigikogu, kohaliku omavalitsuse volikogu või Euroopa Parlamendi valimine. RT I 2003 4 22 237664 2003-01-23"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par161",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 161. Valimise ja rahvahääletuse takistamine",
      "estleg:sectionNumber": "161",
      "estleg:legalText": "1 (1) Valimise või rahvahääletuse või selle tulemuste kindlakstegemise või väljakuulutamise takistamise eest –karistatakse rahalise karistuse või kuni üheaastase vangistusega. 2 (2) Sama teo eest, kui see on toime pandud vägivallaga, –karistatakse ühe- kuni viieaastase vangistusega."
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par162",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 162. Valimis- ja hääletamisvabaduse rikkumine",
      "estleg:sectionNumber": "162",
      "estleg:legalText": "Isiku takistamise eest vabalt teostamast oma õigust valida või olla valitud valimisel või hääletada rahvahääletusel, kui sealjuures on kasutatud vägivalda, pettust, ähvardust või isiku teenistuslikku, majanduslikku või muud sõltuvust süüteo toimepanijast, –karistatakse rahalise karistuse või kuni üheaastase vangistusega."
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par163",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 163. Valimise võltsimine",
      "estleg:sectionNumber": "163",
      "estleg:legalText": "Valimis- või hääletamisdokumendi hävitamise, rikkumise, kõrvaldamise või võltsimise või häälte ebaõige lugemise eest –karistatakse rahalise karistuse või kuni üheaastase vangistusega."
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par164",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 164. Hääle ostmine",
      "estleg:sectionNumber": "164",
      "estleg:legalText": "Isikule ainelise hüvitise andmise või pakkumise eest eesmärgiga mõjutada teda mitte teostama oma valimis- või hääletamisõigust või teostama seda teatud valiku kasuks –karistatakse rahalise karistuse või kuni üheaastase vangistusega. RT I 2006 30 231 1043129 2006-07-14"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par165",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 165. Valimispettus",
      "estleg:sectionNumber": "165",
      "estleg:legalText": "Mitmekordse hääletamise eest, välja arvatud enda elektrooniliselt antud hääle muutmine, või valimisel või rahvahääletusel osalemise eest ilma hääleõiguseta või teise isiku nimel –karistatakse rahatrahviga kuni kolmsada trahviühikut või arestiga. RT I 2005 47 387 938241 2005-09-18"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par166",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 166. Hääletamissaladuse rikkumine",
      "estleg:sectionNumber": "166",
      "estleg:legalText": "Salajase hääletuse korra rikkumise eest valimisel või rahvahääletusel –karistatakse rahatrahviga kuni sada trahviühikut või arestiga."
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par167",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 167. Valimisagitatsiooni takistamine",
      "estleg:sectionNumber": "167",
      "estleg:legalText": "Valimis- või rahvahääletuseelse seadusliku agitatsiooni takistamise eest –karistatakse rahatrahviga kuni kolmsada trahviühikut või arestiga."
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par168",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 168. Ebaseaduslik agitatsioon",
      "estleg:sectionNumber": "168",
      "estleg:legalText": "1 (1) Aktiivse agitatsiooni eest valimise või rahvahääletuse päeval –karistatakse rahatrahviga kuni kakssada trahviühikut või arestiga. 2 (2) Sama teo eest, kui selle on toime pannud juriidiline isik, –karistatakse rahatrahviga kuni 1300 eurot. RT I 2010 22 108 13310847 2011-01-01"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Division10_3",
      "@type": [
        "estleg:Division",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "3. jagu – Süüteod valimisvabaduse vastu",
      "estleg:hasSection": [
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par160"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par161"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par162"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par163"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par164"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par165"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par166"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par167"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par168"
        }
      ]
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Chapter10",
      "@type": [
        "estleg:Chapter",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "10. peatükk – POLIITILISTE JA KODANIKUÕIGUSTE VASTASED SÜÜTEOD",
      "estleg:hasDivision": [
        {
          "@id": "https://data.riik.ee/ontology/estleg#Division10_1"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Division10_2"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Division10_3"
        }
      ]
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par169",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 169. Lapse ülalpidamise kohustuse rikkumine",
      "estleg:sectionNumber": "169",
      "estleg:legalText": "Vanema kuritahtliku kõrvalehoidumise eest oma nooremale kui kaheksateistaastasele lapsele või täisealiseks saanud, kuid abi vajavale töövõimetule lapsele kohtu poolt väljamõistetud igakuise elatusraha maksmisest –karistatakse rahalise karistuse või kuni üheaastase vangistusega."
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par170",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 170. Vanema ülalpidamise kohustuse rikkumine",
      "estleg:sectionNumber": "170",
      "estleg:legalText": "Täisealiseks saanud lapse kuritahtliku kõrvalehoidumise eest oma abi vajavale töövõimetule vanemale kohtu poolt väljamõistetud igakuise elatusraha maksmisest –karistatakse rahalise karistuse või kuni üheaastase vangistusega."
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par171",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 171. Eestkoste- ja hooldusõiguse kuritarvitamine",
      "estleg:sectionNumber": "171",
      "estleg:legalText": "Eestkoste- või hooldusõiguse ärakasutamise eest, suurendades eestkostetava või hooldatava vara arvel oma vara või tegutsedes muul viisil eestkostetava või hooldatava varaliste või isiklike õiguste või huvide vastaselt, –karistatakse rahalise karistuse või kuni kolmeaastase vangistusega."
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par172",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 172. Võõra lapse hõivamine",
      "estleg:sectionNumber": "172",
      "estleg:legalText": "Noorema kui neljateistaastase võõra lapse salajase või avaliku äraviimise eest isiku juurest, kelle hoole all laps seaduslikul alusel viibis, –karistatakse rahalise karistuse või kuni kolmeaastase vangistusega."
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par173",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 173. Lapse müümine ja ostmine",
      "estleg:sectionNumber": "173",
      "estleg:legalText": "1 (1) Lapse müümise või ostmise eest –karistatakse ühe- kuni viieaastase vangistusega. 2 (2) Sama teo eest, kui selle on toime pannud juriidiline isik, –karistatakse rahalise karistusega."
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par174",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 174. Perekondliku kuuluvuse muutmine",
      "estleg:sectionNumber": "174",
      "estleg:legalText": "1 (1) Võõra lapse asendamise eest teise võõra või oma lapsega perekondliku kuuluvuse muutmise eesmärgil –karistatakse rahalise karistuse või kuni kolmeaastase vangistusega. 2 (2) Sama teo eest, kui see on toime pandud: 1 1) pärandi saamise või muul omakasu eesmärgil või 2 2) kui sellega on põhjustatud kodakondsuse muutumine, –karistatakse ühe- kuni viieaastase vangistusega."
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Division11_1",
      "@type": [
        "estleg:Division",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "1. jagu – Süüteod perekonna vastu",
      "estleg:hasSection": [
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par169"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par170"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par171"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par172"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par173"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par174"
        }
      ]
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par175",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 175. Inimkaubandus alaealise ärakasutamise eesmärgil",
      "estleg:sectionNumber": "175",
      "estleg:legalText": "1 (1) Noorema kui kaheksateistaastase isiku mõjutamise eest, et ta alustaks või jätkaks kuriteo toimepanemist, kerjamist, prostitutsiooniga tegelemist või tavapäratutel tingimustel töötamist või astuks modelli või näitlejana üles pornograafilises või erootilises etteastes või teoses, kui puudub käesoleva seadustiku §-s 133 sätestatud süüteokoosseis, samuti noorema kui kaheksateistaastase isiku käesolevas paragrahvis nimetatud tegevusele muul viisil kaasaaitamise eest –karistatakse kahe- kuni küm"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par175_2",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 175<sup>1</sup>. Lapspornole juurdepääsu taotlemine ja selle jälgimine",
      "estleg:sectionNumber": "175",
      "estleg:legalText": "1 (1) Lapspornole teadvalt juurdepääsu taotlemise eest või noorema kui kaheksateistaastase isiku osalusel toimuva pornograafilise etteaste teadliku jälgimise või noorema kui neljateistaastase isiku osalusel toimuva pornograafilise või erootilise etteaste teadliku jälgimise eest –karistatakse rahalise karistuse või kuni üheaastase vangistusega. 2 (2) Sama teo eest, kui see on toime pandud isiku poolt, kes on varem toime pannud käesolevas paragrahvis või §-s 175 või 178–179 sätestatud kuriteo, –ka"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par176",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 176. Alaealise prostitutsioonile kaasaaitamine",
      "estleg:sectionNumber": "176",
      "estleg:legalText": ""
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par177",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 177. Alaealise kasutamine pornograafilise teose valmistamisel",
      "estleg:sectionNumber": "177",
      "estleg:legalText": ""
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par177_2",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 177<sup>1</sup>. Alaealise kasutamine erootilise teose valmistamisel",
      "estleg:sectionNumber": "177",
      "estleg:legalText": ""
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par178",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 178. Lapsporno valmistamine ja selle võimaldamine",
      "estleg:sectionNumber": "178",
      "estleg:legalText": "1 (1) Nooremat kui kaheksateistaastast isikut pornograafilises või nooremat kui neljateistaastast isikut pornograafilises või erootilises situatsioonis kujutava pildi, kirjutise või muu teose või selle reproduktsiooni valmistamise, omandamise või hoidmise, teisele isikule üleandmise, näitamise või muul viisil kättesaadavaks tegemise eest –karistatakse rahalise karistuse või kuni kolmeaastase vangistusega. 1 (1<sup>1</sup>) Sama teo eest, kui see on toime pandud isiku poolt, kes on varem toime pa"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par178_2",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 178<sup>1</sup>. Seksuaalse eesmärgiga kokkulepe lapseealisega kohtumiseks",
      "estleg:sectionNumber": "178",
      "estleg:legalText": "1 (1) Nooremale kui kaheksateistaastasele isikule, kes ei olnud võimeline toimunust aru saama, või nooremale kui neljateistaastasele isikule kohtumisettepaneku tegemise või temaga kohtumiskokkuleppe sõlmimise eest ning kohtumist ettevalmistava teo tegemise eest, kui kohtumise eesmärk on panna nimetatud isiku suhtes toime käesoleva seadustiku §-s 133, 1331, 141–1451, 175, 1751, 178 või 179 sätestatud seksuaalse iseloomuga süütegu, –karistatakse rahalise karistuse või kuni kolmeaastase vangistuseg"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par179",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 179. Lapseealise seksuaalne ahvatlemine",
      "estleg:sectionNumber": "179",
      "estleg:legalText": "1 (1) Nooremale kui neljateistaastasele isikule pornograafilise teose või selle reproduktsiooni üleandmise, näitamise või muul viisil teadvalt kättesaadavaks tegemise või sellisele isikule seksuaalse kuritarvitamise näitamise või sellise isiku nähes suguühtesse astumise või muul viisil teadvalt tema seksuaalse ahvatlemise eest –karistatakse rahalise karistuse või kuni kolmeaastase vangistusega. RT I 2013-12-13 5 113122013005 2013-12-23 1 (1<sup>1</sup>) Sama teo eest, kui see on toime pandud isi"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par179_2",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 179<sup>1</sup>. Lastega töötamise ebaseaduslik võimaldamine",
      "estleg:sectionNumber": "179",
      "estleg:legalText": "1 (1) Isiku lapsega töötava isikuna tööle või teenistusse võtmise või tal muul viisil lastega tegutsemise võimaldamise eest, kui isikul on seadusega keelatud lastega töötamine, samuti õigustatud isiku poolt lastega töötamiseks tegevusloa andmise eest, kui see on seadusega keelatud, –karistatakse rahatrahviga kuni 300 trahviühikut. RT I 2013-12-13 5 113122013005 2013-12-23 2 (2) Sama teo eest, kui selle on toime pannud juriidiline isik, –karistatakse rahatrahviga kuni 3200 eurot. RT I 2010 22 108"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par180",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 180. Alaealisele vägivalla eksponeerimine",
      "estleg:sectionNumber": "180",
      "estleg:legalText": "1 (1) Nooremale kui kaheksateistaastasele isikule vägivalda või julmust propageeriva teose või selle reproduktsiooni üleandmise, näitamise või muul viisil teadvalt kättesaadavaks tegemise või sellise isiku nähes looma põhjuseta tapmise või piinamise või talle muul viisil vägivalla teadva eksponeerimise eest –karistatakse rahalise karistuse või kuni üheaastase vangistusega. 2 (2) Sama teo eest, kui selle on toime pannud juriidiline isik, –karistatakse rahalise karistusega."
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par181",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 181. Alaealise kaasatõmbamine kuriteo toimepanemisele",
      "estleg:sectionNumber": "181",
      "estleg:legalText": ""
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par182",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 182. Alaealise kallutamine alkoholi tarvitamisele",
      "estleg:sectionNumber": "182",
      "estleg:legalText": "Täisealise isiku poolt noorema kui kaheksateistaastase isiku kallutamise eest alkoholi tarvitamisele –karistatakse rahalise karistuse või kuni üheaastase vangistusega. RT I 2004 88 600 829033 2005-01-02"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par182_2",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 182<sup>1</sup>. Alaealisele alkoholi müümine ja ostmine",
      "estleg:sectionNumber": "182",
      "estleg:legalText": "1 (1) Täisealise isiku poolt nooremale kui kaheksateistaastasele isikule alkoholi müümise või ostmise eest, kui süüdlasele on sama teo eest kohaldatud väärteokaristust, –karistatakse rahalise karistuse või kuni üheaastase vangistusega. 2 (2) Nooremale kui kaheksateistaastasele isikule alkoholi müümise eest, kui selle teo on toime pannud juriidiline isik, –karistatakse rahalise karistusega. RT I 2004 88 600 829033 2005-01-02"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Division11_2",
      "@type": [
        "estleg:Division",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "2. jagu – Süüteod alaealise vastu",
      "estleg:hasSection": [
