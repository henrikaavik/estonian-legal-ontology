        }
      ]
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Chapter17",
      "@type": [
        "estleg:Chapter",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "17. peatükk – AMETIALASED SÜÜTEOD",
      "estleg:hasDivision": [
        {
          "@id": "https://data.riik.ee/ontology/estleg#Division17_1"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Division17_2"
        }
      ]
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par302",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 302. Kohtunikule, rahvakohtunikule, uurijale, prokurörile, kaitsjale, kannatanu esindajale ja tema lähedasele raske tervisekahjustuse tekitamine",
      "estleg:sectionNumber": "302",
      "estleg:legalText": "1 (1) Kohtunikule, rahvakohtunikule, uurijale, prokurörile, kaitsjale, kannatanu esindajale või tema lähedasele raske tervisekahjustuse tekitamise eest eesmärgiga sundida kohtunikku, rahvakohtunikku, uurijat, prokuröri, kaitsjat või kannatanu esindajat tegutsema õigusemõistmise huvidele mittevastavalt või kättemaksuks selle isiku poolt oma kohustuste täitmise eest –karistatakse nelja- kuni kaheteistaastase vangistusega. 2 (2) Sama teo eest, kui sellega on põhjustatud käeoleva paragrahvi lõikes 1"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par303",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 303. Vägivald kohtuniku, rahvakohtuniku, uurija, prokuröri, kaitsja, kannatanu esindaja ja tema lähedase suhtes",
      "estleg:sectionNumber": "303",
      "estleg:legalText": "Kohtuniku, rahvakohtuniku, uurija, prokuröri, kaitsja, kannatanu esindaja või tema lähedase suhtes vägivalla toimepanemise eest või kohtuniku, rahvakohtuniku, uurija, prokuröri, kaitsja või kannatanu esindaja muul viisil mõjutamise eest eesmärgiga sundida teda tegutsema õigusemõistmise huvidele mittevastavalt või kättemaksuks tema poolt oma kohustuste täitmise eest –karistatakse rahalise karistuse või ühe- kuni viieaastase vangistusega. RT I 2002 64 390 181957 2002-09-01"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par304",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 304. Kohtuniku, rahvakohtuniku, uurija, prokuröri, kaitsja, kannatanu esindaja ja tema lähedase vara rikkumine ja hävitamine",
      "estleg:sectionNumber": "304",
      "estleg:legalText": "Kohtuniku, rahvakohtuniku, uurija, prokuröri, kaitsja, kannatanu esindaja või tema lähedase vara rikkumise või hävitamise eest eesmärgiga sundida kohtunikku, rahvakohtunikku, uurijat, prokuröri, kaitsjat või kannatanu esindajat tegutsema õigusemõistmise huvidele mittevastavalt või kättemaksuks selle isiku poolt oma kohustuste täitmise eest –karistatakse rahalise karistuse või kuni viieaastase vangistusega. RT I 2002 64 390 181957 2002-09-01"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par305",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 305. Kohtu ja kohtuniku laimamine ja solvamine",
      "estleg:sectionNumber": "305",
      "estleg:legalText": "Kohtu või kohtuniku laimamise või solvamise eest seoses tema osalemisega õigusemõistmisel –karistatakse rahalise karistuse või kuni kaheaastase vangistusega. RT I 2003 83 557 688616 2004-01-01"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par306",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 306. Kuriteo varjamine",
      "estleg:sectionNumber": "306",
      "estleg:legalText": "1 (1) Teise isiku poolt esimese astme kuriteo eelnevalt mittelubatud varjamise eest –karistatakse rahalise karistuse või kuni viieaastase vangistusega. 2 (2) Kuriteo eelnevalt mittelubatud varjamine kuriteo toimepanija vanema, lapse, lapsendaja, lapsendatu, venna, õe, vanavanema, lapselapse, abikaasa või tema vanema poolt ei ole süüline."
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par307",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 307. Kuriteost mitteteatamine",
      "estleg:sectionNumber": "307",
      "estleg:legalText": "1 (1) Teise isiku poolt toimepandud esimese astme kuriteost mitteteatamise eest –karistatakse rahalise karistuse või kuni kolmeaastase vangistusega. 2 (2) Toimepandud esimese astme kuriteost mitteteatamine kuriteo toimepanija vanema, lapse, lapsendaja, lapsendatu, venna, õe, vanavanema, lapselapse, abikaasa või tema vanema poolt ei ole süüline. RT I 2003 83 557 688616 2004-01-01"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par308",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 308. Üleskirjutatud vara hoidmise nõuete rikkumine",
      "estleg:sectionNumber": "308",
      "estleg:legalText": "Tsiviilhagi, täitemenetluse, konfiskeerimise, rahatrahvi, rahalise karistuse, varalise karistuse või kohtukulude hüvitamise tagamiseks üleskirjutatud vara õigustatud isiku loata kasutamise või käsutamise eest isiku poolt, kelle vastutavale hoiule vara oli antud, –karistatakse rahalise karistuse või kuni üheaastase vangistusega. RT I 2005 39 308 919178 2005-07-21"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par309",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 309. Kohtukordniku tegevuse takistamine",
      "estleg:sectionNumber": "309",
      "estleg:legalText": "Kohtukordniku seadusliku korralduse täitmata jätmise või ametialase tegevuse takistamise eest –karistatakse rahalise karistusega."
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Division18_1",
      "@type": [
        "estleg:Division",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "1. jagu – Õigusemõistmise takistamine",
      "estleg:hasSection": [
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par302"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par303"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par304"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par305"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par306"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par307"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par308"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par309"
        }
      ]
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par310",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 310. Ebaseaduslik süüdistuse esitamine",
      "estleg:sectionNumber": "310",
      "estleg:legalText": "Prokuröri poolt teadvalt süütule isikule süüdistuse esitamise eest –karistatakse rahalise karistuse või kuni kolmeaastase vangistusega. RT I 2004 46 329 765405 2004-07-01"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par311",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 311. Kohtuniku poolt teadvalt ebaseadusliku kohtulahendi tegemine",
      "estleg:sectionNumber": "311",
      "estleg:legalText": "Kohtuniku poolt teadvalt ebaseadusliku kohtulahendi tegemise eest –karistatakse viie- kuni kümneaastase vangistusega. RT I 2007 13 69 12789872 2007-03-15"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par311_2",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 311<sup>1</sup>. Kohtunikuabi poolt teadvalt ebaseadusliku kohtulahendi tegemine",
      "estleg:sectionNumber": "311",
      "estleg:legalText": "Kohtunikuabi poolt teadvalt ebaseadusliku kohtulahendi tegemise eest –karistatakse rahalise karistuse või kuni kolmeaastase vangistusega. RT I 2007 13 69 12789872 2007-03-15"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par311_3",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 311<sup>2</sup>. Väärteomenetluses teadvalt ebaseadusliku otsuse tegemine",
      "estleg:sectionNumber": "311",
      "estleg:legalText": "Kohtuvälise menetleja ametniku või töötaja poolt teadvalt ebaseadusliku otsuse tegemise eest väärteomenetluses –karistatakse rahalise karistuse või kuni kolmeaastase vangistusega. RT I 2007 13 69 12789872 2007-03-15"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par311_4",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 311<sup>3</sup>. Süüteomenetluse teadvalt ebaseaduslik lõpetamine",
      "estleg:sectionNumber": "311",
      "estleg:legalText": "Kohtuvälise menetleja ametniku või töötaja poolt väärteomenetluse teadvalt ebaseadusliku lõpetamise eest, samuti prokuröri või uurimisasutuse ametniku poolt kriminaalmenetluse teadvalt ebaseadusliku lõpetamise või prokuröri poolt uurimisasutusele teadvalt ebaseaduslikult kriminaalmenetluse lõpetamise loa andmise eest –karistatakse rahalise karistuse või kuni kolmeaastase vangistusega. RT I 2007 13 69 12789872 2007-03-15"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par312",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 312. Ebaseaduslik ülekuulamine",
      "estleg:sectionNumber": "312",
      "estleg:legalText": "Uurija või prokuröri poolt vägivallaga ütluste andmisele sundimise eest –karistatakse rahalise karistuse või ühe- kuni viieaastase vangistusega."
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par313",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 313. Kohtumenetlust tagava toimingu ebaseaduslik kohaldamine",
      "estleg:sectionNumber": "313",
      "estleg:legalText": "Vahi alla võtmise, vahi all pidamise, kinnipidamise või sundtoomise eest kohtumenetluse tagamise eesmärgil, kui selleks puudusid seaduses ettenähtud alused, –karistatakse rahalise karistuse või kuni kolmeaastase vangistusega."
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par314",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 314. Ebaseaduslik läbiotsimine ja väljatõstmine",
      "estleg:sectionNumber": "314",
      "estleg:legalText": "Ebaseadusliku läbiotsimise või eluruumist väljatõstmise eest –karistatakse rahalise karistusega."
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par315",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 315. Ebaseaduslik jälitustegevus ja teabe varjatud kogumine",
      "estleg:sectionNumber": "315",
      "estleg:legalText": "Ebaseadusliku jälitustoimingu või ebaseaduslikult teabe varjatud kogumise eest, samuti jälitustoiminguga või varjatult kogutud teabe ebaseadusliku varjamise või hävitamise eest, kui selle pani toime isik, kellel oli jälitustegevuseks või teabe varjatud kogumiseks seadusest tulenev õigus, –karistatakse rahalise karistuse või kuni kolmeaastase vangistusega. RT I 2007 13 69 12789872 2007-03-15"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par316",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 316. Tõendi kõrvaldamine ja kunstlik loomine",
      "estleg:sectionNumber": "316",
      "estleg:legalText": "Tõendi kõrvaldamise või kunstliku loomise eest eesmärgiga takistada kuriteona karistatava teo olemasolu või selle puudumise või muude tõendamiseseme asjaolude tuvastamist –karistatakse rahalise karistuse või ühe- kuni viieaastase vangistusega. RT I 2004 46 329 765405 2004-07-01"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par316_2",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 316<sup>1</sup>. Kriminaalasja kohtueelse menetluse ja jälitusmenetluse andmete ebaseaduslik avaldamine",
      "estleg:sectionNumber": "316",
      "estleg:legalText": "Kriminaalasja kohtueelse menetluse andmete või kuriteo ärahoidmiseks või tõkestamiseks toimuva jälitusmenetluse andmete ebaseadusliku avaldamise eest isiku poolt, kellele need andmed said teatavaks seoses töö- või ametiülesannete täitmisega, kui sellega on tehtud võimatuks või oluliselt raskendatud kuriteona karistatava teo olemasolu või selle puudumise või muude tõendamiseseme asjaolude tuvastamine või jälitustoimingu eesmärgi saavutamine jälitusmenetluses, –karistatakse rahalise karistuse või "
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par316_3",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 316<sup>2</sup>. Teabe õigusliku aluseta salastamine ning riigisaladuse ja salastatud välisteabe valel õiguslikul alusel, vale salastamistaseme ja -tähtajaga salastamine",
      "estleg:sectionNumber": "316",
      "estleg:legalText": "1 (1) Teabe õigusliku aluseta salastamise või riigisaladuse või salastatud välisteabe valel õiguslikul alusel, vale salastamistaseme või -tähtajaga salastamise eest eesmärgiga takistada kuriteona karistatava teo olemasolu või selle puudumise või muude tõendamiseseme asjaolude tuvastamist –karistatakse rahalise karistuse või ühe- kuni viieaastase vangistusega. 2 (2) Sama teo eest, kui selle on toime pannud juriidiline isik, –karistatakse rahalise karistusega. 3 (3) Käesolevas paragrahvis sätestat"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par317",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 317. Menetlusosalise, tunnistaja, kannatanu, eksperdi ja tõlgi ilmumise takistamine",
      "estleg:sectionNumber": "317",
      "estleg:legalText": "Menetlusosalise, tunnistaja, eksperdi või tõlgi kohtueelsele või kohtumenetlusele ilmumise takistamise eest –karistatakse rahalise karistuse või kuni üheaastase vangistusega."
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par318",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 318. Tunnistaja, kannatanu ja tõlgi poolt kohustuste täitmisest keeldumine",
      "estleg:sectionNumber": "318",
      "estleg:legalText": "Kannatanu või tunnistaja poolt kriminaal- või väärteomenetluses või tsiviilkohtu- või halduskohtumenetluses ütluse andmisest aluseta keeldumise eest, samuti tõlgi poolt oma ülesannete täitmisest alusetu keeldumise eest –karistatakse rahalise karistuse või kuni üheaastase vangistusega. RT I 2006 7 42 989550 2006-02-04"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par319",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 319. Valekaebus",
      "estleg:sectionNumber": "319",
      "estleg:legalText": "1 (1) Teadvalt vale kaebuse esitamise eest kuriteo toimepanemise kohta teise isiku poolt –karistatakse rahalise karistuse või kuni üheaastase vangistusega. 2 (2) Sama teo eest, kui sellega on kaasnenud tõendite kunstlik loomine, –karistatakse rahalise karistuse või kuni viieaastase vangistusega. 3 (3) Käesoleva paragrahvi lõikes 1 või 2 sätestatud teo eest, kui selle on toime pannud juriidiline isik, –karistatakse rahalise karistusega. RT I 2010 8 34 13275248 2010-02-27"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par320",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 320. Valeütlus ja valevanne",
      "estleg:sectionNumber": "320",
      "estleg:legalText": "1 (1) Kannatanu või tunnistaja poolt kriminaal- või väärteomenetluses või tsiviilkohtu- või halduskohtumenetluses teadvalt vale ütluse andmise eest või menetlusosalise poolt vande all teadvalt vale seletuse või vande all teadvalt vale vara nimekirja või sissetulekute või kulude arvestuse andmise eest –karistatakse rahalise karistuse või kuni kolmeaastase vangistusega. RT I 2011-02-23 1 123022011001 2011-09-01 2 (2) Sama teo eest, kui sellega on kaasnenud tõendite kunstlik loomine, –karistatakse "
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par321",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 321. Vale eksperdiarvamus ja valetõlge",
      "estleg:sectionNumber": "321",
      "estleg:legalText": "1 (1) Eksperdi poolt teadvalt vale eksperdiarvamuse andmise eest või tõlgi poolt teadvalt valesti tõlkimise eest –karistatakse rahalise karistuse või kuni üheaastase vangistusega. 2 (2) Sama teo eest, kui sellega on kaasnenud tõendite kunstlik loomine, –karistatakse rahalise karistuse või kuni viieaastase vangistusega."
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par322",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 322. Sundimine valeütlust ja vale eksperdiarvamust andma ning valetõlget tegema",
      "estleg:sectionNumber": "322",
      "estleg:legalText": "Sundimise eest valeütlust või vale eksperdiarvamust andma või valetõlget tegema, kui see on toime pandud vägivallaga, –karistatakse rahalise karistuse või kuni neljaaastase vangistusega."
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par323",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 323. Kahtlustatava, süüdistatava, kohtualuse, õigeksmõistetu, süüdimõistetu, tunnistaja, eksperdi, tõlgi ja kannatanu suhtes vägivalla toimepanemine",
      "estleg:sectionNumber": "323",
      "estleg:legalText": "Kahtlustatava, süüdistatava, kohtualuse, õigeksmõistetu, süüdimõistetu, tunnistaja, eksperdi, tõlgi või kannatanu suhtes vägivalla toimepanemise eest, et takistada teda täitmast oma kohustusi või teostamast oma õigusi kriminaalmenetluses või maksta talle kätte tema õiguspärase tegevuse eest kriminaalmenetluses, –karistatakse rahalise karistuse või kuni viieaastase vangistusega."
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par323_2",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 323<sup>1</sup>. Saladuse hoidmise kohustuse rikkumine",
      "estleg:sectionNumber": "323",
      "estleg:legalText": "Kinnises kohtumenetluses teatavaks saanud menetlusandmete avaldamise või kohtumäärusega kohaldatud saladuse hoidmise kohustuse rikkumise eest –karistatakse rahalise karistusega või kuni kolmeaastase vangistusega. RT I 2011-02-23 1 123022011001 2011-09-01"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Division18_2",
      "@type": [
        "estleg:Division",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "2. jagu – Isiku õiguste vastased süüteod kohtueelses, kohtuvälises ja kohtumenetluses",
      "estleg:hasSection": [
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par310"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par311"
