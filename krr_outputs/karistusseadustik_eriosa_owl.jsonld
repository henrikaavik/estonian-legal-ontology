        "estleg:Chapter",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "12. peatükk – RAHVATERVISEVASTASED SÜÜTEOD",
      "estleg:hasDivision": [
        {
          "@id": "https://data.riik.ee/ontology/estleg#Division12_1"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Division12_2"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Division12_3"
        },
