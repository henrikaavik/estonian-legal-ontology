        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par271"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par272"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par273"
        }
      ]
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par274",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 274. Vägivald võimuesindaja ja avalikku korda kaitsva muu isiku suhtes",
      "estleg:sectionNumber": "274",
      "estleg:legalText": "1 (1) Võimuesindaja või avalikku korda kaitsva muu isiku suhtes vägivalla toimepanemise eest seoses tema ametikohustuste täitmisega –karistatakse rahalise karistuse või kuni viieaastase vangistusega. 2 (2) Sama teo eest, kui sellega on sunnitud käesoleva paragrahvi lõikes 1 nimetatud isikut ebaseaduslikule teole, –karistatakse kuni viieaastase vangistusega."
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par275",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 275. Võimuesindaja ja avalikku korda kaitsva muu isiku laimamine ja solvamine",
      "estleg:sectionNumber": "275",
      "estleg:legalText": "Võimuesindaja või avalikku korda kaitsva muu isiku laimamise või solvamise eest seoses tema ametikohustuste täitmisega –karistatakse rahalise karistuse või kuni kaheaastase vangistusega."
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par276",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 276. Võimuesindaja seadusliku korralduse eiramine",
      "estleg:sectionNumber": "276",
      "estleg:legalText": "Võimuesindaja seadusliku korralduse eiramise eest –karistatakse rahatrahviga kuni kakssada trahviühikut või arestiga."
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par277",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 277. Ametniku vormiriietuse ja ametitunnistuse ebaseaduslik kasutamine",
      "estleg:sectionNumber": "277",
      "estleg:legalText": "1 (1) Ametniku vormiriietuse või ametitunnistuse ebaseadusliku kasutamise eest –karistatakse rahatrahviga kuni kolmsada trahviühikut või arestiga. 2 (2) Kohus võib kohaldada käesolevas paragrahvis sätestatud süüteo toimepanemise vahetuks objektiks olnud eseme konfiskeerimist vastavalt käesoleva seadustiku §-s 83 sätestatule."
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par278",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 278. Eritalituste vale väljakutsumine",
      "estleg:sectionNumber": "278",
      "estleg:legalText": "Päästeameti, politsei, kiirabi või muude eritalituste teadvalt vale väljakutse või väljasõidu põhjustamise eest –karistatakse rahatrahviga kuni kolmsada trahviühikut või arestiga. RT I 2011-12-29 1 129122011001 2012-01-01"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par279",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 279. Riikliku järelevalve teostamise takistamine",
      "estleg:sectionNumber": "279",
      "estleg:legalText": "Riikliku järelevalve takistamise, järelevalveks vajalike dokumentide või andmete esitamisest keeldumise või tähtaegselt esitamata jätmise või valeandmete esitamise eest või dokumentide või andmete esitamise eest sellisel kujul, mis ei võimaldanud järelevalve teostamist, –karistatakse rahatrahviga kuni kolmsada trahviühikut või arestiga."
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Subdivision16_3_1",
      "@type": [
        "estleg:Subdivision",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "1. jaotis – Võimuesindaja suhtes toimepandud süüteod",
      "estleg:hasSection": [
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par274"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par275"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par276"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par277"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par278"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par279"
        }
      ]
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par280",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 280. Valeandmete esitamine",
      "estleg:sectionNumber": "280",
      "estleg:legalText": "1 (1) Ametiasutusele valeandmete esitamise eest, kui see on toime pandud ametliku dokumendi või muu hüve või tulu saamiseks, –karistatakse rahalise karistuse või kuni üheaastase vangistusega. 2 (2) Sama teo eest, kui selle on toime pannud juriidiline isik, –karistatakse rahalise karistusega."
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par281",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 281. Ebaõigete andmete esitamine kohturegistri pidajale, Eesti väärtpaberite keskregistrile, abieluvararegistrile, notarile ja kohtutäiturile",
      "estleg:sectionNumber": "281",
      "estleg:legalText": "1 (1) Äriregistri pidajale, mittetulundusühingute ja sihtasutuste registri pidajale, laevakinnistusraamatu pidajale, kommertspandiregistri pidajale, Eesti väärtpaberite keskregistri pidajale, abieluvararegistrile, kinnistusraamatu pidajale või notarile ja kohtutäiturile ebaõigete andmete esitamise eest –karistatakse rahalise karistuse või kuni kaheaastase vangistusega. RT I 2007 13 69 12789872 2007-03-15 2 (2) Sama teo eest, kui selle on toime pannud juriidiline isik, –karistatakse rahalise kari"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par282",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 282. Sünnist ja surmast teatamata jätmine",
      "estleg:sectionNumber": "282",
      "estleg:legalText": "Sünnist või surmast seadusega ettenähtud tähtaja jooksul sündi või surma registreerivale ametnikule teatamata jätmise eest –karistatakse rahatrahviga kuni sada trahviühikut või arestiga. RT I 2009 30 177 13187194 2009-06-22"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par283",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 283. Maakasutusnõuete ja maakatastri pidamise korra rikkumine",
      "estleg:sectionNumber": "283",
      "estleg:legalText": "Maakasutusnõuete või maakatastri pidamise korra rikkumise eest, kui see on toime pandud omakasu eesmärgil ja kui sellega on tekitatud suur kahju või põhjustatud muu raske tagajärg, –karistatakse rahalise karistuse või kuni üheaastase vangistusega."
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par284",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 284. Kaitsekoodide üleandmine",
      "estleg:sectionNumber": "284",
      "estleg:legalText": "Arvuti, arvutisüsteemi või arvutivõrgu kaitsekoodide ebaseadusliku üleandmise eest, kui see on toime pandud omakasu eesmärgil ja kui sellega on tekitatud oluline kahju või põhjustatud muu raske tagajärg, –karistatakse rahalise karistuse või kuni kolmeaastase vangistusega."
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par285",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 285. Dokumendi ja arhivaali ebaseaduslik hävitamine",
      "estleg:sectionNumber": "285",
      "estleg:legalText": "1 (1) Kehtetu - RT I 2011-03-21 1 121032011001 2012-01-01 2 (2) Dokumendi või arhivaali ebaseadusliku hävitamise eest, kui sellega on tekitatud oluline kahju, – karistatakse rahalise karistuse või kuni kolmeaastase vangistusega. RT I 2011-03-21 1 121032011001 2012-01-01"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par286",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 286. Dokumendi ja arhivaali kasutamiskõlbmatuks muutmine",
      "estleg:sectionNumber": "286",
      "estleg:legalText": "1 (1) Kehtetu - RT I 2011-03-21 1 121032011001 2012-01-01 2 (2) Dokumendi või arhivaali säilitusnõuete eiramise eest, kui see tõi kaasa dokumendi või arhivaali kasutamiskõlbmatuks muutumise ja sellega on tekitatud oluline kahju, –karistatakse rahalise karistuse või kuni kolmeaastase vangistusega. RT I 2011-03-21 1 121032011001 2012-01-01"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par287",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 287. Dokumendi ja arhivaali kasutamiskõlbmatuks muutmine ettevaatamatusest",
      "estleg:sectionNumber": "287",
      "estleg:legalText": "1 (1) Kehtetu - RT I 2011-03-21 1 121032011001 2012-01-01 2 (2) Dokumendi või arhivaali säilitusnõuete eiramise eest ettevaatamatusest, kui see tõi kaasa dokumendi või arhivaali kasutamiskõlbmatuks muutumise ja sellega on tekitatud oluline kahju, –karistatakse rahalise karistuse või kuni üheaastase vangistusega. RT I 2011-03-21 1 121032011001 2012-01-01"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Subdivision16_3_2",
      "@type": [
        "estleg:Subdivision",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "2. jaotis – Andmetega seotud süüteod",
      "estleg:hasSection": [
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par280"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par281"
