      ]
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Chapter22",
      "@type": [
        "estleg:Chapter",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "22. peatükk – ÜLDOHTLIKUD SÜÜTEOD",
      "estleg:hasDivision": [
        {
          "@id": "https://data.riik.ee/ontology/estleg#Division22_1"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Division22_2"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Division22_3"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Division22_4"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Division22_5"
        }
      ]
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par422",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 422. Sõidukijuhi poolt liiklusnõuete ja sõiduki käitusnõuete rikkumine",
      "estleg:sectionNumber": "422",
      "estleg:legalText": "1 (1) Mootor-, õhu- või veesõiduki või trammi või raudteeveeremi juhi poolt liiklus- või käitusnõuete rikkumise eest, kui sellega on ettevaatamatusest tekitatud inimesele raske tervisekahjustus või põhjustatud inimese surm, –karistatakse kuni viieaastase vangistusega. 2 (2) Sama teo eest, kui sellega on põhjustatud kahe või enama inimese surm, –karistatakse kolme- kuni kaheteistaastase vangistusega."
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par423",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 423. Sõidukijuhi poolt liiklusnõuete ja sõiduki käitusnõuete rikkumine ettevaatamatusest",
      "estleg:sectionNumber": "423",
      "estleg:legalText": "1 (1) Mootor-, õhu- või veesõiduki või trammi või raudteeveeremi juhi poolt liiklus- või käitusnõuete rikkumise eest ettevaatamatusest, kui sellega on tekitatud inimesele raske tervisekahjustus või põhjustatud inimese surm, –karistatakse rahalise karistuse või kuni kolmeaastase vangistusega. 2 (2) Sama teo eest, kui sellega on põhjustatud kahe või enama inimese surm, –karistatakse ühe- kuni viieaastase vangistusega."
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par424",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 424. Mootorsõiduki, maastikusõiduki ja trammi juhtimine joobeseisundis",
      "estleg:sectionNumber": "424",
      "estleg:legalText": "Mootorsõiduki, maastikusõiduki või trammi juhtimise eest joobeseisundis –karistatakse rahalise karistuse või kuni kolmeaastase vangistusega. RT I 2010 44 261 13335732 2011-01-01"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par424_2",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 424<sup>1</sup>. Mootorsõiduki, maastikusõiduki ja trammi juhtimine joobeseisundis ettevaatamatusest",
      "estleg:sectionNumber": "424",
      "estleg:legalText": "Mootorsõiduki, maastikusõiduki või trammi juhtimise eest joobeseisundis ettevaatamatusest –karistatakse rahalise karistuse või kuni üheaastase vangistusega. RT I 2010 44 261 13335732 2011-01-01"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par425",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 425. Liiklusohutusnõuete ja sõiduki käitusnõuete rikkumine",
      "estleg:sectionNumber": "425",
      "estleg:legalText": "1 (1) Raudtee-, vee-, õhu- või teeliikluse korraldamise eest vastutava isiku poolt liiklusohutusnõuete või sõiduki käitusnõuete eiramise eest, kui sellega on põhjustatud oht inimese elule, tervisele, varale või keskkonnale, –karistatakse rahalise karistuse või kuni kolmeaastase vangistusega. 2 (2) Sama teo eest, kui sellega on: 1 1) põhjustatud inimese surm; 2 2) tekitatud inimesele tervisekahjustus või 3 3) tekitatud suur kahju, –karistatakse kolme- kuni kaheteistaastase vangistusega."
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par426",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 426. Alarmsõiduki tähistuse ebaseaduslik kasutamine",
      "estleg:sectionNumber": "426",
      "estleg:legalText": "Mootorsõidukile alarmsõidukil olevaga sarnase värviskeemi ebaseadusliku pealekandmise või erisignaalseadme ebaseadusliku paigutamise eest või selliselt tähistatud mootorsõiduki kasutamise või juhtimise eest –karistatakse rahalise karistusega."
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par427",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 427. Rahvusvahelise õhusõidu eeskirjade rikkumine",
      "estleg:sectionNumber": "427",
      "estleg:legalText": "Loata Eesti Vabariigi õhuruumi sisselendamise või sellest väljalendamise eest, loas tähendatud marsruudist, õhuväravast või lennukõrgusest mittekinnipidamise või rahvusvahelise õhusõidu nõuete muu rikkumise eest –karistatakse rahalise karistuse või kuni üheaastase vangistusega."
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par428",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 428. Reisija poolt kergesti süttiva ja sööbiva aine vedu õhusõidukis",
      "estleg:sectionNumber": "428",
      "estleg:legalText": "1 (1) Reisija poolt õhusõidukis kergesti süttiva või sööbiva aine veo eest –karistatakse rahalise karistusega. 2 (2) Sama teo eest, kui sellega on tekitatud suur kahju, –karistatakse ühe- kuni viieaastase vangistusega."
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par429",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 429. Laevade kokkupõrkel teise laeva päästmiseks abinõude tarvitusele võtmata jätmine",
      "estleg:sectionNumber": "429",
      "estleg:legalText": "Laevade kokkupõrkel laeva kapteni poolt teise laeva päästmiseks vajalike abinõude tarvitusele võtmata jätmise eest, kui nende tarvituselevõtmine oli võimalik tõsise ohuta oma reisijaile, meeskonnale või laevale, –karistatakse rahalise karistuse või kuni kolmeaastase vangistusega."
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par430",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 430. Rongi omavoliline ilma vajaduseta peatamine",
      "estleg:sectionNumber": "430",
      "estleg:legalText": "Rongi ilma vajaduseta peatamise eest hädapiduriga, õhkpidurmagistraali lahutamise teel või mõnel muul viisil, kui sellega on ettevaatamatusest: 1 1) tekitatud inimesele raske tervisekahjustus; 2 2) põhjustatud inimese surm või 3 3) tekitatud suur kahju, –karistatakse rahalise karistuse või kuni viieaastase vangistusega."
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Chapter23",
      "@type": [
        "estleg:Chapter",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "23. peatükk – LIIKLUSSÜÜTEOD",
      "estleg:hasSection": [
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par422"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par423"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par424"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par424"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par425"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par426"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par427"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par428"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par429"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par430"
        }
      ]
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par431",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 431. Karistamine käesolevas peatükis sätestatud süüteo eest",
      "estleg:sectionNumber": "431",
      "estleg:legalText": "1 (1) Kaitseväeteenistusalase süüteo toimepanemise eest karistatakse isikut, kes on kaitseväeteenistuses. RT I 2012-07-10 2 110072012002 2013-04-01 2 (2) Kehtetu - RT I 2012-07-10 2 110072012002 2013-04-01"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par432",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 432. Keeldumine käsu täitmisest",
      "estleg:sectionNumber": "432",
      "estleg:legalText": "1 (1) Ülema seadusliku teenistusalase käsu täitmisest keeldumise eest isiku poolt, kellel on kehtiv distsiplinaarkaristus sellise üleastumise eest –karistatakse kuni kaheaastase vangistusega. RT I 2002 56 350 177120 2002-09-01 2 (2) Sama teo eest, kui see on toime pandud grupi poolt avalikult, –karistatakse kuni kolmeaastase vangistusega. 3 (3) Käesoleva paragrahvi lõikes 1 või 2 sätestatud teo eest, kui see on toime pandud erakorralise või sõjaseisukorra ajal, –karistatakse kahe- kuni kümneaast"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par433",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 433. Käsu täitmata jätmine",
      "estleg:sectionNumber": "433",
      "estleg:legalText": "1 (1) Ülema seadusliku teenistusalase käsu täitmata jätmise eest isiku poolt, kellel on kehtiv distsiplinaarkaristus sellise üleastumise eest –karistatakse kuni üheaastase vangistusega. RT I 2002 56 350 177120 2002-09-01 2 (2) Käesoleva paragrahvi lõikes 1 sätestatud teo eest, kui see on toime pandud erakorralise või sõjaseisukorra ajal, –karistatakse kahe- kuni kümneaastase vangistusega."
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par434",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 434. Kaitseväeteenistuses oleva isiku ähvardamine",
      "estleg:sectionNumber": "434",
      "estleg:legalText": "Kaitseväeteenistuses oleva isiku või tema perekonnaliikme ähvardamise eest tapmise, tervisekahjustuse tekitamise või vara hävitamise või rikkumisega eesmärgiga lõpetada kaitseväeteenistusalaste kohustuste täitmine või muuta nende iseloomu – karistatakse kuni kolmeaastase vangistusega. RT I 2012-07-10 2 110072012002 2013-04-01"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par435",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 435. Vägivald kaitseväeteenistuses oleva isiku suhtes",
      "estleg:sectionNumber": "435",
      "estleg:legalText": "1 (1) Kaitseväeteenistuses olevale isikule või tema perekonnaliikmele raske tervisekahjustuse tekitamise või tema suhtes vägivalla kasutamise eest eesmärgiga lõpetada kaitseväeteenistusalaste kohustuste täitmine või muuta nende iseloomu –karistatakse nelja- kuni kaheteistaastase vangistusega. RT I 2012-07-10 2 110072012002 2013-04-01 2 (2) Sama teo eest, kui see on toime pandud erakorralise või sõjaseisukorra ajal, –karistatakse viie- kuni viieteistaastase vangistusega."
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par436",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 436. Omavoliline lahkumine väeosast ja muust teenistuskohast",
      "estleg:sectionNumber": "436",
      "estleg:legalText": "1 (1) Väeosast või muust teenistuskohast omavolilise lahkumise eest, samuti väeosast väljalubatu poolt tähtajaks teenistusse ilmumata jätmise eest, kui omavoliline äraolek on kestnud üle kolme päeva, –karistatakse kuni üheaastase vangistusega. 2 (2) Sama teo eest, kui omavoliline äraolek on kestnud üle kolmekümne päeva, –karistatakse kuni kaheaastase vangistusega. 3 (3) Käesoleva paragrahvi lõikes 1 või 2 sätestatud teo eest, kui see on toime pandud erakorralise või sõjaseisukorra ajal, sõltumat"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par437",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 437. Omavoliline lahkumine väeosast ja muust teenistuskohast teenistusrelvaga",
      "estleg:sectionNumber": "437",
      "estleg:legalText": "Väeosast või muust teenistuskohast omavolilise lahkumise eest teenistusrelvaga –karistatakse ühe- kuni viieaastase vangistusega."
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par438",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 438. Väeosa ja muu teenistuskoha omavoliline mahajätmine lahinguolukorras",
      "estleg:sectionNumber": "438",
      "estleg:legalText": "Väeosa või muu teenistuskoha omavolilise mahajätmise eest lahinguolukorras –karistatakse kahe- kuni kümneaastase vangistusega."
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par439",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 439. Väejooks",
      "estleg:sectionNumber": "439",
      "estleg:legalText": "1 (1) Väeosast või muust teenistuskohast omavolilise lahkumise eest, kui see on toime pandud kaitseväeteenistusest kõrvalehoidumise eesmärgil, –karistatakse ühe- kuni viieaastase vangistusega. RT I 2005 68 529 969347 2006-01-01 2 (2) Sama teo eest, kui see on toime pandud erakorralise või sõjaseisukorra ajal, –karistatakse kahe- kuni kümneaastase vangistusega."
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par440",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 440. Kaitseväeteenistusest kõrvalehoidumine",
      "estleg:sectionNumber": "440",
      "estleg:legalText": "1 (1) Kaitseväeteenistusest kõrvalehoidumise eest endale vigastuse tekitamise või tekitada laskmise, haiguse simuleerimise, dokumendi võltsimise või muu pettuse teel –karistatakse ühe- kuni viieaastase vangistusega. 2 (2) Sama teo eest eesmärgiga kõrvale hoiduda kaitseväeteenistusalaste kohustuste kandmisest –karistatakse kuni kolmeaastase vangistusega. 3 (3) Käesoleva paragrahvi lõikes 1 või 2 sätestatud teo eest erakorralise või sõjaseisukorra ajal –karistatakse kahe- kuni kümneaastase vangist"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par441",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 441. Masinate juhtimise ja käitusnõuete rikkumine",
      "estleg:sectionNumber": "441",
      "estleg:legalText": "Lahingutehnika, spetsiaal- või transpordimasina käitusnõuete rikkumise eest, kui sellega on ettevaatamatusest: 1 1) põhjustatud inimese surm; 2 2) tekitatud inimesele raske tervisekahjustus või 3 3) tekitatud suur kahju, –karistatakse ühe- kuni viieaastase vangistusega."
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par442",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 442. Lendude ja nendeks ettevalmistamise nõuete rikkumine",
      "estleg:sectionNumber": "442",
      "estleg:legalText": "Lendude või nendeks ettevalmistamise nõuete rikkumise eest, kui sellega on ettevaatamatusest: 1 1) põhjustatud inimese surm; 2 2) tekitatud inimesele raske tervisekahjustus või 3 3) tekitatud suur kahju, –karistatakse kahe- kuni kümneaastase vangistusega."
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par443",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 443. Laevajuhtimisnõuete rikkumine",
      "estleg:sectionNumber": "443",
      "estleg:legalText": "Laevajuhtimisnõuete rikkumise eest, kui sellega on ettevaatamatusest: 1 1) põhjustatud inimese surm; 2 2) tekitatud inimesele raske tervisekahjustus; 3 3) põhjustatud laeva hukkumine või 4 4) tekitatud suur kahju, –karistatakse kahe- kuni kümneaastase vangistusega."
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par444",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 444. Sise- ja distsiplinaarmäärustiku rikkumine",
      "estleg:sectionNumber": "444",
      "estleg:legalText": ""
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par445",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 445. Vale teenistusalane ettekanne",
      "estleg:sectionNumber": "445",
      "estleg:legalText": "1 (1) Vale suulise või kirjaliku teenistusalase ettekande eest –karistatakse kuni üheaastase vangistusega. 2 (2) Sama teo eest, kui sellega on: 1 1) põhjustatud inimese surm; 2 2) tekitatud inimesele tervisekahjustus või 3 3) tekitatud suur kahju, –karistatakse kuue- kuni viieteistaastase vangistusega. 3 (3) Kehtetu - RT I 2012-07-10 2 110072012002 2013-04-01"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par446",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 446. Võimu kuritarvitamine",
      "estleg:sectionNumber": "446",
      "estleg:legalText": "1 (1) Ülema poolt võimuliialduse, võimupiiridest või teenistusvolitustest üleastumise eest, kui sellega on tekitatud oluline kahju isiku seadusega kaitstud õigustele või huvidele või riigi huvidele, –karistatakse kuni viieaastase vangistusega. RT I 2010 17 93 13307502 2010-05-10 2 (2) Sama teo eest, kui see on toime pandud erakorralise või sõjaseisukorra ajal, –karistatakse ühe- kuni viieaastase vangistusega."
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par447",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 447. Teenistusalane lohakus",
      "estleg:sectionNumber": "447",
      "estleg:legalText": "1 (1) Tegevväelase poolt oma teenistusalase ülesande täitmata jätmise või pealiskaudse täitmise eest sellesse kohusetundetu või hooletu suhtumise tõttu, kui sellega on tekitatud oluline kahju isiku seadusega kaitstud õigustele või huvidele või riigi huvidele, –karistatakse kuni kaheaastase vangistusega. RT I 2012-07-10 2 110072012002 2013-04-01 2 (2) Sama teo eest erakorralise või sõjaseisukorra ajal –karistatakse kuni viieaastase vangistusega."
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par448",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 448. Kaitsejõudude vara pillamine",
      "estleg:sectionNumber": "448",
      "estleg:legalText": "1 (1) Kaitsejõudude relvastuse, tehnika, varustuse või muu vara pantimise, mahajätmise, kaotamise, kohusetundetu hoidmise või rikkumise eest, kui sellega on tekitatud suur kahju, –karistatakse kuni viieaastase vangistusega. 2 (2) Sama teo eest, kui see on toime pandud erakorralise või sõjaseisukorra ajal, –karistatakse ühe- kuni viieaastase vangistusega."
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par449",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 449. Relvastatud üksuse üleandmine ja vara jätmine vaenlasele",
      "estleg:sectionNumber": "449",
      "estleg:legalText": "Ülema poolt temale usaldatud relvastatud üksuse omavolilise üleandmise eest vaenlasele, samuti kindlustuse, lahingutehnika või muu vara jätmise eest vaenlasele, kui seda ei ole tinginud lahinguolukord, –karistatakse kolme- kuni kaheteistaastase vangistusega. RT I 2012-07-10 2 110072012002 2013-04-01"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par450",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 450. Hukkuva sõjalaeva mahajätmine",
      "estleg:sectionNumber": "450",
      "estleg:legalText": "1 (1) Hukkuva sõjalaeva mahajätmise eest komandöri poolt, kes ei täitnud oma teenistuskohustusi lõpuni, samuti laeva meeskonda kuuluva isiku poolt ilma komandöri sellekohase korralduseta –karistatakse ühe- kuni viieaastase vangistusega. 2 (2) Sama teo eest, kui see on toime pandud erakorralise või sõjaseisukorra ajal, –karistatakse kahe- kuni kümneaastase vangistusega."
    },
