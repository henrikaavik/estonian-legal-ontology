      "@type": [
        "estleg:Division",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "4. jagu – Süüteod töötervishoiu ja tööohutuse valdkonnas",
      "estleg:hasSection": [
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par197"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par198"
        }
      ]
