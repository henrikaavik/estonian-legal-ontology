        }
      ]
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Chapter16",
      "@type": [
        "estleg:Chapter",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "16. peatükk – AVALIKU RAHU VASTASED SÜÜTEOD",
      "estleg:hasDivision": [
        {
          "@id": "https://data.riik.ee/ontology/estleg#Division16_1"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Division16_2"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Division16_3"
        }
      ]
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par288",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 288. Ametiisiku mõiste",
      "estleg:sectionNumber": "288",
      "estleg:legalText": "1 (1) Ametiisik käesoleva seadustiku eriosa tähenduses on füüsiline isik, kellel on avaliku ülesande täitmiseks ametiseisund, sõltumata sellest, kas ta täidab talle pandud ülesandeid alaliselt või ajutiselt, tasu eest või tasuta, teenistuses olles või vabakutselisena või lepingu, nimetamise või valimise alusel. RT I 2013-07-05 2 105072013002 2013-07-15 2 (2) Ametiisik käesoleva seadustiku §-des 293–298 nimetatud kuritegudes on ka vahekohtunik ja füüsiline isik, kellel on pädevus juhtida eraõigus"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par289",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 289.",
      "estleg:sectionNumber": "289",
      "estleg:legalText": ""
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par290",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 290.",
      "estleg:sectionNumber": "290",
      "estleg:legalText": ""
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par291",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 291. Võimuliialdus",
      "estleg:sectionNumber": "291",
      "estleg:legalText": "Ametialaseid ülesandeid täitva ametiisiku poolt relva, erivahendi või vägivalla ebaseadusliku kasutamise eest –karistatakse rahalise karistuse või ühe- kuni viieaastase vangistusega."
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par291_2",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 291<sup>1</sup>. Riikliku järelevalve ebaseaduslik teostamine",
      "estleg:sectionNumber": "291",
      "estleg:legalText": "Riiklikku järelevalvet teostava või kohalikule omavalitsusele seadusega pandud järelevalvekohustust täitva ametiisiku poolt teadvalt ebaseadusliku otsuse või toimingu tegemise eest või otsuse või toimingu ebaseaduslikult tegemata jätmise eest, kui sellega on tekitatud oluline varaline kahju või kui sellega on teisele isikule, välja arvatud riik ja kohalik omavalitsusüksus, põhjustatud muu raske tagajärg, –karistatakse rahalise karistusega või kuni viieaastase vangistusega. RT I 2007 13 69 127898"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par292",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 292. Andmekogu pidamise nõuete rikkumine",
      "estleg:sectionNumber": "292",
      "estleg:legalText": "Riigi või kohaliku omavalitsuse andmekogu pidaja ametniku või töötaja poolt ebaseaduslikult registrisse andmete kandmise või andmete kandmata jätmise eest, samuti andmete avalikustamise, andmetele juurdepääsu võimaldamise või andmete edastamise või muude andmekogu pidamise nõuete rikkumise eest, kui sellega on tekitatud oluline kahju teise isiku seadusega kaitstud õigustele või huvidele, –karistatakse rahalise karistuse või kuni kolmeaastase vangistusega. RT I 2007 13 69 12789872 2007-03-15"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Division17_1",
      "@type": [
        "estleg:Division",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "1. jagu – Võimu kuritarvitamine",
      "estleg:hasSection": [
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par288"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par289"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par290"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par291"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par291"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par292"
        }
      ]
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par293",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 293. Pistise võtmine",
      "estleg:sectionNumber": "293",
      "estleg:legalText": "1 (1) Ametiisiku poolt talle või kolmandale isikule vara või muu soodustuse lubamisega nõustumise või vara või muu soodustuse vastuvõtmise eest vastutasuna selle eest, et ametiisik on oma ametiseisundit kasutades toime pannud või on alust arvata, et ta edaspidi paneb toime seadusega lubatud teo, või on seaduslikult jätnud teo toime panemata või on alust arvata, et ta jätab selle toime panemata edaspidi, –karistatakse rahalise karistuse või kuni kolmeaastase vangistusega. RT I 2008 33 200 1299762"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par294",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 294. Altkäemaksu võtmine",
      "estleg:sectionNumber": "294",
      "estleg:legalText": "1 (1) Ametiisiku poolt talle või kolmandale isikule vara või muu soodustuse lubamisega nõustumise või vara või muu soodustuse vastuvõtmise eest vastutasuna selle eest, et ametiisik on oma ametiseisundit kasutades toime pannud või on alust arvata, et ta edaspidi paneb toime seadusega mittelubatud teo, või on ebaseaduslikult jätnud teo toime panemata või on alust arvata, et ta jätab selle toime panemata edaspidi, –karistatakse ühe- kuni viieaastase vangistusega. RT I 2008 33 200 12997629 2008-07-2"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par295",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 295. Pistise vahendus",
      "estleg:sectionNumber": "295",
      "estleg:legalText": "1 (1) Pistise vahendamise eest –karistatakse rahalise karistuse või kuni üheaastase vangistusega. 2 (2) Sama teo eest, kui see on toime pandud: 1 1) isiku poolt, kes on varem toime pannud pistise või altkäemaksu vahenduse, või 2 2) ametiseisundit kasutades, –karistatakse rahalise karistuse või kuni kolmeaastase vangistusega. RT I 2013-07-05 2 105072013002 2013-07-15 3 (3) Käesoleva paragrahvi lõikes 1 või 2 sätestatud teo eest, kui selle on toime pannud juriidiline isik, –karistatakse rahalise k"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par296",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 296. Altkäemaksu vahendus",
      "estleg:sectionNumber": "296",
      "estleg:legalText": "1 (1) Altkäemaksu vahendamise eest –karistatakse rahalise karistuse või kuni üheaastase vangistusega. 2 (2) Sama teo eest, kui see on toime pandud: 1 1) isiku poolt, kes on varem toime pannud altkäemaksu või pistise vahenduse, või 2 2) ametiseisundit kasutades, –karistatakse rahalise karistuse või kuni kolmeaastase vangistusega. RT I 2013-07-05 2 105072013002 2013-07-15 3 (3) Käesoleva paragrahvi lõikes 1 või 2 sätestatud teo eest, kui selle on toime pannud juriidiline isik, –karistatakse rahali"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par297",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 297. Pistise andmine",
      "estleg:sectionNumber": "297",
      "estleg:legalText": "1 (1) Pistise lubamise või andmise eest –karistatakse rahalise karistuse või kuni kolmeaastase vangistusega. RT I 2002 56 350 177120 2002-09-01 2 (2) Sama teo eest, kui see on toime pandud: 1 1) isiku poolt, kes on varem toime pannud pistise või altkäemaksu andmise; 2 2) grupi poolt või 3 3) suures ulatuses, –karistatakse kuni viieaastase vangistusega. RT I 2013-07-05 2 105072013002 2013-07-15 3 (3) Käesoleva paragrahvi lõikes 1 või 2 sätestatud teo eest, kui selle on toime pannud juriidiline is"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par298",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 298. Altkäemaksu andmine",
      "estleg:sectionNumber": "298",
      "estleg:legalText": "1 (1) Altkäemaksu lubamise või andmise eest –karistatakse ühe- kuni viieaastase vangistusega. RT I 2002 56 350 177120 2002-09-01 2 (2) Sama teo eest, kui see on toime pandud: 1 1) isiku poolt, kes on varem toime pannud altkäemaksu või pistise andmise 2 2) grupi poolt; 3 3) suures ulatuses või 4 4) raske tagajärjega, –karistatakse kahe- kuni kümneaastase vangistusega. RT I 2013-07-05 2 105072013002 2013-07-15 3 (3) Käesoleva paragrahvi lõikes 1 sätestatud teo eest, kui selle on toime pannud jurii"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par298_2",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 298<sup>1</sup>. Mõjuvõimuga kauplemine",
      "estleg:sectionNumber": "298",
      "estleg:legalText": "1 (1) Vara või muu soodustuse lubamisega nõustumise või vastuvõtmise eest vastutasuna selle eest, et isik kasutab ebaseaduslikult oma tegelikku või eeldatavat mõju eesmärgiga saavutada avaliku halduse ülesandeid täitvalt ametiisikult tema ametiseisundit kasutades teo toimepanemine või toimepanemata jätmine vara või muu soodustuse andja või kolmanda isiku huvides, –karistatakse rahalise karistusega või kuni kolmeaastase vangistusega. 2 (2) Sama teo eest, kui selle on toime pannud juriidiline isik"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par299",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 299. Ametialane võltsimine",
      "estleg:sectionNumber": "299",
      "estleg:legalText": "1 (1) Ametiisiku poolt dokumendi võltsimise või võltsitud dokumendi väljaandmise eest –karistatakse rahalise karistuse või kuni kolmeaastase vangistusega. RT I 2007 13 69 12789872 2007-03-15 2 (2) Kehtetu - RT I 2007 13 69 12789872 2007-03-15"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par300",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 300. Riigihangete teostamise nõuete rikkumine",
      "estleg:sectionNumber": "300",
      "estleg:legalText": "Riigihangete konkursil ühele osalejatest põhjendamatute soodustingimuste või eeliste loomise või muul viisil riigihangete teostamise nõuete rikkumise eest, kui sellega on tekitatud oluline varaline kahju, –karistatakse rahalise karistuse või kuni üheaastase vangistusega. RT I 2007 13 69 12789872 2007-03-15"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par300_2",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 300<sup>1</sup>. Toimingupiirangu rikkumine",
      "estleg:sectionNumber": "300",
      "estleg:legalText": "1 (1) Korruptsioonivastases seaduses kehtestatud toimingupiirangu teadva rikkumise eest suures ulatuses –karistatakse rahalise karistuse või kuni üheaastase vangistusega. RT I 2007 13 69 12789872 2007-03-15 2 (2) Sama teo eest, kui see on toime pandud ulatuses üle 320 000 eurot, –karistatakse rahalise karistuse või kuni kolmeaastase vangistusega. RT I 2013-07-05 2 105072013002 2013-07-15"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par300_3",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 300<sup>2</sup>. Notari poolt teadvalt ebaseadusliku ametitoimingu tegemine",
      "estleg:sectionNumber": "300",
      "estleg:legalText": "1 (1) Notari poolt teadvalt ametitoiminguga seotud kohustuse täitmata jätmise eest, kui sellega on tekitatud oluline varaline kahju, samuti tõestamistoimingu või muu ametitoimingu tegemise keelu teadva rikkumise eest, samuti teadvalt ametitoimingu tegemise eest, milles osaleb notar ise, tema abikaasa, notari otsejoones sugulane või nende esindaja, või mis on tehtud notari või tema lähikondlase kasuks, –karistatakse rahalise karistuse või kuni kolmeaastase vangistusega. 2 (2) Sama teo eest, kui s"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Par301",
      "@type": [
        "estleg:Section",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "§ 301. Konfiskeerimise kohaldamine",
      "estleg:sectionNumber": "301",
      "estleg:legalText": "Kohus võib kohaldada käesoleva seadustiku §-des 293 kuni 299 sätestatud süüteo toimepanemise vahetuks objektiks olnud eseme konfiskeerimist vastavalt käesoleva seadustiku §-s 83 sätestatule."
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Division17_2",
      "@type": [
        "estleg:Division",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "2. jagu – Aususe kohustuse rikkumine",
      "estleg:hasSection": [
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par293"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par294"
        },
        {
          "@id": "https://data.riik.ee/ontology/estleg#Par295"
