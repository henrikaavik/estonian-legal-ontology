    {
      "@id": "https://data.riik.ee/ontology/estleg#Chapter11",
      "@type": [
        "estleg:Chapter",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "11. peatükk – SÜÜTEOD PEREKONNA JA ALAEALISE VASTU",
      "estleg:hasDivision": [
        {
          "@id": "https://data.riik.ee/ontology/estleg#Division11_1"
        },
