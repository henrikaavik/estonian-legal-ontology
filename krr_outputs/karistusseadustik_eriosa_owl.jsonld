    {
      "@id": "https://data.riik.ee/ontology/estleg#Syytegu",
      "@type": [
        "estleg:LegalConcept",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "Süütegu",
      "skos:definition": "Karistusseadustikus või muus seaduses sätestatud karistatav tegu.",
      "dc:references": "KarS § 3 lg 1"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Kuritegu",
      "@type": [
        "estleg:LegalConcept",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "Kuritegu",
      "skos:definition": "Karistusseadustikus sätestatud süütegu, mille eest on füüsilisele isikule põhikaristusena ette nähtud rahaline karistus või vangistus ja juriidilisele isikule rahaline karistus või sundlõpetamine.",
      "dc:references": "KarS § 3 lg 3"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Vaartegu",
      "@type": [
        "estleg:LegalConcept",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "Väärtegu",
      "skos:definition": "Karistusseadustikus või muus seaduses sätestatud süütegu, mille eest on põhikaristusena ette nähtud rahatrahv või arest.",
      "dc:references": "KarS § 3 lg 4"
    },
    {
      "@id": "https://data.riik.ee/ontology/estleg#Tahtlus",
      "@type": [
        "estleg:LegalConcept",
        "owl:NamedIndividual"
      ],
      "rdfs:label": "Tahtlus",
      "skos:definition": "Tahtlus on kavatsetus, otsene tahtlus või kaudne tahtlus.",
      "dc:references": "KarS § 16"
    },
    {
