    },
    {
      "@id": "estleg:TsUS_Par_48",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_tsiviilseadustik_osa3"
      ],
      "estleg:paragrahv": "§48",
      "rdfs:label": "Eseme mõiste",
      "estleg:requestedCluster": "things_48_49",
      "estleg:summary": "Esemeks on asjad, õigused ja muud hüved, mis võivad olla õiguse objektiks.",
      "estleg:relatesToConcept": "estleg:Concept_Thing",
      "estleg:sourceAct": "Tsiviilseadustiku üldosa seadus"
    },
    {
      "@id": "estleg:TsUS_Par_49",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_tsiviilseadustik_osa3"
      ],
      "estleg:paragrahv": "§49",
      "rdfs:label": "Asja mõiste",
      "estleg:requestedCluster": "things_48_49",
      "estleg:summary": "Asi on kehaline ese; seaduses sätestatud juhtudel kohaldatakse õigusele asja reegleid ning loomadele asjade sätteid, kui ei ole sätestatud teisiti.",
      "estleg:relatesToConcept": "estleg:Concept_CorporealThing",
      "estleg:sourceAct": "Tsiviilseadustiku üldosa seadus"
    },
    {
      "@id": "estleg:TsUS_Par_50",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_tsiviilseadustik_osa3"
      ],
      "estleg:paragrahv": "§50",
      "rdfs:label": "Kinnisasi ja vallasasi",
      "estleg:requestedCluster": "property_types_50_61",
      "estleg:summary": "Kinnisasi on maatükk; muu asi on vallasasi; seaduses sätestatud juhtudel võib vallasasjale kohaldada kinnisasja sätteid.",
      "estleg:relatesToConcept": "estleg:Concept_ImmovableMovable",
      "estleg:sourceAct": "Tsiviilseadustiku üldosa seadus"
    },
    {
      "@id": "estleg:TsUS_Par_51",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_tsiviilseadustik_osa3"
      ],
      "estleg:paragrahv": "§51",
      "rdfs:label": "Asendatav asi",
      "estleg:requestedCluster": "property_types_50_61",
      "estleg:summary": "Asendatav on liigitunnustega määratav vallasasi; poolte kokkuleppel saab asendatava ja asendamatu asja omadusi vastastikku ümber määrata.",
      "estleg:relatesToConcept": "estleg:Concept_ImmovableMovable",
      "estleg:sourceAct": "Tsiviilseadustiku üldosa seadus"
    },
    {
      "@id": "estleg:TsUS_Par_52",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_tsiviilseadustik_osa3"
      ],
      "estleg:paragrahv": "§52",
      "rdfs:label": "Äratarvitatav asi",
      "estleg:requestedCluster": "property_types_50_61",
      "estleg:summary": "Äratarvitatav on vallasasi, mis tavakasutuses hävib või võõrandatakse; sama kehtib ka kogumitele, mille kasutus seisneb üksikosade võõrandamises.",
      "estleg:relatesToConcept": "estleg:Concept_ImmovableMovable",
      "estleg:sourceAct": "Tsiviilseadustiku üldosa seadus"
    },
    {
      "@id": "estleg:TsUS_Par_53",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_tsiviilseadustik_osa3"
      ],
      "estleg:paragrahv": "§53",
      "rdfs:label": "Oluline osa",
      "estleg:requestedCluster": "property_types_50_61",
      "estleg:summary": "Oluline osa on eraldamatu koostisosa; asi ja selle olulised osad ei saa üldjuhul olla eri omandis ega erinevalt asjaõigustega koormatud.",
      "estleg:relatesToConcept": "estleg:Concept_EssentialPart",
      "estleg:sourceAct": "Tsiviilseadustiku üldosa seadus"
    },
    {
      "@id": "estleg:TsUS_Par_54",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_tsiviilseadustik_osa3"
      ],
      "estleg:paragrahv": "§54",
      "rdfs:label": "Kinnisasja osad",
      "estleg:requestedCluster": "property_types_50_61",
      "estleg:summary": "Kinnisasja oluliste osade hulka kuuluvad püsivalt ühendatud asjad; erandid on nt võõrale maale asjaõiguse alusel püstitatud ehitis ja teatud tehnovõrgud; õiguse lõppemisel võib ehitis muutuda maatüki oluliseks osaks.",
      "estleg:relatesToConcept": "estleg:Concept_EssentialPart",
      "estleg:sourceAct": "Tsiviilseadustiku üldosa seadus"
    },
    {
      "@id": "estleg:TsUS_Par_55",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_tsiviilseadustik_osa3"
      ],
      "estleg:paragrahv": "§55",
      "rdfs:label": "Ehitise osad",
      "estleg:requestedCluster": "property_types_50_61",
      "estleg:summary": "Ehitise olulised osad on ehitisega püsivalt seotud ja kahjustuseta eraldamatud asjad; ajutiseks otstarbeks ühendatu ei ole ehitise osa.",
      "estleg:relatesToConcept": "estleg:Concept_EssentialPart",
      "estleg:sourceAct": "Tsiviilseadustiku üldosa seadus"
    },
    {
      "@id": "estleg:TsUS_Par_56",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_tsiviilseadustik_osa3"
      ],
      "estleg:paragrahv": "§56",
      "rdfs:label": "Mõtteline osa",
      "estleg:requestedCluster": "property_types_50_61",
      "estleg:summary": "Mõtteline osa on tegelikkuses piiritlemata osa asjast, mida väljendatakse murdosana.",
      "estleg:relatesToConcept": "estleg:Concept_EssentialPart",
      "estleg:sourceAct": "Tsiviilseadustiku üldosa seadus"
    },
    {
      "@id": "estleg:TsUS_Par_57",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_tsiviilseadustik_osa3"
      ],
      "estleg:paragrahv": "§57",
      "rdfs:label": "Päraldis",
      "estleg:requestedCluster": "property_types_50_61",
      "estleg:summary": "Päraldis on peaasja teeniv, kuid mitte selle osa olev vallasasi; peaasjaga seotud õigused ja kohustused laienevad üldjuhul ka päraldisele.",
      "estleg:relatesToConcept": "estleg:Concept_Accessory",
      "estleg:sourceAct": "Tsiviilseadustiku üldosa seadus"
    },
    {
      "@id": "estleg:TsUS_Par_58",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_tsiviilseadustik_osa3"
      ],
      "estleg:paragrahv": "§58",
      "rdfs:label": "Dokumendid päraldisena",
      "estleg:requestedCluster": "property_types_50_61",
      "estleg:summary": "Asja omandamist, valdamist või kinnisasjale ehitamist tõendavad dokumendid, kaardid ja plaanid on asja päraldised.",
      "estleg:relatesToConcept": "estleg:Concept_Accessory",
      "estleg:sourceAct": "Tsiviilseadustiku üldosa seadus"
    },
    {
      "@id": "estleg:TsUS_Par_59",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_tsiviilseadustik_osa3"
      ],
      "estleg:paragrahv": "§59",
      "rdfs:label": "Majandus- või kutsetegevuses kasutatava kinnisasja päraldised",
      "estleg:requestedCluster": "property_types_50_61",
      "estleg:summary": "Majandus- või kutsetegevuse kinnisasja päraldisteks on mh selle tegevuse jaoks vajalikud masinad, seadmed, tööriistad ja muud vallasasjad.",
      "estleg:relatesToConcept": "estleg:Concept_Accessory",
      "estleg:sourceAct": "Tsiviilseadustiku üldosa seadus"
    },
    {
      "@id": "estleg:TsUS_Par_60",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_tsiviilseadustik_osa3"
      ],
      "estleg:paragrahv": "§60",
      "rdfs:label": "Põllumajandusliku kinnisasja päraldised",
      "estleg:requestedCluster": "property_types_50_61",
      "estleg:summary": "Põllumajandusliku kinnisasja päraldised hõlmavad mh inventari, masinaid, loomi ning järgmise saagini vajalikke saadusi.",
      "estleg:relatesToConcept": "estleg:Concept_Accessory",
      "estleg:sourceAct": "Tsiviilseadustiku üldosa seadus"
    },
    {
      "@id": "estleg:TsUS_Par_61",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_tsiviilseadustik_osa3"
      ],
      "estleg:paragrahv": "§61",
      "rdfs:label": "Päraldise lõppemine",
      "estleg:requestedCluster": "property_types_50_61",
      "estleg:summary": "Päraldis lõpeb peaasjast lahutamisel koos tahtega päraldise teenimisfunktsioon lõpetada; ajutine lahutamine päraldist ei lõpeta.",
      "estleg:relatesToConcept": "estleg:Concept_Accessory",
      "estleg:sourceAct": "Tsiviilseadustiku üldosa seadus"
    },
    {
      "@id": "estleg:TsUS_Par_62",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_tsiviilseadustik_osa3"
      ],
      "estleg:paragrahv": "§62",
      "rdfs:label": "Kasu",
      "estleg:requestedCluster": "ownership_economics_62_66",
      "estleg:summary": "Kasu hõlmab vilju ja kasutuseeliseid; sätestatakse asja- ja õigusvilja mõiste ning vilja kuulumine õigustatud isikule ajaperioodi järgi.",
      "estleg:relatesToConcept": "estleg:Concept_FruitsBenefits",
      "estleg:sourceAct": "Tsiviilseadustiku üldosa seadus"
    },
    {
      "@id": "estleg:TsUS_Par_63",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_tsiviilseadustik_osa3"
      ],
      "estleg:paragrahv": "§63",
      "rdfs:label": "Kulutused",
      "estleg:requestedCluster": "ownership_economics_62_66",
      "estleg:summary": "Esemele tehtud kulutused jagunevad vajalikeks, kasulikeks ja toreduslikeks kulutusteks.",
      "estleg:relatesToConcept": "estleg:Concept_FruitsBenefits",
      "estleg:sourceAct": "Tsiviilseadustiku üldosa seadus"
    },
    {
      "@id": "estleg:TsUS_Par_64",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_tsiviilseadustik_osa3"
      ],
      "estleg:paragrahv": "§64",
      "rdfs:label": "Kulutuste hüvitamine vilja väljaandmisel",
      "estleg:requestedCluster": "ownership_economics_62_66",
      "estleg:summary": "Vilja väljaandmise kohustusega isik võib nõuda vilja saamiseks tehtud vajalike kulutuste hüvitamist kuni vilja väärtuse ulatuses.",
      "estleg:relatesToConcept": "estleg:Concept_FruitsBenefits",
      "estleg:sourceAct": "Tsiviilseadustiku üldosa seadus"
    },
    {
      "@id": "estleg:TsUS_Par_65",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_tsiviilseadustik_osa3"
      ],
      "estleg:paragrahv": "§65",
      "rdfs:label": "Eseme väärtus",
      "estleg:requestedCluster": "ownership_economics_62_66",
      "estleg:summary": "Eseme väärtuseks loetakse harilik väärtus ehk kohalik keskmine müügihind (turuhind), kui seadus või tehing ei sätesta teisiti.",
      "estleg:relatesToConcept": "estleg:Concept_PropertyEstate",
      "estleg:sourceAct": "Tsiviilseadustiku üldosa seadus"
    },
    {
      "@id": "estleg:TsUS_Par_66",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_tsiviilseadustik_osa3"
      ],
      "estleg:paragrahv": "§66",
      "rdfs:label": "Vara mõiste",
      "estleg:requestedCluster": "ownership_economics_62_66",
      "estleg:summary": "Vara on isikule kuuluvate rahaliselt hinnatavate õiguste ja kohustuste kogum, kui seadus ei sätesta teisiti.",
      "estleg:relatesToConcept": "estleg:Concept_PropertyEstate",
      "estleg:sourceAct": "Tsiviilseadustiku üldosa seadus"
    }
  ]
}
