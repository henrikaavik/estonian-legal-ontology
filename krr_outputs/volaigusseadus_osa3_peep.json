    },
    {
      "@id": "estleg:VOS3_Par_76",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_volaigusseadus_osa3"
      ],
      "estleg:paragrahv": "§ 76",
      "rdfs:label": "§ 76. Kohustuse täitmine",
      "estleg:requestedCluster": "kohustuste_taitmine",
      "estleg:summary": "Kohustus tuleb täita vastavalt lepingule või seadusele.",
      "estleg:sourceAct": "Võlaõigusseadus",
      "estleg:normativeType": [
        {
          "@id": "estleg:NormType_Obligation"
        }
      ],
      "estleg:dutyHolder": "Kohustus"
    },
    {
      "@id": "estleg:VOS3_Par_77",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_volaigusseadus_osa3"
      ],
      "estleg:paragrahv": "§ 77",
      "rdfs:label": "§ 77. Kohustuse täitmise kvaliteet",
      "estleg:requestedCluster": "kohustuste_taitmine",
      "estleg:summary": "Võlgnik peab täitma kohustuse lepingule või seadusele vastava kvaliteediga; kokkuleppe puudumisel vähemalt keskmise kvaliteediga.",
      "estleg:sourceAct": "Võlaõigusseadus",
      "estleg:normativeType": [
        {
          "@id": "estleg:NormType_Obligation"
        }
      ],
      "estleg:dutyHolder": "Võlgnik"
    },
    {
      "@id": "estleg:VOS3_Par_78",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_volaigusseadus_osa3"
      ],
      "estleg:paragrahv": "§ 78",
      "rdfs:label": "§ 78. Kohustuse täitmine kolmanda isiku poolt",
      "estleg:requestedCluster": "kohustuste_taitmine",
      "estleg:summary": "Kui isiklik täitmine pole nõutav, võib kohustuse täita ka kolmas isik; sellega vabaneb võlgnik täitmiskohustusest.",
      "estleg:sourceAct": "Võlaõigusseadus",
      "estleg:normativeType": [
        {
          "@id": "estleg:NormType_Right"
        }
      ]
    },
    {
      "@id": "estleg:VOS3_Par_82",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_volaigusseadus_osa3"
      ],
      "estleg:paragrahv": "§ 82",
      "rdfs:label": "§ 82. Kohustuse täitmise aeg ja sissenõutavus",
      "estleg:requestedCluster": "kohustuste_taitmine",
      "estleg:summary": "Sätestab, millal kohustus muutub täitmisele kuuluvaks ja sissenõutavaks.",
      "estleg:sourceAct": "Võlaõigusseadus"
    },
    {
      "@id": "estleg:VOS3_Par_83",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_volaigusseadus_osa3"
      ],
      "estleg:paragrahv": "§ 83",
      "rdfs:label": "§ 83. Kohustuse ositi täitmine",
      "estleg:requestedCluster": "kohustuste_taitmine",
      "estleg:summary": "Kui kohustus on ühekordne, võib võlausaldaja üldjuhul ositi täitmisest keelduda.",
      "estleg:sourceAct": "Võlaõigusseadus",
      "estleg:normativeType": [
        {
          "@id": "estleg:NormType_Right"
        }
      ]
    },
    {
      "@id": "estleg:VOS3_Par_84",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_volaigusseadus_osa3"
      ],
      "estleg:paragrahv": "§ 84",
      "rdfs:label": "§ 84. Kohustuse ennetähtaegne täitmine",
      "estleg:requestedCluster": "kohustuste_taitmine",
      "estleg:summary": "Võlausaldaja ei või nõuda ennetähtaegset täitmist, kuid peab selle vastu võtma, kui puudub õigustatud huvi keeldumiseks.",
      "estleg:sourceAct": "Võlaõigusseadus",
      "estleg:normativeType": [
        {
          "@id": "estleg:NormType_Obligation"
        }
      ]
    },
    {
      "@id": "estleg:VOS3_Par_85",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_volaigusseadus_osa3"
      ],
      "estleg:paragrahv": "§ 85",
      "rdfs:label": "§ 85. Kohustuse täitmise koht",
      "estleg:requestedCluster": "kohustuste_taitmine",
      "estleg:summary": "Täitmise koht määratakse lepingu, seaduse või võlasuhte olemuse järgi.",
      "estleg:sourceAct": "Võlaõigusseadus"
    },
    {
      "@id": "estleg:VOS3_Par_100",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_volaigusseadus_osa3"
      ],
      "estleg:paragrahv": "§ 100",
      "rdfs:label": "§ 100. Kohustuse rikkumise mõiste",
      "estleg:requestedCluster": "viivitus_ja_rikkumine",
      "estleg:summary": "Kohustuse rikkumine on täitmata jätmine või mittekohane täitmine, sh viivitus.",
      "estleg:sourceAct": "Võlaõigusseadus"
    },
    {
      "@id": "estleg:VOS3_Par_101",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_volaigusseadus_osa3"
      ],
      "estleg:paragrahv": "§ 101",
      "rdfs:label": "§ 101. Õiguskaitsevahendid kohustuse rikkumise korral",
      "estleg:requestedCluster": "viivitus_ja_rikkumine",
      "estleg:summary": "Määrab võlausaldaja peamised õiguskaitsevahendid (täitmise nõue, kahju hüvitis, taganemine, hinna alandamine jm).",
      "estleg:sourceAct": "Võlaõigusseadus"
    },
    {
      "@id": "estleg:VOS3_Par_102",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_volaigusseadus_osa3"
      ],
      "estleg:paragrahv": "§ 102",
      "rdfs:label": "§ 102. Teatamiskohustus",
      "estleg:requestedCluster": "viivitus_ja_rikkumine",
      "estleg:summary": "Võlgnik peab viivitamata teatama täitmist takistavast asjaolust ja selle mõjust.",
      "estleg:sourceAct": "Võlaõigusseadus",
      "estleg:normativeType": [
        {
          "@id": "estleg:NormType_Obligation"
        }
      ],
      "estleg:dutyHolder": "Võlgnik"
    },
    {
      "@id": "estleg:VOS3_Par_103",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_volaigusseadus_osa3"
      ],
      "estleg:paragrahv": "§ 103",
      "rdfs:label": "§ 103. Rikkumise vabandatavus",
      "estleg:requestedCluster": "viivitus_ja_rikkumine",
      "estleg:summary": "Võlgnik vastutab rikkumise eest, välja arvatud juhul, kui rikkumine on vabandatav.",
      "estleg:sourceAct": "Võlaõigusseadus"
    },
    {
      "@id": "estleg:VOS3_Par_113",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_volaigusseadus_osa3"
      ],
      "estleg:paragrahv": "§ 113",
      "rdfs:label": "§ 113. Viivis",
      "estleg:requestedCluster": "viivitus_ja_rikkumine",
      "estleg:summary": "Rahalise kohustuse täitmisega viivitamisel võib võlausaldaja nõuda viivist.",
      "estleg:sourceAct": "Võlaõigusseadus",
      "estleg:normativeType": [
        {
          "@id": "estleg:NormType_Right"
        }
      ]
    },
    {
      "@id": "estleg:VOS3_Par_114",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_volaigusseadus_osa3"
      ],
      "estleg:paragrahv": "§ 114",
      "rdfs:label": "§ 114. Täiendav tähtaeg kohustuse täitmiseks",
      "estleg:requestedCluster": "viivitus_ja_rikkumine",
      "estleg:summary": "Võlausaldaja võib anda rikkumise korral täitmiseks täiendava mõistliku tähtaja.",
      "estleg:sourceAct": "Võlaõigusseadus",
      "estleg:normativeType": [
        {
          "@id": "estleg:NormType_Right"
        }
      ]
    },
    {
      "@id": "estleg:VOS3_Par_119",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_volaigusseadus_osa3"
      ],
      "estleg:paragrahv": "§ 119",
      "rdfs:label": "§ 119. Vastuvõtuviivituse mõiste ja tagajärjed",
      "estleg:requestedCluster": "viivitus_ja_rikkumine",
      "estleg:summary": "Võlausaldaja satub vastuvõtuviivitusse, kui ta takistab kohase täitmise vastuvõtmist.",
      "estleg:sourceAct": "Võlaõigusseadus"
    },
    {
      "@id": "estleg:VOS3_Par_104",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_volaigusseadus_osa3"
      ],
      "estleg:paragrahv": "§ 104",
      "rdfs:label": "§ 104. Vastutus süü puhul",
      "estleg:requestedCluster": "vastutus",
      "estleg:summary": "Mõnel juhul vastutab isik rikkumise eest vaid süü olemasolul.",
      "estleg:sourceAct": "Võlaõigusseadus"
    },
    {
      "@id": "estleg:VOS3_Par_105",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_volaigusseadus_osa3"
      ],
      "estleg:paragrahv": "§ 105",
      "rdfs:label": "§ 105. Õiguskaitsevahendid võlgniku vastutusest sõltumata",
      "estleg:requestedCluster": "vastutus",
      "estleg:summary": "Teatud õiguskaitsevahendid on kasutatavad ka siis, kui võlgnik ei vastuta rikkumise eest.",
      "estleg:sourceAct": "Võlaõigusseadus"
    },
    {
      "@id": "estleg:VOS3_Par_106",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_volaigusseadus_osa3"
      ],
      "estleg:paragrahv": "§ 106",
      "rdfs:label": "§ 106. Vastutusest vabastamise või vastutuse piiramise kokkulepe",
      "estleg:requestedCluster": "vastutus",
      "estleg:summary": "Poolte kokkuleppel saab vastutust piirata, kui seadus seda ei keela.",
      "estleg:sourceAct": "Võlaõigusseadus"
    },
    {
      "@id": "estleg:VOS3_Par_115",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_volaigusseadus_osa3"
      ],
      "estleg:paragrahv": "§ 115",
      "rdfs:label": "§ 115. Kahju hüvitamine",
      "estleg:requestedCluster": "vastutus",
      "estleg:summary": "Rikkumise korral võib nõuda kahju hüvitamist koos täitmisega või selle asemel.",
      "estleg:sourceAct": "Võlaõigusseadus",
      "estleg:normativeType": [
        {
          "@id": "estleg:NormType_Right"
        }
      ]
    },
    {
      "@id": "estleg:VOS3_Par_127",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_volaigusseadus_osa3"
      ],
      "estleg:paragrahv": "§ 127",
      "rdfs:label": "§ 127. Kahju hüvitamise eesmärk ja ulatus",
      "estleg:requestedCluster": "vastutus",
      "estleg:summary": "Kahjuhüvitise eesmärk on asetada kahjustatud isik võimalikult olukorda, kus ta oleks ilma rikkumiseta olnud.",
      "estleg:sourceAct": "Võlaõigusseadus"
    },
    {
      "@id": "estleg:VOS3_Par_128",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_volaigusseadus_osa3"
      ],
      "estleg:paragrahv": "§ 128",
      "rdfs:label": "§ 128. Hüvitatava kahju liigid",
      "estleg:requestedCluster": "vastutus",
      "estleg:summary": "Hüvitatav kahju võib olla varaline või mittevaraline.",
      "estleg:sourceAct": "Võlaõigusseadus",
      "estleg:normativeType": [
        {
          "@id": "estleg:NormType_Right"
        }
      ]
    },
    {
      "@id": "estleg:VOS3_Par_134",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_volaigusseadus_osa3"
      ],
      "estleg:paragrahv": "§ 134",
      "rdfs:label": "§ 134. Mittevaralise kahju hüvitamise erisused",
      "estleg:requestedCluster": "vastutus",
      "estleg:summary": "Mittevaralise kahju hüvitamine lepingulise rikkumise korral on piiratud eritingimustega.",
      "estleg:sourceAct": "Võlaõigusseadus",
      "estleg:semanticallySimilarTo": [
        {
          "@id": "estleg:VOS_Par649"
        }
      ]
    },
    {
      "@id": "estleg:VOS3_Par_136",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_volaigusseadus_osa3"
      ],
      "estleg:paragrahv": "§ 136",
      "rdfs:label": "§ 136. Kahju hüvitamise viis",
      "estleg:requestedCluster": "vastutus",
      "estleg:summary": "Kahju hüvitatakse üldjuhul ühekordse rahasummana, vajadusel perioodiliste maksetena.",
      "estleg:sourceAct": "Võlaõigusseadus"
    },
    {
      "@id": "estleg:VOS3_Par_139",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_volaigusseadus_osa3"
      ],
      "estleg:paragrahv": "§ 139",
      "rdfs:label": "§ 139. Kahjustatud isiku osa kahju tekkimisel",
      "estleg:requestedCluster": "vastutus",
      "estleg:summary": "Kui kahjustatud isik ise soodustas kahju tekkimist, võib hüvitist vähendada.",
      "estleg:sourceAct": "Võlaõigusseadus",
      "estleg:normativeType": [
        {
          "@id": "estleg:NormType_Right"
        }
      ]
    },
    {
      "@id": "estleg:VOS3_Par_140",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_volaigusseadus_osa3"
      ],
      "estleg:paragrahv": "§ 140",
      "rdfs:label": "§ 140. Kahju hüvitamise piiramine",
      "estleg:requestedCluster": "vastutus",
      "estleg:summary": "Kohus võib hüvitist vähendada, kui täies ulatuses hüvitamine oleks äärmiselt ebaõiglane.",
      "estleg:sourceAct": "Võlaõigusseadus",
      "estleg:normativeType": [
        {
          "@id": "estleg:NormType_Right"
        }
      ],
      "estleg:competentAuthority": [
        {
          "@id": "estleg:Institution_kohus"
        }
      ],
      "estleg:competenceType": "general"
    }
  ]
}
