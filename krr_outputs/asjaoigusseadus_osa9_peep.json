    {
      "@id": "estleg:AOS_Osa9_Par_98",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_asjaoigusseadus_osa9"
      ],
      "estleg:paragrahv": "§ 98",
      "rdfs:label": "Leiu teatamiskohustus",
      "estleg:requestedCluster": "esmane_omandamine",
      "estleg:summary": "Leidja peab leitud asja kohta teatama omanikule, kaotajale või pädevale asutusele; see loob aluse hilisemaks õiguspäraseks omandamiseks, kui omanik välja ei ilmu.",
      "estleg:sourceAct": "Asjaõigusseadus",
      "estleg:normativeType": [
        {
          "@id": "estleg:NormType_Obligation"
        }
      ],
      "estleg:dutyHolder": "Leidja"
    },
    {
      "@id": "estleg:AOS_Osa9_Par_101",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_asjaoigusseadus_osa9"
      ],
      "estleg:paragrahv": "§ 101",
      "rdfs:label": "Leitud asja omandamine",
      "estleg:requestedCluster": "esmane_omandamine",
      "estleg:summary": "Kui omanik seaduses ette nähtud tähtaja jooksul asja välja ei nõua, võib leitud asi minna leidja või muu õigustatud isiku omandisse.",
      "estleg:sourceAct": "Asjaõigusseadus",
      "estleg:normativeType": [
        {
          "@id": "estleg:NormType_Right"
        }
      ]
    },
    {
      "@id": "estleg:AOS_Osa9_Par_102",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_asjaoigusseadus_osa9"
      ],
      "estleg:paragrahv": "§ 102",
      "rdfs:label": "Peremehetu asja hõivamine",
      "estleg:requestedCluster": "esmane_omandamine",
      "estleg:summary": "Peremehetu vallasasi omandatakse hõivamisega, kui hõivajal on omandamise tahe ja seadus ei näe ette erisust.",
      "estleg:sourceAct": "Asjaõigusseadus"
    },
    {
      "@id": "estleg:AOS_Osa9_Par_104",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_asjaoigusseadus_osa9"
      ],
      "estleg:paragrahv": "§ 104",
      "rdfs:label": "Uue vallasasja valmistamine",
      "estleg:requestedCluster": "esmane_omandamine",
      "estleg:summary": "Uue asja valmistamisel tekib omand seaduses sätestatud eeldustel valmistajale või materjali omanikule.",
      "estleg:sourceAct": "Asjaõigusseadus"
    },
    {
      "@id": "estleg:AOS_Osa9_Par_92",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_asjaoigusseadus_osa9"
      ],
      "estleg:paragrahv": "§ 92",
      "rdfs:label": "Vallasomandi ülemineku põhireegel",
      "estleg:requestedCluster": "voorandamise_teel_omandamine",
      "estleg:summary": "Vallasomand läheb üle omandi ülemineku kokkuleppe ja valduse üleandmise koosmõjul.",
      "estleg:sourceAct": "Asjaõigusseadus",
      "estleg:referencedBy": [
        {
          "@id": "estleg:Eluruumide_erastamise_seadus_Par_13"
        }
      ]
    },
    {
      "@id": "estleg:AOS_Osa9_Par_93",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_asjaoigusseadus_osa9"
      ],
      "estleg:paragrahv": "§ 93",
      "rdfs:label": "Valduse üleandmise viisid",
      "estleg:requestedCluster": "voorandamise_teel_omandamine",
      "estleg:summary": "Valduse üleandmine võib toimuda asja tegeliku üleandmisega või seaduses tunnustatud asendusvormides.",
      "estleg:sourceAct": "Asjaõigusseadus",
      "estleg:normativeType": [
        {
          "@id": "estleg:NormType_Right"
        }
      ]
    },
    {
      "@id": "estleg:AOS_Osa9_Par_119",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_asjaoigusseadus_osa9"
      ],
      "estleg:paragrahv": "§ 119",
      "rdfs:label": "Kinnisomandi omandamine kande kaudu",
      "estleg:requestedCluster": "voorandamise_teel_omandamine",
      "estleg:summary": "Kinnisasja omand tekib üldjuhul kinnistusraamatusse kande tegemisel asjaõiguslepingu alusel.",
      "estleg:sourceAct": "Asjaõigusseadus",
      "estleg:semanticallySimilarTo": [
        {
          "@id": "estleg:TMS_Par_156"
        },
        {
          "@id": "estleg:TMS_Par_156"
        }
      ],
      "estleg:referencedBy": [
        {
          "@id": "estleg:Korteriomandi_ja_korterihist_Par_3"
        },
        {
          "@id": "estleg:Korteriomandi_ja_korterihist_Par_58"
        }
      ]
    },
    {
      "@id": "estleg:AOS_Osa9_Par_64_1",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_asjaoigusseadus_osa9"
      ],
      "estleg:paragrahv": "§ 64¹",
      "rdfs:label": "Kinnisomandi üleandmine ja koormamine",
      "estleg:requestedCluster": "voorandamise_teel_omandamine",
      "estleg:summary": "Kinnisomandi üleandmine eeldab notariaalset asjaõiguslepingut ning kinnistusraamatu kannet.",
      "estleg:sourceAct": "Asjaõigusseadus"
    },
    {
      "@id": "estleg:AOS_Osa9_Par_95",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_asjaoigusseadus_osa9"
      ],
      "estleg:paragrahv": "§ 95",
      "rdfs:label": "Vallasasja heauskne omandamine",
      "estleg:requestedCluster": "heausuline_omandamine",
      "estleg:summary": "Mitteomanikult omandamine on võimalik, kui omandaja on heauskne ega teadnud ega pidanud teadma võõrandaja käsutusõiguse puudumisest.",
      "estleg:sourceAct": "Asjaõigusseadus"
    },
    {
      "@id": "estleg:AOS_Osa9_Par_56_1",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_asjaoigusseadus_osa9"
      ],
      "estleg:paragrahv": "§ 56¹",
      "rdfs:label": "Heauskne omandamine kinnistusraamatu andmetele tuginedes",
      "estleg:requestedCluster": "heausuline_omandamine",
      "estleg:summary": "Kinnistusraamatu andmetele tuginev heauskne omandaja on kaitstud, kui ebaõigsus ei olnud talle teada ega pidanud olema teada.",
      "estleg:sourceAct": "Asjaõigusseadus"
    },
    {
      "@id": "estleg:AOS_Osa9_Par_123",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_asjaoigusseadus_osa9"
      ],
      "estleg:paragrahv": "§ 123",
      "rdfs:label": "Kinnisasja heauskne omandamine",
      "estleg:requestedCluster": "heausuline_omandamine",
      "estleg:summary": "Kinnisasja heauskne omandamine tugineb kinnistusraamatu usaldatavuse põhimõttele ning kaitseb õiguskäivet seaduses sätestatud piirides.",
      "estleg:sourceAct": "Asjaõigusseadus"
    },
    {
      "@id": "estleg:Concept_EsmaneOmandamine",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "rdfs:label": "Esmase omandamise põhimõte",
      "skos:definition": "Esmane omandamine tekib ilma varasema omaniku õiguse üleminekuta (nt hõivamine, leid, uue asja valmistamine).",
      "estleg:belongsToCluster": "esmane_omandamine"
    },
    {
      "@id": "estleg:Concept_DerivativeAcquisition",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "rdfs:label": "Tuletatud omandamise põhimõte",
      "skos:definition": "Võõrandamise teel omandamine eeldab üldjuhul võõrandaja käsutusõigust, asjaõiguslikku kokkulepet ja vastavat üleandmistegu või registrikannet.",
      "estleg:belongsToCluster": "voorandamise_teel_omandamine"
    },
    {
      "@id": "estleg:Concept_GoodFaithAcquisition",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "rdfs:label": "Heauskse omandamise kaitsepõhimõte",
      "skos:definition": "Heauskse omandamise normid kaitsevad õiguskäibe usaldust, võimaldades teatud tingimustel omandi üleminekut ka käsutusõiguseta isikult.",
      "estleg:belongsToCluster": "heausuline_omandamine"
    }
  ]
}
