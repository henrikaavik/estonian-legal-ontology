@prefix legal: <http://example.org/estonian-legal#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/estonian-legal> a owl:Ontology ;
  rdfs:label "Estonian Civil Code General Part Ontology"@en ;
  rdfs:comment "Core ontology for Tsiviilseadustiku üldosa sample graph."@en .

legal:LegalDocument a owl:Class ;
  rdfs:label "Legal Document"@en .

legal:Article a owl:Class ;
  rdfs:subClassOf legal:LegalDocument ;
  rdfs:label "Article"@en .

legal:Norm a owl:Class ;
  rdfs:label "Norm"@en .

legal:containsNorm a owl:ObjectProperty ;
  rdfs:domain legal:Article ;
  rdfs:range legal:Norm ;
  rdfs:label "contains norm"@en .

legal:articleNumber a owl:DatatypeProperty ;
  rdfs:domain legal:Article ;
  rdfs:range xsd:string ;
  rdfs:label "article number"@en .

legal:sourceText a owl:DatatypeProperty ;
  rdfs:domain legal:Norm ;
  rdfs:range xsd:string ;
  rdfs:label "source text"@en .

legal:Tsiviilseadustik a legal:LegalDocument ;
  rdfs:label "Tsiviilseadustiku üldosa seadus"@et .

legal:Article_1 a legal:Article ;
  legal:articleNumber "1" ;
  rdfs:label "Seaduse ülesanne"@et ;
  legal:containsNorm legal:Norm_1_1 .

legal:Norm_1_1 a legal:Norm ;
  legal:sourceText "Käesolevas seaduses sätestatakse tsiviilõiguse üldpõhimõtted."@et .

legal:Article_2 a legal:Article ;
  legal:articleNumber "2" ;
  rdfs:label "Tsiviilõiguse allikad"@et ;
  legal:containsNorm legal:Norm_2_1, legal:Norm_2_2 .

legal:Norm_2_1 a legal:Norm ;
  legal:sourceText "(1) Tsiviilõiguse allikad on seadus ja tava."@et .

legal:Norm_2_2 a legal:Norm ;
  legal:sourceText "(2) Tava tekib käitumisviisi pikemaajalisest rakendamisest, kui käibes osalevad isikud peavad seda õiguslikult siduvaks. Tava ei saa muuta seadust."@et .

legal:Article_3 a legal:Article ;
  legal:articleNumber "3" ;
  rdfs:label "Seaduse tõlgendamine"@et ;
  legal:containsNorm legal:Norm_3_1 .

legal:Norm_3_1 a legal:Norm ;
  legal:sourceText "Seaduse sätet tõlgendatakse koos seaduse teiste sätetega, lähtudes seaduse sõnastusest, mõttest ja eesmärgist."@et .

legal:Article_4 a legal:Article ;
  legal:articleNumber "4" ;
  rdfs:label "Analoogia"@et ;
  legal:containsNorm legal:Norm_4_1 .

legal:Norm_4_1 a legal:Norm ;
  legal:sourceText "Õigussuhet reguleeriva sätte puudumisel kohaldatakse sätet, mis reguleerib reguleerimata õigussuhtele lähedast õigussuhet, kui õigussuhte reguleerimata jätmine ei vasta seaduse mõttele ega eesmärgile. Sellise sätte puudumisel lähtutakse seaduse või õiguse üldisest mõttest."@et .

legal:Article_5 a legal:Article ;
  legal:articleNumber "5" ;
  rdfs:label "Tsiviilõiguste ja -kohustuste tekkimise alused"@et ;
  legal:containsNorm legal:Norm_5_1 .

legal:Norm_5_1 a legal:Norm ;
  legal:sourceText "Tsiviilõigused ja -kohustused tekivad tehingutest, seaduses sätestatud sündmustest ja muudest toimingutest, millega seadus seob tsiviilõiguste ja -kohustuste tekkimise, samuti õigusvastastest tegudest."@et .