    {
      "@id": "estleg:VOS_Par_635",
      "@type": [
        "owl:NamedIndividual",
        "estleg:Section"
      ],
      "estleg:sectionNumber": "635",
      "rdfs:label": "§ 635. Töövõtulepingu mõiste",
      "estleg:inPart": {
