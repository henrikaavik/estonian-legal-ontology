        {
          "@id": "estleg:NormType_Obligation"
        }
      ]
    },
    {
      "@id": "estleg:VOS_Par_636",
      "@type": [
        "owl:NamedIndividual",
        "estleg:Section"
      ],
      "estleg:sectionNumber": "636",
      "rdfs:label": "§ 636. Asja üleandmise kohustus",
      "estleg:inPart": {
        "@id": "estleg:VOS_Part9"
      },
      "estleg:coversConcept": [
        {
          "@id": "estleg:ContractForWork"
        }
      ],
      "estleg:summary": "Reguleerib, millal ja kuidas peab töövõtja tellijale töö tulemuse üle andma.",
