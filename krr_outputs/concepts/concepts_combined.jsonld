    },
    {
      "@id": "estleg:Concept_vedelkutusevaru_seadus_II_varukategooria",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "II varukategooria",
      "skos:definition": "diislikütus, kerge kütteõli, petrool ja reaktiivkütus (lennukipetrool)",
      "estleg:definedIn": [
        {
          "@id": "estleg:vedelkutusevaru_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Vedelkütusevaru seadus",
      "rdfs:label": "II varukategooria (vedelkutusevaru_seadus)",
      "skos:closeMatch": [
