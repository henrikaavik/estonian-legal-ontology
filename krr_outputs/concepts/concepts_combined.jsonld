    {
      "@id": "estleg:Concept_pornograafilise_sisuga_ja_vagivalda_voi_julmust_propageerivate_teoste_leviku_reg_teose_levitamine",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "teose levitamine",
      "skos:definition": "teose või selle mis tahes vormis produtseeritud koopiate müümine, laenutamine või muul viisil üleandmine",
      "estleg:definedIn": [
        {
          "@id": "estleg:pornograafilise_sisuga_ja_vagivalda_voi_julmust_propageerivate_teoste_leviku_reg_Par_1"
        }
      ],
