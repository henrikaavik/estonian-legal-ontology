          "@id": "estleg:kaubandustegevuse_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Kaubandustegevuse seadus",
      "rdfs:label": "klient (kaubandustegevuse_seadus)"
    },
    {
      "@id": "estleg:Concept_kaubandustegevuse_seadus_mgikoht",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "müügikoht",
      "skos:definition": "koht, kus kaupleja vahetult pakub ja müüb kaupa või pakub ja osutab teenust.",
      "estleg:definedIn": [
        {
          "@id": "estleg:kaubandustegevuse_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Kaubandustegevuse seadus",
      "rdfs:label": "müügikoht (kaubandustegevuse_seadus)"
    },
    {
      "@id": "estleg:Concept_kaubandustegevuse_seadus_tnava",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "tänava",
      "skos:definition": "või turukaubanduse korraldamine või kaubanduse korraldamine avalikul üritusel.",
      "estleg:definedIn": [
        {
          "@id": "estleg:kaubandustegevuse_seadus_Par_3"
        }
      ],
      "estleg:sourceAct": "Kaubandustegevuse seadus",
      "rdfs:label": "tänava (kaubandustegevuse_seadus)"
    },
    {
      "@id": "estleg:Concept_kaubandustegevuse_seadus_Kesoleva_seaduse_thenduses_on_tegevuskoht_hulgikaubandus",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "Käesoleva seaduse tähenduses on tegevuskoht hulgikaubandus",
      "skos:definition": ", jaekaubandus-, toitlustus- või teenindusettevõtte koosseisu kuuluv kaupleja müügikoht, mille juurde võib kuuluda tootmis-, hoiu- või muu ruum. 2 (2) Müügikoht ja selle vahetus läheduses väljaspool siseruume asuv hooajaline laiendus loetakse üheks müügikohaks. 3 (3) Müügikoha hooajaline laiendus peab olema kooskõlastatud valla- või linnavalitsusega. 4 (4) Üheks tegevuskohaks loetakse, sõltumata müügikohtade arvust: 1 1) sama kaupleja müügikohad ühel avalikul üritusel",
      "estleg:definedIn": [
        {
          "@id": "estleg:kaubandustegevuse_seadus_Par_14"
        }
      ],
      "estleg:sourceAct": "Kaubandustegevuse seadus",
      "rdfs:label": "Käesoleva seaduse tähenduses on tegevuskoht hulgikaubandus (kaubandustegevuse_seadus)"
    },
    {
      "@id": "estleg:Concept_kaugkutteseadus_vrgupiirkond_on_maa",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "võrgupiirkond on maa",
      "skos:definition": "ala, kus asub ja kus arendatakse ühe võrguettevõtja omandis või valduses olevat võrku",
      "estleg:definedIn": [
        {
          "@id": "estleg:kaugkutteseadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Kaugkütteseadus",
