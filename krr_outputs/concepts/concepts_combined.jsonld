      ],
      "skos:prefLabel": "tehingud nii oma arvel kui klientide nimel",
      "skos:definition": "välisvaluutaga, - finantsfutuuride ja -optsioonidega, - vahetuskursi- ja intressiinstrumentidega, - turukõlblike väärtpaberitega, - muude rahaturu instrumentidega",
      "estleg:definedIn": [
