      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "lühivalikukood on numbri",
      "skos:definition": "või eraldusmärk või nende kombinatsioon, mis on seotud kliendile määratud Eesti numeratsiooniplaani kuuluva numbriga ning mida kasutatakse kliendile üldkasutatava elektroonilise side teenuse osutamiseks",
      "estleg:definedIn": [
