        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "pingestamata kuni 250",
      "skos:definition": "voldise nimipingega ühefaasiliste kaitsejuhita pistikute ja ühendusjuhtmete ning sisustusvalgustite paigaldamist, remonti ja hooldust",
      "estleg:definedIn": [
