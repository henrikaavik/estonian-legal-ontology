        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "mobiiltelefonivõrk on statsionaarsete lõpp",
      "skos:definition": "punktideta sidevõrk, mis võimaldab edastada kõnet ja vastab mobiiltelefonivõrgule kehtestatud nõuetele",
