    {
      "@id": "estleg:Concept_autoveoseadus_Mereveo_korral_ei_tohi_kombineeritud_veo_alg__vi_lppetapi_teeligu_pikkus_peale",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "Mereveo korral ei tohi kombineeritud veo alg- või lõppetapi teelõigu pikkus peale",
      "skos:definition": "või mahalaadimise meresadamast otsejoones mõõdetuna ületada 150 kilomeetrit.",
      "estleg:definedIn": [
        {
          "@id": "estleg:autoveoseadus_Par_11"
        }
      ],
      "estleg:sourceAct": "Autoveoseadus",
      "rdfs:label": "Mereveo korral ei tohi kombineeritud veo alg- või lõppetapi teelõigu pikkus peale (autoveoseadus)"
    },
    {
      "@id": "estleg:Concept_e_raha_asutuste_seadus_andmete_silitamine_e",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "andmete säilitamine e",
      "skos:definition": "raha seadmetel teiste ettevõtjate, riigi ja kohalike omavalitsusüksuste jaoks ja nende arvel. 2 (2) Käesoleva paragrahvi lõike 1 punktis 1 nimetatud teenust võivad osutada üksnes e-raha asutus ning krediidiasutus. 3 (3) E-raha võib levitada üksnes isik, kellele e-raha väljastav e-raha asutus või krediidiasutus on sellekohase õiguse andnud (edaspidi edasimüüja ).",
      "estleg:definedIn": [
        {
          "@id": "estleg:e_raha_asutuste_seadus_Par_4"
        }
      ],
      "estleg:sourceAct": "E-raha asutuste seadus",
      "rdfs:label": "andmete säilitamine e (e_raha_asutuste_seadus)"
    },
    {
      "@id": "estleg:Concept_e_raha_asutuste_seadus_nuded_A",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "nõuded A",
      "skos:definition": "tsooni riikide keskvalitsustele ja keskpankadele",
      "estleg:definedIn": [
        {
          "@id": "estleg:e_raha_asutuste_seadus_Par_40"
        }
      ],
      "estleg:sourceAct": "E-raha asutuste seadus",
      "rdfs:label": "nõuded A (e_raha_asutuste_seadus)"
    },
    {
      "@id": "estleg:Concept_e_raha_asutuste_seadus_nudmiseni_hoiused_A",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "nõudmiseni hoiused A",
      "skos:definition": "tsooni riikide krediidiasutustes. 2 (2) Lisaks käesoleva paragrahvi lõikes 1 sätestatule võib e-raha asutus investeerida oma vahendeid piisavalt likviidsetesse võlakohustustesse, mis ei ole emiteeritud e-raha asutuses olulist osalust omava äriühingu poolt ega selle äriühinguga samasse konsolideerimisgruppi kuuluva äriühingu poolt ning mis tulenevad: 1 1) nõuetest B-tsooni riikide keskvalitsustele ja keskpankadele juhul, kui nõuded on nomineeritud ja väljastatud selle B-tsooni riigi rahvuslikus valuutas",
      "estleg:definedIn": [
        {
          "@id": "estleg:e_raha_asutuste_seadus_Par_40"
        }
      ],
      "estleg:sourceAct": "E-raha asutuste seadus",
      "rdfs:label": "nõudmiseni hoiused A (e_raha_asutuste_seadus)"
    },
    {
      "@id": "estleg:Concept_e_raha_asutuste_seadus_niisugustest_nuetest_A",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "niisugustest nõuetest A",
      "skos:definition": "tsooni krediidiasutustele, mis ei kuulu nende krediidiasutuste omavahendite koosseisu",
      "estleg:definedIn": [
        {
          "@id": "estleg:e_raha_asutuste_seadus_Par_40"
        }
      ],
      "estleg:sourceAct": "E-raha asutuste seadus",
