    },
    {
      "@id": "estleg:Concept_riigisaladuse_ja_salastatud_valisteabe_seadus_turvaala",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "turvaala",
      "skos:definition": "konfidentsiaalse, salajase või täiesti salajase taseme riigisaladuse või salastatud välisteabe ja seda sisaldava salastatud teabekandja töötlemiseks kasutatav ala.",
      "estleg:definedIn": [
        {
          "@id": "estleg:riigisaladuse_ja_salastatud_valisteabe_seadus_Par_3"
        }
      ],
      "estleg:sourceAct": "Riigisaladuse ja salastatud välisteabe seadus",
      "rdfs:label": "turvaala (riigisaladuse_ja_salastatud_valisteabe_seadus)"
    },
    {
      "@id": "estleg:Concept_riigisaladuse_seadus_riigisaladus",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "riigisaladus",
      "skos:definition": "üksnes käesolevas seaduses sätestatud Eesti Vabariigi julgeoleku tagamise huvides avalikuks tuleku eest kaitset vajav teave, mis kuulub riigile, on riigi kontrolli all või on toodetud riigi poolt või riigi jaoks",
      "estleg:definedIn": [
        {
          "@id": "estleg:riigisaladuse_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Riigisaladuse seadus",
      "rdfs:label": "riigisaladus (riigisaladuse_seadus)"
    },
    {
      "@id": "estleg:Concept_riigisaladuse_seadus_salastatud_teabekandja",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "salastatud teabekandja",
      "skos:definition": "dokument, andmekogum või muu materiaalne objekt, mis sisaldab riigisaladust või esitab seda elektroonilises vormis",
      "estleg:definedIn": [
        {
          "@id": "estleg:riigisaladuse_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Riigisaladuse seadus",
      "rdfs:label": "salastatud teabekandja (riigisaladuse_seadus)"
    },
    {
      "@id": "estleg:Concept_riigisaladuse_seadus_riigisaladuse_valdaja",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "riigisaladuse valdaja",
      "skos:definition": "asutus, institutsioon või juriidiline või füüsiline isik, kelle valduses on riigisaladus või salastatud teabekandja",
      "estleg:definedIn": [
        {
          "@id": "estleg:riigisaladuse_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Riigisaladuse seadus",
      "rdfs:label": "riigisaladuse valdaja (riigisaladuse_seadus)"
    },
    {
      "@id": "estleg:Concept_riigisaladuse_seadus_juurdepsuvajadus",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "juurdepääsuvajadus",
      "skos:definition": "töö- või teenistusülesandest, samuti õppe- või uurimistööst tulenev riigisaladusega tutvumise või selle töötlemise vajadus, samuti seadusest tulenev õigus tutvuda kriminaalasjas, tsiviilasjas, haldusasjas või haldusõiguserikkumise asjas riigisaladust sisaldava teabekandjaga või osaleda riigisaladuseks oleva teabe käsitlemisel kohtumenetluse või kohtueelse menetluse käigus",
      "estleg:definedIn": [
        {
          "@id": "estleg:riigisaladuse_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Riigisaladuse seadus",
      "rdfs:label": "juurdepääsuvajadus (riigisaladuse_seadus)"
    },
    {
      "@id": "estleg:Concept_riigisaladuse_seadus_phjendatud_teadmisvajadus",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "põhjendatud teadmisvajadus",
      "skos:definition": "vajadus teada või töödelda konkreetset riigisaladust või salastatud teabekandjat",
