    {
      "@id": "estleg:Concept_vaarismetalltoodete_seadus_vrismetall",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "väärismetall",
      "skos:definition": "puhas kuld, hõbe, plaatina ja pallaadium ning nende sulamid",
