    {
      "@id": "estleg:Concept_kaubandustegevuse_seadus_kaupleja",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "kaupleja",
      "skos:definition": "isik või asutus, kes majandus- või kutsetegevuse raames pakub ja müüb kaupa või pakub ja osutab teenust",
      "estleg:definedIn": [
        {
          "@id": "estleg:kaubandustegevuse_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Kaubandustegevuse seadus",
      "rdfs:label": "kaupleja (kaubandustegevuse_seadus)"
    },
    {
      "@id": "estleg:Concept_kaubandustegevuse_seadus_kaubanduse_korraldaja",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "kaubanduse korraldaja",
      "skos:definition": "isik või asutus, kes majandus- või kutsetegevuse raames korraldab turu- või tänavakaubandust või kaubandust avalikul üritusel, sealhulgas laadal ja messil",
      "estleg:definedIn": [
        {
          "@id": "estleg:kaubandustegevuse_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Kaubandustegevuse seadus",
      "rdfs:label": "kaubanduse korraldaja (kaubandustegevuse_seadus)"
    },
    {
      "@id": "estleg:Concept_kaubandustegevuse_seadus_mja",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "müüja",
      "skos:definition": "kaupleja nimel klienti teenindav füüsiline isik või isik, kes müüb kaupa või osutab teenust väljaspool majandus- või kutsetegevust tänava- või turukaubanduse korras",
      "estleg:definedIn": [
        {
          "@id": "estleg:kaubandustegevuse_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Kaubandustegevuse seadus",
      "rdfs:label": "müüja (kaubandustegevuse_seadus)"
    },
    {
      "@id": "estleg:Concept_kaubandustegevuse_seadus_kaup",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "kaup",
      "skos:definition": "müügiks pakutav või müüdav vallasasi",
