    {
      "@id": "estleg:Concept_sotsiaalmaksuseadus_juriidilise_isiku_juhtimis",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "juriidilise isiku juhtimis",
      "skos:definition": "või kontrollorgani tulumaksuseaduse (RT I 1999, 101, 903",
      "estleg:definedIn": [
        {
          "@id": "estleg:sotsiaalmaksuseadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Sotsiaalmaksuseadus",
