      ],
      "estleg:sourceAct": "Riigisaladuse ja salastatud välisteabe seadus",
      "rdfs:label": "teabevaldaja (riigisaladuse_ja_salastatud_valisteabe_seadus)"
    },
    {
      "@id": "estleg:Concept_riigisaladuse_ja_salastatud_valisteabe_seadus_juurdepsuvajadus",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "juurdepääsuvajadus",
      "skos:definition": "töö- või teenistusülesandest, samuti õppe- või uurimistööst, riigihankest või rahvusvahelisest hankest tulenev riigisaladuse või salastatud välisteabe töötlemise vajadus, samuti õigus tutvuda riigisaladuse või salastatud välisteabega muul käesolevas seaduses sätestatud alusel",
      "estleg:definedIn": [
        {
          "@id": "estleg:riigisaladuse_ja_salastatud_valisteabe_seadus_Par_3"
        }
      ],
      "estleg:sourceAct": "Riigisaladuse ja salastatud välisteabe seadus",
      "rdfs:label": "juurdepääsuvajadus (riigisaladuse_ja_salastatud_valisteabe_seadus)",
