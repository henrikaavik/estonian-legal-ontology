        },
        {
          "@id": "estleg:Concept_valisriigi_kutsekvalifikatsiooni_tunnustamise_seadus_Kehtetu"
        },
        {
          "@id": "estleg:Concept_vedelkutuse_seadus_kehtetu"
        },
