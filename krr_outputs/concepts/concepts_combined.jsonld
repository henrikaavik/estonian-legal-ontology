    },
    {
      "@id": "estleg:Concept_krediidiasutuste_seadus_kui_isik_omab_vhemalt_20_protsenti_rihingu_aktsia",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "kui isik omab vähemalt 20 protsenti äriühingu aktsia",
      "skos:definition": "või osakapitalist või aktsiate või osadega määratud häältest",
      "estleg:definedIn": [
        {
          "@id": "estleg:krediidiasutuste_seadus_Par_7"
        }
      ],
      "estleg:sourceAct": "Krediidiasutuste seadus",
      "rdfs:label": "kui isik omab vähemalt 20 protsenti äriühingu aktsia (krediidiasutuste_seadus)"
    },
    {
      "@id": "estleg:Concept_krediidiasutuste_seadus_Krediidiasutuse_oluline_osalus_heski_teises_rihingus_ei_tohi_letada_15_protsenti",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "Krediidiasutuse oluline osalus üheski teises äriühingus ei tohi ületada 15 protsenti krediidiasutuse neto",
      "skos:definition": "omavahenditest. 4 (4) Krediidiasutuse investeeringute summa kokku finantspõhivarasse oluliste osalustena ei tohi ületada 60 protsenti krediidiasutuse neto-omavahenditest. 5 (5) Krediidiasutuse investeeringud kokku ei tohi olla suuremad krediidiasutuse neto-omavahenditest. 6 (6) Käesoleva paragrahvi lõigetes 3-5 nimetatud piiranguid ei rakendata: 1 1) finantspõhivara suhtes, mille krediidiasutus on omandanud seoses osaluse omandamisega krediidi- või finantseerimisasutuses või sama krediidiasutuse abiettevõtjas",
      "estleg:definedIn": [
        {
          "@id": "estleg:krediidiasutuste_seadus_Par_81"
        }
      ],
      "estleg:sourceAct": "Krediidiasutuste seadus",
      "rdfs:label": "Krediidiasutuse oluline osalus üheski teises äriühingus ei tohi ületada 15 protsenti krediidiasutuse neto (krediidiasutuste_seadus)"
    },
    {
      "@id": "estleg:Concept_kutseseadus_kompetentsus",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "kompetentsus",
      "skos:definition": "edukaks kutsetegevuseks vajalik teadmiste, oskuste, kogemuste ja hoiakute kogum",
      "estleg:definedIn": [
