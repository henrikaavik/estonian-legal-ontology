    {
      "@id": "estleg:Concept_surveseadme_ohutuse_seadus_IV_liik",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "IV liik",
      "skos:definition": "aerosooliballoonid, välja arvatud aerosooliballoonid, mille maht on väiksem kui 50 milliliitrit, metallist aerosooliballoonid, mille maht on suurem kui 1000 milliliitrit, kaitsva kattega klaasist või mittekillustuvast plastist aerosooliballoonid, mille maht on suurem kui 220 milliliitrit, ja kaitsva katteta klaasist või killustuvast plastist aerosooliballoonid, mille maht on suurem kui 150 milliliitrit ja millele kohaldatakse Euroopa Ühenduse Nõukogu 1975. aasta 20. mai direktiivi 75/324/EMÜ aerosoolidispensereid käsitlevate liikmesriikide õigusaktide ühtlustamise kohta (EÜT L 147, 9.06.1975, lk 40)",
      "estleg:definedIn": [
        {
          "@id": "estleg:surveseadme_ohutuse_seadus_Par_5"
        }
      ],
      "estleg:sourceAct": "Surveseadme ohutuse seadus",
