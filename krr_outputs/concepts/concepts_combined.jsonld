          "@id": "estleg:sundeksemplari_seadus_Par_3"
        }
      ],
      "estleg:sourceAct": "Sundeksemplari seadus",
      "rdfs:label": "auvis (sundeksemplari_seadus)"
    },
    {
      "@id": "estleg:Concept_sundeksemplari_seadus_elektrooniline_teavik",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "elektrooniline teavik",
      "skos:definition": "magnet-, optilisele või muule alusele (magnetlint, magnetketas, kompaktplaat ja muu) masinloetavas vormis jäädvustatud informatsiooni kandja",
      "estleg:definedIn": [
