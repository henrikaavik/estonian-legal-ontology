    {
      "@id": "estleg:Concept_euroopa_liidu_liikmesriigist_ebaseaduslikult_valjaviidud_kultuurivaartuste_tagas_kultuurivrtus",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "kultuuriväärtus",
      "skos:definition": "asi, mis liikmesriigi õigusaktide kohaselt on enne liikmesriigist ebaseaduslikku väljaviimist määratletud kui kunstilise, ajaloolise või arheoloogilise väärtusega rahvuslik rikkus ja mis kuulub ühte käesoleva seaduse § 3 alusel kehtestatud kategooriasse. Kultuuriväärtus on ka asi või asjade kogum, mis ei kuulu ühtegi nimetatud kategooriatest, kuid mis kuulub liikmesriigi õigusaktide kohaselt riiklikuna käsitatavasse kogusse või liikmesriigi kohaliku või piirkondliku muuseumi, arhiivi või raamatukogu kogusse või kogusse, mida märkimisväärselt rahastab riik, või usulise ühenduse kogusse ning on kogu lahutamatu osa",
      "estleg:definedIn": [
        {
          "@id": "estleg:euroopa_liidu_liikmesriigist_ebaseaduslikult_valjaviidud_kultuurivaartuste_tagas_Par_2"
        }
      ],
      "estleg:sourceAct": "Euroopa Liidu liikmesriigist ebaseaduslikult väljaviidud kultuuriväärtuste tagastamise seadus",
      "rdfs:label": "kultuuriväärtus (euroopa_liidu_liikmesriigist_ebaseaduslikult_valjaviidud_kultuurivaartuste_tagas)"
    },
    {
      "@id": "estleg:Concept_euroopa_liidu_liikmesriigist_ebaseaduslikult_valjaviidud_kultuurivaartuste_tagas_kultuurivrtuse_ebaseaduslik_vljaviimine_liikmesriigist",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "kultuuriväärtuse ebaseaduslik väljaviimine liikmesriigist",
      "skos:definition": "kultuuriväärtuse väljaviimine Euroopa Liidu liikmesriigi territooriumilt, kui rikutakse kultuuriväärtuste väljaviimiseks liikmesriigi õigusaktidega kehtestatud korda või määrust nr 3911/92/EMÜ (EÜT L 395, 31.12.1992, lk 1), või kultuuriväärtuse tagastamata jätmine pärast ajutise väljaviimise tähtaja lõppemist või ajutise väljaviimise muu tingimuse rikkumine",
      "estleg:definedIn": [
        {
          "@id": "estleg:euroopa_liidu_liikmesriigist_ebaseaduslikult_valjaviidud_kultuurivaartuste_tagas_Par_2"
