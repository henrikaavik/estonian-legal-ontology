    },
    {
      "@id": "estleg:Concept_krediidiasutuste_seadus_ema",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "ema",
      "skos:definition": "ja tütarettevõtjana vastavalt käesoleva paragrahvi lõigetele 1-3",
      "estleg:definedIn": [
        {
          "@id": "estleg:krediidiasutuste_seadus_Par_7"
        }
      ],
