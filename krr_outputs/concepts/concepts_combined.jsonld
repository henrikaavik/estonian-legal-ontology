      ],
      "skos:prefLabel": "riigi julgeoleku volitatud esindaja",
      "skos:definition": "Kaitseministeeriumi põhimääruses määratud Kaitseministeeriumi struktuuriüksus, mille ülesandeks on salastatud välisteabe kaitse korraldamine ja kontroll",
      "estleg:definedIn": [
