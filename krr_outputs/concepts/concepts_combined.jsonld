          "@id": "estleg:Concept_toostusomandi_oiguskorralduse_aluste_seadus_kauba"
        }
      ]
    },
    {
      "@id": "estleg:Concept_kaubandustegevuse_seadus_klient",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "klient",
      "skos:definition": "tarbija tarbijakaitseseaduse tähenduses (edaspidi tarbija ) ja tarbijaks mitteolev isik, kes soovib teha või teeb tehingu kauplejaga",
      "estleg:definedIn": [
