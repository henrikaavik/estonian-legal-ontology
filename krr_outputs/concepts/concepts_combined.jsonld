        {
          "@id": "estleg:vaarismetalltoodete_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Väärismetalltoodete seadus",
      "rdfs:label": "väärismetall (vaarismetalltoodete_seadus)"
    },
    {
      "@id": "estleg:Concept_vaarismetalltoodete_seadus_vrismetalli_proov",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "väärismetalli proov",
      "skos:definition": "arv, mis näitab, mitu massiosa puhast kulda, hõbedat, plaatinat või pallaadiumi sisaldub vastava väärismetalli sulamis selle tuhande massiosa kohta",
      "estleg:definedIn": [
        {
          "@id": "estleg:vaarismetalltoodete_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Väärismetalltoodete seadus",
      "rdfs:label": "väärismetalli proov (vaarismetalltoodete_seadus)"
    },
    {
      "@id": "estleg:Concept_vaarismetalltoodete_seadus_vrismetalli_standardproov",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "väärismetalli standardproov",
      "skos:definition": "käesoleva seadusega lubatud väärismetalli proov",
      "estleg:definedIn": [
        {
          "@id": "estleg:vaarismetalltoodete_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Väärismetalltoodete seadus",
      "rdfs:label": "väärismetalli standardproov (vaarismetalltoodete_seadus)"
    },
    {
      "@id": "estleg:Concept_vaarismetalltoodete_seadus_vrismetalltoode",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "väärismetalltoode",
      "skos:definition": "ese, mis on tervikuna või osaliselt valmistatud ühest või enamast vähemalt väikseima standardprooviga väärismetallist",
      "estleg:definedIn": [
        {
          "@id": "estleg:vaarismetalltoodete_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Väärismetalltoodete seadus",
      "rdfs:label": "väärismetalltoode (vaarismetalltoodete_seadus)"
    },
    {
