    {
      "@id": "estleg:Concept_toiduseadus_pakendamis",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "pakendamis",
      "skos:definition": "ja märgistamisnõuded",
      "estleg:definedIn": [
