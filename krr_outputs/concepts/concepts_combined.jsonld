    {
      "@id": "estleg:Concept_etendusasutuse_seadus_Jdvustamine_kesoleva_seaduse_thenduses_on_teose_esituse_salvestamine_heli",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "Jäädvustamine käesoleva seaduse tähenduses on teose esituse salvestamine heli",
      "skos:definition": "või videolindile, filmile või heliplaadile või muul viisil. 3 (3) Jäädvustamisele kuuluvate teoste loetelu kehtestab etendusasutuse juht loomenõukogu ettepaneku alusel. 4 (4) Jäädvustatavate teoste loetelu esitatakse etendusasutuse moodustajale või asutajale teadmiseks.",
      "estleg:definedIn": [
        {
          "@id": "estleg:etendusasutuse_seadus_Par_13"
        }
      ],
      "estleg:sourceAct": "Etendusasutuse seadus",
      "rdfs:label": "Jäädvustamine käesoleva seaduse tähenduses on teose esituse salvestamine heli (etendusasutuse_seadus)"
    },
    {
      "@id": "estleg:Concept_ettevotluse_toetamise_ja_laenude_riikliku_tagamise_seadus_laen",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "laen",
      "skos:definition": "krediidiasutuse vara või bilansiväline kohustus, mis tuleneb lepingust, mille kohaselt laenuandja annab või kohustub andma raha või muu vara laenusaajale või lepingust tulenevalt muule õigustatud isikule, laenusaaja aga kohustub laenuandjale raha või muu vara tagastama kindlaksmääratud tingimustel",
      "estleg:definedIn": [
