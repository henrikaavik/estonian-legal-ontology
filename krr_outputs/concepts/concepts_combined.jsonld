    {
      "@id": "estleg:Concept_meresoiduohutuse_seadus_veesiduk",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "veesõiduk",
      "skos:definition": "ujuvvahend, mis on mõeldud veekogul liiklemiseks",
      "estleg:definedIn": [
        {
          "@id": "estleg:meresoiduohutuse_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Meresõiduohutuse seadus",
      "rdfs:label": "veesõiduk (meresoiduohutuse_seadus)"
    },
    {
      "@id": "estleg:Concept_meresoiduohutuse_seadus_laev",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "laev",
      "skos:definition": "veesõiduk või teisaldatav ujuvvahend kogupikkusega 24 või enam meetrit. Laevana käsitatakse ka veesõidukit kogupikkusega 12–24 meetrit, mida kasutatakse majandustegevuseks või kutsetööks või koolituseks (välja arvatud väikelaevajuhtide väljaõpe) või riigihaldusülesannete täitmiseks. Majandustegevusena ei käsitata väikelaeva kasutamist või rentimist sporditegevuseks ja vaba aja veetmiseks, samuti kasutamist müügi eesmärgil või õppeotstarbel",
      "estleg:definedIn": [
        {
          "@id": "estleg:meresoiduohutuse_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Meresõiduohutuse seadus",
      "rdfs:label": "laev (meresoiduohutuse_seadus)"
    },
    {
      "@id": "estleg:Concept_meresoiduohutuse_seadus_vikelaev",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "väikelaev",
      "skos:definition": "veesõiduk kogupikkusega 2,5–24 meetrit, välja arvatud käesoleva paragrahvi punkti 2 teises lauses sätestatud erand, sõltumata registrikuuluvusest. Väikelaevana ei käsitata võistlusspordiks ja treeninguteks kasutatavat spordialaliidu poolt vastavalt märgistatud veesõidukit (näiteks jeti, purjelaud, purjejaht, võistluspurjekas ja muu selline), tuule või lihaste jõul liikuvat veesõidukit kogupikkusega kuni 4 meetrit ja primitiivse konstruktsiooniga veesõidukit (näiteks ruhi, ruup, lodi ja muu selline), samuti erikonstruktsiooniga veesõidukit",
      "estleg:definedIn": [
        {
          "@id": "estleg:meresoiduohutuse_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Meresõiduohutuse seadus",
      "rdfs:label": "väikelaev (meresoiduohutuse_seadus)"
    },
    {
      "@id": "estleg:Concept_meresoiduohutuse_seadus_ro",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "ro",
      "skos:definition": "ro-reisiparvlaev – merereise tegev sõidukite peale- ja mahasõitmise vahenditega reisilaev, mis veab üle 12 reisija",
      "estleg:definedIn": [
        {
          "@id": "estleg:meresoiduohutuse_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Meresõiduohutuse seadus",
      "rdfs:label": "ro (meresoiduohutuse_seadus)"
    },
    {
      "@id": "estleg:Concept_meresoiduohutuse_seadus_kiirreisilaev",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "kiirreisilaev",
      "skos:definition": "kiirlaev, mille mõiste on toodud rahvusvahelises konventsioonis inimelude ohutusest merel ja selle konventsiooni 1978. aasta protokollis (RT II 2001, 22, 117) ning mis veab üle 12 reisija",
      "estleg:definedIn": [
        {
          "@id": "estleg:meresoiduohutuse_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Meresõiduohutuse seadus",
      "rdfs:label": "kiirreisilaev (meresoiduohutuse_seadus)"
    },
    {
      "@id": "estleg:Concept_meresoiduohutuse_seadus_erikonstruktsiooniga_veesiduk",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "erikonstruktsiooniga veesõiduk",
      "skos:definition": "veesõiduk kogupikkusega kuni 24 meetrit, mis oma omadustelt ei täida muude käesoleva paragrahvi punktides 3, 7 ja 8 nimetatud veesõidukite nõudeid ning kriteeriume, sealhulgas kaugjuhitav veesõiduk ning eksperimentaalveesõiduk (näiteks veesuusarobot, surfjeti ja muu selline)",
      "estleg:definedIn": [
        {
          "@id": "estleg:meresoiduohutuse_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Meresõiduohutuse seadus",
      "rdfs:label": "erikonstruktsiooniga veesõiduk (meresoiduohutuse_seadus)"
    },
    {
      "@id": "estleg:Concept_meresoiduohutuse_seadus_jeti",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "jeti",
      "skos:definition": "parrasteta jugakäituriga veesõiduk kogupikkusega kuni 4 meetrit, mida ei saa konstruktsiooniliselt käsitada paadina ja mida juhitakse sellel istudes või seistes",
      "estleg:definedIn": [
        {
          "@id": "estleg:meresoiduohutuse_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Meresõiduohutuse seadus",
      "rdfs:label": "jeti (meresoiduohutuse_seadus)"
    },
    {
      "@id": "estleg:Concept_meresoiduohutuse_seadus_purjelaud",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "purjelaud",
      "skos:definition": "tuule jõul liikuv veesõiduk, mille taglasel puudub jäik ühendus lauaga",
      "estleg:definedIn": [
        {
          "@id": "estleg:meresoiduohutuse_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Meresõiduohutuse seadus",
      "rdfs:label": "purjelaud (meresoiduohutuse_seadus)"
    },
    {
      "@id": "estleg:Concept_meresoiduohutuse_seadus_reeder",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "reeder",
      "skos:definition": "ettevõtja, kes valdab laeva ja kasutab seda oma nimel ning on kantud vastavasse laevaregistrisse",
      "estleg:definedIn": [
        {
          "@id": "estleg:meresoiduohutuse_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Meresõiduohutuse seadus",
      "rdfs:label": "reeder (meresoiduohutuse_seadus)"
    },
    {
      "@id": "estleg:Concept_meresoiduohutuse_seadus_ldkasutatav_veetee",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "üldkasutatav veetee",
      "skos:definition": "väljaspool sadama sissesõiduteed ja akvatooriumi asuv laevaliikluseks ettenähtud mõõdistatud veeala, mis on tähistatud kaardil ja vajaduse korral ka looduses. Sadama sissesõidutee käesoleva seaduse tähenduses on veetee osa, mis võimaldab laeval konkreetsesse sadamasse sisse sõita ja samast sadamast väljuda",
      "estleg:definedIn": [
        {
          "@id": "estleg:meresoiduohutuse_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Meresõiduohutuse seadus",
      "rdfs:label": "üldkasutatav veetee (meresoiduohutuse_seadus)"
    },
    {
      "@id": "estleg:Concept_meresoiduohutuse_seadus_volitatud_klassifikatsioonihing",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "volitatud klassifikatsiooniühing",
      "skos:definition": "laeva tehnilist järelevalvet teostav ühing, kes juhindub oma tegevuses Eestis kehtivatest õigusaktidest, rahvusvahelistest konventsioonidest ja enda kehtestatud reeglitest ning kellega Veeteede Ameti peadirektor on Vabariigi Valitsuse volitusel sõlminud halduslepingu Eesti riigilippu kandvate laevade tehnilise järelevalve teostamiseks ja neile tunnistuste väljastamiseks",
      "estleg:definedIn": [
        {
          "@id": "estleg:meresoiduohutuse_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Meresõiduohutuse seadus",
      "rdfs:label": "volitatud klassifikatsiooniühing (meresoiduohutuse_seadus)"
    },
    {
      "@id": "estleg:Concept_meresoiduohutuse_seadus_klassifitseeritud_laev",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "klassifitseeritud laev",
      "skos:definition": "laev, mis kuulub klassifikatsiooniühingu järelevalve alla",
      "estleg:definedIn": [
        {
          "@id": "estleg:meresoiduohutuse_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Meresõiduohutuse seadus",
      "rdfs:label": "klassifitseeritud laev (meresoiduohutuse_seadus)"
    },
    {
      "@id": "estleg:Concept_meresoiduohutuse_seadus_klassifitseerimata_laev",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "klassifitseerimata laev",
      "skos:definition": "laev, mis kuulub Veeteede Ameti järelevalve alla",
      "estleg:definedIn": [
        {
          "@id": "estleg:meresoiduohutuse_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Meresõiduohutuse seadus",
      "rdfs:label": "klassifitseerimata laev (meresoiduohutuse_seadus)"
    },
    {
      "@id": "estleg:Concept_meresoiduohutuse_seadus_kohalik_rannasit",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "kohalik rannasõit",
      "skos:definition": "meresõit Eesti rannikulähedastes vetes kuni 20 meremiili kaugusel kaldast",
      "estleg:definedIn": [
        {
          "@id": "estleg:meresoiduohutuse_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Meresõiduohutuse seadus",
      "rdfs:label": "kohalik rannasõit (meresoiduohutuse_seadus)"
    },
    {
      "@id": "estleg:Concept_meresoiduohutuse_seadus_ohtlik_last",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "ohtlik last",
      "skos:definition": "pakitult või mahtlastina veetav kemikaal või kemikaali sisaldav toode, materjal või valmistoode, mis sadamas käitlemisel või mereveol või sisevetel vedamisel võib ohustada inimese elu või kahjustada tema tervist või vara või keskkonda. RT I 2002 61 375 184811 2003-01-01+02:00",
      "estleg:definedIn": [
        {
          "@id": "estleg:meresoiduohutuse_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Meresõiduohutuse seadus",
      "rdfs:label": "ohtlik last (meresoiduohutuse_seadus)"
