          "@id": "estleg:Concept_telekommunikatsiooniseadus_Majandus"
        },
        {
          "@id": "estleg:Concept_turismiseadus_Majandus"
        },
        {
          "@id": "estleg:Concept_vedelkutuse_seadus_Majandus"
        }
      ]
    },
