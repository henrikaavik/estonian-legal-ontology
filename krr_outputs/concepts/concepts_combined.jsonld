    {
      "@id": "estleg:Concept_surveseadme_ohutuse_seadus_Kehtetud",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "Kehtetud",
      "skos:definition": "RT I 2004 30 208 742737 2004-05-01 12 (12) Käesolevas seaduses kasutatakse toote nõuetele vastavuse tõendamise seaduse (RT I 1999, 92, 825",
      "estleg:definedIn": [
        {
          "@id": "estleg:surveseadme_ohutuse_seadus_Par_4"
        }
      ],
      "estleg:sourceAct": "Surveseadme ohutuse seadus",
