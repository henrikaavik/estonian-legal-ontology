    {
      "@id": "estleg:Concept_nakkushaiguste_ennetamise_ja_torje_seadus_nakkustekitaja",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "nakkustekitaja",
      "skos:definition": "prioon, viirus, bakter, mikroskoopiline seen, algloom, ussnugiline ja lülijalgne, samuti nende komponendid ja toksiinid, mis on võimelised tekitama nakkushaigust",
      "estleg:definedIn": [
        {
          "@id": "estleg:nakkushaiguste_ennetamise_ja_torje_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Nakkushaiguste ennetamise ja tõrje seadus",
      "rdfs:label": "nakkustekitaja (nakkushaiguste_ennetamise_ja_torje_seadus)"
    },
    {
      "@id": "estleg:Concept_nakkushaiguste_ennetamise_ja_torje_seadus_nakkushaigus",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "nakkushaigus",
      "skos:definition": "haigus või haigustunnusteta kandlusseisund, mis on põhjustatud nakkustekitaja sattumisest organismi ja mis levib või mille puhul on alust oletada levikut inimeselt inimesele või loomalt inimesele otseselt või kaudselt",
      "estleg:definedIn": [
        {
          "@id": "estleg:nakkushaiguste_ennetamise_ja_torje_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Nakkushaiguste ennetamise ja tõrje seadus",
      "rdfs:label": "nakkushaigus (nakkushaiguste_ennetamise_ja_torje_seadus)",
      "skos:closeMatch": [
        {
          "@id": "estleg:Concept_nakkushaiguste_ennetamise_ja_torje_seadus_nakkushaige"
        }
      ]
    },
    {
      "@id": "estleg:Concept_nakkushaiguste_ennetamise_ja_torje_seadus_eriti_ohtlik_nakkushaigus",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "eriti ohtlik nakkushaigus",
      "skos:definition": "suure nakatuvusega haigus, mis levib kiiresti ja ulatuslikult või mille kulg on raske või eluohtlik. Käesoleva seaduse tähenduses on eriti ohtlikud nakkushaigused katk, koolera, kollapalavik, viiruslikud hemorraagilised palavikud ja tuberkuloos",
      "estleg:definedIn": [
        {
          "@id": "estleg:nakkushaiguste_ennetamise_ja_torje_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Nakkushaiguste ennetamise ja tõrje seadus",
      "rdfs:label": "eriti ohtlik nakkushaigus (nakkushaiguste_ennetamise_ja_torje_seadus)"
    },
    {
      "@id": "estleg:Concept_nakkushaiguste_ennetamise_ja_torje_seadus_nakkushaige",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "nakkushaige",
      "skos:definition": "inimene, kellel on arstiteaduses tunnustatud meetoditega diagnoositud nakkushaigus",
      "estleg:definedIn": [
        {
          "@id": "estleg:nakkushaiguste_ennetamise_ja_torje_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Nakkushaiguste ennetamise ja tõrje seadus",
      "rdfs:label": "nakkushaige (nakkushaiguste_ennetamise_ja_torje_seadus)"
    },
    {
      "@id": "estleg:Concept_nakkushaiguste_ennetamise_ja_torje_seadus_nakkuskahtlane_isik",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "nakkuskahtlane isik",
      "skos:definition": "nakkushaigega samades tingimustes olnud või haigest nakatuda võinud, kuid arstliku läbivaatuse ajaks mittehaigestunud isik",
      "estleg:definedIn": [
        {
          "@id": "estleg:nakkushaiguste_ennetamise_ja_torje_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Nakkushaiguste ennetamise ja tõrje seadus",
      "rdfs:label": "nakkuskahtlane isik (nakkushaiguste_ennetamise_ja_torje_seadus)"
    },
    {
      "@id": "estleg:Concept_nakkushaiguste_ennetamise_ja_torje_seadus_nakkushaiguste_trje",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "nakkushaiguste tõrje",
      "skos:definition": "selliste tervisekaitseabinõude rakendamine, mis võimaldavad nakkushaige või nakkuskahtlase isiku varakult avastada ning teda uurida ja ravida, selgitada tema nakatumise põhjused ja viisid, tõkestada nakkushaiguse levikut ning vältida tervete nakatumist",
      "estleg:definedIn": [
        {
          "@id": "estleg:nakkushaiguste_ennetamise_ja_torje_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Nakkushaiguste ennetamise ja tõrje seadus",
      "rdfs:label": "nakkushaiguste tõrje (nakkushaiguste_ennetamise_ja_torje_seadus)"
    },
    {
      "@id": "estleg:Concept_nakkushaiguste_ennetamise_ja_torje_seadus_epideemia",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "epideemia",
      "skos:definition": "nakkushaiguse puhang, mis nõuab nakkustõrje meetmete laiaulatuslikku rakendamist.",
      "estleg:definedIn": [
        {
          "@id": "estleg:nakkushaiguste_ennetamise_ja_torje_seadus_Par_2"
