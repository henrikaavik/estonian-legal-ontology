    {
      "@id": "estleg:Concept_inimgeeniuuringute_seadus_DNA_kirjeldus",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "DNA kirjeldus",
      "skos:definition": "geeniuuringute tulemusena loodud DNA digitaalne mudel",
      "estleg:definedIn": [
        {
