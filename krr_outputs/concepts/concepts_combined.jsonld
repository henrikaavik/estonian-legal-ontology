      ],
      "skos:prefLabel": "ettemakstud preemiate eraldis",
      "skos:definition": "arvestuslik suurus kindlustusmaksest, mille ulatuses on kindlustusandjal kindlustusrisk ja sellega seotud kulud kandmata",
      "estleg:definedIn": [
