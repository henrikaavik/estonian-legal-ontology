    },
    {
      "@id": "estleg:Concept_rahvusvahelise_sojalise_koostoo_seadus_Vlisriigi_relvajudude_transiit_kesoleva_seaduse_thenduses_on_vlisriigi_relvajudu",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "Välisriigi relvajõudude transiit käesoleva seaduse tähenduses on välisriigi relvajõudude viibimine Eesti Vabariigi territooriumil selle maismaa",
      "skos:definition": "osa läbimiseks. 2 (2) Kui Eesti Vabariik ja asjaomane välisriik on kollektiivse enesekaitse põhimõtet sisaldava lepingu osapooled, otsustab relvajõududele transiidiloa andmise kaitseminister. 3 (3) Käesoleva paragrahvi lõikes 2 nimetatud välislepingu puudumise korral otsustab relvajõududele transiidiloa andmise: 1 1) kaitseminister käskkirjaga, kui üksuse isikkoosseisus on kuni 2000 liiget",
      "estleg:definedIn": [
        {
          "@id": "estleg:rahvusvahelise_sojalise_koostoo_seadus_Par_19"
        }
      ],
      "estleg:sourceAct": "Rahvusvahelise sõjalise koostöö seadus",
      "rdfs:label": "Välisriigi relvajõudude transiit käesoleva seaduse tähenduses on välisriigi relvajõudude viibimine Eesti Vabariigi territooriumil selle maismaa (rahvusvahelise_sojalise_koostoo_seadus)"
    },
    {
      "@id": "estleg:Concept_rahvusvahelisel_tsiviilmissioonil_osalemise_seadus_rahvusvaheline_tsiviilmissioon",
      "@type": [
        "owl:NamedIndividual",
