      ],
      "skos:prefLabel": "metsamajandamiskava või",
      "skos:definition": "soovituste andmise kuupäev ja andja nimi või nimetus. 2 (2) Metsaeraldise takseerkirjeldusse kantakse metsaeraldise kohta järgmised andmed: 1 1) tunnus",
      "estleg:definedIn": [
        {
          "@id": "estleg:keskkonnaregistri_seadus_Par_10"
        }
      ],
      "estleg:sourceAct": "Keskkonnaregistri seadus",
