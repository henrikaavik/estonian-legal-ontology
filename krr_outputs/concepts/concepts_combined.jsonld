    {
      "@id": "estleg:Concept_ekspordi_riikliku_tagamise_seadus_eksporditagatis",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "eksporditagatis",
      "skos:definition": "riikliku eksporditagatise andja ja tagatisevõtja vahel käesoleva seaduse § 11 lõikes 1 sätestatud tingimustele vastavast kirjalikust kindlustuslepingust tulenev riigi poolt tagatud kohustus hüvitada käesoleva seaduse alusel tagatavate riskide realiseerumisest tagatisevõtjale tulenev kahju",
      "estleg:definedIn": [
        {
          "@id": "estleg:ekspordi_riikliku_tagamise_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Ekspordi riikliku tagamise seadus",
      "rdfs:label": "eksporditagatis (ekspordi_riikliku_tagamise_seadus)"
    },
    {
      "@id": "estleg:Concept_ekspordi_riikliku_tagamise_seadus_eksporditehing",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "eksporditehing",
      "skos:definition": "kaupade müük ja teenuste osutamine välisriiki või kaupade müügiks pakkumine välisriigis, samuti nende toimingutega seotud investeeringud ja finantseerimistehingud, muu hulgas otse- või kaudsed investeeringud välisriigis asuvasse ettevõtjasse, välisriigis asuva ettevõtja omakapitali suurendamine või sellisele ettevõtjale laenu andmine",
      "estleg:definedIn": [
        {
          "@id": "estleg:ekspordi_riikliku_tagamise_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Ekspordi riikliku tagamise seadus",
      "rdfs:label": "eksporditehing (ekspordi_riikliku_tagamise_seadus)"
    },
    {
      "@id": "estleg:Concept_ekspordi_riikliku_tagamise_seadus_tagatisevtja",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "tagatisevõtja",
      "skos:definition": "vähemalt ühe käesolevas seaduses loetletud riski realiseerumisest tekkiva kahju hüvitamiseks riikliku eksporditagatise andjaga käesoleva seaduse § 11 lõikes 1 sätestatud tingimustele vastava kindlustuslepingu sõlminud Eestis äriregistrisse kantud ettevõtja või Euroopa Majanduspiirkonna lepinguriigis registreeritud äriühing, kellel on Eestis äriregistrisse kantud filiaal ja kes tegutseb Eestis filiaali kaudu. Ostjakrediidi korral võib tagatisevõtja olla ka välisriigis registreeritud krediidi- või finantseerimisasutus või krediidi- või finantseerimisasutuse nimel tegutsev filiaal, kellel on õigus välisriigis osutada vähemalt ühte krediidiasutuste seaduse § 6 lõike 1 punktides 1–12 nimetatud finantsteenust ja mille asukohariigi finantsjärelevalve asutus tagab piisava järelevalve krediidi- või finantseerimisasutuse või selle filiaali üle ning välisriigi finantsjärelevalve asutusel on piisav õiguslik alus ja võimalus koostööks Finantsinspektsiooniga",
      "estleg:definedIn": [
        {
          "@id": "estleg:ekspordi_riikliku_tagamise_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Ekspordi riikliku tagamise seadus",
      "rdfs:label": "tagatisevõtja (ekspordi_riikliku_tagamise_seadus)"
    },
    {
      "@id": "estleg:Concept_ekspordi_riikliku_tagamise_seadus_vlgnik",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "võlgnik",
      "skos:definition": "eksporditehingu osapooleks olev isik, kelle kohustuste tagamiseks on sõlmitud riikliku eksporditagatise andjaga käesoleva seaduse § 11 lõikes 1 sätestatud tingimustele vastav kindlustusleping. Võlgnikuna on käsitatav ka isik, kes käendab või muul viisil tagab võlgniku kohustusi tagatavas eksporditehingus. Riikliku eksporditagatise andja ei ole võlgnik käesoleva seaduse tähenduses. Võlgnik võib olla avalik-õiguslik või eraõiguslik",
      "estleg:definedIn": [
        {
          "@id": "estleg:ekspordi_riikliku_tagamise_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Ekspordi riikliku tagamise seadus",
      "rdfs:label": "võlgnik (ekspordi_riikliku_tagamise_seadus)"
    },
    {
      "@id": "estleg:Concept_ekspordi_riikliku_tagamise_seadus_avalik",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "avalik",
      "skos:definition": "õiguslik võlgnik – avaliku võimu ülesandeid täitev asutus või juriidiline isik, keda ei saa kohtu või halduskorras maksejõuetuks tunnistada. Kui avaliku võimu ülesandeid täitev asutus või juriidiline isik tagab täielikult ja tingimusteta eraõigusliku võlgniku eksporditagatisega kaetud kohustused, käsitatakse viimast avalik-õigusliku võlgnikuna",
      "estleg:definedIn": [
        {
          "@id": "estleg:ekspordi_riikliku_tagamise_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Ekspordi riikliku tagamise seadus",
      "rdfs:label": "avalik (ekspordi_riikliku_tagamise_seadus)",
