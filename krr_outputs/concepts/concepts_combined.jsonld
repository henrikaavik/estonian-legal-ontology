    {
      "@id": "estleg:Concept_toote_nouetele_vastavuse_seadus_importija",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "importija",
      "skos:definition": "Euroopa Liidus asuv isik, kes laseb toote kolmandast riigist liidu turule",
      "estleg:definedIn": [
        {
          "@id": "estleg:toote_nouetele_vastavuse_seadus_Par_4"
        }
      ],
      "estleg:sourceAct": "Toote nõuetele vastavuse seadus",
      "rdfs:label": "importija (toote_nouetele_vastavuse_seadus)"
    },
    {
      "@id": "estleg:Concept_toote_nouetele_vastavuse_seadus_krvaldamine",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "kõrvaldamine",
      "skos:definition": "mis tahes meede, mille eesmärk on turustusahelas oleva toote turul kättesaadavaks tegemise vältimine",
      "estleg:definedIn": [
        {
          "@id": "estleg:toote_nouetele_vastavuse_seadus_Par_4"
        }
      ],
      "estleg:sourceAct": "Toote nõuetele vastavuse seadus",
      "rdfs:label": "kõrvaldamine (toote_nouetele_vastavuse_seadus)"
    },
    {
      "@id": "estleg:Concept_toote_nouetele_vastavuse_seadus_levitaja",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "levitaja",
      "skos:definition": "turustusahelas osalev isik, sealhulgas kaupleja kaubandustegevuse seaduse § 2 punkti 1 tähenduses, kes teeb toote turul kättesaadavaks, välja arvatud tootja või importija",
      "estleg:definedIn": [
        {
          "@id": "estleg:toote_nouetele_vastavuse_seadus_Par_4"
        }
      ],
      "estleg:sourceAct": "Toote nõuetele vastavuse seadus",
      "rdfs:label": "levitaja (toote_nouetele_vastavuse_seadus)"
    },
    {
      "@id": "estleg:Concept_toote_nouetele_vastavuse_seadus_standard",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "standard",
      "skos:definition": "konsensuse alusel koostatud ja üldiseks ning korduvaks kasutamiseks standardiorganisatsiooni poolt vastuvõetud dokument, mis sisaldab tehnilist spetsifikatsiooni tegevuse või selle tulemuse kohta. Standardi järgimine on üldiselt vabatahtlik",
      "estleg:definedIn": [
        {
          "@id": "estleg:toote_nouetele_vastavuse_seadus_Par_4"
        }
      ],
      "estleg:sourceAct": "Toote nõuetele vastavuse seadus",
      "rdfs:label": "standard (toote_nouetele_vastavuse_seadus)"
    },
    {
      "@id": "estleg:Concept_toote_nouetele_vastavuse_seadus_standardiorganisatsioon",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "standardiorganisatsioon",
      "skos:definition": "riiklikul, regionaalsel või rahvusvahelisel tasandil tunnustatud standardite koostamise, korraldamise ja vastuvõtmisega tegelev isik",
      "estleg:definedIn": [
        {
          "@id": "estleg:toote_nouetele_vastavuse_seadus_Par_4"
        }
      ],
      "estleg:sourceAct": "Toote nõuetele vastavuse seadus",
      "rdfs:label": "standardiorganisatsioon (toote_nouetele_vastavuse_seadus)"
    },
    {
      "@id": "estleg:Concept_toote_nouetele_vastavuse_seadus_tagasinudmine",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "tagasinõudmine",
      "skos:definition": "mis tahes meede, mille eesmärk on saada turult tagasi toode, mis on seal lõpptarbija jaoks kättesaadavaks tehtud",
      "estleg:definedIn": [
        {
          "@id": "estleg:toote_nouetele_vastavuse_seadus_Par_4"
        }
      ],
      "estleg:sourceAct": "Toote nõuetele vastavuse seadus",
      "rdfs:label": "tagasinõudmine (toote_nouetele_vastavuse_seadus)"
    },
    {
      "@id": "estleg:Concept_toote_nouetele_vastavuse_seadus_tarbija",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "tarbija",
      "skos:definition": "tarbijakaitseseaduse § 2 punktis 1 määratletud isik",
      "estleg:definedIn": [
        {
          "@id": "estleg:toote_nouetele_vastavuse_seadus_Par_4"
        }
      ],
      "estleg:sourceAct": "Toote nõuetele vastavuse seadus",
      "rdfs:label": "tarbija (toote_nouetele_vastavuse_seadus)"
    },
    {
      "@id": "estleg:Concept_toote_nouetele_vastavuse_seadus_tehniline_norm",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "tehniline norm",
      "skos:definition": "õigusaktis sätestatud toote, protsessi või teenuse suhtes kohaldatav tehniline spetsifikatsioon. Tehnilise normina käsitatakse ka õigusnormi, milles kehtestatud maksu tasumise kohustusega mõjutatakse toote tarbimist. Samuti käsitatakse tehnilise normina tehnilist eeskirja määruse (EÜ) nr 764/2008 tähenduses. Tehnilise normina ei käsitata riiklikku sotsiaalkindlustust reguleeriva õigusakti sätteid",
      "estleg:definedIn": [
        {
          "@id": "estleg:toote_nouetele_vastavuse_seadus_Par_4"
        }
      ],
      "estleg:sourceAct": "Toote nõuetele vastavuse seadus",
      "rdfs:label": "tehniline norm (toote_nouetele_vastavuse_seadus)"
    },
    {
      "@id": "estleg:Concept_toote_nouetele_vastavuse_seadus_tootja",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "tootja",
      "skos:definition": "isik, kes valmistab toote või kes laseb toote projekteerida või valmistada ja kes turustab seda toodet oma nime või kaubamärgi all. Tootjana käsitatakse ka importijat ja levitajat, kes laseb toote turule oma nime või kaubamärgi all või kes muudab juba turule lastud toodet viisil, mis võib mõjutada toote vastavust kohaldatavatele nõuetele",
      "estleg:definedIn": [
        {
          "@id": "estleg:toote_nouetele_vastavuse_seadus_Par_4"
        }
      ],
      "estleg:sourceAct": "Toote nõuetele vastavuse seadus",
      "rdfs:label": "tootja (toote_nouetele_vastavuse_seadus)"
    },
    {
      "@id": "estleg:Concept_toote_nouetele_vastavuse_seadus_turule_laskmine",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "turule laskmine",
      "skos:definition": "toote esmakordne kättesaadavaks tegemine Euroopa Liidu turul",
      "estleg:definedIn": [
        {
          "@id": "estleg:toote_nouetele_vastavuse_seadus_Par_4"
        }
      ],
      "estleg:sourceAct": "Toote nõuetele vastavuse seadus",
      "rdfs:label": "turule laskmine (toote_nouetele_vastavuse_seadus)"
    },
    {
      "@id": "estleg:Concept_toote_nouetele_vastavuse_seadus_turul_kttesaadavaks_tegemine",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "turul kättesaadavaks tegemine",
      "skos:definition": "toote tasu eest või tasuta pakkumine Euroopa Liidu turul majandustegevuse käigus kas levitamiseks, tarbimiseks või kasutamiseks",
      "estleg:definedIn": [
        {
          "@id": "estleg:toote_nouetele_vastavuse_seadus_Par_4"
        }
      ],
      "estleg:sourceAct": "Toote nõuetele vastavuse seadus",
      "rdfs:label": "turul kättesaadavaks tegemine (toote_nouetele_vastavuse_seadus)"
    },
    {
      "@id": "estleg:Concept_toote_nouetele_vastavuse_seadus_vastavushindamine",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "vastavushindamine",
      "skos:definition": "menetlus, mille eesmärk on tõendada toote, protsessi, teenuse, süsteemi, isiku või asutuse vastavust määratletud nõuetele",
      "estleg:definedIn": [
        {
          "@id": "estleg:toote_nouetele_vastavuse_seadus_Par_4"
        }
      ],
      "estleg:sourceAct": "Toote nõuetele vastavuse seadus",
      "rdfs:label": "vastavushindamine (toote_nouetele_vastavuse_seadus)"
    },
    {
      "@id": "estleg:Concept_toote_nouetele_vastavuse_seadus_vastavushindamisasutus",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "vastavushindamisasutus",
      "skos:definition": "asutus, kes teeb vastavushindamise toiminguid, sealhulgas kalibreerimist, katsetamist, sertifitseerimist või inspekteerimist",
      "estleg:definedIn": [
        {
          "@id": "estleg:toote_nouetele_vastavuse_seadus_Par_4"
        }
      ],
      "estleg:sourceAct": "Toote nõuetele vastavuse seadus",
      "rdfs:label": "vastavushindamisasutus (toote_nouetele_vastavuse_seadus)"
    },
    {
      "@id": "estleg:Concept_toote_nouetele_vastavuse_seadus_volitatud_esindaja",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "volitatud esindaja",
      "skos:definition": "Euroopa Liidus asuv isik, kes on saanud tootjalt kirjaliku volituse tegutseda tema nimel kindlaksmääratud ülesannetes. 2 (2) Lisaks käesoleva paragrahvi lõikes 1 sätestatud mõistetele kasutatakse käesolevas seaduses ka määruses (EÜ) nr 765/2008 kasutatud mõisteid.",
      "estleg:definedIn": [
        {
          "@id": "estleg:toote_nouetele_vastavuse_seadus_Par_4"
        }
      ],
      "estleg:sourceAct": "Toote nõuetele vastavuse seadus",
      "rdfs:label": "volitatud esindaja (toote_nouetele_vastavuse_seadus)"
    },
    {
      "@id": "estleg:Concept_toote_nouetele_vastavuse_seadus_ehitusmaterjalid_ja",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "ehitusmaterjalid ja",
      "skos:definition": "tooted",
      "estleg:definedIn": [
        {
          "@id": "estleg:toote_nouetele_vastavuse_seadus_Par_50"
        }
      ],
      "estleg:sourceAct": "Toote nõuetele vastavuse seadus",
      "rdfs:label": "ehitusmaterjalid ja (toote_nouetele_vastavuse_seadus)"
    },
    {
      "@id": "estleg:Concept_toote_nouetele_vastavuse_seadus_Maksu",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "Maksu",
      "skos:definition": "ja Tolliamet kontrollib imporditavate toodete ohutust ja nõuetele vastavust, tehes selleks koostööd asjaomase turujärelevalveasutusega.",
      "estleg:definedIn": [
        {
          "@id": "estleg:toote_nouetele_vastavuse_seadus_Par_50"
        }
      ],
      "estleg:sourceAct": "Toote nõuetele vastavuse seadus",
      "rdfs:label": "Maksu (toote_nouetele_vastavuse_seadus)"
    },
    {
      "@id": "estleg:Concept_toote_ohutuse_seadus_Levitaja_kesoleva_seaduse_thenduses_on_iga_majandus",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "Levitaja käesoleva seaduse tähenduses on iga majandus",
      "skos:definition": "või kutsetegevuse käigus toodet turustusahelas pakkuv isik, kelle tegevus ei mõjuta toote ohutust.",
      "estleg:definedIn": [
        {
          "@id": "estleg:toote_ohutuse_seadus_Par_5"
        }
      ],
      "estleg:sourceAct": "Toote ohutuse seadus",
      "rdfs:label": "Levitaja käesoleva seaduse tähenduses on iga majandus (toote_ohutuse_seadus)"
    },
    {
      "@id": "estleg:Concept_tootervishoiu_ja_tooohutuse_seadus_Kesolevas_seaduses_mistetakse_ttervishoiuna_ttaja_tervisekahjustuse_vltimiseks_t",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "Käesolevas seaduses mõistetakse töötervishoiuna töötaja tervisekahjustuse vältimiseks töökorraldus",
      "skos:definition": "ja meditsiiniabinõude rakendamist, töö kohandamist töötaja võimetele ning töötaja füüsilise, vaimse ja sotsiaalse heaolu edendamist. 2 (2) Käesolevas seaduses mõistetakse tööohutusena töökorraldusabinõude ja tehnikavahendite süsteemi sellise töökeskkonna seisundi saavutamiseks, mis võimaldab töötajal teha tööd oma tervist ohtu seadmata. 3 (3) Töötervishoiu- ja tööohutusalase väljaõppe ja täiendõppe korra kehtestab sotsiaalminister oma määrusega.",
      "estleg:definedIn": [
        {
          "@id": "estleg:tootervishoiu_ja_tooohutuse_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Töötervishoiu ja tööohutuse seadus",
      "rdfs:label": "Käesolevas seaduses mõistetakse töötervishoiuna töötaja tervisekahjustuse vältimiseks töökorraldus (tootervishoiu_ja_tooohutuse_seadus)"
    },
    {
      "@id": "estleg:Concept_tootervishoiu_ja_tooohutuse_seadus_Terviseriski_vltimiseks_vi_vhendamiseks_peavad_tkohas_olema_kaitse",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "Terviseriski vältimiseks või vähendamiseks peavad töökohas olema kaitse",
      "skos:definition": ", pääste- ja esmaabivahendid, ohutusmärgid ning muud ohutusvahendid. Esmaabi korralduse ettevõttes ja ohumärguannete kasutamise nõuded kehtestab sotsiaalminister oma määrusega. 5 (5) Tegevusalade töötervishoiu ja tööohutuse nõuded kehtestab Vabariigi Valitsus. RT I 2003 20 120 260826 2003-07-01+03:00",
      "estleg:definedIn": [
        {
          "@id": "estleg:tootervishoiu_ja_tooohutuse_seadus_Par_4"
        }
      ],
      "estleg:sourceAct": "Töötervishoiu ja tööohutuse seadus",
      "rdfs:label": "Terviseriski vältimiseks või vähendamiseks peavad töökohas olema kaitse (tootervishoiu_ja_tooohutuse_seadus)"
    },
    {
      "@id": "estleg:Concept_tootervishoiu_ja_tooohutuse_seadus_korraldama_sidehendused_ettevttevliste_pste",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "korraldama sideühendused ettevõtteväliste pääste",
      "skos:definition": "ja hädaabiteenistustega",
      "estleg:definedIn": [
        {
          "@id": "estleg:tootervishoiu_ja_tooohutuse_seadus_Par_15"
        }
      ],
      "estleg:sourceAct": "Töötervishoiu ja tööohutuse seadus",
      "rdfs:label": "korraldama sideühendused ettevõtteväliste pääste (tootervishoiu_ja_tooohutuse_seadus)"
    },
    {
      "@id": "estleg:Concept_tootervishoiu_ja_tooohutuse_seadus_Ttervishoiuteenuse_osutaja_registreerimistaotluses_ja",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "Töötervishoiuteenuse osutaja registreerimistaotluses ja",
      "skos:definition": "tõendis esitatavate andmete loetelu ning registreerimistaotlusele lisatavate dokumentide loetelu kehtestab sotsiaalminister. 9 (9) Töötervishoiuteenuse osutaja on kohustatud teatama kirjalikult Tervishoiuametile registreerimistaotluses nimetatud andmete muudatustest 15 päeva jooksul muudatuste toimumisest arvates. 10 (10) Töötervishoiuteenuse osutaja, kelle tegevus hõlmab töötervishoiuarsti või töötervishoiuõe tööülesannete täitmist, taotleb töötervishoiuteenuse osutamiseks Tervishoiuametilt tegevusluba tervishoiuteenuste korraldamise seaduses (RT I 2001, 50, 284",
      "estleg:definedIn": [
        {
          "@id": "estleg:tootervishoiu_ja_tooohutuse_seadus_Par_19"
        }
      ],
      "estleg:sourceAct": "Töötervishoiu ja tööohutuse seadus",
      "rdfs:label": "Töötervishoiuteenuse osutaja registreerimistaotluses ja (tootervishoiu_ja_tooohutuse_seadus)"
    },
    {
      "@id": "estleg:Concept_tootervishoiu_ja_tooohutuse_seadus_kehtestatud_korras_ja_tingimustel_ning_temale_ei_kohaldata_kesoleva_paragrahvi_l",
