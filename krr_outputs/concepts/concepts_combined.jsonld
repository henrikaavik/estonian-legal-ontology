    {
      "@id": "estleg:Concept_autoveoseadus_vedaja",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "vedaja",
      "skos:definition": "autoveo tegevusluba omav äriseadustikus nimetatud ja äriregistrisse kantud ettevõtja või seaduse alusel teise registrisse kantud isik, oma kulul korraldatava autoveo puhul ka kohalik omavalitsusüksus.",
