    },
    {
      "@id": "estleg:Concept_maksualase_teabevahetuse_seadus_maksukohustuslase_identifitseerimisnumber_vi",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "maksukohustuslase identifitseerimisnumber või",
      "skos:definition": "numbrid",
      "estleg:definedIn": [
