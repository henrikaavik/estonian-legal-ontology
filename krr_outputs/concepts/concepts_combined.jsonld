    {
      "@id": "estleg:Concept_finantsinspektsiooni_seadus_Kehtetu_7",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "Kehtetu",
      "skos:definition": "RT I 2005 13 64 860642 2005-03-18+02:00 3 (3) Vara käesoleva seaduse tähenduses on vastavalt õigusaktidele bilansi aktiva kokku. 4 (4) Arvestusvara käesoleva seaduse tähenduses on kindlustusmaksete kogusumma ja vara summa. RT I 2005 13 64 860642 2005-03-18+02:00",
      "estleg:definedIn": [
        {
          "@id": "estleg:finantsinspektsiooni_seadus_Par_37"
        }
      ],
      "estleg:sourceAct": "Finantsinspektsiooni seadus",
      "rdfs:label": "Kehtetu (finantsinspektsiooni_seadus)"
    },
    {
      "@id": "estleg:Concept_finantskriisi_ennetamise_ja_lahendamise_seadus_artiklite_6",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "artiklite 6",
      "skos:definition": "17 alusel. 3 (3) Käesolevas seaduses käsitatakse krediidiasutusena ka investeerimisühingut ja tema suhtes kohaldatakse kõike krediidiasutuse suhtes sätestatut, kui käesolevas seaduses ei ole sätestatud teisiti.",
      "estleg:definedIn": [
        {
          "@id": "estleg:finantskriisi_ennetamise_ja_lahendamise_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Finantskriisi ennetamise ja lahendamise seadus",
      "rdfs:label": "artiklite 6 (finantskriisi_ennetamise_ja_lahendamise_seadus)"
    },
    {
      "@id": "estleg:Concept_finantskriisi_ennetamise_ja_lahendamise_seadus_Kriitilised_funktsioonid_kesoleva_seaduse_thenduses_on_krediidiasutuse_osutatava",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "Kriitilised funktsioonid käesoleva seaduse tähenduses on krediidiasutuse osutatavad makse",
      "skos:definition": "ja arveldusteenused ning muud teenused või tegevused, mille seiskumine või toimepidevuse oluline häire kahjustab või võib kahjustada finantsturu toimimist, finantsstabiilsust või ka reaalmajandust või avaldada negatiivset mõju teistele finantssüsteemi osalistele.",
      "estleg:definedIn": [
        {
          "@id": "estleg:finantskriisi_ennetamise_ja_lahendamise_seadus_Par_5"
        }
      ],
      "estleg:sourceAct": "Finantskriisi ennetamise ja lahendamise seadus",
      "rdfs:label": "Kriitilised funktsioonid käesoleva seaduse tähenduses on krediidiasutuse osutatavad makse (finantskriisi_ennetamise_ja_lahendamise_seadus)"
    },
