    {
      "@id": "estleg:Concept_kaevandamisseadus_maavara_vi_maa",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "maavara või maa",
      "skos:definition": "ainese kasutamise eesmärgil nende maapõuest väljamisel, allmaakaeveõõne rajamisel, geoloogilisel uuringul või kaevanduse osaks oleva allmaaehitise ehitamisel maapõues tehtav töö",
      "estleg:definedIn": [
        {
          "@id": "estleg:kaevandamisseadus_Par_3"
        }
      ],
      "estleg:sourceAct": "Kaevandamisseadus",
      "rdfs:label": "maavara või maa (kaevandamisseadus)"
    },
    {
      "@id": "estleg:Concept_kaevandamisseadus_maavara_vi_maa_2",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "maavara või maa",
      "skos:definition": "ainese kaevandamise või esmatöötlemisega seonduv vedu",
      "estleg:definedIn": [
        {
          "@id": "estleg:kaevandamisseadus_Par_3"
        }
      ],
      "estleg:sourceAct": "Kaevandamisseadus",
      "rdfs:label": "maavara või maa (kaevandamisseadus)"
    },
    {
      "@id": "estleg:Concept_kaevandamisseadus_maavara_vi_maa_3",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "maavara või maa",
      "skos:definition": "ainese esmatöötlemine, sealhulgas maavara või maa-ainese tööstuslikul viisil purustamine, sorteerimine, veetustamine, brikettimine ja ladustamine, või 4 4) puistangute moodustamine, kaevandatud ala või puistangute rekultiveerimine. [Lõike 1 sõnastus alates 1. 04. 2005] 1 (1) Kaevandamine on: 1 1) maavara kasutamise eesmärgil selle maapõuest väljamisel, allmaakaeveõõne rajamisel, geoloogilisel uuringul või kaevanduse osaks oleva allmaaehitise ehitamisel maapõues tehtav töö",
      "estleg:definedIn": [
        {
          "@id": "estleg:kaevandamisseadus_Par_3"
        }
      ],
      "estleg:sourceAct": "Kaevandamisseadus",
      "rdfs:label": "maavara või maa (kaevandamisseadus)"
    },
    {
      "@id": "estleg:Concept_kaevandamisseadus_Kaevandus_on_maavara_vi_maa",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "Kaevandus on maavara või maa",
      "skos:definition": "ainese kaevandamisega seonduv tootmisüksus, mis koosneb maavara või maa-ainese kaevandamiseks vajalikest rajatistest ja hoonetest. RT I 2004 84 572 824890 2005-04-01+03:00",
      "estleg:definedIn": [
        {
          "@id": "estleg:kaevandamisseadus_Par_3"
        }
      ],
      "estleg:sourceAct": "Kaevandamisseadus",
      "rdfs:label": "Kaevandus on maavara või maa (kaevandamisseadus)"
    },
    {
      "@id": "estleg:Concept_kaevandamisseadus_Uuringu",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "Uuringu",
      "skos:definition": "või kaevandamisloa omanik käesoleva seaduse tähenduses on isik, kellele nimetatud luba on maapõueseaduse alusel väljastatud või võõrandatud. 2 (2) Uuringu- või kaevandamisloa omanik peab tagama, et kaevandamise projekti koostab ja kaevandab käesoleva seaduse §-s 10 nimetatud isik, kes kohustub kinni pidama uuringu- või kaevandamisloa tingimustest.",
      "estleg:definedIn": [
        {
          "@id": "estleg:kaevandamisseadus_Par_9"
        }
      ],
      "estleg:sourceAct": "Kaevandamisseadus",
      "rdfs:label": "Uuringu (kaevandamisseadus)"
    },
    {
      "@id": "estleg:Concept_kaevandamisseadus_Isiku_nuetele_vastavuse_hindamise_ja_tendamise_korra_kehtestab_majandus",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "Isiku nõuetele vastavuse hindamise ja tõendamise korra kehtestab majandus",
      "skos:definition": "ja kommunikatsiooniminister. ./dyn=828901&id=675678",
      "estleg:definedIn": [
        {
          "@id": "estleg:kaevandamisseadus_Par_17"
        }
      ],
      "estleg:sourceAct": "Kaevandamisseadus",
      "rdfs:label": "Isiku nõuetele vastavuse hindamise ja tõendamise korra kehtestab majandus (kaevandamisseadus)",
      "skos:exactMatch": [
        {
          "@id": "estleg:Concept_kuttegaasi_ohutuse_seadus_Isiku_nuetele_vastavuse_hindamise_ja_tendamise_korra_kehtestab_majandus"
