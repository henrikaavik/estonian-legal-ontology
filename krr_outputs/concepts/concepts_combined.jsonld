    {
      "@id": "estleg:Concept_energiamajanduse_korralduse_seadus_avaliku_sektori_asutus",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "avaliku sektori asutus",
      "skos:definition": "hankija riigihangete seaduse tähenduses",
      "estleg:definedIn": [
        {
          "@id": "estleg:energiamajanduse_korralduse_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Energiamajanduse korralduse seadus",
      "rdfs:label": "avaliku sektori asutus (energiamajanduse_korralduse_seadus)"
    },
    {
      "@id": "estleg:Concept_energiamajanduse_korralduse_seadus_avaliku_sektori_rakendusasutus",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "avaliku sektori rakendusasutus",
      "skos:definition": "energiasäästu poliitika elluviimisesse kaasatud riigiasutus või avalik-õiguslik juriidiline isik, kes vastutab energia ja süsinikdioksiidi maksustamise, rahastamiskavade ja -instrumentide, eelarvepoliitika meetmete, standardite ja normide, energiamärgistuse süsteemide ning koolitus- ja haridustegevuse elluviimise või jälgimise eest",
      "estleg:definedIn": [
        {
          "@id": "estleg:energiamajanduse_korralduse_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Energiamajanduse korralduse seadus",
      "rdfs:label": "avaliku sektori rakendusasutus (energiamajanduse_korralduse_seadus)"
    },
    {
      "@id": "estleg:Concept_energiamajanduse_korralduse_seadus_energia",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "energia",
      "skos:definition": "energiatooted, sealhulgas põlevkütus, soojus, taastuvenergia, elekter ja muu energiatoode",
      "estleg:definedIn": [
        {
          "@id": "estleg:energiamajanduse_korralduse_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Energiamajanduse korralduse seadus",
      "rdfs:label": "energia (energiamajanduse_korralduse_seadus)"
    },
    {
      "@id": "estleg:Concept_energiamajanduse_korralduse_seadus_energiaaudit",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "energiaaudit",
      "skos:definition": "süstemaatiline menetlus, mida tehakse adekvaatsete teadmiste saamiseks hoone või hoonete rühma, tööstusliku või kaubandusliku protsessi või käitise või eraõiguslike või avalik-õiguslike teenuste energiatarbimise profiili kohta ning millega määratakse kulutõhusa energiasäästu võimalused ja säästu suurus ning mille tulemuste põhjal koostatakse aruanne",
      "estleg:definedIn": [
        {
          "@id": "estleg:energiamajanduse_korralduse_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Energiamajanduse korralduse seadus",
      "rdfs:label": "energiaaudit (energiamajanduse_korralduse_seadus)"
    },
    {
      "@id": "estleg:Concept_energiamajanduse_korralduse_seadus_energia_jaemgi_ettevtja",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "energia jaemüügi ettevõtja",
      "skos:definition": "füüsiline või juriidiline isik, kes müüb energiat lõpptarbijatele",
      "estleg:definedIn": [
        {
          "@id": "estleg:energiamajanduse_korralduse_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Energiamajanduse korralduse seadus",
      "rdfs:label": "energia jaemüügi ettevõtja (energiamajanduse_korralduse_seadus)"
    },
    {
      "@id": "estleg:Concept_energiamajanduse_korralduse_seadus_energiajuhtimisssteem",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "energiajuhtimissüsteem",
      "skos:definition": "kogum üksteisega seotud või üksteist mõjutavaid elemente, mis esinevad kavas, millega kehtestatakse energiatõhususe eesmärk ja strateegia selle eesmärgi saavutamiseks",
      "estleg:definedIn": [
        {
          "@id": "estleg:energiamajanduse_korralduse_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Energiamajanduse korralduse seadus",
      "rdfs:label": "energiajuhtimissüsteem (energiamajanduse_korralduse_seadus)"
    },
    {
      "@id": "estleg:Concept_energiamajanduse_korralduse_seadus_energia_lpptarbimine",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "energia lõpptarbimine",
      "skos:definition": "kogu energia, mis tarnitakse tööstus-, transpordi-, teenindus- ja põllumajandussektorile ning kodumajapidamistele, välja arvatud tarned energia muundamise sektorile ja energiatööstusele",
      "estleg:definedIn": [
        {
          "@id": "estleg:energiamajanduse_korralduse_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Energiamajanduse korralduse seadus",
      "rdfs:label": "energia lõpptarbimine (energiamajanduse_korralduse_seadus)"
    },
    {
      "@id": "estleg:Concept_energiamajanduse_korralduse_seadus_energiasst",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "energiasääst",
      "skos:definition": "säästetud energia hulk, mis määratakse, mõõtes või hinnates tarbimist enne ja pärast energiatõhususe parandamise meetme rakendamist olukorras, kus on tagatud võrdsed välistingimused, mis võivad mõjutada energiatarbimist",
      "estleg:definedIn": [
        {
          "@id": "estleg:energiamajanduse_korralduse_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Energiamajanduse korralduse seadus",
      "rdfs:label": "energiasääst (energiamajanduse_korralduse_seadus)"
    },
    {
      "@id": "estleg:Concept_energiamajanduse_korralduse_seadus_energiatarnija",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "energiatarnija",
      "skos:definition": "füüsiline või juriidiline isik, sealhulgas jaotusvõrguettevõtja, kes vastutab energia transpordi eest lõpptarbijale või tarbijapaigaldiseni",
      "estleg:definedIn": [
        {
          "@id": "estleg:energiamajanduse_korralduse_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Energiamajanduse korralduse seadus",
      "rdfs:label": "energiatarnija (energiamajanduse_korralduse_seadus)"
    },
    {
      "@id": "estleg:Concept_energiamajanduse_korralduse_seadus_energiateenus",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "energiateenus",
      "skos:definition": "füüsiline kasu, teenus või kaup, mis saadakse energia kombineerimisel energiatõhusa tehnoloogiaga või tegevusega, mis võib hõlmata teenuse osutamiseks vajalikke toiminguid, hooldust ja kontrolli, mida tehakse lepingu alusel ja mille puhul on tõestatud, et tavaolukorras aitab see parandada kontrollitavat ja mõõdetavat või hinnatavat energiatõhusust või säästa primaarenergiat",
      "estleg:definedIn": [
        {
          "@id": "estleg:energiamajanduse_korralduse_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Energiamajanduse korralduse seadus",
      "rdfs:label": "energiateenus (energiamajanduse_korralduse_seadus)"
    },
    {
      "@id": "estleg:Concept_energiamajanduse_korralduse_seadus_energiateenuse_osutaja",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "energiateenuse osutaja",
      "skos:definition": "füüsiline või juriidiline isik, kes osutab energiateenuseid või rakendab muid energiatõhususe parandamise meetmeid lõpptarbija seadmetes või ruumides",
      "estleg:definedIn": [
        {
          "@id": "estleg:energiamajanduse_korralduse_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Energiamajanduse korralduse seadus",
      "rdfs:label": "energiateenuse osutaja (energiamajanduse_korralduse_seadus)"
    },
    {
      "@id": "estleg:Concept_energiamajanduse_korralduse_seadus_energiathusus",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "energiatõhusus",
      "skos:definition": "töö, teenuse, kauba või energiaväljundi ja energiasisendi vaheline suhe",
      "estleg:definedIn": [
        {
          "@id": "estleg:energiamajanduse_korralduse_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Energiamajanduse korralduse seadus",
      "rdfs:label": "energiatõhusus (energiamajanduse_korralduse_seadus)"
    },
    {
      "@id": "estleg:Concept_energiamajanduse_korralduse_seadus_energiathususe_leping",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "energiatõhususe leping",
      "skos:definition": "lõpptarbija ja energiateenuse osutaja vaheline leping, mille täitmist kontrollitakse ja jälgitakse kogu lepingu kehtivuse aja jooksul ning mille alusel lõpptarbija tasub energiateenuse osutamiseks tehtud investeeringute eest sõltuvalt lepingus kokkulepitud energiatõhususe parandamise tasemest või muust kokkulepitud energiatõhususe kriteeriumist, näiteks rahalisest säästust",
      "estleg:definedIn": [
        {
          "@id": "estleg:energiamajanduse_korralduse_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Energiamajanduse korralduse seadus",
      "rdfs:label": "energiatõhususe leping (energiamajanduse_korralduse_seadus)"
    },
    {
      "@id": "estleg:Concept_energiamajanduse_korralduse_seadus_energiathususe_parandamine",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "energiatõhususe parandamine",
      "skos:definition": "energiatõhususe suurendamine tehnoloogiliste, käitumuslike või majanduslike muutuste abil",
      "estleg:definedIn": [
        {
          "@id": "estleg:energiamajanduse_korralduse_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Energiamajanduse korralduse seadus",
      "rdfs:label": "energiatõhususe parandamine (energiamajanduse_korralduse_seadus)"
    },
    {
      "@id": "estleg:Concept_energiamajanduse_korralduse_seadus_energiavahendaja",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "energiavahendaja",
      "skos:definition": "nõudluspoole teenusepakkuja, kes ühendab mitmed lühiajalised tarbimiskoormused müümiseks otse või enampakkumisel organiseeritud energiaturgudel, milleks on elektribörs või börsiväline turg energia, võimsuse, bilansi- ja lisateenustega kauplemiseks mis tahes ajavahemikul, sealhulgas tärminlepingute turud, päev-ette-turud ja päevasisesed turud",
      "estleg:definedIn": [
        {
          "@id": "estleg:energiamajanduse_korralduse_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Energiamajanduse korralduse seadus",
      "rdfs:label": "energiavahendaja (energiamajanduse_korralduse_seadus)"
    },
    {
      "@id": "estleg:Concept_energiamajanduse_korralduse_seadus_jaotusvrguettevtja",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "jaotusvõrguettevõtja",
      "skos:definition": "jaotusvõrguettevõtja elektrituruseaduse ja maagaasiseaduse tähenduses",
      "estleg:definedIn": [
        {
          "@id": "estleg:energiamajanduse_korralduse_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Energiamajanduse korralduse seadus",
      "rdfs:label": "jaotusvõrguettevõtja (energiamajanduse_korralduse_seadus)"
    },
    {
      "@id": "estleg:Concept_energiamajanduse_korralduse_seadus_kasulik_ldprandapind",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "kasulik üldpõrandapind",
      "skos:definition": "hoone köetav pind, mis on hoone kõigi nende ruumide suletud netopindade summa, mille ruumiõhu kvaliteedi tagamiseks, sealhulgas temperatuuri hoidmiseks, tõstmiseks või langetamiseks, kasutatakse energiat",
      "estleg:definedIn": [
        {
          "@id": "estleg:energiamajanduse_korralduse_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Energiamajanduse korralduse seadus",
      "rdfs:label": "kasulik üldpõrandapind (energiamajanduse_korralduse_seadus)"
    },
    {
      "@id": "estleg:Concept_energiamajanduse_korralduse_seadus_kaugktte_ja",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "kaugkütte ja",
      "skos:definition": "jahutuse taristu – torustike, seadmete, abiseadmete ja nendega seotud ehitiste kohakindlalt ehitatud talitluslik kogum või selle osa, mis on vajalik soojuse või jahutuse jaotamiseks, välja arvatud tarbijapaigaldised",
      "estleg:definedIn": [
        {
          "@id": "estleg:energiamajanduse_korralduse_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Energiamajanduse korralduse seadus",
      "rdfs:label": "kaugkütte ja (energiamajanduse_korralduse_seadus)"
    },
    {
      "@id": "estleg:Concept_energiamajanduse_korralduse_seadus_keskvalitsus",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "keskvalitsus",
      "skos:definition": "riigi ametiasutused ja hallatavad riigiasutused",
      "estleg:definedIn": [
        {
          "@id": "estleg:energiamajanduse_korralduse_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Energiamajanduse korralduse seadus",
      "rdfs:label": "keskvalitsus (energiamajanduse_korralduse_seadus)"
    },
    {
      "@id": "estleg:Concept_energiamajanduse_korralduse_seadus_koostootmine",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "koostootmine",
      "skos:definition": "soojusenergia ja elektrienergia või mehaanilise energia samaaegne tootmine ühes protsessis",
      "estleg:definedIn": [
        {
          "@id": "estleg:energiamajanduse_korralduse_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Energiamajanduse korralduse seadus",
      "rdfs:label": "koostootmine (energiamajanduse_korralduse_seadus)"
    },
    {
      "@id": "estleg:Concept_energiamajanduse_korralduse_seadus_lpptarbija",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "lõpptarbija",
      "skos:definition": "füüsiline või juriidiline isik, kes kasutab energiat oma vajadusteks. Kütte, jahutuse ja sooja tarbevee lõpptarbijaks kortermajades on ühistud või ühisused, kui energia müüki ei ole korraldatud teisiti",
      "estleg:definedIn": [
        {
          "@id": "estleg:energiamajanduse_korralduse_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Energiamajanduse korralduse seadus",
      "rdfs:label": "lõpptarbija (energiamajanduse_korralduse_seadus)"
    },
    {
      "@id": "estleg:Concept_energiamajanduse_korralduse_seadus_nutiarvesti",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "nutiarvesti",
      "skos:definition": "elektrooniline süsteem, mis on võimeline mõõtma energia tarbimist, andes kohtloetavast arvestist rohkem teavet, ning edastama ja vastu võtma andmeid elektroonilist sidevahendit kasutades",
      "estleg:definedIn": [
        {
          "@id": "estleg:energiamajanduse_korralduse_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Energiamajanduse korralduse seadus",
      "rdfs:label": "nutiarvesti (energiamajanduse_korralduse_seadus)"
    },
    {
      "@id": "estleg:Concept_energiamajanduse_korralduse_seadus_nudluse_juhtimine",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "nõudluse juhtimine",
      "skos:definition": "abinõud, mille eesmärk on mõjutada elektritarbimise mahtu ja ajalist jaotust, et vähendada esmast elektritarbimist ja lühiajalisi kõrgeid koormusi (tipu koormusi)",
      "estleg:definedIn": [
        {
          "@id": "estleg:energiamajanduse_korralduse_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Energiamajanduse korralduse seadus",
      "rdfs:label": "nõudluse juhtimine (energiamajanduse_korralduse_seadus)"
    },
    {
      "@id": "estleg:Concept_energiamajanduse_korralduse_seadus_osalev_isik",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "osalev isik",
      "skos:definition": "ettevõtja või avaliku sektori asutus, kes on võtnud endale vabatahtliku kokkuleppega kohustuse saavutada teatavad eesmärgid või kes on hõlmatud riikliku regulatiivse poliitikameetmega",
      "estleg:definedIn": [
        {
          "@id": "estleg:energiamajanduse_korralduse_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Energiamajanduse korralduse seadus",
      "rdfs:label": "osalev isik (energiamajanduse_korralduse_seadus)"
    },
    {
      "@id": "estleg:Concept_energiamajanduse_korralduse_seadus_poliitikameede",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "poliitikameede",
      "skos:definition": "mõjutusvahend, mille Riigikogu, Vabariigi Valitsus või minister on ametlikult kehtestanud või rakendanud turuosalistele toetava raamistiku, nõude või stiimuli loomiseks, et pakkuda ja osta energiateenuseid ning rakendada muid abinõusid energiatõhususe parandamiseks. Poliitikameede võib olla regulatiivne mõjutusvahend, finants- või fiskaalinstrument, vabatahtlik tegevus või teavitustegevus",
      "estleg:definedIn": [
        {
          "@id": "estleg:energiamajanduse_korralduse_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Energiamajanduse korralduse seadus",
      "rdfs:label": "poliitikameede (energiamajanduse_korralduse_seadus)"
    },
    {
      "@id": "estleg:Concept_energiamajanduse_korralduse_seadus_primaarenergia",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "primaarenergia",
      "skos:definition": "looduslikust allikast saadud energia, mida tarbitakse teisteks energialiikideks muundamata, välja arvatud mitteenergeetilised kasutusalad",
      "estleg:definedIn": [
        {
          "@id": "estleg:energiamajanduse_korralduse_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Energiamajanduse korralduse seadus",
      "rdfs:label": "primaarenergia (energiamajanduse_korralduse_seadus)"
    },
    {
      "@id": "estleg:Concept_energiamajanduse_korralduse_seadus_thus_kaugkte_ja",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "tõhus kaugküte ja",
      "skos:definition": "jahutus – kaugkütte- või kaugjahutussüsteem, mis kasutab vähemalt 50 protsenti taastuvenergiat, 50 protsenti heitsoojust, 75 protsenti koostoodetud soojust või 50 protsenti taastuvenergia ja heitsoojuse või koostoodetud soojuse kombinatsiooni",
      "estleg:definedIn": [
        {
          "@id": "estleg:energiamajanduse_korralduse_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Energiamajanduse korralduse seadus",
      "rdfs:label": "tõhus kaugküte ja (energiamajanduse_korralduse_seadus)"
    },
    {
      "@id": "estleg:Concept_energiamajanduse_korralduse_seadus_volitatud_isik",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "volitatud isik",
      "skos:definition": "juriidiline isik, kellele Vabariigi Valitsus või riigiasutus on delegeerinud volituse arendada, juhtida või hallata energiapoliitika osaks olevat rahastamiskava Vabariigi Valitsuse või riigiasutuse nimel",
      "estleg:definedIn": [
        {
          "@id": "estleg:energiamajanduse_korralduse_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Energiamajanduse korralduse seadus",
      "rdfs:label": "volitatud isik (energiamajanduse_korralduse_seadus)"
    },
    {
      "@id": "estleg:Concept_energiamajanduse_korralduse_seadus_vikese_ja_keskmise_suurusega_ettevtja",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "väikese ja keskmise suurusega ettevõtja",
      "skos:definition": "ettevõtja, kellel on vähem kui 250 töötajat ja kelle aastakäive ei ületa 50 miljonit eurot või aastabilansi kogumaht ei ületa 43 miljonit eurot",
      "estleg:definedIn": [
        {
          "@id": "estleg:energiamajanduse_korralduse_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Energiamajanduse korralduse seadus",
      "rdfs:label": "väikese ja keskmise suurusega ettevõtja (energiamajanduse_korralduse_seadus)"
    },
    {
      "@id": "estleg:Concept_energiamajanduse_korralduse_seadus_ksikmeede",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "üksikmeede",
      "skos:definition": "meede, mis aitab parandada energiatõhususe kontrollitavat ja mõõdetavat või hinnatavat paranemist ning mida rakendatakse poliitikameetme tulemusena",
      "estleg:definedIn": [
        {
          "@id": "estleg:energiamajanduse_korralduse_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Energiamajanduse korralduse seadus",
      "rdfs:label": "üksikmeede (energiamajanduse_korralduse_seadus)"
    },
    {
      "@id": "estleg:Concept_energiamajanduse_korralduse_seadus_ldine_energiathususkohustus",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "üldine energiatõhususkohustus",
      "skos:definition": "käesolevas seaduses sätestatud kohustus energiasäästu saavutamiseks või energiatõhususe parandamiseks energia tootmisel, ülekandel ja jaotamisel ning energia lõpptarbija juures",
      "estleg:definedIn": [
        {
          "@id": "estleg:energiamajanduse_korralduse_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Energiamajanduse korralduse seadus",
      "rdfs:label": "üldine energiatõhususkohustus (energiamajanduse_korralduse_seadus)"
    },
    {
      "@id": "estleg:Concept_energiamajanduse_korralduse_seadus_lekandevrguettevtja",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "ülekandevõrguettevõtja",
      "skos:definition": "põhivõrguettevõtja elektrituruseaduse tähenduses ja süsteemihaldur maagaasiseaduse tähenduses.",
      "estleg:definedIn": [
        {
          "@id": "estleg:energiamajanduse_korralduse_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Energiamajanduse korralduse seadus",
      "rdfs:label": "ülekandevõrguettevõtja (energiamajanduse_korralduse_seadus)"
    },
    {
      "@id": "estleg:Concept_erakonnaseadus_Kesoleva_paragrahvi_like_8_punktis_3_nimetatud_majandamiskulud_on_kesoleva_seadu",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "Käesoleva paragrahvi lõike 8 punktis 3 nimetatud majandamiskulud on käesoleva seaduse tähenduses kontori rendi",
      "skos:definition": "ja kommunaalkulud, transpordi-, kütuse-, side-, põhivara kulumi-, kindlustus-, väikevahendite jms kulud. 11 (11) Käesoleva paragrahvi lõigetes 8 ja 9 nimetatud kulude kohta näidatakse aruandes kululiik ja sellele vastava kulu maksumus kvartali koondsummana. 12 (12) Erakond esitab erakondade rahastamise järelevalve komisjonile kvartali lõpu seisuga kvartalile järgneva kuu 10. kuupäevaks raamatupidamisliku väljatrüki oma tasumata arvete kohta ja bilansi. 13 (13) Kui erakond avastab esitatud aruandes puuduse, esitab ta erakondade rahastamise järelevalve komisjonile viivitamatult muudatust kajastava aruande. Kui uus aruanne esitatakse enne, kui komisjon on puuduse avastanud, ei kohaldata § 12 4 lõikes 2 sätestatud kohustust kanda riigieelarvesse summa, mis vastab aruandes avastatud puudusele. Kui käesoleva lõike esimeses lauses nimetatud puuduse andmete esitamisel on põhjustanud käesoleva paragrahvi lõikes 1 nimetatud juhul erakonna liige või sidusorganisatsioon, kohaldatakse § 12 4 lõikes 2 sätestatud kohustust kanda riigieelarvesse summa, mis vastab aruandes avastatud puudusele, arvestades käesoleva lõike esimeses lauses sätestatut erakonna liikme või sidusorganisatsiooni suhtes. 14 (14) Erakond on kohustatud pidama teabe avalikustamiseks veebilehte, mille aadressist ta teavitab registriosakonda. RT I 2014-06-21 8 121062014008 2015-01-01",
      "estleg:definedIn": [
        {
          "@id": "estleg:erakonnaseadus_Par_12"
        }
      ],
      "estleg:sourceAct": "Erakonnaseadus",
      "rdfs:label": "Käesoleva paragrahvi lõike 8 punktis 3 nimetatud majandamiskulud on käesoleva seaduse tähenduses kontori rendi (erakonnaseadus)"
    },
