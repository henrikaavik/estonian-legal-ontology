        }
      ]
    },
    {
      "@id": "estleg:Concept_narkootiliste_ja_psuhhotroopsete_ainete_ning_nende_lahteainete_seadus_lhteained",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "lähteained",
      "skos:definition": "Euroopa Parlamendi ja nõukogu määruse (EÜ) nr 273/2004 narkootikumide lähteainete kohta (ELT L 047, 18.02.2004, lk 1–10) artikli 2 alapunktis a ja nõukogu määruse (EÜ) nr 111/2005, millega kehtestatakse ühenduse ja kolmandate riikide vahelise narkootikumide lähteainetega kauplemise järelevalve eeskirjad (ELT L 022, 26.01.2005, lk 1–10), artikli 2 alapunktis a nimetatud ained",
      "estleg:definedIn": [
        {
          "@id": "estleg:narkootiliste_ja_psuhhotroopsete_ainete_ning_nende_lahteainete_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Narkootiliste ja psühhotroopsete ainete ning nende lähteainete seadus",
      "rdfs:label": "lähteained (narkootiliste_ja_psuhhotroopsete_ainete_ning_nende_lahteainete_seadus)"
    },
    {
      "@id": "estleg:Concept_narkootiliste_ja_psuhhotroopsete_ainete_ning_nende_lahteainete_seadus_kitlemine",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "käitlemine",
      "skos:definition": "narkootiliste või psühhotroopsete ainete või lähteainete omamine, valdamine, vahendamine, tarbimine, kasvatamine, korjamine, valmistamine, tootmine, töötlemine, pakkimine, säilitamine, hoidmine, laadimine, vedu, sisse- ja väljavedu, tolliprotseduuri transiit rakendamine (edaspidi transiit ), tasu eest või tasuta tarnimine kolmandale isikule",
      "estleg:definedIn": [
        {
          "@id": "estleg:narkootiliste_ja_psuhhotroopsete_ainete_ning_nende_lahteainete_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Narkootiliste ja psühhotroopsete ainete ning nende lähteainete seadus",
      "rdfs:label": "käitlemine (narkootiliste_ja_psuhhotroopsete_ainete_ning_nende_lahteainete_seadus)",
      "skos:exactMatch": [
        {
          "@id": "estleg:Concept_narkootiliste_ja_psuhhotroopsete_ainete_seadus_kitlemine"
        },
        {
          "@id": "estleg:Concept_vaarismetalltoodete_seadus_kitlemine"
        }
      ]
    },
    {
