    {
      "@id": "estleg:Concept_euroopa_liidu_uhise_pollumajanduspoliitika_rakendamise_seadus_Pld_kesoleva_seaduse_thenduses_on_htne_maa",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "Põld käesoleva seaduse tähenduses on ühtne maa",
      "skos:definition": "ala, millel kasvatatakse põllumajanduskultuuri või mida kasutatakse püsirohumaana või mis on põllumajanduslikust kasutusest ajutiselt väljas. 4 (4) Põllumassiiv käesoleva seaduse tähenduses on maastikul selgelt eristuvate püsivate objektidega piiristatud ühtne maa-ala, mis koosneb ühest või mitmest põllust ning millel on numberkood. 5 (5) Nõuded ühtse pindalatoetuse saamist taotleva isiku kasutuses oleva põllumajandusmaa ja selle kasutamise kohta kehtestab põllumajandusminister ./dyn=922110&id=848182",
      "estleg:definedIn": [
        {
          "@id": "estleg:euroopa_liidu_uhise_pollumajanduspoliitika_rakendamise_seadus_Par_12"
        }
      ],
      "estleg:sourceAct": "Euroopa Liidu ühise põllumajanduspoliitika rakendamise seadus",
      "rdfs:label": "Põld käesoleva seaduse tähenduses on ühtne maa (euroopa_liidu_uhise_pollumajanduspoliitika_rakendamise_seadus)"
    },
    {
      "@id": "estleg:Concept_euroopa_liidu_uhise_pollumajanduspoliitika_rakendamise_seadus_Puu",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "Puu",
      "skos:definition": "ja köögivilja turukorralduses osalemiseks peab toetust taotlev tootjaorganisatsioon või tootjaorganisatsioonide liit olema tunnustatud. Tunnustamise taotlemiseks esitab isik PRIA-le vormikohase kirjaliku taotluse. Kui taotluse esitab äriühing, siis tootjaorganisatsiooni liikmena käesoleva seaduse tähenduses käsitatakse osanikku või aktsionäri. 2 (2) Tootjaorganisatsiooni ja tootjaorganisatsioonide liidu tunnustamisega seotud otsuseid teeb PRIA. 3 (3) Tunnustamise taotlemise ja taotluse menetlemise nõuded ning korra ja taotluse vormi kehtestab põllumajandusminister ./dyn=922110&id=785649 . 4 (4) Eeltunnustamise ja eeltunnustamise toetamise nõuded, taotlemise korra ning taotluse vormi kehtestab põllumajandusminister ./dyn=922110&id=785649 . RT I 2005 5 16 841205 2005-02-01+02:00",
      "estleg:definedIn": [
        {
          "@id": "estleg:euroopa_liidu_uhise_pollumajanduspoliitika_rakendamise_seadus_Par_36"
        }
      ],
      "estleg:sourceAct": "Euroopa Liidu ühise põllumajanduspoliitika rakendamise seadus",
      "rdfs:label": "Puu (euroopa_liidu_uhise_pollumajanduspoliitika_rakendamise_seadus)"
    },
    {
      "@id": "estleg:Concept_euroopa_liidu_uhise_pollumajanduspoliitika_rakendamise_seadus_impordi",
      "@type": [
        "owl:NamedIndividual",
