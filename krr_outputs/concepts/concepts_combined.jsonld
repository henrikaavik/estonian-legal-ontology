      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "koeproov",
      "skos:definition": "inimeselt geeniuuringuteks võetud rakud, rakkudevaheline aine ja kehavedelikud",
      "estleg:definedIn": [
