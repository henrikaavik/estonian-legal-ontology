    {
      "@id": "estleg:Concept_korruptsioonivastane_seadus_Ametiisikuna_kesoleva_seaduse_mistes_ksitatakse_valla",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "Ametiisikuna käesoleva seaduse mõistes käsitatakse valla",
      "skos:definition": "või linnaametiasutuse juhti ja ametiasutuse hallatava asutuse juhti, kui nii on otsustanud valla- või linnavolikogu. 4 (4) Ametiisikuna käesoleva seaduse mõistes käsitatakse mittetulundusühingu juhatuse liikmeid, kui mittetulundusühingu on asutanud või selles osaleb riik, kohalik omavalitsus või avalik-õiguslik juriidiline isik või kui see on sätestatud mittetulundusühingu tegevust reguleerivas seaduses või põhikirjas või kui sellise otsuse on vastu võtnud pädev mittetulundusühingu juhtorgan.",
      "estleg:definedIn": [
        {
          "@id": "estleg:korruptsioonivastane_seadus_Par_4"
        }
      ],
      "estleg:sourceAct": "Korruptsioonivastane seadus",
      "rdfs:label": "Ametiisikuna käesoleva seaduse mõistes käsitatakse valla (korruptsioonivastane_seadus)"
    },
    {
      "@id": "estleg:Concept_korruptsioonivastane_seadus_kesoleva_like_punktides_1",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "käesoleva lõike punktides 1",
      "skos:definition": "5 märkimata majandusliku või muu kasuna. RT I 2002 53 336 174795 2002-07-01+03:00",
      "estleg:definedIn": [
        {
          "@id": "estleg:korruptsioonivastane_seadus_Par_5"
        }
      ],
      "estleg:sourceAct": "Korruptsioonivastane seadus",
      "rdfs:label": "käesoleva lõike punktides 1 (korruptsioonivastane_seadus)",
      "skos:exactMatch": [
        {
          "@id": "estleg:Concept_sotsiaalmaksuseadus_kesoleva_like_punktides_1"
        }
      ]
    },
    {
      "@id": "estleg:Concept_krediidiandjate_ja_vahendajate_seadus_Kesolevat_seadust_kohaldatakse_Eestis_asutatud_ja_tegutsevale_krediidiandjale_ja",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "Käesolevat seadust kohaldatakse Eestis asutatud ja tegutsevale krediidiandjale ja",
      "skos:definition": "vahendajale, samuti välisriigi krediidiandjale ja -vahendajale ning tema Eestis asuvale filiaalile, kes oma majandus- või kutsetegevuse raames annab või vahendab Eestis tarbijale krediiti. 2 (2) Käesolevas seaduses krediidivahendaja kohta sätestatut kohaldatakse ka sellise isiku suhtes, kes vahendab krediiti, mida annab isik, kes ei tegutse oma majandus- või kutsetegevuses ja ei ole käesoleva seaduse tähenduses krediidiandja. 3 (3) Tarbija käesoleva seaduse tähenduses on võlaõigusseaduse § 1 lõikes 5 nimetatud isik. Kui käesoleva paragrahvi lõikes 2 nimetatud krediidivahendaja vahendab tarbijale krediiti, mida annab osaliselt või täielikult tarbija, kohaldatakse krediidilepingule käesolevas seaduses ja võlaõigusseaduses tarbijakrediidilepingu kohta sätestatut. 4 (4) Käesolevat seadust kohaldatakse Eesti krediidiandja või -vahendaja tegevusele ja filiaalile välisriigis, kui välisriigi õigusaktidest ei tulene teisiti. 5 (5) Käesolevas seaduses sätestatut ei kohaldata: 1 1) riikliku tagatise või ettevõtluse riiklike toetuste andjale",
      "estleg:definedIn": [
        {
          "@id": "estleg:krediidiandjate_ja_vahendajate_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Krediidiandjate ja -vahendajate seadus",
      "rdfs:label": "Käesolevat seadust kohaldatakse Eestis asutatud ja tegutsevale krediidiandjale ja (krediidiandjate_ja_vahendajate_seadus)"
    },
    {
      "@id": "estleg:Concept_krediidiandjate_ja_vahendajate_seadus_Hoiu",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "Hoiu",
      "skos:definition": "laenuühistu, kes annab või vahendab tarbijale krediiti, on krediidiandja või -vahendaja käesoleva seaduse tähenduses ja talle kohaldatakse käesolevas seaduses ning teistes õigusaktides krediidiandja või -vahendaja kohta sätestatut käesolevas seaduses ja hoiu-laenuühistu seaduses ettenähtud erisustega. Käesolevat seadust ei kohaldata hoiu-laenuühistule, kui on täidetud järgmised tingimused: 1 1) mitte ühegi hoiu-laenuühistu sõlmitava või vahendatava krediidilepingu krediidi kulukuse määr ei ületa krediidi andmise ajal Eesti Panga viimati avaldatud viimase kuue kuu keskmist krediidiasutuste poolt eraisikutele antud tarbimislaenude kulukuse määra",
      "estleg:definedIn": [
        {
          "@id": "estleg:krediidiandjate_ja_vahendajate_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Krediidiandjate ja -vahendajate seadus",
      "rdfs:label": "Hoiu (krediidiandjate_ja_vahendajate_seadus)",
      "skos:exactMatch": [
        {
          "@id": "estleg:Concept_krediidiandjate_ja_vahendajate_seadus_hoiu"
        },
        {
          "@id": "estleg:Concept_rahapesu_ja_terrorismi_rahastamise_tokestamise_seadus_hoiu"
        }
      ]
    },
    {
      "@id": "estleg:Concept_krediidiandjate_ja_vahendajate_seadus_hoiu",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "hoiu",
      "skos:definition": "laenuühistu liikmete arv on väiksem kui 3000. 7 (7) Käesolevat seadust ei kohaldata krediidiasutusele ja välisriigi krediidiasutuse filiaalile Eestis, kui krediidiasutuste seaduses ei ole sätestatud teisiti. Käesolevas seaduses krediidiasutuse kohta sätestatu laieneb ka välisriigi krediidiasutuse filiaalile Eestis. 8 (8) Krediidiandja ja -vahendaja suhtes, välja arvatud käesoleva seaduse § 5 lõike 3 või § 6 lõike 2 tähenduses elamukinnisvaraga seotud tarbijakrediiti andva või vahendava isiku või käesoleva seaduse § 7 tähenduses nõustamisteenust osutava isiku suhtes, kohaldatakse üksnes käesoleva seaduse §-des 20, 38, 40 ja 43, § 44 lõigetes 2 ja 3 ning §-des 46–53, 57 ja 58 sätestatut, kui täidetud on kõik järgmised tingimused: RT I 2016-03-11 1 111032016001 2016-03-21 1 1) krediidiandja või -vahendaja emaettevõtja on Euroopa Majanduspiirkonna lepinguriigis (edaspidi lepinguriik ) asutatud krediidiasutus",
      "estleg:definedIn": [
        {
          "@id": "estleg:krediidiandjate_ja_vahendajate_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Krediidiandjate ja -vahendajate seadus",
      "rdfs:label": "hoiu (krediidiandjate_ja_vahendajate_seadus)",
      "skos:exactMatch": [
        {
          "@id": "estleg:Concept_rahapesu_ja_terrorismi_rahastamise_tokestamise_seadus_hoiu"
        }
      ]
    },
    {
      "@id": "estleg:Concept_krediidiandjate_ja_vahendajate_seadus_krediidiandja_vi",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "krediidiandja või",
      "skos:definition": "vahendaja on käesoleva lõike punktis 1 nimetatud krediidiasutuse kontrollitav äriühing väärtpaberituru seaduse § 10 tähenduses ja see krediidiandja või -vahendaja kuulub Finantsinspektsiooni või teise lepinguriigi finantsjärelevalve asutuse konsolideeritud järelevalve alla. 9 (9) Käesolevat seadust ei kohaldata ettevõtjale, kes oma majandus- või kutsetegevuses müüb tarbijale eseme või osutab teenust ja selle tegevuse kõrvaltegevusena võimaldab tarbijale tasulist maksetähtpäeva edasilükkamist ning loovutab sellest lepingust tuleneva rahalise nõude vastavalt võlaõigusseaduse §-s 256 nimetatud faktooringulepingule teisele isikule (edaspidi faktoor ) või vahendab tarbijale krediiti, kui täidetud on kõik järgmised tingimused: 1 1) faktoor või krediidiandja, kelle krediiti ettevõtja vahendab, on krediidiasutus või tal on tegevusluba krediidiandjana tegutsemiseks või ta tegutseb krediidiandjana käesoleva paragrahvi lõike 8 kohaselt",
      "estleg:definedIn": [
        {
          "@id": "estleg:krediidiandjate_ja_vahendajate_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Krediidiandjate ja -vahendajate seadus",
      "rdfs:label": "krediidiandja või (krediidiandjate_ja_vahendajate_seadus)"
    },
    {
      "@id": "estleg:Concept_krediidiandjate_ja_vahendajate_seadus_Kesolevat_seadust_ei_kohaldata_makseasutusele_ja_e",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "Käesolevat seadust ei kohaldata makseasutusele ja e",
      "skos:definition": "raha asutusele, kui makseasutuste ja e-raha asutuste seaduses ei ole sätestatud teisiti. 11 (11) Käesolevas seaduses krediidi andmise või krediidi vahendamise kohta sätestatut ei kohaldata: 1 1) võlaõigusseaduse § 403 lõikes 3 nimetatud krediidilepingutele ja krediidivahenduslepingutele",
      "estleg:definedIn": [
        {
          "@id": "estleg:krediidiandjate_ja_vahendajate_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Krediidiandjate ja -vahendajate seadus",
      "rdfs:label": "Käesolevat seadust ei kohaldata makseasutusele ja e (krediidiandjate_ja_vahendajate_seadus)"
    },
    {
      "@id": "estleg:Concept_krediidiandjate_ja_vahendajate_seadus_Teenuse_osutamine_kesoleva_seaduse_thenduses_hlmab_krediidi",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "Teenuse osutamine käesoleva seaduse tähenduses hõlmab krediidi",
      "skos:definition": "ja liisingutehingut, tasulist maksetähtpäeva edasilükkamise ning muud finantseerimise tehingut ehk krediidi andmist, krediidi vahendamist ning nõustamisteenuse osutamist. 13 (13) Käesolevas seaduses krediidiandja või -vahendaja aktsionäri, aktsiakapitali ja aktsia kohta sätestatut kohaldatakse ka krediidiandja või -vahendaja osanikule, osakapitalile ja osale.",
      "estleg:definedIn": [
        {
          "@id": "estleg:krediidiandjate_ja_vahendajate_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Krediidiandjate ja -vahendajate seadus",
      "rdfs:label": "Teenuse osutamine käesoleva seaduse tähenduses hõlmab krediidi (krediidiandjate_ja_vahendajate_seadus)"
    },
    {
      "@id": "estleg:Concept_krediidiandjate_ja_vahendajate_seadus_Oluline_osalus_kesoleva_seaduse_thenduses_on_otsene_vi_kaudne_osalus_krediidiand",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "Oluline osalus käesoleva seaduse tähenduses on otsene või kaudne osalus krediidiandja aktsia",
      "skos:definition": "või osakapitalis, mis on vähemalt 20 protsenti äriühingu aktsia- või osakapitalist, seda väljendavatest kõigist õigustest või kõigist häältest äriühingus, või osalus, mis võimaldab saavutada olulise mõju äriühingu juhtorganite üle. 2 (2) Osalus on otsene, kui isik omab või teostab seda isiklikult. 3 (3) Osalus on kaudne, kui: 1 1) seda omab või teostab isik koos ühe või mitme kontrollitava äriühinguga",
      "estleg:definedIn": [
        {
          "@id": "estleg:krediidiandjate_ja_vahendajate_seadus_Par_28"
        }
      ],
      "estleg:sourceAct": "Krediidiandjate ja -vahendajate seadus",
      "rdfs:label": "Oluline osalus käesoleva seaduse tähenduses on otsene või kaudne osalus krediidiandja aktsia (krediidiandjate_ja_vahendajate_seadus)"
    },
    {
      "@id": "estleg:Concept_krediidiandjate_ja_vahendajate_seadus_Kesolevas_peatkis_aktsiakapitali_ja_aktsiate_suhtes_stestatut_kohaldatakse_ka_os",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "Käesolevas peatükis aktsiakapitali ja aktsiate suhtes sätestatut kohaldatakse ka osakapitali ja osade kohta ning hoiu",
      "skos:definition": "laenuühistu liikme osamaksu kohta. Käesolevas peatükis aktsionäri kohta sätestatut kohaldatakse ka osaniku või ühistu liikme kohta. 5 (5) Olulise osaluse ja kontrollitava äriühingu kindlaksmääramisel lähtutakse Euroopa Parlamendi ja nõukogu määruse (EL) nr 575/2013 krediidiasutuste ja investeerimisühingute suhtes kohaldatavate usaldatavusnõuete kohta ja määruse (EL) nr 648/2012 muutmise kohta (ELT L 176, 27.06.2013, lk 1–337) artikli 4 lõike 1 punktides 35–38 sätestatust.",
      "estleg:definedIn": [
        {
          "@id": "estleg:krediidiandjate_ja_vahendajate_seadus_Par_28"
        }
      ],
      "estleg:sourceAct": "Krediidiandjate ja -vahendajate seadus",
      "rdfs:label": "Käesolevas peatükis aktsiakapitali ja aktsiate suhtes sätestatut kohaldatakse ka osakapitali ja osade kohta ning hoiu (krediidiandjate_ja_vahendajate_seadus)"
    },
    {
      "@id": "estleg:Concept_krediidiandjate_ja_vahendajate_seadus_Krediidiandja_vi",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "Krediidiandja või",
      "skos:definition": "vahendaja juhid ja töötajad peavad tegutsema nende puhul eeldatava ettenägelikkuse ja hoolsusega ning vastavalt nende ametikohale esitatavatele nõuetele, seades krediidiandja või -vahendaja ning tarbijate majanduslikud huvid kõrgemale oma isiklikest majanduslikest huvidest. 2 (2) Arvestades ameti- või töökohaga seotud ülesandeid ja vastutust peavad krediidiandja või -vahendaja juhtidel ja töötajatel olema teenuse osutamiseks vajalikud teadmised, oskused ja kogemused, mis on seotud järgmisega: 1 1) pakutavate krediidilepingute ja osutatavate teenuste tundmine",
      "estleg:definedIn": [
        {
          "@id": "estleg:krediidiandjate_ja_vahendajate_seadus_Par_40"
        }
      ],
      "estleg:sourceAct": "Krediidiandjate ja -vahendajate seadus",
      "rdfs:label": "Krediidiandja või (krediidiandjate_ja_vahendajate_seadus)"
    },
    {
      "@id": "estleg:Concept_krediidiandjate_ja_vahendajate_seadus_Krediidiandja_vi_3",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "Krediidiandja või",
      "skos:definition": "vahendaja määrab käesoleva seaduse §-s 44 nimetatud sise-eeskirjas juhtide ja töötajate teadmiste, oskuste ja kogemuste taseme, mis on vajalik krediidiandja või -vahendaja organisatsioonis ameti- või töökohtadel ülesannete täitmiseks. Teadmiste ja pädevuse taseme määramisel arvestatakse ameti- või töökohaga seotud ülesannete täitmiseks vajalikku kvalifikatsiooni ja ametialast kogemust. 4 (4) Töötaja käesoleva seaduse tähenduses on krediidiandja või -vahendaja heaks töölepingu või muu võlaõigusliku lepingu alusel tööd tegev füüsiline isik: 1 1) kelle tööülesannete hulka kuuluvad krediidi andmise või krediidi vahendamisega seotud tegevused, sealhulgas tarbija krediidivõimelisuse hindamise eest vastutamine, samuti nõustamisteenuse või muu krediidi andmise või krediidi vahendamisega seotud teenuse osutamisega seotud tegevused",
      "estleg:definedIn": [
        {
          "@id": "estleg:krediidiandjate_ja_vahendajate_seadus_Par_40"
        }
      ],
      "estleg:sourceAct": "Krediidiandjate ja -vahendajate seadus",
      "rdfs:label": "Krediidiandja või (krediidiandjate_ja_vahendajate_seadus)"
    },
    {
      "@id": "estleg:Concept_krediidiandjate_ja_vahendajate_seadus_Nuded_krediidiandja_vi",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "Nõuded krediidiandja või",
      "skos:definition": "vahendaja juhtide ja töötajate erialastele teadmistele, oskustele ning kogemustele võib kehtestada valdkonna eest vastutav minister ./dyn=120042017008&id=122112016023 määrusega. 2015-02-18 RT I 2015-03-19 4 119032015004 2016-03-21",
      "estleg:definedIn": [
        {
          "@id": "estleg:krediidiandjate_ja_vahendajate_seadus_Par_40"
        }
      ],
      "estleg:sourceAct": "Krediidiandjate ja -vahendajate seadus",
      "rdfs:label": "Nõuded krediidiandja või (krediidiandjate_ja_vahendajate_seadus)"
    },
    {
      "@id": "estleg:Concept_krediidiandjate_ja_vahendajate_seadus_Lisaks_kesolevas_seaduses_stestatule_peab_krediidiandja_vi",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "Lisaks käesolevas seaduses sätestatule peab krediidiandja või",
      "skos:definition": "vahendaja tarbijale krediidi andmisel või krediidi vahendamisel igakülgselt vältima ebaausate kauplemisvõtete kasutamist ja järgima võlaõigusseaduses sätestatud tarbijale piisavate selgituste ja teabe esitamise, tarbija krediidivõimelisuse hindamise ning muid vastutustundliku laenamise nõudeid. 2 (2) Krediidi andmisel või krediidi vahendamisel on krediidiandja või -vahendaja kohustatud tarbija ja samuti tema esindaja isikusamasuse tuvastama ja esitatud teavet kontrollima. 3 (3) Krediidiandja või -vahendaja suhted klientidega reguleeritakse kirjalikus või kirjalikku taasesitamist võimaldavas või elektroonilises vormis sõlmitud lepingutega. Krediidiandja või -vahendaja on kohustatud säilitama andmed tarbija rahaliste kohustuste suuruse ja maksekohustuste täitmise kohta ning kasutama neid andmeid, et hinnata tarbija krediidivõimelisust. RT I 2016-03-11 1 111032016001 2016-03-21 4 (4) Tarbija krediidivõimelisuse hindamine käesoleva seaduse tähenduses on võlaõigusseaduse § 403 4 lõike 1 punktides 1 ja 2 nimetatud tegevus, mille käigus teeb krediidiandja või -vahendaja kindlaks, kas tarbija on võimeline oma kohustusi kokkulepitud tingimustel täitma. RT I 2016-03-11 1 111032016001 2016-03-21 5 (5) Krediidiandja või -vahendaja säilitab kõik krediidi väljastamise ning krediidi teenindamisega seotud käesolevas seaduses nimetatud andmed ja dokumendid, mille alusel tarbijale krediiti antakse või teenust osutatakse, sealhulgas krediiditoimikusse kuuluvad andmed ja dokumendid, muutumatuna ja Finantsinspektsioonile kättesaadavana kogu tarbijaga õigussuhte kestmise aja ning vähemalt kolme aasta jooksul tarbijaga lepingu lõppemisest arvates. 6 (6) Finantsinspektsioonil on õigus nõuda, et pärast krediidiandjale või -vahendajale antud tegevusloa lõppemist peab ta säilitama andmeid käesoleva paragrahvi lõikes 5 sätestatud tähtaja möödumiseni.",
      "estleg:definedIn": [
        {
          "@id": "estleg:krediidiandjate_ja_vahendajate_seadus_Par_47"
        }
      ],
      "estleg:sourceAct": "Krediidiandjate ja -vahendajate seadus",
      "rdfs:label": "Lisaks käesolevas seaduses sätestatule peab krediidiandja või (krediidiandjate_ja_vahendajate_seadus)"
    },
    {
      "@id": "estleg:Concept_krediidiandjate_ja_vahendajate_seadus_Krediidiandja_vi_1",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "Krediidiandja või",
      "skos:definition": "vahendaja peab tarbija krediidivõimelisuse hindamise eesmärgil kogutud vajalike andmete ja dokumentide kohta krediiditoimikut. Krediiditoimikut tuleb pidada iga tarbija kohta eraldi. 2 (2) Krediiditoimik on käesoleva seaduse tähenduses lepingute, õiendite, otsuste, analüüside ja muude krediidi andmise ja teenindamisega seotud dokumentide kogum. 3 (3) Krediidiandja või -vahendaja peab tagama kogu krediidiperioodi jooksul tarbija krediidivõimelisuse analüüsiks vajalike andmete ja dokumentide olemasolu krediiditoimikus. 4 (4) Krediiditoimik peab andma piisavalt informatsiooni krediidi andmise eest vastutavale isikule või struktuuriüksusele, samuti siseaudiitorile ja audiitorile ning Finantsinspektsioonile tarbija krediidivõimelisuse hindamiseks. 5 (5) Krediiditoimik peab sisaldama krediidi andmise, jälgimise ja hindamise kohta vähemalt järgmist teavet ja järgmisi dokumente: 1 1) andmed tarbija kohta, sealhulgas tema nimi, isikukood või selle puudumise korral sünniaeg ja -koht ning elukoht",
      "estleg:definedIn": [
        {
          "@id": "estleg:krediidiandjate_ja_vahendajate_seadus_Par_48"
        }
      ],
      "estleg:sourceAct": "Krediidiandjate ja -vahendajate seadus",
      "rdfs:label": "Krediidiandja või (krediidiandjate_ja_vahendajate_seadus)"
    },
    {
      "@id": "estleg:Concept_krediidiandjate_ja_vahendajate_seadus_tarbijaga_slmitud_krediidi",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "tarbijaga sõlmitud krediidi",
      "skos:definition": "ja tagatislepingud",
      "estleg:definedIn": [
        {
          "@id": "estleg:krediidiandjate_ja_vahendajate_seadus_Par_48"
        }
      ],
      "estleg:sourceAct": "Krediidiandjate ja -vahendajate seadus",
      "rdfs:label": "tarbijaga sõlmitud krediidi (krediidiandjate_ja_vahendajate_seadus)"
    },
    {
      "@id": "estleg:Concept_krediidiandjate_ja_vahendajate_seadus_hpoteekkrediidiandja_vi",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "hüpoteekkrediidiandja või",
      "skos:definition": "vahendaja puhul dokumendid tagatiseks oleva kinnisvara kontrollimise, kindlustamise ja hindamise kohta, sealhulgas kinnisvara hindaja hinnang tagatise maksumuse kohta. 6 (6) Krediiditoimikus sisalduvate õiendite ja dokumentide sisu ja ulatus võivad olla erinevad olenevalt krediidilepingust, tarbijast ja krediidi suurusest. 7 (7) Krediiditoimikus sisalduv informatsioon võib info- ja dokumendihaldussüsteemis paikneda jagatult, kuid krediidiandja või -vahendaja peab tagama selle kättesaadavuse igal ajahetkel.",
      "estleg:definedIn": [
        {
          "@id": "estleg:krediidiandjate_ja_vahendajate_seadus_Par_48"
        }
      ],
      "estleg:sourceAct": "Krediidiandjate ja -vahendajate seadus",
      "rdfs:label": "hüpoteekkrediidiandja või (krediidiandjate_ja_vahendajate_seadus)"
    },
    {
      "@id": "estleg:Concept_krediidiandjate_ja_vahendajate_seadus_Krediidiandja_sise",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "Krediidiandja sise",
      "skos:definition": "eeskirjas peab krediidi andmise kohta olema sätestatud: 1 1) krediidisumma ja krediidi tagatisvara suhe ning krediidi põhiosa ja intressimakse ning tarbija sissetuleku suhe",
      "estleg:definedIn": [
        {
          "@id": "estleg:krediidiandjate_ja_vahendajate_seadus_Par_49"
        }
      ],
      "estleg:sourceAct": "Krediidiandjate ja -vahendajate seadus",
      "rdfs:label": "Krediidiandja sise (krediidiandjate_ja_vahendajate_seadus)"
    },
    {
      "@id": "estleg:Concept_krediidiandjate_ja_vahendajate_seadus_Krediidiandjal_ja",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "Krediidiandjal ja",
      "skos:definition": "vahendajal tuleb käesoleva paragrahvi lõike 1 punktis 1 nimetatud tarbija regulaarse sissetuleku hindamisel: 1 1) arvesse võtta, millised on tarbija sissetulekuallikad, sealhulgas töötasu, pension, investeeringutulu, dividendid, tulud füüsilisest isikust ettevõtja tegevusest, tulud ettevõtlusest, üüritulu, hüvitised, toetused ja elatis, ning milline on tarbija sissetulekute laekumise regulaarsus sõltuvalt tarbija töölepingu või muu lepingu vormist",
      "estleg:definedIn": [
        {
          "@id": "estleg:krediidiandjate_ja_vahendajate_seadus_Par_49"
        }
      ],
      "estleg:sourceAct": "Krediidiandjate ja -vahendajate seadus",
      "rdfs:label": "Krediidiandjal ja (krediidiandjate_ja_vahendajate_seadus)"
    },
    {
      "@id": "estleg:Concept_krediidiandjate_ja_vahendajate_seadus_Krediidiandja_vi_6",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "Krediidiandja või",
      "skos:definition": "vahendaja on kohustatud informeerima tarbijat võimalikest ohtudest krediidi võtmisel. 7 (7) Hüpoteekkrediidiandja või -vahendaja ei tohi tarbija krediidivõimelisuse hindamisel tugineda üksnes asjaolule, et tagatiseks oleva kinnisvara väärtus ületab krediidi summat, või eeldusele, et kinnisvara väärtus tõuseb, välja arvatud juhul, kui krediidilepingu eesmärk on kinnisvara ehitamine või renoveerimine. 8 (8) Miinimumnõuded krediidisumma ja krediidi tagatisvara suhtele ning krediidi põhiosa ja intressimakse ja tarbija sissetuleku suhtele võib kehtestada valdkonna eest vastutav minister ./../vaheleht.html määrusega. Tagatisvara käesoleva seaduse tähenduses on krediidilepingu tagatiseks olev vara.",
      "estleg:definedIn": [
        {
          "@id": "estleg:krediidiandjate_ja_vahendajate_seadus_Par_49"
        }
      ],
      "estleg:sourceAct": "Krediidiandjate ja -vahendajate seadus",
      "rdfs:label": "Krediidiandja või (krediidiandjate_ja_vahendajate_seadus)"
    },
    {
      "@id": "estleg:Concept_krediidiandjate_ja_vahendajate_seadus_Teenuste_osutamisel_Eestis_peab_vlisriigi_krediidiandja_vi",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "Teenuste osutamisel Eestis peab välisriigi krediidiandja või",
      "skos:definition": "vahendaja järgima käesoleva seadusega ja selle alusel tema tegevuse kohta kehtestatud nõudeid ning muid Eesti õigusaktidest tulenevaid nõudeid Eestis tegutsemise kohta. 5 (5) Käesoleva paragrahvi lõikes 2 sätestatut ei kohaldata: 1 1) lepinguriigi hüpoteekkrediidivahendajale, kes vahendab krediidilepinguid, mida pakuvad krediidiandjad, kes ei ole krediidiasutused Euroopa Parlamendi ja nõukogu direktiivi 2013/36/EL, mis käsitleb krediidiasutuste tegevuse alustamise tingimusi ning krediidiasutuste ja investeerimisühingute usaldatavusnõuete täitmise järelevalvet, millega muudetakse direktiivi 2002/87/EÜ ning millega tunnistatakse kehtetuks direktiivid 2006/48/EÜ ja 2006/49/EÜ (ELT L 176, 27.06.2013, lk 338–436), tähenduses ja kellel ei ole Eestis filiaali asutamiseks või piiriüleselt teenuste osutamiseks luba",
      "estleg:definedIn": [
        {
          "@id": "estleg:krediidiandjate_ja_vahendajate_seadus_Par_73"
        }
      ],
      "estleg:sourceAct": "Krediidiandjate ja -vahendajate seadus",
      "rdfs:label": "Teenuste osutamisel Eestis peab välisriigi krediidiandja või (krediidiandjate_ja_vahendajate_seadus)"
    },
    {
