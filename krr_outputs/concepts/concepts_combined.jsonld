        }
      ],
      "estleg:sourceAct": "Aiandustoodete seadus",
      "rdfs:label": "puuvilja (aiandustoodete_seadus)"
    },
    {
      "@id": "estleg:Concept_aiandustoodete_seadus_puuvilja_3",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "puuvilja",
      "skos:definition": ", köögivilja- ja marjakasvatajate ühing",
      "estleg:definedIn": [
        {
          "@id": "estleg:aiandustoodete_seadus_Par_29"
