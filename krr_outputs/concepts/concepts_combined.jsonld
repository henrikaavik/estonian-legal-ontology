      "rdfs:label": "Tehnilise kontrolli teostaja käesoleva seaduse tähenduses on A (majandustegevuse_seadustiku_uldosa_seadus)"
    },
    {
      "@id": "estleg:Concept_majandustegevuse_seadustiku_uldosa_seadus_mte",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "mõõte",
      "skos:definition": "ja teimilaborina tegutsemine",
      "estleg:definedIn": [
        {
          "@id": "estleg:majandustegevuse_seadustiku_uldosa_seadus_Par_83"
        }
      ],
      "estleg:sourceAct": "Majandustegevuse seadustiku üldosa seadus",
