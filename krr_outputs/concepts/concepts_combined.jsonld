    {
      "@id": "estleg:Concept_aiandustoodete_seadus_Kesoleva_paragrahvi_like_1_punktides_3_ja_4_nimetatud_juhtudel_peab_aiandustoote",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "Käesoleva paragrahvi lõike 1 punktides 3 ja 4 nimetatud juhtudel peab aiandustoote kasutamisotstarve kajastuma saate",
      "skos:definition": "või müügidokumentides ja seda toodet ei või kasutada muul otstarbel. 3 (3) Aiandustooteid võib importida või turustada tööstustoormeks töötlemise tõendi alusel. Tõendi väljastab Taimetoodangu Inspektsiooni järelevalveametnik isiku kirjaliku taotluse alusel aiandustoote koguse või partii kohta. Pärast aiandustoote koguse või partii töötlemist peab töötleja täitma tõendis töötlemise kohta ettenähtud osa ja saatma tõendi viie tööpäeva jooksul töötlemise lõpetamisest arvates Taimetoodangu Inspektsioonile tagasi.",
      "estleg:definedIn": [
        {
          "@id": "estleg:aiandustoodete_seadus_Par_12"
        }
      ],
      "estleg:sourceAct": "Aiandustoodete seadus",
      "rdfs:label": "Käesoleva paragrahvi lõike 1 punktides 3 ja 4 nimetatud juhtudel peab aiandustoote kasutamisotstarve kajastuma saate (aiandustoodete_seadus)"
    },
    {
      "@id": "estleg:Concept_aiandustoodete_seadus_puuvilja",
