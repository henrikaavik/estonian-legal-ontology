    {
      "@id": "estleg:Concept_riigisaladuse_ja_salastatud_valisteabe_seadus_riigisaladus",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "riigisaladus",
      "skos:definition": "Eesti Vabariigi julgeoleku või välissuhtlemise tagamise huvides avalikuks tuleku eest kaitset vajav üksnes käesolevas seaduses ja selle alusel antud õigusaktides sätestatud tunnustele vastav teave, välja arvatud salastatud välisteave",
      "estleg:definedIn": [
        {
          "@id": "estleg:riigisaladuse_ja_salastatud_valisteabe_seadus_Par_3"
        }
      ],
      "estleg:sourceAct": "Riigisaladuse ja salastatud välisteabe seadus",
      "rdfs:label": "riigisaladus (riigisaladuse_ja_salastatud_valisteabe_seadus)",
      "skos:exactMatch": [
        {
          "@id": "estleg:Concept_riigisaladuse_seadus_riigisaladus"
        }
      ]
    },
    {
      "@id": "estleg:Concept_riigisaladuse_ja_salastatud_valisteabe_seadus_salastatud_vlisteave",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "salastatud välisteave",
      "skos:definition": "välisriigi, Euroopa Liidu, NATO või mõne muu rahvusvahelise organisatsiooni või rahvusvahelise kokkuleppega loodud institutsiooni (edaspidi koos nimetatud salastatud välisteabe avaldaja ) poolt salastatud ja Eestile avaldatud teave ning Eesti Vabariigi poolt välislepingu täitmiseks loodud teave, mis tuleb salastada välislepingu kohaselt",
      "estleg:definedIn": [
        {
          "@id": "estleg:riigisaladuse_ja_salastatud_valisteabe_seadus_Par_3"
        }
      ],
      "estleg:sourceAct": "Riigisaladuse ja salastatud välisteabe seadus",
      "rdfs:label": "salastatud välisteave (riigisaladuse_ja_salastatud_valisteabe_seadus)"
    },
    {
      "@id": "estleg:Concept_riigisaladuse_ja_salastatud_valisteabe_seadus_salastatud_teabekandja",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "salastatud teabekandja",
      "skos:definition": "mis tahes objekt, millele on jäädvustatud riigisaladus või salastatud välisteave",
