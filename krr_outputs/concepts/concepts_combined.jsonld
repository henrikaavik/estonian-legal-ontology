    },
    {
      "@id": "estleg:Concept_maaelu_ja_pollumajandusturu_korraldamise_seadus_Pllumajandustootja_kesoleva_seaduse_thenduses_on_fsilisest_isikust_ettevtja_vi_j",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "Põllumajandustootja käesoleva seaduse tähenduses on füüsilisest isikust ettevõtja või juriidiline isik või füüsiliste või juriidiliste isikute ühendus või riigi",
      "skos:definition": "ja kohaliku omavalitsuse asutus, kelle põllumajandusettevõte (majandusüksus) asub Eestis ja kelle püsiv tegevus on põllumajandussaaduste tootmine. 2 (2) Põllumajandussaadus käesoleva seaduse tähenduses on asutamislepingu lisas 1 loetletud toode, välja arvatud kalatooted, ja puuvill.",
      "estleg:definedIn": [
