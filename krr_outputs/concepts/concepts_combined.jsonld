        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "narkootilised ja psühhotroopsed ained",
      "skos:definition": "käesoleva seaduse § 3 1 lõike 1 alusel kehtestatud nimekirjas loetletud ained ja nende ainete stereoisomeerid, estrid, eetrid ja soolad ning nimetatud aineid sisaldavad ravimid",
      "estleg:definedIn": [
