    {
      "@id": "estleg:Concept_autorioiguse_seadus_Kodeeritud_programmi_sisaldavate_signaalide_puhul_on_satelliidi_kaudu_teose_edas",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "Kodeeritud programmi sisaldavate signaalide puhul on satelliidi kaudu teose edastamise tingimuseks üldsuse teavitamine dekodeerimisvahendite olemasolust kas televisiooni",
      "skos:definition": "või raadioteenuse osutaja poolt või tema nõusolekul. RT I 2011-01-06 1 106012011001 2011-01-16",
      "estleg:definedIn": [
        {
          "@id": "estleg:autorioiguse_seadus_Par_10"
        }
      ],
      "estleg:sourceAct": "Autoriõiguse seadus",
      "rdfs:label": "Kodeeritud programmi sisaldavate signaalide puhul on satelliidi kaudu teose edastamise tingimuseks üldsuse teavitamine dekodeerimisvahendite olemasolust kas televisiooni (autorioiguse_seadus)"
    },
    {
      "@id": "estleg:Concept_autorioiguse_seadus_kehtetu_3",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "kehtetu",
      "skos:definition": "RT I 1999 97 859 77999 2000-01-06 4 4) tõlkida oma teos (õigus teose tõlkimisele)",
      "estleg:definedIn": [
        {
          "@id": "estleg:autorioiguse_seadus_Par_13"
        }
      ],
      "estleg:sourceAct": "Autoriõiguse seadus",
      "rdfs:label": "kehtetu (autorioiguse_seadus)"
    },
    {
      "@id": "estleg:Concept_autorioiguse_seadus_teostada_oma_disaini",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "teostada oma disaini",
      "skos:definition": ", tarbekunstiteose jms projekt. 2 (2) Kehtetu - RT I 2000 78 497 72346 2000-10-22 3 (3) Rentimine käesoleva seaduse tähenduses on teose, selle koopia või käesolevas seaduses nimetatud muu resultaadi andmine ajutiseks kasutamiseks otsese või kaudse varalise või ärilise kasu saamise eesmärgil. 4 (4) Laenutamine käesoleva seaduse tähenduses on teose, selle koopia või käesolevas seaduses nimetatud muu resultaadi andmine ajutiseks kasutamiseks üldsusele avatud asutuse kaudu otsese või kaudse varalise või ärilise kasu saamise eesmärgita. 5 (5) Andmebaasi koopia esmane müük lõpetab õiguse kontrollida selle andmebaasi koopia edasist müüki. 6 (6) Kehtetu - RT I 2004 71 500 807257 2004-10-29",
      "estleg:definedIn": [
        {
          "@id": "estleg:autorioiguse_seadus_Par_13"
        }
      ],
      "estleg:sourceAct": "Autoriõiguse seadus",
      "rdfs:label": "teostada oma disaini (autorioiguse_seadus)"
    },
    {
      "@id": "estleg:Concept_autoveoseadus_autovedu",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "autovedu",
      "skos:definition": "sõitjate või veose kohaletoimetamine selleks ettenähtud ja kehtestatud korras registreeritud sõidukiga. Autovedu hõlmab ka sõitjate või veoseta sõiduki liikumist",
      "estleg:definedIn": [
        {
          "@id": "estleg:autoveoseadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Autoveoseadus",
      "rdfs:label": "autovedu (autoveoseadus)"
    },
    {
      "@id": "estleg:Concept_autoveoseadus_tasuline_autovedu",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "tasuline autovedu",
      "skos:definition": "sõitjate või veose kohaletoimetamine, mille eest vedaja saab tasu mis tahes vormis",
      "estleg:definedIn": [
        {
          "@id": "estleg:autoveoseadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Autoveoseadus",
