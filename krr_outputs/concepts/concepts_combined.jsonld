      ],
      "skos:prefLabel": "sissetooja",
      "skos:definition": "käesoleva seaduse § 5 lõike 1 punktides 2 ja 3 tähendatud isikud ja asutused. RT I 2005 65 495 966224 2006-06-01+03:00",
