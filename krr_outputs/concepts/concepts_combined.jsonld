      "skos:exactMatch": [
        {
          "@id": "estleg:Concept_maagaasiseadus_vrgupiirkond_on_maa"
        }
      ]
    },
    {
      "@id": "estleg:Concept_keskkonnajarelevalve_seadus_planeeringu",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "planeeringu",
      "skos:definition": ", maakasutuse, maakorralduse ja maa-arvestuse nõuetest kinnipidamise kontrollimine ning seaduses sätestatud abinõude rakendamine nõuetest kinnipidamise tagamiseks",
      "estleg:definedIn": [
        {
          "@id": "estleg:keskkonnajarelevalve_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Keskkonnajärelevalve seadus",
      "rdfs:label": "planeeringu (keskkonnajarelevalve_seadus)"
    },
    {
      "@id": "estleg:Concept_keskkonnajarelevalve_seadus_Loodussaadus_kesoleva_seaduse_thenduses_on_looduslikust_leiu",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "Loodussaadus käesoleva seaduse tähenduses on looduslikust leiu",
      "skos:definition": ", kasvu- või elukohast eemaldatud: 1 1) maavara, vesi, muld, maa-aines, kivistis ja mineraal",
      "estleg:definedIn": [
        {
          "@id": "estleg:keskkonnajarelevalve_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Keskkonnajärelevalve seadus",
      "rdfs:label": "Loodussaadus käesoleva seaduse tähenduses on looduslikust leiu (keskkonnajarelevalve_seadus)"
    },
    {
      "@id": "estleg:Concept_keskkonnajarelevalve_seadus_Riigi_ja_kohaliku_omavalitsuse_keskkonnakaitseinspektoril_on_igus_kontrollida_fs",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "Riigi ja kohaliku omavalitsuse keskkonnakaitseinspektoril on õigus kontrollida füüsilist ning era- ja avalik",
      "skos:definition": "õiguslikku juriidilist isikut, riigiasutust ja omavalitsusorganit või -asutust ning nende tegevuskohta, kui isiku või asutuse tegevus mõjutab või võib mõjutada keskkonda ning ohustab või võib ohustada inimeste elu, tervist või vara või kui isik või asutus varub loodussaadust või varjab või oletatavalt varjab ebaseaduslikult hangitud loodussaadust. 2 (2) Keskkonnakaitseinspektor oma pädevuse piires: 1 1) kontrollib keskkonnakaitse- ja -kasutusalaste õigusaktide nõuetest kinnipidamist",
      "estleg:definedIn": [
        {
          "@id": "estleg:keskkonnajarelevalve_seadus_Par_16"
        }
      ],
      "estleg:sourceAct": "Keskkonnajärelevalve seadus",
      "rdfs:label": "Riigi ja kohaliku omavalitsuse keskkonnakaitseinspektoril on õigus kontrollida füüsilist ning era- ja avalik (keskkonnajarelevalve_seadus)"
    },
    {
      "@id": "estleg:Concept_keskkonnajarelevalve_seadus_peatab_keskkonnakaitse__vi",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "peatab keskkonnakaitse- või",
      "skos:definition": "kasutusalaste nõuetega vastuolus oleva tegevuse ja õiguspärase tegevuse, kui see ohustab inimeste elu, tervist või vara",
      "estleg:definedIn": [
        {
          "@id": "estleg:keskkonnajarelevalve_seadus_Par_16"
        }
      ],
      "estleg:sourceAct": "Keskkonnajärelevalve seadus",
      "rdfs:label": "peatab keskkonnakaitse- või (keskkonnajarelevalve_seadus)"
    },
    {
      "@id": "estleg:Concept_keskkonnajarelevalve_seadus_Kella_6_st_hommikul_kuni_kella_22",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "Kella 6-st hommikul kuni kella 22",
      "skos:definition": "ni õhtul (edaspidi päevane aeg ), on keskkonnakaitseinspektoril koos temaga kaasas olevate isikutega käesoleva paragrahvi lõikes 2 nimetatud eesmärgil õigus minna tegevuskohta, kui on alust arvata, et seal: 1 1) toimub loodussaaduste varumine, töötlemine ja hoidmine",
      "estleg:definedIn": [
        {
          "@id": "estleg:keskkonnajarelevalve_seadus_Par_16"
        }
      ],
      "estleg:sourceAct": "Keskkonnajärelevalve seadus",
      "rdfs:label": "Kella 6-st hommikul kuni kella 22 (keskkonnajarelevalve_seadus)"
    },
    {
      "@id": "estleg:Concept_keskkonnajarelevalve_seadus_Kella_22_st_htul_kuni_kella_6",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "Kella 22-st õhtul kuni kella 6",
      "skos:definition": "ni hommikul (edaspidi öine aeg ), on keskkonnakaitseinspektoril koos temaga kaasas olevate isikutega käesoleva paragrahvi lõikes 2 nimetatud eesmärgil õigus kontrollida sel ajal töötavat ettevõtet või käsilolevat loodussaaduse varumist, nagu kalapüük, jaht, puude raie, samaselt päevasel ajal toimuva kontrollimisega. Muul juhul on õigus minna öisel ajal tegevuskohta ainult riigi ja kohaliku omavalitsuse keskkonnakaitseinspektoril ja temaga kaasas olevatel isikutel, kui on alust arvata, et: 1 1) seal paiknevad ebaseaduslikult hangitud loodussaadused",
      "estleg:definedIn": [
        {
          "@id": "estleg:keskkonnajarelevalve_seadus_Par_16"
        }
      ],
      "estleg:sourceAct": "Keskkonnajärelevalve seadus",
      "rdfs:label": "Kella 22-st õhtul kuni kella 6 (keskkonnajarelevalve_seadus)"
    },
    {
      "@id": "estleg:Concept_keskkonnajarelevalve_seadus_Keskkonnakaitseinspektoril_on_igus_jrelevalve_teostamise_eesmrgil_viibida_ning_l",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "Keskkonnakaitseinspektoril on õigus järelevalve teostamise eesmärgil viibida ning liikuda sõidukiga või ujuvvahendiga maa",
      "skos:definition": "või veealal, kus on looduskaitseseaduse ( RT I 2004, 38, 258 ./745306 ) alusel kehtestatud liikumispiirangud. RT I 2005 57 451 955779 2005-11-18+02:00",
      "estleg:definedIn": [
        {
          "@id": "estleg:keskkonnajarelevalve_seadus_Par_16"
        }
      ],
