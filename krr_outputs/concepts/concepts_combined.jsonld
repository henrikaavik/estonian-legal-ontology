        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "käitlemine",
      "skos:definition": "väärismetalltoodete valmistamine, sissevedu, müügiks pakkumine ja tasu eest võõrandamine",
      "estleg:definedIn": [
