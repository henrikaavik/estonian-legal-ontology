    {
      "@id": "estleg:Concept_narkootiliste_ja_psuhhotroopsete_ainete_ning_nende_lahteainete_seadus_kitlemiseks_vajalikud_load",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "käitlemiseks vajalikud load",
      "skos:definition": "Sotsiaalministeeriumi või Ravimiameti poolt antavad ühekordsed kindlaks määratud kehtivusajaga tegevusload tootjatele, apteekidele, hulgimüüjatele, teadusasutustele ja muudele asutustele, lähteainete käitlejatele, sisse- ja väljaveoload ning impordi- ja ekspordiload, samuti jälitusasutuse poolt antavad load käesoleva seaduse §-s 5 viidatud juhtudel",
      "estleg:definedIn": [
        {
          "@id": "estleg:narkootiliste_ja_psuhhotroopsete_ainete_ning_nende_lahteainete_seadus_Par_2"
        }
