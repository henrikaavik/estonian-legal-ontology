      "skos:closeMatch": [
        {
          "@id": "estleg:Concept_riikliku_statistika_seadus_Teadus"
        }
      ]
    },
    {
      "@id": "estleg:Concept_reklaamiseadus_vlireklaam",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "välireklaam",
      "skos:definition": "avalikus kohas asuv või avalikust kohast jälgitav reklaam. 2 (2) Reklaamina ei käsitata: 1 1) majandus- või kutsetegevuse kohas, kus müüakse kaupa või osutatakse teenust, antavat teavet kauba, teenuse või selle müügitingimuste kohta, ning käesoleva lõike punktis 2 nimetatud teavet",
      "estleg:definedIn": [
        {
          "@id": "estleg:reklaamiseadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Reklaamiseadus",
      "rdfs:label": "välireklaam (reklaamiseadus)"
    },
    {
      "@id": "estleg:Concept_reklaamiseadus_majandus",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "majandus",
      "skos:definition": "või kutsetegevuse koha tähistust selle nime, liigi, kauba müügi või teenuse osutamise aja, isiku nime, kaubamärgi ja domeeninimega ehitisel, kus majandus- või kutsetegevuse koht asub, ja majandus- või kutsetegevuse koha sissepääsu juures",
      "estleg:definedIn": [
        {
          "@id": "estleg:reklaamiseadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Reklaamiseadus",
      "rdfs:label": "majandus (reklaamiseadus)",
      "skos:exactMatch": [
