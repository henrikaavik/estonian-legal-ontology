    },
    {
      "@id": "estleg:Concept_inimgeeniuuringute_seadus_geenidoonor",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "geenidoonor",
      "skos:definition": "inimene, kes annab käesoleva seaduse alusel oma koeproovi ja kelle kohta koostatakse terviseseisundi kirjeldus ning sugupuu",
      "estleg:definedIn": [
        {
          "@id": "estleg:inimgeeniuuringute_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Inimgeeniuuringute seadus",
      "rdfs:label": "geenidoonor (inimgeeniuuringute_seadus)"
    },
    {
      "@id": "estleg:Concept_inimgeeniuuringute_seadus_terviseseisundi_kirjeldus",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "terviseseisundi kirjeldus",
      "skos:definition": "geeniuuringutes kasutamiseks kogutud andmed, mis kajastavad geenidoonori tervislikku seisundit, põetud haigusi ja nende ravi, eluviisi, elukeskkonda ja pärilikke omadusi",
      "estleg:definedIn": [
        {
          "@id": "estleg:inimgeeniuuringute_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Inimgeeniuuringute seadus",
      "rdfs:label": "terviseseisundi kirjeldus (inimgeeniuuringute_seadus)"
    },
    {
      "@id": "estleg:Concept_inimgeeniuuringute_seadus_sugupuu",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "sugupuu",
      "skos:definition": "geenivaramus olev teave geenidoonori ülenejate ja alanejate sugulaste nime, sünniaja ja suguluse kohta",
      "estleg:definedIn": [
        {
          "@id": "estleg:inimgeeniuuringute_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Inimgeeniuuringute seadus",
      "rdfs:label": "sugupuu (inimgeeniuuringute_seadus)"
    },
    {
      "@id": "estleg:Concept_inimgeeniuuringute_seadus_geeniuuring",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "geeniuuring",
      "skos:definition": "DNA, koeproovi teiste koostisosade, terviseseisundi kirjelduste ja sugupuude teaduslik uurimine, kirjeldamine ja nendevaheliste seoste kindlakstegemine eesmärgiga saada andmeid inimese geenide, geeniproduktide ja pärilike omaduste kohta",
      "estleg:definedIn": [
        {
          "@id": "estleg:inimgeeniuuringute_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Inimgeeniuuringute seadus",
      "rdfs:label": "geeniuuring (inimgeeniuuringute_seadus)",
      "skos:closeMatch": [
        {
          "@id": "estleg:Concept_inimgeeniuuringute_seadus_geeniuurija"
        }
      ]
    },
    {
      "@id": "estleg:Concept_inimgeeniuuringute_seadus_geeniuurija",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "geeniuurija",
      "skos:definition": "füüsiline või juriidiline isik või riigi- või kohaliku omavalitsuse asutus, kes teostab geeniuuringuid",
      "estleg:definedIn": [
        {
          "@id": "estleg:inimgeeniuuringute_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Inimgeeniuuringute seadus",
      "rdfs:label": "geeniuurija (inimgeeniuuringute_seadus)"
    },
    {
      "@id": "estleg:Concept_inimgeeniuuringute_seadus_geeniandmed",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "geeniandmed",
      "skos:definition": "teave, mida saadakse geeniuuringute tulemusena inimese geenide, geeniproduktide või pärilike omaduste kohta, sealhulgas DNA või selle osa kirjeldus",
      "estleg:definedIn": [
        {
          "@id": "estleg:inimgeeniuuringute_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Inimgeeniuuringute seadus",
      "rdfs:label": "geeniandmed (inimgeeniuuringute_seadus)"
    },
    {
      "@id": "estleg:Concept_inimgeeniuuringute_seadus_geenivaramu",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "geenivaramu",
      "skos:definition": "koeproovide, DNA kirjelduste, terviseseisundi kirjelduste, sugupuude, geeniandmete ja geenidoonori isiku tuvastamist võimaldavate andmete kogu, mille loob ja mida peab vastutav töötleja",
      "estleg:definedIn": [
        {
          "@id": "estleg:inimgeeniuuringute_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Inimgeeniuuringute seadus",
      "rdfs:label": "geenivaramu (inimgeeniuuringute_seadus)"
    },
    {
      "@id": "estleg:Concept_inimgeeniuuringute_seadus_kodeerimine",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "kodeerimine",
      "skos:definition": "koeproovi, DNA kirjelduse, terviseseisundi kirjelduse ja sugupuu juures isiku tuvastamist võimaldavate andmete asendamine kordumatu tunnuskoodiga",
      "estleg:definedIn": [
        {
          "@id": "estleg:inimgeeniuuringute_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Inimgeeniuuringute seadus",
      "rdfs:label": "kodeerimine (inimgeeniuuringute_seadus)"
    },
    {
      "@id": "estleg:Concept_inimgeeniuuringute_seadus_tagasikodeerimine",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "tagasikodeerimine",
      "skos:definition": "koeproovile, DNA kirjeldusele, terviseseisundi kirjeldusele ja sugupuule antud kordumatu tunnuskoodi abil geenidoonori isiku tuvastamine või geenidoonori isikust lähtuvalt tema koeproovi, DNA kirjelduse või terviseseisundi kirjelduse tuvastamine.",
      "estleg:definedIn": [
        {
          "@id": "estleg:inimgeeniuuringute_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Inimgeeniuuringute seadus",
      "rdfs:label": "tagasikodeerimine (inimgeeniuuringute_seadus)"
    },
    {
      "@id": "estleg:Concept_isikut_toendavate_dokumentide_seadus_Haldusorgan_vib_isikut_tendava_dokumendi_vljaandmise_ja_kehtetuks_tunnistamise_m",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "Haldusorgan võib isikut tõendava dokumendi väljaandmise ja kehtetuks tunnistamise menetlustes ning e",
      "skos:definition": "residendi digitaalse isikutunnistuse väljaandmise, kehtivuse peatamise ja kehtetuks tunnistamise menetluses tähtsust omavate asjaolude väljaselgitamiseks ja kontrollimiseks edastada isikuandmeid kolmandatele isikutele. Kolmandad isikud võivad töödelda neile edastatud isikuandmeid ulatuses, mis on vajalik menetluses tähtsust omavate asjaolude väljaselgitamiseks. RT I 2019-03-13 2 113032019002 2019-03-15 9 (9) Isikut tõendava dokumendi väljaandmise ja kehtetuks tunnistamise menetluste läbiviimisel ning e-residendi digitaalse isikutunnistuse väljaandmise, kehtivuse peatamise ja kehtetuks tunnistamise menetluse läbiviimisel on haldusorganil õigus koguda andmeid menetluses tähtsust omada võivate asjaolude kohta andmekogudest, teistelt avalik-õiguslikke ülesandeid täitvatelt asutustelt ja isikutelt ning eraõiguslikelt isikutelt. Nimetatud isikutel ja asutustel on kohustus need andmed haldusorganile edastada ja haldusorganil on õigus neid andmeid töödelda. RT I 2019-03-13 2 113032019002 2019-03-15",
      "estleg:definedIn": [
        {
          "@id": "estleg:isikut_toendavate_dokumentide_seadus_Par_9"
        }
      ],
