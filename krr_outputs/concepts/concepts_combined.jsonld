      ]
    },
    {
      "@id": "estleg:Concept_riigisaladuse_ja_salastatud_valisteabe_seadus_teabevaldaja",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "teabevaldaja",
      "skos:definition": "asutus, põhiseaduslik institutsioon või juriidiline või füüsiline isik, kelle valduses on riigisaladus või salastatud välisteave",
      "estleg:definedIn": [
