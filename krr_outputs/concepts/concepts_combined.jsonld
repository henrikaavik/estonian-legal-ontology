    },
    {
      "@id": "estleg:Concept_riigisaladuse_seadus_elektrooniline_teabeturve",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "elektrooniline teabeturve",
      "skos:definition": "teabe (riigisaladuse) käideldavuse, salajasuse ja terviklikkuse olemasolu tagamine riigisaladuse automatiseeritud infotöötlussüsteemides. RT I 2003 23 147 263037 2003-04-01+03:00",
      "estleg:definedIn": [
