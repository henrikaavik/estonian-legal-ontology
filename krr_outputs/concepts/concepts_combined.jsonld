    {
      "@id": "estleg:Concept_elektriohutusseadus_Tehnilise_kontrolli_teostajad_jaotatakse_kesoleva_seaduse_thenduses_A",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "Tehnilise kontrolli teostajad jaotatakse käesoleva seaduse tähenduses A",
      "skos:definition": ", B- või C-tüüpi inspekteerimisasutuste kriteeriumidele vastavateks, lähtudes Eesti standardi EVS-EN 45004:1997 lisas toodud sõltumatuse kriteeriumidest. 3 (3) Esimese liigi elektripaigaldiste tehnilist kontrolli võib teostada A-tüüpi inspekteerimisasutuste kriteeriumidele vastav tehnilise kontrolli teostaja. 4 (4) Teise liigi elektripaigaldiste tehnilist kontrolli võib teostada A-, B- või C-tüüpi inspekteerimisasutuste kriteeriumidele vastav tehnilise kontrolli teostaja. 5 (5) Kolmanda liigi elektripaigaldise tehnilist kontrolli võib teostada käesoleva paragrahvi lõike 2 nõuetele vastav tehnilise kontrolli teostaja, samuti elektritöö ettevõtja. RT I 2002 110 659 234208 2002-12-31+02:00",
      "estleg:definedIn": [
        {
          "@id": "estleg:elektriohutusseadus_Par_25"
        }
      ],
      "estleg:sourceAct": "Elektriohutusseadus",
      "rdfs:label": "Tehnilise kontrolli teostajad jaotatakse käesoleva seaduse tähenduses A (elektriohutusseadus)"
    },
