    {
      "@id": "estleg:Concept_valisriigi_kutsekvalifikatsiooni_tunnustamise_seadus_tkogemus_peab_olema_omandatud_asjaomasel_kutse__vi_erialal_tegeliku_ja_seaduslik",
      "@type": [
        "owl:NamedIndividual",
