    {
      "@id": "estleg:Concept_riigihangete_seadus_hisveevrgi_ja",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "ühisveevärgi ja",
      "skos:definition": "kanalisatsiooni käitamine eesmärgiga pakkuda avalikkusele joogivee tootmise, transpordi või jaotamisega seotud teenust, 2 2) joogivee tarnimine sellisesse ühisveevärki ja 3 3) vesiehitusprojektid, maaniisutus või -kuivendustööd, kui nimetatud projektide, niisutus- või kuivendustööde käigus saadava vee kogumahust rohkem kui 20 protsenti kasutatakse joogivee tarneks või 4 4) reovee ärajuhtimine, puhastus ja töötlemine. 2 (2) Kui hankija, välja arvatud käesoleva seaduse § 10 lõike 1 punktis 1 nimetatud hankija, varustab üldkasutatavat teenust osutavat veevärki joogiveega, ei loeta seda käesoleva paragrahvi lõikes 1 nimetatud tegevuseks, kui: 1 1) hankija toodab joogivett seetõttu, et selle joogivee kasutamine on talle vajalik muu kui käesoleva seaduse §-des 83–84, 86–89 või käesolevas paragrahvis nimetatud tegevusteks ja 2 2) üldkasutatava ühisveevärgi varustamine sõltub ainult hankija omatarbimise mahust ega ole ületanud 30 protsenti hankija summaarsest joogivee tootmisest, võttes arvesse tema kolme viimase aasta keskmist joogivee toodangut.",
      "estleg:definedIn": [
        {
          "@id": "estleg:riigihangete_seadus_Par_85"
        }
      ],
      "estleg:sourceAct": "Riigihangete seadus",
      "rdfs:label": "ühisveevärgi ja (riigihangete_seadus)",
      "skos:exactMatch": [
        {
          "@id": "estleg:Concept_uhisveevargi_ja_kanalisatsiooni_seadus_hisveevrgi_ja"
        }
      ]
    },
    {
      "@id": "estleg:Concept_riigikaitseseadus_Riigikaitseline_tkohustus_on_t",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "Riigikaitseline töökohustus on töö",
      "skos:definition": "või teenistussuhtest tulenev töökohustus, mis on vahetult seotud riigikaitseülesannete, sisejulgeoleku ja põhiseadusliku korra või elutähtsa teenuse toimepidevuse tagamisega. 5 (5) Sundtöökohustus on ühekordne töö- või teenistussuhteväline ametiasutuse avaliku võimu teostamise toetamine kõrgendatud kaitsevalmiduse või sõjaseisukorra ajal. Sundtöökohustust ei või rakendada tööandja ja töötaja vahelisest või sellele sarnanevast suhtest tulenevale tööle. Sundtöökohustuse panemise eelduseks ei ole erialase väljaõppe või hariduse omamine.",
      "estleg:definedIn": [
        {
          "@id": "estleg:riigikaitseseadus_Par_44"
        }
      ],
      "estleg:sourceAct": "Riigikaitseseadus",
      "rdfs:label": "Riigikaitseline töökohustus on töö (riigikaitseseadus)"
    },
