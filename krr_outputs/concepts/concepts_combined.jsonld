    {
      "@id": "estleg:Concept_surveseadme_ohutuse_seadus_I_liik",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "I liik",
      "skos:definition": "surveseadmed, milles on ette nähtud suurema kui 0,5-baarise sisemise töörõhu tekkimine ja millele kohaldatakse Euroopa Parlamendi ja Euroopa Liidu Nõukogu 1997. aasta 29. mai direktiivi 97/23/EÜ surveseadmeid käsitlevate liikmesriikide õigusaktide ühtlustamise kohta (EÜT L 181, 9.07.1997, lk 1)",
      "estleg:definedIn": [
        {
          "@id": "estleg:surveseadme_ohutuse_seadus_Par_5"
        }
