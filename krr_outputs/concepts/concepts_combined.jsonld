    {
      "@id": "estleg:Concept_alkoholi_tubaka_kutuse_ja_elektriaktsiisi_seadus_Vahetoode_kesoleva_seaduse_mistes_on_kesoleva_paragrahvi_ligetes_2",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "Vahetoode käesoleva seaduse mõistes on käesoleva paragrahvi lõigetes 2",
      "skos:definition": "4 nimetamata toode, mille etanoolisisaldus on üle 1,2 mahuprotsendi kuni 22 (kaasa arvatud) mahuprotsenti ja mille KNi esimesed neli numbrit on 2204, 2205 või 2206. 6 (6) Muu alkohol käesoleva seaduse mõistes on toode, mille etanoolisisaldus: 1 1) on üle 1,2 mahuprotsendi ja mille KNi esimesed neli numbrit on 2207 või 2208",
      "estleg:definedIn": [
        {
          "@id": "estleg:alkoholi_tubaka_kutuse_ja_elektriaktsiisi_seadus_Par_12"
        }
      ],
      "estleg:sourceAct": "Alkoholi-, tubaka-, kütuse- ja elektriaktsiisi seadus",
      "rdfs:label": "Vahetoode käesoleva seaduse mõistes on käesoleva paragrahvi lõigetes 2 (alkoholi_tubaka_kutuse_ja_elektriaktsiisi_seadus)"
    },
