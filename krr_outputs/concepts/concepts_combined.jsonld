      "rdfs:label": "ettemakstud preemiate eraldis (kindlustustegevuse_seadus)"
    },
    {
      "@id": "estleg:Concept_kindlustustegevuse_seadus_rahuldamata_nuete_eraldis",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "rahuldamata nõuete eraldis",
      "skos:definition": "toimunud kindlustusjuhtumitest ja teadaolevatest asjaoludest tõenäoliselt tulenevate kohustuste hinnanguline suurus",
      "estleg:definedIn": [
        {
          "@id": "estleg:kindlustustegevuse_seadus_Par_75"
        }
      ],
      "estleg:sourceAct": "Kindlustustegevuse seadus",
      "rdfs:label": "rahuldamata nõuete eraldis (kindlustustegevuse_seadus)"
    },
    {
      "@id": "estleg:Concept_kindlustustegevuse_seadus_elukindlustuse_eraldis",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "elukindlustuse eraldis",
      "skos:definition": "elukindlustuslepingutest tulenevate kohustuste nüüdisväärtus. Elukindlustuse eraldisse ei kuulu toimunud kindlustusjuhtumitest tulenevad kohustused",
      "estleg:definedIn": [
        {
          "@id": "estleg:kindlustustegevuse_seadus_Par_75"
        }
      ],
      "estleg:sourceAct": "Kindlustustegevuse seadus",
      "rdfs:label": "elukindlustuse eraldis (kindlustustegevuse_seadus)"
    },
    {
      "@id": "estleg:Concept_kindlustustegevuse_seadus_boonuste_eraldis",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "boonuste eraldis",
      "skos:definition": "elukindlustuslepingute lisakasum, mida pole arvestatud elukindlustuse eraldises.",
      "estleg:definedIn": [
        {
          "@id": "estleg:kindlustustegevuse_seadus_Par_75"
        }
      ],
      "estleg:sourceAct": "Kindlustustegevuse seadus",
      "rdfs:label": "boonuste eraldis (kindlustustegevuse_seadus)"
    },
    {
      "@id": "estleg:Concept_kindlustustegevuse_seadus_kindlustusleping_ei_ole_elu",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "kindlustusleping ei ole elu",
      "skos:definition": "ega vastutuskindlustusleping",
      "estleg:definedIn": [
        {
          "@id": "estleg:kindlustustegevuse_seadus_Par_130"
        }
      ],
      "estleg:sourceAct": "Kindlustustegevuse seadus",
      "rdfs:label": "kindlustusleping ei ole elu (kindlustustegevuse_seadus)"
    },
    {
      "@id": "estleg:Concept_kindlustustegevuse_seadus_vhemalt_ks_konsolideerimisgrupi_ksustest_tegutseb_kindlustussektoris_ning_vhemal",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "vähemalt üks konsolideerimisgrupi üksustest tegutseb kindlustussektoris ning vähemalt üks pangandus",
      "skos:definition": "ja investeerimisteenuste sektoris",
      "estleg:definedIn": [
        {
          "@id": "estleg:kindlustustegevuse_seadus_Par_187"
        }
      ],
      "estleg:sourceAct": "Kindlustustegevuse seadus",
      "rdfs:label": "vähemalt üks konsolideerimisgrupi üksustest tegutseb kindlustussektoris ning vähemalt üks pangandus (kindlustustegevuse_seadus)"
    },
    {
      "@id": "estleg:Concept_kindlustustegevuse_seadus_nii_konsolideerimisgruppi_kuuluvate_kindlustussektoris_tegutsevate_ksuste_konsol",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "nii konsolideerimisgruppi kuuluvate kindlustussektoris tegutsevate üksuste konsolideeritud toimingud kui ka pangandus",
      "skos:definition": "ja investeerimisteenuste sektoris tegutsevate üksuste konsolideeritud toimingud on konsolideerimisgrupis märkimisväärsed käesoleva seaduse § 188 lõike 3 või 4 tähenduses. 2 (2) Konsolideerimisgrupp on finantskonglomeraat, kui ta vastab lisaks käesoleva paragrahvi lõikes 1 sätestatule veel ühele järgmistest tingimustest: 1 1) konsolideerimisgrupi juhtiv üksus on kindlustusandja, krediidiasutus või investeerimisühing, kes on ühtlasi kas finantssektori üksuse emaettevõtja, finantssektori üksuses märkimisväärset osalust omav üksus või üksus, mis omab finantssektori üksuses valitsevat mõju või 2 2) konsolideerimisgrupp, kelle juhtiv üksus ei ole kindlustusandja, krediidiasutus või investeerimisühing, tegutseb peamiselt finantssektoris käesoleva seaduse § 188 lõike 2 tähenduses. 3 (3) Finantskonglomeraadina käsitatakse iga konsolideerimisgrupi osa, mis vastab käesoleva paragrahvi lõigetes 1 ja 2 sätestatud tingimustele. 4 (4) Finantssektor koosneb ühest või mõlemast finantssektori osast. Finantssektori osad käesoleva jao tähenduses on kindlustussektor ning pangandus- ja investeerimisteenuste sektor. Lisaks finantssektori osadele võib finantssektorisse kuuluda ka segafinantsvaldusettevõtja. 5 (5) Kindlustussektor on finantssektori osa, kus võivad tegutseda üksnes järgmised üksused: 1 1) kindlustusandja",
      "estleg:definedIn": [
        {
          "@id": "estleg:kindlustustegevuse_seadus_Par_187"
        }
      ],
      "estleg:sourceAct": "Kindlustustegevuse seadus",
      "rdfs:label": "nii konsolideerimisgruppi kuuluvate kindlustussektoris tegutsevate üksuste konsolideeritud toimingud kui ka pangandus (kindlustustegevuse_seadus)"
    },
    {
      "@id": "estleg:Concept_kindlustustegevuse_seadus_Pangandus",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "Pangandus",
      "skos:definition": "ja investeerimisteenuste sektor on finantssektori osa, kus võivad tegutseda üksnes järgmised üksused: 1 1) krediidiasutus",
      "estleg:definedIn": [
        {
          "@id": "estleg:kindlustustegevuse_seadus_Par_187"
        }
      ],
      "estleg:sourceAct": "Kindlustustegevuse seadus",
      "rdfs:label": "Pangandus (kindlustustegevuse_seadus)"
    },
    {
      "@id": "estleg:Concept_kindlustustegevuse_seadus_Lisaks_kesoleva_paragrahvi_likes_6_stestatule_loetakse_ka_fondivalitseja_tegutse",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "Lisaks käesoleva paragrahvi lõikes 6 sätestatule loetakse ka fondivalitseja tegutsevaks pangandus",
      "skos:definition": "ja investeerimisteenuste sektoris ning finantskonglomeraati kuuluva fondivalitseja suhtes kohaldatakse käesolevas jaos krediidiasutuse suhtes sätestatut.",
      "estleg:definedIn": [
        {
          "@id": "estleg:kindlustustegevuse_seadus_Par_187"
        }
      ],
      "estleg:sourceAct": "Kindlustustegevuse seadus",
      "rdfs:label": "Lisaks käesoleva paragrahvi lõikes 6 sätestatule loetakse ka fondivalitseja tegutsevaks pangandus (kindlustustegevuse_seadus)"
    },
    {
      "@id": "estleg:Concept_kinnisasja_omandamise_kitsendamise_seadus_kui_omandajaks_on_Vabariigi_Valitsuse_mrusega_kehtestatud_nimekirja_kantud_avali",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "kui omandajaks on Vabariigi Valitsuse määrusega kehtestatud nimekirja kantud avalik",
      "skos:definition": "õiguslik juriidiline isik või avalikke funktsioone täitev eraõiguslik juriidiline isik, kes omandab kinnisasja oma funktsioonide täitmiseks ./dyn=918117&id=629877",
      "estleg:definedIn": [
        {
          "@id": "estleg:kinnisasja_omandamise_kitsendamise_seadus_Par_1"
        }
      ],
      "estleg:sourceAct": "Kinnisasja omandamise kitsendamise seadus",
      "rdfs:label": "kui omandajaks on Vabariigi Valitsuse määrusega kehtestatud nimekirja kantud avalik (kinnisasja_omandamise_kitsendamise_seadus)"
    },
    {
      "@id": "estleg:Concept_kohalike_maksude_seadus_Mgimaksu_maksavad_valla_vi_linna_territooriumil_kauplemis",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "Müügimaksu maksavad valla või linna territooriumil kauplemis",
      "skos:definition": "või teenindusluba omavad füüsilisest isikust ettevõtjad ja juriidilised isikud. [Lõike 1 sõnastus alates 1. 07. 2004] 1 (1) Müügimaksu maksavad valla või linna territooriumil kauplemis- või teenindusluba omavad füüsilisest isikust ettevõtjad ja juriidilised isikud. Müügimaksu maksab tegevuskohajärgselt kaupleja kaubandustegevuse seaduse (RT I 2004, 12, 78) mõistes, kes on registreeritud majandustegevuse registris ja tegutseb jaekaubanduse, toitlustuse või teeninduse valdkonnas. 2 (2) Müügimaksuga maksustatakse maksumaksja poolt valla või linna territooriumil müüdud kaupade ja teenuste maksumus müügihinnas. Kaupade ja teenuste müügihind käesoleva seaduse tähenduses on käibemaksuseaduses (RT I 2003, 82, 554",
      "estleg:definedIn": [
        {
          "@id": "estleg:kohalike_maksude_seadus_Par_8"
        }
      ],
      "estleg:sourceAct": "Kohalike maksude seadus",
      "rdfs:label": "Müügimaksu maksavad valla või linna territooriumil kauplemis (kohalike_maksude_seadus)"
    },
    {
      "@id": "estleg:Concept_kohalike_maksude_seadus_Valla",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "Valla",
      "skos:definition": "ja linnavalitsusel on õigus anda müügimaksu soodustusi ja vabastusi volikogu poolt kehtestatud tingimustel ja korras. RT I 2004 45 319 761232 2004-05-27+03:00",
      "estleg:definedIn": [
        {
          "@id": "estleg:kohalike_maksude_seadus_Par_8"
        }
      ],
      "estleg:sourceAct": "Kohalike maksude seadus",
      "rdfs:label": "Valla (kohalike_maksude_seadus)",
      "skos:exactMatch": [
        {
          "@id": "estleg:Concept_korruptsioonivastane_seadus_valla"
        },
        {
          "@id": "estleg:Concept_riigiloivuseadus_valla"
        }
      ],
      "skos:closeMatch": [
        {
