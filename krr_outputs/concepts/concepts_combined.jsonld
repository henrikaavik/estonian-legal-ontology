      ],
      "skos:prefLabel": "NSV Liidu Julgeoleku Ministeerium",
      "skos:definition": "MGB (Ministerstvo Gosudarstvennoi Bezopasnosti), mis eksisteeris 1946. aasta 15. märtsist kuni 1953. aasta 15. märtsini",
      "estleg:definedIn": [
        {
          "@id": "estleg:eestit_okupeerinud_riikide_julgeolekuorganite_voi_relvajoudude_luure_voi_vastulu_Par_2"
