          "@id": "estleg:sundeksemplari_seadus_Par_3"
        }
      ],
      "estleg:sourceAct": "Sundeksemplari seadus",
      "rdfs:label": "elektrooniline teavik (sundeksemplari_seadus)"
    },
    {
      "@id": "estleg:Concept_sundeksemplari_seadus_sissetooja",
