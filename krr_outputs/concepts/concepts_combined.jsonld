        }
      ],
      "estleg:sourceAct": "Väärismetalltoodete seadus",
      "rdfs:label": "käitlemine (vaarismetalltoodete_seadus)"
    },
    {
      "@id": "estleg:Concept_vaarismetalltoodete_seadus_valmistamine",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "valmistamine",
      "skos:definition": "uute väärismetalltoodete tasu eest võõrandamise eesmärgil valmistamine ning kasutatud väärismetalltoodete parandamine, ümbertegemine ja ennistamine",
      "estleg:definedIn": [
        {
          "@id": "estleg:vaarismetalltoodete_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Väärismetalltoodete seadus",
      "rdfs:label": "valmistamine (vaarismetalltoodete_seadus)"
    },
    {
      "@id": "estleg:Concept_vaarismetalltoodete_seadus_sissevedu",
      "@type": [
        "owl:NamedIndividual",
