    {
      "@id": "estleg:Concept_oppetoetuste_ja_oppelaenu_seadus_phitoetus",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "põhitoetus",
      "skos:definition": "õpilasele ja üliõpilasele, välja arvatud doktoriõppes õppivale isikule, käesolevas seaduses sätestatud tingimustel antav rahaline toetus hariduse omandamisega kaasnevate kulutuste katmiseks",
      "estleg:definedIn": [
        {
          "@id": "estleg:oppetoetuste_ja_oppelaenu_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Õppetoetuste ja õppelaenu seadus",
      "rdfs:label": "põhitoetus (oppetoetuste_ja_oppelaenu_seadus)"
    },
    {
      "@id": "estleg:Concept_oppetoetuste_ja_oppelaenu_seadus_tiendav_toetus",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "täiendav toetus",
      "skos:definition": "§ 5 lõikes 1 nimetatud põhitoetuse saamise nõuetele vastavale õpilasele ja üliõpilasele, kelle elukoht asub väljaspool omavalitsusüksust ja sellega piirnevaid omavalitsusi, kus asub õppeasutus, käesolevas seaduses sätestatud tingimustel antav täiendav rahaline toetus eluasemele ja transpordile tehtavate kulutuste katmiseks, täiendav toetus ei laiene doktoriõppes õppivale isikule",
      "estleg:definedIn": [
        {
          "@id": "estleg:oppetoetuste_ja_oppelaenu_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Õppetoetuste ja õppelaenu seadus",
      "rdfs:label": "täiendav toetus (oppetoetuste_ja_oppelaenu_seadus)"
    },
    {
      "@id": "estleg:Concept_oppetoetuste_ja_oppelaenu_seadus_tiendav_toetus_2",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "täiendav toetus",
      "skos:definition": "§ 5 lõikes 1 nimetatud põhitoetuse saamise nõuetele vastavale õpilasele (välja arvatud põhihariduse baasil kutsekeskharidust omandavale õpilasele) ja üliõpilasele, kelle elukoht asub väljaspool omavalitsusüksust ja sellega piirnevaid omavalitsusi, kus asub õppeasutus, käesolevas seaduses sätestatud tingimustel antav täiendav rahaline toetus eluasemele ja transpordile tehtavate kulutuste katmiseks, täiendav toetus ei laiene doktoriõppes õppivale isikule",
      "estleg:definedIn": [
        {
          "@id": "estleg:oppetoetuste_ja_oppelaenu_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Õppetoetuste ja õppelaenu seadus",
      "rdfs:label": "täiendav toetus (oppetoetuste_ja_oppelaenu_seadus)"
    },
    {
      "@id": "estleg:Concept_oppetoetuste_ja_oppelaenu_seadus_doktoranditoetus",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "doktoranditoetus",
      "skos:definition": "doktoriõppes õppivale isikule (edaspidi doktorant ) käesolevas seaduses sätestatud tingimustel antav rahaline toetus doktoriõpingutele ja teadustööle pühendumise soodustamiseks ning hariduse omandamisega kaasnevate kulutuste katmiseks. RT I 2004 84 567 824843 2005-09-01+03:00",
      "estleg:definedIn": [
        {
          "@id": "estleg:oppetoetuste_ja_oppelaenu_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Õppetoetuste ja õppelaenu seadus",
      "rdfs:label": "doktoranditoetus (oppetoetuste_ja_oppelaenu_seadus)"
    },
    {
      "@id": "estleg:Concept_paasteseadus_pstetd",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "päästetööd",
      "skos:definition": "inimeste ja vara päästmiseks ning keskkonna kaitseks tehtavad tööd tulekahjude, loodusõnnetuste, katastroofide, avariide, plahvatuste, liiklusõnnetuste ja muude õnnetuste (edaspidi õnnetused ) korral, samuti õnnetustega kaasnevate ohtude likvideerimiseks tehtavad tööd",
      "estleg:definedIn": [
        {
          "@id": "estleg:paasteseadus_Par_3"
        }
      ],
      "estleg:sourceAct": "Päästeseadus",
      "rdfs:label": "päästetööd (paasteseadus)"
    },
    {
      "@id": "estleg:Concept_paasteseadus_demineerimistd",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "demineerimistööd",
      "skos:definition": "plahvatusohtlike esemete otsimine varem koostatud kava alusel, plahvatusohtlike esemete hävitamine, pommiähvarduste ja pommikahtluste kontroll, pommitehniline kontroll ning plahvatusjärgne tegevus sündmuskohal",
      "estleg:definedIn": [
        {
          "@id": "estleg:paasteseadus_Par_3"
        }
      ],
      "estleg:sourceAct": "Päästeseadus",
      "rdfs:label": "demineerimistööd (paasteseadus)"
    },
    {
      "@id": "estleg:Concept_paasteseadus_riiklik_tuleohutusjrelevalve",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "riiklik tuleohutusjärelevalve",
      "skos:definition": "tuleohutust käsitlevate õigusaktide täitmiseks tehtavad tööd. RT I 2004 54 390 778895 2004-07-01+03:00",
      "estleg:definedIn": [
        {
          "@id": "estleg:paasteseadus_Par_3"
        }
      ],
      "estleg:sourceAct": "Päästeseadus",
      "rdfs:label": "riiklik tuleohutusjärelevalve (paasteseadus)"
    },
    {
      "@id": "estleg:Concept_paasteseadus_Raudteetranspordi_ja_tsiviillennunduse_tuleohutusnuded_kehtestatakse_majandus",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "Raudteetranspordi ja tsiviillennunduse tuleohutusnõuded kehtestatakse majandus",
      "skos:definition": "ja kommunikatsiooniministri määrusega ./dyn=834108&id=89551",
      "estleg:definedIn": [
        {
          "@id": "estleg:paasteseadus_Par_21"
        }
      ],
      "estleg:sourceAct": "Päästeseadus",
      "rdfs:label": "Raudteetranspordi ja tsiviillennunduse tuleohutusnõuded kehtestatakse majandus (paasteseadus)"
    },
    {
      "@id": "estleg:Concept_paasteseadus_Allmaarajatiste_tuleohutusnuded_kehtestatakse_majandus",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "Allmaarajatiste tuleohutusnõuded kehtestatakse majandus",
      "skos:definition": "ja kommunikatsiooniministri määrusega ./dyn=834108&id=257278 . 4 (4) Metsa ja muu taimestikuga kaetud alade tuleohutusnõuded kehtestatakse keskkonnaministri määrusega ./dyn=834108&id=25629 . 5 (5) Kaitsejõudude tuleohutusnõuded kehtestatakse kaitseministri määrusega ./dyn=834108&id=81272 . 6 (6) Kui seadus või seaduse alusel antud õigusakt ei sätesta teisiti, sisaldavad tegevusala ja toote kohustuslikud ohutusnõuded ka tuleohutusnõudeid. 7 (7) Tuleohutusnõudeid sisaldav ministri määrus antakse kokkuleppel siseministriga. 8 (8) Üldplaneering ja detailplaneering kooskõlastatakse planeerimisseaduse (RT I 2002, 99, 579) § 17 kohaselt maavalitsuse või kohaliku omavalitsuse määratud juhtudel riigi või kohaliku omavalitsuse päästeasutusega. 9 (9) Kohaliku omavalitsuse kirjaliku nõusoleku, ehitusloa või ehitise kasutusloa taotlemisel ehitusseaduse (RT I 2002, 47, 297",
      "estleg:definedIn": [
        {
          "@id": "estleg:paasteseadus_Par_21"
        }
      ],
      "estleg:sourceAct": "Päästeseadus",
      "rdfs:label": "Allmaarajatiste tuleohutusnõuded kehtestatakse majandus (paasteseadus)"
    },
    {
      "@id": "estleg:Concept_pakendiseadus_mgipakend",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "müügipakend",
      "skos:definition": "lõppkasutajale või tarbijale müügikohas üleandmiseks ettenähtud müügiühiku osa",
      "estleg:definedIn": [
        {
          "@id": "estleg:pakendiseadus_Par_3"
        }
      ],
      "estleg:sourceAct": "Pakendiseadus",
      "rdfs:label": "müügipakend (pakendiseadus)"
    },
    {
      "@id": "estleg:Concept_pakendiseadus_rhmapakend",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "rühmapakend",
      "skos:definition": "mõeldud teatud hulga müügiühikute rühmitamiseks müügikohas, sõltumata sellest, kas pakend müüakse koos kaubaga lõppkasutajale või tarbijale või kasutatakse seda vaid kauba käsitsemise lihtsustamiseks, kauba kaitsmiseks või esitlemiseks, kusjuures rühmapakendit on võimalik eemaldada toote omadusi muutmata",
      "estleg:definedIn": [
        {
          "@id": "estleg:pakendiseadus_Par_3"
        }
      ],
      "estleg:sourceAct": "Pakendiseadus",
      "rdfs:label": "rühmapakend (pakendiseadus)"
    },
    {
      "@id": "estleg:Concept_pakendiseadus_veopakend",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "veopakend",
      "skos:definition": "mõeldud teatud arvu kaubaühikute või rühmapakendis kaupade käsitsemiseks ja veoks, et vältida veol kauba füüsilisi kahjustusi, siia ei kuulu maantee-, raudtee-, mere- ja õhuveokonteinerid. 2 (2) Sõltuvalt pakendi taaskasutuskordadest on käesoleva paragrahvi lõikes 1 nimetatud pakendi liikide alaliigid järgmised: 1 1) korduskasutuspakend – mõeldud ja kavandatud läbima oma olelustsükli jooksul korduskasutussüsteemis vähemalt mitu käiku või ringi, sõltuvalt pakendi kasutusotstarbest, -võimalusest ja -kõlblikkusest",
      "estleg:definedIn": [
        {
          "@id": "estleg:pakendiseadus_Par_3"
        }
      ],
      "estleg:sourceAct": "Pakendiseadus",
      "rdfs:label": "veopakend (pakendiseadus)"
    },
    {
      "@id": "estleg:Concept_pakendiseadus_hekorrapakend",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "ühekorrapakend",
      "skos:definition": "mõeldud üksnes ühekordseks kasutamiseks. 3 (3) Pakendimaterjali liigid on järgmised: 1 1) klaas",
      "estleg:definedIn": [
        {
          "@id": "estleg:pakendiseadus_Par_3"
        }
      ],
      "estleg:sourceAct": "Pakendiseadus",
      "rdfs:label": "ühekorrapakend (pakendiseadus)"
    },
    {
      "@id": "estleg:Concept_palgaseadus_Phipalk_on_tlepingus_vi_igusaktis_kindlaks_mratud_tunni",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "Põhipalk on töölepingus või õigusaktis kindlaks määratud tunni",
      "skos:definition": ", päeva-, nädala- või kuupalgamäära alusel arvutatud palk. 3 (3) Seaduses, haldusaktis, kollektiiv- või töölepingus ettenähtud juhtudel maksab tööandja töötajale peale põhipalga lisatasu või juurdemakseid. 4 (4) Lisatasu on summa, mida tööandja maksab töötajale põhipalgale lisaks täiendavate tööülesannete täitmise või nõutavast tulemuslikuma töö eest või muudel õigusaktis, kollektiiv- või töölepingus ettenähtud juhtudel, samuti preemiana tööandja ühepoolse otsuse alusel. 5 (5) Juurdemakse on summa, mida tööandja maksab töötajale selleks, et tagada talle ettenähtud palgatase ja hüvitada võimalik palga vähenemine. 6 (6) Keskmine palk on töötajal teatud aja jooksul teenitud palga kogusummast arvutatav keskmine tasu mingi ajaühiku (tunni, päeva, nädala, kuu vms.) kohta. Keskmise palga arvutamise kord sätestatakse Vabariigi Valitsuse ./dyn=924080&id=73121 määrusega. 7 (7) Palga alammäär on Vabariigi Valitsuse ./dyn=924080&id=832145",
      "estleg:definedIn": [
        {
          "@id": "estleg:palgaseadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Palgaseadus",
      "rdfs:label": "Põhipalk on töölepingus või õigusaktis kindlaks määratud tunni (palgaseadus)"
    },
