      "@id": "estleg:Concept_planeerimisseadus_ldiste_riigikaitseliste_vajaduste_arvestamine_ja_vajaduse_korral_riigikaitselise",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "üldiste riigikaitseliste vajaduste arvestamine ja vajaduse korral riigikaitselise otstarbega maa-alade määramine ning maakonnaplaneeringus määratud riigikaitselise otstarbega maa",
      "skos:definition": "alade piiride täpsustamine",
      "estleg:definedIn": [
        {
          "@id": "estleg:planeerimisseadus_Par_8"
        }
      ],
      "estleg:sourceAct": "Planeerimisseadus",
      "rdfs:label": "üldiste riigikaitseliste vajaduste arvestamine ja vajaduse korral riigikaitselise otstarbega maa-alade määramine ning maakonnaplaneeringus määratud riigikaitselise otstarbega maa (planeerimisseadus)"
    },
    {
      "@id": "estleg:Concept_planeerimisseadus_muude_seadustest_ja_teistest_igusaktidest_tulenevate_maakasutus",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "muude seadustest ja teistest õigusaktidest tulenevate maakasutus",
      "skos:definition": "ja ehitustingimuste kajastamine planeeringus. 4 (4) Üldplaneering võib põhjendatud vajaduse korral sisaldada kehtestatud maakonnaplaneeringu muutmise ettepanekuid. 5 (5) Üldplaneeringu koostamine on kohustuslik olulise ruumilise mõjuga objekti asukoha valiku tegemisel. Olulise ruumilise mõjuga objekti üldplaneeringuga planeeritava maa-ala suuruse määrab maavanem koostöös vastava kohaliku omavalitsusega ja kooskõlastab keskkonnaminister. 6 (6) Olulise ruumilise mõjuga objekt käesoleva seaduse tähenduses on objekt, millest tingitud transpordivood, saasteainete hulk, külastajate hulk ja tooraine või tööjõu vajadus muutuvad objekti kavandatavas asukohas senisega võrreldes oluliselt ning mille mõju ulatub suurele territooriumile. Olulise ruumilise mõjuga objektide nimekirja kehtestab Vabariigi Valitsus ./dyn=893069&id=610351 . 7 (7) Kehtestatud üldplaneering on aluseks detailplaneeringute koostamisele detailplaneeringu koostamise kohustusega aladel ja juhtudel ning maakorraldusele ja projekteerimistingimuste väljaandmisele väljaspool detailplaneeringu koostamise kohustusega alasid. 8 (8) Üldplaneeringuga määratakse detailplaneeringute koostamise vajadus ja järjestus ning näidatakse majanduslikud võimalused üldplaneeringu elluviimiseks. 9 (9) Üldplaneeringu koostamisel võetakse arvesse keskkonnamõju strateegilise hindamise tulemusi. RT I 2005 15 87 867983 2005-04-03+03:00",
      "estleg:definedIn": [
        {
          "@id": "estleg:planeerimisseadus_Par_8"
        }
      ],
      "estleg:sourceAct": "Planeerimisseadus",
      "rdfs:label": "muude seadustest ja teistest õigusaktidest tulenevate maakasutus (planeerimisseadus)"
    },
    {
      "@id": "estleg:Concept_planeerimisseadus_leriigilise_planeeringu_puhul",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "üleriigilise planeeringu puhul",
      "skos:definition": "vähemalt üks üleriigilise levikuga päevaleht",
      "estleg:definedIn": [
        {
          "@id": "estleg:planeerimisseadus_Par_11"
        }
      ],
      "estleg:sourceAct": "Planeerimisseadus",
      "rdfs:label": "üleriigilise planeeringu puhul (planeerimisseadus)"
    },
    {
      "@id": "estleg:Concept_planeerimisseadus_maakonnaplaneeringu_puhul",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "maakonnaplaneeringu puhul",
      "skos:definition": "regulaarselt ilmuv maakonnaleht või vähemalt üks üleriigilise levikuga päevaleht ja vähemalt üks kord kuus ilmuv valla- või linnaleht",
      "estleg:definedIn": [
        {
          "@id": "estleg:planeerimisseadus_Par_11"
        }
      ],
      "estleg:sourceAct": "Planeerimisseadus",
      "rdfs:label": "maakonnaplaneeringu puhul (planeerimisseadus)"
    },
    {
      "@id": "estleg:Concept_planeerimisseadus_ldplaneeringu_ja_detailplaneeringu_puhul",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "üldplaneeringu ja detailplaneeringu puhul",
      "skos:definition": "vähemalt üks kord kuus ilmuv valla- või linnaleht ja regulaarselt ilmuv maakonnaleht või üleriigilise levikuga päevaleht, mis on kohaliku omavalitsuse poolt määratud valla või linna ametlike teadete avaldamise kohaks.",
      "estleg:definedIn": [
        {
          "@id": "estleg:planeerimisseadus_Par_11"
        }
      ],
      "estleg:sourceAct": "Planeerimisseadus",
      "rdfs:label": "üldplaneeringu ja detailplaneeringu puhul (planeerimisseadus)"
    },
    {
      "@id": "estleg:Concept_planeerimisseadus_ldplaneeringu_ja_detailplaneeringu_koostamisse_kaasatakse_planeeritava_maa",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "Üldplaneeringu ja detailplaneeringu koostamisse kaasatakse planeeritava maa",
      "skos:definition": "ala kinnisasjade omanikud ja elanikud ning teised huvitatud isikud. 1 (1<sup>1</sup>) Maareformi seaduse (RT 1991, 34, 426",
      "estleg:definedIn": [
        {
          "@id": "estleg:planeerimisseadus_Par_16"
        }
      ],
      "estleg:sourceAct": "Planeerimisseadus",
      "rdfs:label": "Üldplaneeringu ja detailplaneeringu koostamisse kaasatakse planeeritava maa (planeerimisseadus)"
    },
    {
      "@id": "estleg:Concept_planeerimisseadus_maakonnaplaneeringu_puhul_koosts_planeeritava_maa",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "maakonnaplaneeringu puhul koostöös planeeritava maa",
      "skos:definition": "ala kohalike omavalitsustega, planeeritava maa-ala naabrusesse jäävate maakondade maavanemate ning Keskkonnaministeeriumi ja teiste ministeeriumidega, kelle valitsemisalas olevaid küsimusi planeering käsitleb",
      "estleg:definedIn": [
        {
          "@id": "estleg:planeerimisseadus_Par_16"
        }
      ],
      "estleg:sourceAct": "Planeerimisseadus",
      "rdfs:label": "maakonnaplaneeringu puhul koostöös planeeritava maa (planeerimisseadus)"
    },
    {
      "@id": "estleg:Concept_planeerimisseadus_ldplaneeringu_puhul_koosts_planeeritava_maa",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "üldplaneeringu puhul koostöös planeeritava maa",
      "skos:definition": "ala naabrusesse jäävate kohalike omavalitsustega ja vastava maavanemaga",
      "estleg:definedIn": [
        {
          "@id": "estleg:planeerimisseadus_Par_16"
        }
      ],
      "estleg:sourceAct": "Planeerimisseadus",
      "rdfs:label": "üldplaneeringu puhul koostöös planeeritava maa (planeerimisseadus)"
    },
    {
      "@id": "estleg:Concept_planeerimisseadus_detailplaneeringu_puhul_koosts_planeeritava_maa",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "detailplaneeringu puhul koostöös planeeritava maa",
      "skos:definition": "ala kinnisasjade omanikega ning olemasolevate või kavandatavate tehnovõrkude omanikega või valdajatega, et tagada planeeritava maa-ala varustatus tehnovõrkudega. 5 (5) Kui planeeringu koostamise käigus tehakse keskkonnamõju strateegiline hindamine, peab planeeringu koostamise käigus tegema koostööd keskkonnamõju strateegilise hindamise eksperdiga keskkonnamõju hindamise ja keskkonnajuhtimissüsteemi seaduse tähenduses. 6 (6) Kui on otstarbekas, võib keskkonnamõju strateegilise hindamise menetluse ühendada planeeringu koostamise menetlusega. Sellisel juhul peavad olema täidetud mõlemale menetlusele kehtestatud nõuded. RT I 2005 15 87 867983 2005-04-03+03:00",
      "estleg:definedIn": [
        {
          "@id": "estleg:planeerimisseadus_Par_16"
        }
      ],
      "estleg:sourceAct": "Planeerimisseadus",
      "rdfs:label": "detailplaneeringu puhul koostöös planeeritava maa (planeerimisseadus)"
    },
    {
      "@id": "estleg:Concept_planeerimisseadus_maakonnaplaneeringute_le",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "maakonnaplaneeringute üle",
      "skos:definition": "Siseministeerium",
      "estleg:definedIn": [
        {
          "@id": "estleg:planeerimisseadus_Par_23"
        }
      ],
      "estleg:sourceAct": "Planeerimisseadus",
      "rdfs:label": "maakonnaplaneeringute üle (planeerimisseadus)"
    },
    {
      "@id": "estleg:Concept_planeerimisseadus_ldplaneeringute_ja_detailplaneeringute_le",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "üldplaneeringute ja detailplaneeringute üle",
      "skos:definition": "maavanem. 2 (2) Detailplaneeringu üle ei teostata käesolevas paragrahvis sätestatud järelevalvet, kui: 1 1) detailplaneering on koostatud vastavuses kehtestatud üldplaneeringuga ja kõigi avalikul väljapanekul esitatud vastuväidetega on arvestatud",
      "estleg:definedIn": [
        {
          "@id": "estleg:planeerimisseadus_Par_23"
        }
      ],
      "estleg:sourceAct": "Planeerimisseadus",
      "rdfs:label": "üldplaneeringute ja detailplaneeringute üle (planeerimisseadus)"
    },
    {
      "@id": "estleg:Concept_pohikooli_ja_gumnaasiumiseadus_lasteaed",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "lasteaed",
      "skos:definition": "algkool",
      "estleg:definedIn": [
        {
          "@id": "estleg:pohikooli_ja_gumnaasiumiseadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Põhikooli- ja gümnaasiumiseadus",
      "rdfs:label": "lasteaed (pohikooli_ja_gumnaasiumiseadus)"
    },
    {
      "@id": "estleg:Concept_pohikooli_ja_gumnaasiumiseadus_Riigikooli_korraldab_ja_kujundab_mber_Haridus",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "Riigikooli korraldab ja kujundab ümber Haridus",
      "skos:definition": "ja Teadusministeerium. Munitsipaalkooli korraldab ja kujundab valla- või linnavolikogu otsusel ümber valla- või linnavalitsus. Kooli ümberkorraldamise või ümberkujundamise otsus tehakse arvestusega, et sellest on võimalik teavitada kirjalikult Haridus- ja Teadusministeeriumi, maavanemat, kooli, lapsevanemaid (eestkostjaid, hooldajaid) ja õpilasi vähemalt kuus kuud enne uue õppeaasta algust. 3 (3) Kooli ümberkorraldamine ja ümberkujundamine võib toimuda järgmistel juhtudel: 1 1) linnas või vallas on koolitusnõudlus suurenenud või vähenenud",
      "estleg:definedIn": [
        {
          "@id": "estleg:pohikooli_ja_gumnaasiumiseadus_Par_49"
        }
      ],
      "estleg:sourceAct": "Põhikooli- ja gümnaasiumiseadus",
      "rdfs:label": "Riigikooli korraldab ja kujundab ümber Haridus (pohikooli_ja_gumnaasiumiseadus)"
    },
    {
      "@id": "estleg:Concept_politsei_ja_piirivalve_seadus_Loa_isiku_kaasamiseks_annab_Politsei",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "Loa isiku kaasamiseks annab Politsei",
      "skos:definition": "ja Piirivalveameti peadirektor või tema volitatud ametnik. 4 (4) Salajasele koostööle võib kaasata ainult täisealisi isikuid nende nõusolekul, välja arvatud kriminaalmenetluse seadustiku § 126 1 lõikes 6 sätestatud juhul. 5 (5) Salajasele koostööle kaasatud isikud on kohustatud hoiduma teadvalt väära või laimava teabe edasiandmisest ning hoidma saladuses neile koostöö käigus teatavaks saanud andmed, samuti jälitustoimingute tegemisel kasutatavad vahendid, meetodid ja taktika. 6 (6) Salajasele koostööle kaasatud isikul on õigus keelduda jälitustoimingute tegemisest oma lähedaste isikute suhtes. 7 (7) Kontrolli salajasele koostööle kaasatud isiku tegevuse üle teostab Politsei- ja Piirivalveameti peadirektor või tema volitatud ametnik. 8 (8) Isiku kaasamise dokumenteerimise korra kehtestab valdkonna eest vastutav minister ./dyn=131122014023&id=118012013019 määrusega. RT I 2012-06-29 2 129062012002 2013-01-01",
      "estleg:definedIn": [
        {
          "@id": "estleg:politsei_ja_piirivalve_seadus_Par_7"
        }
      ],
      "estleg:sourceAct": "Politsei ja piirivalve seadus",
      "rdfs:label": "Loa isiku kaasamiseks annab Politsei (politsei_ja_piirivalve_seadus)"
    },
    {
      "@id": "estleg:Concept_politsei_ja_piirivalve_seadus_Variisiku_kasutamiseks_annab_kirjaliku_loa_Politsei",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "Variisiku kasutamiseks annab kirjaliku loa Politsei",
      "skos:definition": "ja Piirivalveameti peadirektor või tema volitatud ametnik. 4 (4) Variisikul on kõik politseiametniku kohustused niivõrd, kuivõrd see ei too kaasa muudetud identiteedi paljastamist. 5 (5) Variisiku isik jäetakse salastatuks ka pärast jälitustoimingu lõpetamist, kui avalikustamine võib seada ohtu variisiku või tema lähikondsete elu, tervise, au või hea nime või vara või tema edasise tegutsemise variisiku või politseiagendina. RT I 2012-06-29 2 129062012002 2013-01-01",
      "estleg:definedIn": [
        {
          "@id": "estleg:politsei_ja_piirivalve_seadus_Par_7"
        }
      ],
      "estleg:sourceAct": "Politsei ja piirivalve seadus",
      "rdfs:label": "Variisiku kasutamiseks annab kirjaliku loa Politsei (politsei_ja_piirivalve_seadus)"
    },
    {
      "@id": "estleg:Concept_politsei_ja_piirivalve_seadus_keda_Politsei",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "keda Politsei",
      "skos:definition": "ja Piirivalveamet on tunnustanud vabatahtliku merepäästjana ja 3 3) kes vabatahtlikult osaleb Politsei- ja Piirivalveameti tegevuses käesolevas seaduses sätestatud alustel ja tingimustel. 2 (2) Vabatahtliku merepäästja osalemine politsei tegevuses käesoleva seaduse kohaselt on vabatahtliku merepäästja poolt politsei ülesandel iseseisvalt või koos politseiametnikuga merepäästetöö tegemine. 3 (3) Politsei tegevuses osalemise ajal on vabatahtlik merepäästja riigivõimu esindaja, kelle seaduslik korraldus merepäästetöö tegemisel on päästetavale isikule ja muule asjassepuutuvale isikule täitmiseks kohustuslik.",
      "estleg:definedIn": [
        {
          "@id": "estleg:politsei_ja_piirivalve_seadus_Par_108"
        }
      ],
      "estleg:sourceAct": "Politsei ja piirivalve seadus",
      "rdfs:label": "keda Politsei (politsei_ja_piirivalve_seadus)"
    },
    {
