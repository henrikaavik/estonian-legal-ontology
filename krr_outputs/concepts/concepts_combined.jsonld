    {
      "@id": "estleg:Concept_vedelkutuse_seadus_ktuse_tarbimisse_lubamine_on_aktsiisikauba_tarbimisse_lubamine_alkoholi",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "kütuse tarbimisse lubamine on aktsiisikauba tarbimisse lubamine alkoholi",
      "skos:definition": ", tubaka- ja kütuseaktsiisi seaduse (RT I 2003, 2, 17",
      "estleg:definedIn": [
        {
          "@id": "estleg:vedelkutuse_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Vedelkütuse seadus",
      "rdfs:label": "kütuse tarbimisse lubamine on aktsiisikauba tarbimisse lubamine alkoholi (vedelkutuse_seadus)"
    },
    {
      "@id": "estleg:Concept_vedelkutuse_seadus_Majandus",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "Majandus",
      "skos:definition": "ja kommunikatsiooniministril on õigus lubada sportsõidukites kasutamiseks ettenähtud nõuetele mittevastava spetsiifiliste omadustega kütuse piiratud koguses tarbimisse lubamist vastava spordiliidu taotlusel. 5 (5) Käesoleva paragrahvi lõikes 4 nimetatud loa taotluses peavad olema järgmised andmed: 1 1) spordiliidu nimetus, registrikood, asukoha aadress ja kontaktandmed",
      "estleg:definedIn": [
        {
          "@id": "estleg:vedelkutuse_seadus_Par_8"
        }
      ],
      "estleg:sourceAct": "Vedelkütuse seadus",
      "rdfs:label": "Majandus (vedelkutuse_seadus)"
    },
    {
      "@id": "estleg:Concept_vedelkutuse_seadus_Vastavussertifikaadi_vormi_ja_selle_titmise_juhendi_kehtestab_majandus",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "Vastavussertifikaadi vormi ja selle täitmise juhendi kehtestab majandus",
      "skos:definition": "ja kommunikatsiooniminister ./dyn=965588&id=809958 . 3 (3) Vastavussertifikaat koostatakse vähemalt kahes eksemplaris, millest üks jääb väljaandjale ning teine (teised) vastavushindamise tellijale. 4 (4) Käesoleva seaduse § 9 lõikes 5 sätestatud juhtudel tuleb kontrollimisel esitada vastavussertifikaadi originaal või selle v��ljaandja või aktsiisilaopidaja kinnitatud koopia. 5 (5) Vastavussertifikaadi väljaandja säilitab igale kütusekogusele vormistatud vastavussertifikaati koos katseprotokolliga seitsme aasta jooksul vastavushindamise läbiviimisest arvates. 6 (6) Vastavussertifikaati või selle koopiat tuleb säilitada vastavalt raamatupidamise seaduse (RT I 2002, 102, 600) alusel raamatupidamise algdokumendi säilitamisele sätestatud nõuetele. RT I 2004 53 365 775944 2004-07-18+03:00",
      "estleg:definedIn": [
        {
          "@id": "estleg:vedelkutuse_seadus_Par_12"
        }
      ],
      "estleg:sourceAct": "Vedelkütuse seadus",
      "rdfs:label": "Vastavussertifikaadi vormi ja selle täitmise juhendi kehtestab majandus (vedelkutuse_seadus)"
    },
    {
      "@id": "estleg:Concept_vedelkutusevaru_seadus_I_varukategooria",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "I varukategooria",
      "skos:definition": "autobensiin, lennukibensiin ja reaktiivmootoribensiin",
