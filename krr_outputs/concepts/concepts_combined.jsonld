      "rdfs:label": "blokeeritava ühenduse füüsiline isik (rahvusvahelise_sanktsiooni_seadus)"
    },
    {
      "@id": "estleg:Concept_rahvusvahelise_sojalise_koostoo_seadus_RO_phikirja_VI_ja_VII_peatkis_stestatu_alusel_rahu",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "ÜRO põhikirja VI ja VII peatükis sätestatu alusel rahu",
      "skos:definition": "ja julgeoleku säilitamise või taastamise eesmärgil korraldatav sõjaline operatsioon ning rahvusvahelise õiguse üldtunnustatud tavade ja põhimõtetega kooskõlas olev muu sõjaline operatsioon.",
      "estleg:definedIn": [
