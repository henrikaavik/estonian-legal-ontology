    {
      "@id": "estleg:Concept_alkoholi_tubaka_kutuse_ja_elektriaktsiisi_seadus_mis_on_valmistatud_biomassist_ja_mille_KNi_kaheksa_numbrit_on_3824_90_55_vi_3824",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "mis on valmistatud biomassist ja mille KNi kaheksa numbrit on 3824 90 55 või 3824 90 80",
      "skos:definition": "3824 90 99. Biomassina käsitatakse põllumajanduslikke tooteid, kaasa arvatud taimseid ja loomseid aineid, metsandusest saadud toodete, jäätmete ja jääkide bioloogiliselt lagunevat fraktsiooni ning tööstuse- ja olmejäätmete bioloogiliselt lagunevat fraktsiooni",
      "estleg:definedIn": [
        {
          "@id": "estleg:alkoholi_tubaka_kutuse_ja_elektriaktsiisi_seadus_Par_19"
        }
      ],
      "estleg:sourceAct": "Alkoholi-, tubaka-, kütuse- ja elektriaktsiisi seadus",
