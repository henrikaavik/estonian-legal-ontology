    {
      "@id": "estleg:Concept_rahvusvahelise_sanktsiooni_seadus_rahvusvaheline_sanktsioon",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "rahvusvaheline sanktsioon",
      "skos:definition": "abinõu, mille eesmärk on sundida blokeeritavat ühendust täitma rahvusvahelise õiguse normidest ja põhimõtetest tulenevaid kohustusi ning mis ei ole seotud relvajõudude kasutamisega",
      "estleg:definedIn": [
        {
          "@id": "estleg:rahvusvahelise_sanktsiooni_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Rahvusvahelise sanktsiooni seadus",
      "rdfs:label": "rahvusvaheline sanktsioon (rahvusvahelise_sanktsiooni_seadus)"
    },
    {
      "@id": "estleg:Concept_rahvusvahelise_sanktsiooni_seadus_blokeeritav_hendus",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "blokeeritav ühendus",
      "skos:definition": "riik, teatud territoorium, režiim, organisatsioon või muu üksus, kelle suhtes kasutatakse käesolevas seaduses ettenähtud abinõusid",
      "estleg:definedIn": [
        {
          "@id": "estleg:rahvusvahelise_sanktsiooni_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Rahvusvahelise sanktsiooni seadus",
      "rdfs:label": "blokeeritav ühendus (rahvusvahelise_sanktsiooni_seadus)"
    },
    {
      "@id": "estleg:Concept_rahvusvahelise_sanktsiooni_seadus_blokeeritava_henduse_juriidiline_isik",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "blokeeritava ühenduse juriidiline isik",
      "skos:definition": "juriidiline isik, kes on registreeritud blokeeritavas riigis, kelle alaline asukoht on blokeeritavas riigis, kelle ainuosanik või -aktsionär on blokeeritav ühendus või keda blokeeritav ühendus kontrollib muul viisil",
      "estleg:definedIn": [
        {
          "@id": "estleg:rahvusvahelise_sanktsiooni_seadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Rahvusvahelise sanktsiooni seadus",
      "rdfs:label": "blokeeritava ühenduse juriidiline isik (rahvusvahelise_sanktsiooni_seadus)"
    },
