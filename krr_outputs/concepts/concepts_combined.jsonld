    {
      "@id": "estleg:Concept_soodaseadus_Taimetoodangu_Inspektsioon_ning_Veterinaar",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "Taimetoodangu Inspektsioon ning Veterinaar",
      "skos:definition": "ja Toiduamet teostavad järelevalvet eksporditava sööda üle ja väljastavad sööda tootja või vahendaja avalduse alusel dokumendi, mis tõendab järelevalvet tootja või vahendaja üle. 6 (6) Sööda impordil on lubatud kohaldada seestöötlemise ja tollikontrolli all töötlemise tolliprotseduure tolliseaduse tähenduses üksnes siis, kui sööta töödeldakse käesoleva seaduse alusel tunnustatud või registreeritud ettevõttes. RT I 2004 34 236 745321 2004-05-01+03:00",
      "estleg:definedIn": [
        {
          "@id": "estleg:soodaseadus_Par_31"
        }
      ],
      "estleg:sourceAct": "Söödaseadus",
      "rdfs:label": "Taimetoodangu Inspektsioon ning Veterinaar (soodaseadus)"
    },
