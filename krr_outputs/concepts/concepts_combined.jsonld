    {
      "@id": "estleg:Concept_reklaamiseadus_reklaam",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "reklaam",
      "skos:definition": "teave, mis on avalikustatud mis tahes üldtajutaval kujul, tasu eest või tasuta, teenuse osutamise või kauba müügi suurendamise, ürituse edendamise või isiku käitumise avalikes huvides suunamise eesmärgil",
      "estleg:definedIn": [
        {
          "@id": "estleg:reklaamiseadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Reklaamiseadus",
      "rdfs:label": "reklaam (reklaamiseadus)"
    },
    {
      "@id": "estleg:Concept_reklaamiseadus_reklaami_avalikustaja",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "reklaami avalikustaja",
      "skos:definition": "füüsiline või juriidiline isik või riigi- või kohaliku omavalitsuse asutus (edaspidi isik ), kes reklaami avalikult esitab, edastab, näitab või levitab",
      "estleg:definedIn": [
        {
          "@id": "estleg:reklaamiseadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Reklaamiseadus",
      "rdfs:label": "reklaami avalikustaja (reklaamiseadus)"
    },
    {
      "@id": "estleg:Concept_reklaamiseadus_reklaami_tellija",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "reklaami tellija",
      "skos:definition": "isik, kes reklaami vahetult tellib või kelle huvides reklaam avalikustatakse",
      "estleg:definedIn": [
        {
          "@id": "estleg:reklaamiseadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Reklaamiseadus",
      "rdfs:label": "reklaami tellija (reklaamiseadus)"
    },
    {
      "@id": "estleg:Concept_reklaamiseadus_reklaami_teostaja",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "reklaami teostaja",
      "skos:definition": "isik, kes reklaami loob või teostab või korraldab selle avalikustamist, välja arvatud tehniline teostaja",
      "estleg:definedIn": [
        {
          "@id": "estleg:reklaamiseadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Reklaamiseadus",
      "rdfs:label": "reklaami teostaja (reklaamiseadus)"
    },
    {
      "@id": "estleg:Concept_reklaamiseadus_teenus",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "teenus",
      "skos:definition": "müügiks pakutav või müüdav hüve, mis ei ole kaup",
      "estleg:definedIn": [
        {
          "@id": "estleg:reklaamiseadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Reklaamiseadus",
