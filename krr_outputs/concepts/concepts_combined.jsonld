        },
        {
          "@id": "estleg:Concept_turvaseadus_valve"
        },
        {
          "@id": "estleg:Concept_turvaseadus_Vallas"
        }
      ]
    },
    {
      "@id": "estleg:Concept_koolieelse_lasteasutuse_seadus_Lasteasutuse_korraldab_ja_kujundab_valla__vi_linnavolikogu_otsusel_mber_valla",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "Lasteasutuse korraldab ja kujundab valla- või linnavolikogu otsusel ümber valla",
      "skos:definition": "või linnavalitsus. Lasteasutuse ümberkorraldamise või ümberkujundamise otsus tehakse arvestusega, et sellest on võimalik teavitada kirjalikult Haridus- ja Teadusministeeriumi, maavanemat, lasteasutust ja vanemaid (eestkostjaid, hooldajaid) vähemalt neli kuud enne ümberkorraldamise või ümberkujundamise tähtaega. 2 (2) Lasteasutuse ümberkorraldamine käesoleva seaduse tähenduses seisneb lasteasutuste ühinemises või jagunemises. Lasteasutused ühinevad või jagunevad järgmiselt: 1 1) lasteasutused ühendatakse üheks lasteasutuseks, kusjuures ühendatavad lasteasutused lõpetavad tegevuse ja nende baasil moodustatakse uus lasteasutus",
      "estleg:definedIn": [
        {
          "@id": "estleg:koolieelse_lasteasutuse_seadus_Par_33"
        }
      ],
      "estleg:sourceAct": "Koolieelse lasteasutuse seadus",
      "rdfs:label": "Lasteasutuse korraldab ja kujundab valla- või linnavolikogu otsusel ümber valla (koolieelse_lasteasutuse_seadus)"
    },
    {
      "@id": "estleg:Concept_kooperatiivsete_riiklik_kooperatiivsete_ja_uhiskondlike_organisatsioonide_vara_t_Kohustatud_subjektid_kesoleva_seaduse_thenduses_on_ETKVL",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "Kohustatud subjektid käesoleva seaduse tähenduses on ETKVL",
      "skos:definition": "i süsteemi organisatsioonid, ühiskondlikud massiorganisatsioonid (ametiühingud jm.), majanditevahelised organisatsioonid, samuti muud kooperatiivsed ja ühiskondlikud organisatsioonid ja nende ühendused ning nende reorganiseerimise või nende vara osastamise teel moodustatud uued organisatsioonid. 2 (2) Kolhooside, sealhulgas kalurikolhooside vara taasriigistamist ja erastamist reguleeritakse 1992. aasta 11. märtsi Eesti Vabariigi põllumajandusreformi seaduse ja sellest tulenevate normatiivaktidega. 3 (3) Kohustatud subjektideks olevad organisatsioonid määrab kindlaks ja kinnitab nende nimekirja Eesti Vabariigi Valitsus kolme kuu jooksul käesoleva seaduse vastuvõtmisest arvates, teatades kohustatud subjektile tema nimekirja kandmisest kümne päeva jooksul. Hilisem nimekirja täiendamine on kehtetu. Kohustatud subjekt kustutatakse nimekirjast Vabariigi Valitsuse otsusega pärast seda, kui on lõpule viidud tema vara taasriigistamine või erastamine.",
      "estleg:definedIn": [
        {
          "@id": "estleg:kooperatiivsete_riiklik_kooperatiivsete_ja_uhiskondlike_organisatsioonide_vara_t_Par_2"
        }
      ],
      "estleg:sourceAct": "Kooperatiivsete, riiklik-kooperatiivsete ja ühiskondlike organisatsioonide vara taasriigistamise ja erastamise kohta",
      "rdfs:label": "Kohustatud subjektid käesoleva seaduse tähenduses on ETKVL (kooperatiivsete_riiklik_kooperatiivsete_ja_uhiskondlike_organisatsioonide_vara_t)"
    },
    {
      "@id": "estleg:Concept_korruptsioonivastane_seadus_Ametikoht_kesoleva_seaduse_thenduses_on_t",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "Ametikoht käesoleva seaduse tähenduses on töö",
      "skos:definition": "või teenistuskoht, millele isik on valitud, nimetatud või töölepingu alusel tööle võetud. 2 (2) Ametiseisund on ametikohast tulenev ametiisiku õiguspädevus vastu võtta teistele isikutele kohustuslikke otsuseid, teha toiminguid, osaleda riigi- või munitsipaalvara erastamise, võõrandamise või kasutusse andmise otsuste tegemisel ning kohustus täita oma ametialaseid kohustusi ausalt ja õiguspäraselt.",
      "estleg:definedIn": [
        {
          "@id": "estleg:korruptsioonivastane_seadus_Par_3"
        }
      ],
      "estleg:sourceAct": "Korruptsioonivastane seadus",
      "rdfs:label": "Ametikoht käesoleva seaduse tähenduses on töö (korruptsioonivastane_seadus)"
    },
    {
      "@id": "estleg:Concept_korruptsioonivastane_seadus_Kesoleva_seaduse_jrgi_on_ametiisik_paragrahv_3_likes_2_stestatud_ametiseisundit_",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "Käesoleva seaduse järgi on ametiisik paragrahv 3 lõikes 2 sätestatud ametiseisundit omav riigi",
      "skos:definition": "või kohaliku omavalitsuse ametnik, samuti tema ülesandeid täitev koosseisuväline teenistuja. 2 (2) Ametiisikud käesoleva seaduse tähenduses on ka: 1 1) Riigikogu liige",
      "estleg:definedIn": [
