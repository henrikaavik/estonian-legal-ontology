          "@id": "estleg:toiduseadus_Par_24"
        }
      ],
      "estleg:sourceAct": "Toiduseadus",
      "rdfs:label": "pakendamis (toiduseadus)"
    },
    {
      "@id": "estleg:Concept_toiduseadus_veo",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "veo",
      "skos:definition": "ja säilitamistingimused. 3 (3) Enda koostatud tehniline kirjeldus ja sellesse tehtavad muudatused peavad olema vormistatud dokumendina, millest peab lisaks käesoleva paragrahvi lõikes 2 toodud andmetele nähtuma vähemalt selle vormistamise kuupäev ning allkirjaga kinnitanud isiku nimi ja ametinimetus. RT I 2001 93 566 73270 2002-01-01+02:00",
      "estleg:definedIn": [
        {
          "@id": "estleg:toiduseadus_Par_24"
        }
      ],
      "estleg:sourceAct": "Toiduseadus",
      "rdfs:label": "veo (toiduseadus)"
    },
    {
      "@id": "estleg:Concept_tolliseadus_Toll_on_Maksu",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "Toll on Maksu",
      "skos:definition": "ja Tolliamet. 9 (9) Tolliametnik on Maksu- ja Tolliameti ametnik, kes tööülesannete täitmisel teostab tolliformaalsusi. 10 (10) Tolliformaalsused on tollikontroll ja teised toimingud, mida tuleb asjaomasel isikul või tollil tollieeskirjade täitmiseks teha. 11 (11) Tolliasutus on Maksu- ja Tolliameti struktuuriüksus, kus on võimalik teostada kõiki või osa tolliformaalsusi.",
      "estleg:definedIn": [
        {
          "@id": "estleg:tolliseadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Tolliseadus",
      "rdfs:label": "Toll on Maksu (tolliseadus)"
    },
    {
      "@id": "estleg:Concept_toostusheite_seadus_Pinna_katmine_kesoleva_seaduse_thenduses_on_he",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "Pinna katmine käesoleva seaduse tähenduses on ühe",
      "skos:definition": "või mitmekordse pideva pinnakattevahendi kihi kandmine: 1 1) M1-kategooria uutele autodele, samuti N1-kategooria sõidukitele, kui pinnakattevahend kantakse peale samas käitises, kus M1-kategooria sõidukitele",
      "estleg:definedIn": [
        {
          "@id": "estleg:toostusheite_seadus_Par_120"
        }
      ],
      "estleg:sourceAct": "Tööstusheite seadus",
      "rdfs:label": "Pinna katmine käesoleva seaduse tähenduses on ühe (toostusheite_seadus)"
    },
    {
      "@id": "estleg:Concept_toostusheite_seadus_N2",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "N2",
      "skos:definition": "ja N3-kategooria sõidukite tehnilise varustuse juurde lahutamatu osana kuuluvale kattele",
      "estleg:definedIn": [
        {
          "@id": "estleg:toostusheite_seadus_Par_120"
        }
      ],
      "estleg:sourceAct": "Tööstusheite seadus",
      "rdfs:label": "N2 (toostusheite_seadus)"
    },
    {
      "@id": "estleg:Concept_toostusheite_seadus_N1",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "N1",
      "skos:definition": ", N2- ja N3-kategooria furgoonidele ja veoautodele, välja arvatud veoautode kabiinid",
      "estleg:definedIn": [
        {
          "@id": "estleg:toostusheite_seadus_Par_120"
        }
      ],
      "estleg:sourceAct": "Tööstusheite seadus",
      "rdfs:label": "N1 (toostusheite_seadus)"
    },
    {
      "@id": "estleg:Concept_toostusheite_seadus_M2",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "M2",
      "skos:definition": "ja M3-kategooria bussidele, O1-, O2-, O3- ja O4-kategooria haagistele",
      "estleg:definedIn": [
        {
          "@id": "estleg:toostusheite_seadus_Par_120"
        }
      ],
      "estleg:sourceAct": "Tööstusheite seadus",
      "rdfs:label": "M2 (toostusheite_seadus)"
    },
    {
      "@id": "estleg:Concept_toostusheite_seadus_puit",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "puit",
      "skos:definition": ", tekstiil-, kanga-, kile-, paber- ja nahkpinnale. 2 (2) Pinna katmise hulka ei arvata aluspinna metalliga katmist elektroforees- ja keemilise pihustusmeetodiga. Kui sama tooteartikli juures on pinna katmise üheks etapiks mingi trükimeetodi kasutamine, loetakse trükkimine pinna katmise üheks osaks. Pinna katmiseks ei loeta trükkimist käesoleva seaduse § 126 tähenduses.",
      "estleg:definedIn": [
        {
          "@id": "estleg:toostusheite_seadus_Par_120"
        }
      ],
      "estleg:sourceAct": "Tööstusheite seadus",
      "rdfs:label": "puit (toostusheite_seadus)"
    },
    {
      "@id": "estleg:Concept_toostusomandi_oiguskorralduse_aluste_seadus_kauba",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "kauba",
      "skos:definition": "ja teenindusmärgid (edaspidi kaubamärk ), mida registreeritakse kaubamärgiseaduse (RT I 2002, 49, 308",
      "estleg:definedIn": [
        {
          "@id": "estleg:toostusomandi_oiguskorralduse_aluste_seadus_Par_1"
        }
      ],
      "estleg:sourceAct": "Tööstusomandi õiguskorralduse aluste seadus",
      "rdfs:label": "kauba (toostusomandi_oiguskorralduse_aluste_seadus)"
    },
    {
      "@id": "estleg:Concept_toostusomandi_oiguskorralduse_aluste_seadus_taotlus",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "taotlus",
      "skos:definition": "tööstusomandi kaitse seaduse kohaselt esitatud registreerimistaotlus tööstusomandi esemele õiguskaitse saamiseks. Patendikaitse taotlemise korral mõistetakse taotluse all patenditaotlust",
      "estleg:definedIn": [
        {
          "@id": "estleg:toostusomandi_oiguskorralduse_aluste_seadus_Par_3"
        }
      ],
      "estleg:sourceAct": "Tööstusomandi õiguskorralduse aluste seadus",
      "rdfs:label": "taotlus (toostusomandi_oiguskorralduse_aluste_seadus)"
    },
    {
      "@id": "estleg:Concept_toostusomandi_oiguskorralduse_aluste_seadus_taotleja",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "taotleja",
      "skos:definition": "isik või selle isiku õigusjärglane, kes on esitanud taotluse tööstusomandi esemele õiguskaitse saamiseks",
      "estleg:definedIn": [
        {
          "@id": "estleg:toostusomandi_oiguskorralduse_aluste_seadus_Par_3"
        }
      ],
      "estleg:sourceAct": "Tööstusomandi õiguskorralduse aluste seadus",
