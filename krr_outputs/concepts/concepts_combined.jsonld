    {
      "@id": "estleg:Concept_valisohu_kaitse_seadus_Mootor",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "Mootor",
      "skos:definition": ", õhu-, vee- ja rööbassõiduki, mopeedi, maanteevälise liikurmasina, traktori ning muu liikuva saasteallika heitgaasi saasteainete sisaldus ja suitsusus ning müratase ei tohi ületada kehtestatud normatiive. 2 (2) Maanteeväline liikurmasin käesoleva seaduse tähenduses on liikuv masin, transporditav tööstusseade või kerega või ilma kereta sõiduk, mis ei ole mõeldud reisijate või kauba veoks maanteel ning millele on paigaldatud survesüütemootor netovõimsusega 18–560 kilovatti. 3 (3) Käesoleva paragrahvi lõikes 1 nimetatud liikuva saasteallika heitgaasi saasteainete sisalduse ja suitsususe normatiivid, sealhulgas välisõhku eralduvate saasteainete heitkoguste piirväärtused mootorsõiduki läbisõidu või energiaühiku kohta, ning mürataseme piirväärtused kehtestab keskkonnaminister määrustega ./dyn=874386&id=921174",
      "estleg:definedIn": [
        {
          "@id": "estleg:valisohu_kaitse_seadus_Par_55"
        }
      ],
      "estleg:sourceAct": "Välisõhu kaitse seadus",
      "rdfs:label": "Mootor (valisohu_kaitse_seadus)"
    },
