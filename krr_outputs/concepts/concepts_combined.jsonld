      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "blokeeritava ühenduse füüsiline isik",
      "skos:definition": "välismaalane, kes tegutseb blokeeritava ühenduse huvides, või blokeeritava riigi kodanik.",
      "estleg:definedIn": [
        {
          "@id": "estleg:rahvusvahelise_sanktsiooni_seadus_Par_2"
        }
      ],
