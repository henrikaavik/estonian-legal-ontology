        }
      ],
      "estleg:sourceAct": "Sundeksemplari seadus",
      "rdfs:label": "trükis (sundeksemplari_seadus)"
    },
    {
      "@id": "estleg:Concept_sundeksemplari_seadus_auvis",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "auvis",
      "skos:definition": "eriseadmete abil kuulmis- ja nägemismeelega tajutava informatsiooni kandja: heliplaat, helilint, helikassett, diapositiiv, diafilm, videokassett, mikrokaart ja mikrofilm",
      "estleg:definedIn": [
