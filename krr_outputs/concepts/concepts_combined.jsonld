      ],
      "skos:prefLabel": "isiku majandus",
      "skos:definition": "või kutsetegevuses kasutatava sõiduki tähistust selle isiku nime, kontaktandmete, kaubamärgi, domeeninime ja tegevusalaga",
      "estleg:definedIn": [
