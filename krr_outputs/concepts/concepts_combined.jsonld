      "rdfs:label": "sadama navigatsioonimärgistus (sadamaseadus)"
    },
    {
      "@id": "estleg:Concept_sadamaseadus_sadama_eeskiri",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "sadama eeskiri",
      "skos:definition": "sadamateenuste osutamisele esitatavad käitus-, navigatsiooni-, keskkonna-, ohutus- ja muud nõuded ning info sadama kohta",
      "estleg:definedIn": [
        {
          "@id": "estleg:sadamaseadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Sadamaseadus",
      "rdfs:label": "sadama eeskiri (sadamaseadus)"
    },
    {
      "@id": "estleg:Concept_sadamaseadus_sadamakapten",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "sadamakapten",
      "skos:definition": "sadamas ohutut veeliiklust ja veesõidukite ohutut seismist korraldav isik",
      "estleg:definedIn": [
        {
          "@id": "estleg:sadamaseadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Sadamaseadus",
      "rdfs:label": "sadamakapten (sadamaseadus)"
    },
    {
      "@id": "estleg:Concept_sadamaseadus_sadama_turvalem",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "sadama turvaülem",
      "skos:definition": "sadamas turvanõuete täitmist korraldav isik",
      "estleg:definedIn": [
        {
          "@id": "estleg:sadamaseadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Sadamaseadus",
      "rdfs:label": "sadama turvaülem (sadamaseadus)"
    },
    {
      "@id": "estleg:Concept_sadamaseadus_sadamarajatis",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "sadamarajatis",
      "skos:definition": "sadama maa-alal või akvatooriumil (edaspidi mõlemad koos sadamaala ) turvanõuete täitmiseks määratud laeva ja sadama vahelise koostöö ja liidese koht, mis hõlmab vajaduse korral ka sadama territooriumi, akvatooriumi ja sissesõiduteed",
      "estleg:definedIn": [
        {
          "@id": "estleg:sadamaseadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Sadamaseadus",
      "rdfs:label": "sadamarajatis (sadamaseadus)"
    },
    {
      "@id": "estleg:Concept_sadamaseadus_laeva_ja_sadama_vaheline_liides",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "laeva ja sadama vaheline liides",
      "skos:definition": "vastastikune mõju, mis tekib ajal, mil laev on otseselt ja vahetult seotud tegevusega, mis hõlmab inimeste või kaupade liikumist või sadamateenuste osutamist laevale või laevalt",
      "estleg:definedIn": [
        {
          "@id": "estleg:sadamaseadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Sadamaseadus",
      "rdfs:label": "laeva ja sadama vaheline liides (sadamaseadus)"
    },
    {
      "@id": "estleg:Concept_sadamaseadus_sadamarajatise_turvalem",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "sadamarajatise turvaülem",
      "skos:definition": "sadamarajatise turvanõuete täitmist korraldav isik",
      "estleg:definedIn": [
        {
          "@id": "estleg:sadamaseadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Sadamaseadus",
      "rdfs:label": "sadamarajatise turvaülem (sadamaseadus)"
    },
    {
      "@id": "estleg:Concept_sadamaseadus_turvaettevtja",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "turvaettevõtja",
      "skos:definition": "ettevõtja, kes võib täita käesolevas seaduses sätestatud ülesandeid, kellel on turvateenuse osutamiseks tegevusluba turvaseaduse tähenduses ning käesoleva seaduse §-s 18 sätestatud tegevusluba",
      "estleg:definedIn": [
        {
          "@id": "estleg:sadamaseadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Sadamaseadus",
      "rdfs:label": "turvaettevõtja (sadamaseadus)"
    },
    {
      "@id": "estleg:Concept_sadamaseadus_turvatase",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "turvatase",
      "skos:definition": "riskimäär, millele vastavalt rakendatakse turvaintsidendi ärahoidmiseks kaitse- ja turvameetmeid",
      "estleg:definedIn": [
        {
          "@id": "estleg:sadamaseadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Sadamaseadus",
      "rdfs:label": "turvatase (sadamaseadus)"
    },
    {
      "@id": "estleg:Concept_sadamaseadus_turvaintsident",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "turvaintsident",
      "skos:definition": "vahejuhtum, tegu või asjaolu, mis võib ohustada laeva, laeva ja sadama vahelise liidese või sadama ja sadamarajatise turvalisust",
      "estleg:definedIn": [
        {
          "@id": "estleg:sadamaseadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Sadamaseadus",
      "rdfs:label": "turvaintsident (sadamaseadus)"
    },
    {
      "@id": "estleg:Concept_sadamaseadus_riigikaitse_lesannetega_sadam",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "riigikaitse ülesannetega sadam",
      "skos:definition": "sadam, mis on ette nähtud üksnes sõjalaevade ja mereväe abilaevade sildumiseks ja teenindamiseks",
      "estleg:definedIn": [
        {
          "@id": "estleg:sadamaseadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Sadamaseadus",
      "rdfs:label": "riigikaitse ülesannetega sadam (sadamaseadus)"
    },
    {
      "@id": "estleg:Concept_sadamaseadus_riigihalduslesannetega_sadam",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "riigihaldusülesannetega sadam",
      "skos:definition": "sadam, mis on ette nähtud üksnes riigihaldusülesandeid täitvate laevade sildumiseks ja teenindamiseks",
      "estleg:definedIn": [
        {
          "@id": "estleg:sadamaseadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Sadamaseadus",
      "rdfs:label": "riigihaldusülesannetega sadam (sadamaseadus)"
    },
    {
      "@id": "estleg:Concept_sadamaseadus_vikesadam",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "väikesadam",
      "skos:definition": "sadam või sadama osa, kus osutatakse sadamateenuseid alla 24-meetrise kogupikkusega veesõidukitele",
      "estleg:definedIn": [
        {
          "@id": "estleg:sadamaseadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Sadamaseadus",
      "rdfs:label": "väikesadam (sadamaseadus)"
    },
    {
      "@id": "estleg:Concept_sadamaseadus_laevaheitmed",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "laevaheitmed",
      "skos:definition": "kõik jäätmed, välja arvatud lastijäätmed, sealhulgas reovesi, prügi, pilsivesi, masinaruumist või veomahutist pärit naftasaadusi ja õli sisaldavad jäätmed ning jäätmed, mis tekivad veesõiduki töö käigus ja kuuluvad rahvusvahelise konventsiooni merereostuse vältimiseks laevadelt (edaspidi MARPOL ) 73/78 I, IV, V ja VI lisa kohaldamisalasse, ning lastiga seotud jäätmed, mis on määratletud MARPOL 73/78 V lisa rakendamise juhistes",
      "estleg:definedIn": [
        {
          "@id": "estleg:sadamaseadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Sadamaseadus",
      "rdfs:label": "laevaheitmed (sadamaseadus)"
    },
    {
      "@id": "estleg:Concept_sadamaseadus_lastijtmed",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "lastijäätmed",
      "skos:definition": "veesõiduki pardal lastiruumides või mahutites oleva lasti jäägid, mis jäävad järele pärast lastimis-, lossimis- ja koristustööde lõpetamist, sealhulgas lastimise ja lossimise ülejäägid",
      "estleg:definedIn": [
        {
          "@id": "estleg:sadamaseadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Sadamaseadus",
      "rdfs:label": "lastijäätmed (sadamaseadus)"
    },
    {
      "@id": "estleg:Concept_sadamaseadus_prgi",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "prügi",
      "skos:definition": "MARPOL V lisas määratletud veesõiduki tavapärase tegevuse käigus tekkivad mis tahes liiki toidu-, olme- ja muud jäätmed, millest on vaja pidevalt või perioodiliselt vabaneda, välja arvatud toorkala ja selle osad ning ained, mis on määratletud või nimetatud MARPOL-i teistes lisades",
      "estleg:definedIn": [
        {
          "@id": "estleg:sadamaseadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Sadamaseadus",
      "rdfs:label": "prügi (sadamaseadus)"
    },
    {
      "@id": "estleg:Concept_sadamaseadus_reovesi",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "reovesi",
      "skos:definition": "MARPOL IV lisas määratletud mis tahes tüüpi tualeti, pissuaari, bidee või WC äravooluava kaudu ärajuhitud vedelik või muud jäätmed, meditsiiniruumis (dispanser, haiglasektsioon) asuva pesuvanni, pesutorustiku või äravooluava kaudu ärajuhitud vedelik, elusloomi sisaldavast ruumist ärajuhitud vedelik või eespool loetletud ärajuhitud vedelike või jäätmetega segunenud muu reovesi",
      "estleg:definedIn": [
        {
          "@id": "estleg:sadamaseadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Sadamaseadus",
      "rdfs:label": "reovesi (sadamaseadus)"
    },
    {
      "@id": "estleg:Concept_sadamaseadus_lastiga_seotud_jtmed",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "lastiga seotud jäätmed",
      "skos:definition": "veesõiduki pardal lasti kinnitamise või käitlemise tulemusel jäätmeteks muutunud mis tahes materjalid, seahulgas näiteks pakkimispuit, tõstealused, vooderdus- ja pakkematerjalid, vineer, paber, papp, terastrossid ja -tropid ning muu selline",
      "estleg:definedIn": [
        {
          "@id": "estleg:sadamaseadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Sadamaseadus",
      "rdfs:label": "lastiga seotud jäätmed (sadamaseadus)"
    },
    {
      "@id": "estleg:Concept_sadamaseadus_sadama_vastuvtuseadmed",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "sadama vastuvõtuseadmed",
      "skos:definition": "paiksed, ankurdatud või liikuvad seadmed, millega saab vastu võtta laevaheitmeid ja lastijäätmeid.",
      "estleg:definedIn": [
        {
          "@id": "estleg:sadamaseadus_Par_2"
        }
      ],
      "estleg:sourceAct": "Sadamaseadus",
      "rdfs:label": "sadama vastuvõtuseadmed (sadamaseadus)"
    },
