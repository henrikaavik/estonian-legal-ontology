          "@id": "estleg:sundeksemplari_seadus_Par_3"
        }
      ],
      "estleg:sourceAct": "Sundeksemplari seadus",
      "rdfs:label": "sundeksemplar (sundeksemplari_seadus)"
    },
    {
      "@id": "estleg:Concept_sundeksemplari_seadus_trkis",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "trükis",
      "skos:definition": "trükitehniliste vahenditega valmistatud informatsioonikandja, kaasa arvatud rahvusvahelises pimedate kirjas (Braille' kirjas) trükis",
      "estleg:definedIn": [
