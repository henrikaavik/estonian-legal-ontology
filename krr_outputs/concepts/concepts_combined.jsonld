          "@id": "estleg:Concept_turvaseadus_kaitse"
        }
      ]
    },
    {
      "@id": "estleg:Concept_kutseseadus_kutseala",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "kutseala",
      "skos:definition": "samalaadset kompetentsust eeldav tegevusvaldkond",
      "estleg:definedIn": [
        {
          "@id": "estleg:kutseseadus_Par_3"
        }
      ],
      "estleg:sourceAct": "Kutseseadus",
      "rdfs:label": "kutseala (kutseseadus)"
    },
    {
      "@id": "estleg:Concept_kutseseadus_kutsetegevuse_valdkond",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "kutsetegevuse valdkond",
      "skos:definition": "tegevusvaldkond, mis hõlmab mitut lähedast kutseala",
      "estleg:definedIn": [
        {
          "@id": "estleg:kutseseadus_Par_3"
        }
      ],
      "estleg:sourceAct": "Kutseseadus",
      "rdfs:label": "kutsetegevuse valdkond (kutseseadus)"
    },
    {
      "@id": "estleg:Concept_kutseseadus_kvalifikatsioon",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "kvalifikatsioon",
      "skos:definition": "hindamise ametliku tulemusena tunnustatud kompetentsus, millega kaasneb iseseisvus ja vastutus.",
      "estleg:definedIn": [
        {
          "@id": "estleg:kutseseadus_Par_3"
        }
      ],
      "estleg:sourceAct": "Kutseseadus",
      "rdfs:label": "kvalifikatsioon (kutseseadus)",
      "skos:exactMatch": [
