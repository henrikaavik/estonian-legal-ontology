    {
      "@id": "estleg:Concept_taiskasvanute_koolituse_seadus_Enne_kesoleva_seaduse_justumist_tiskasvanute_koolitusasutusena_tegutsenud_riigi_",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "Enne käesoleva seaduse jõustumist täiskasvanute koolitusasutusena tegutsenud riigi- ja kohaliku omavalitsuse asutused ning avalik",
      "skos:definition": "õiguslikud juriidilised isikud on kuni 2016. aasta 30. juunini võrdsustatud täienduskoolitusasutuse pidajaga käesoleva seaduse tähenduses. 3 (3) Täienduskoolitusasutuse pidajad peavad käesoleva seaduse § 7 lõikes 1 nimetatud täienduskoolitusasutuse tegevuse kvaliteedi tagamise alused kehtestama hiljemalt 2016. aasta 1. juuliks.",
      "estleg:definedIn": [
        {
          "@id": "estleg:taiskasvanute_koolituse_seadus_Par_20"
        }
      ],
      "estleg:sourceAct": "Täiskasvanute koolituse seadus",
      "rdfs:label": "Enne käesoleva seaduse jõustumist täiskasvanute koolitusasutusena tegutsenud riigi- ja kohaliku omavalitsuse asutused ning avalik (taiskasvanute_koolituse_seadus)"
    },
    {
      "@id": "estleg:Concept_teeseadus_Riigimetsa_majandamist_korraldaval_isikul_vi_riigiasutusel_on_igus_vajadusel_slm",
      "@type": [
        "owl:NamedIndividual",
