      "@id": "estleg:Concept_surveseadme_ohutuse_seadus_V_liik",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "V liik",
      "skos:definition": "plahvatus- või tuleohtliku, väga tuleohtliku, eriti tuleohtliku, mürgise või väga mürgise vedeliku (edaspidi ohtlik vedelik ) anumad, milles rõhu tekitab vedelikusamba kõrgus või hüdrauliline löök",
      "estleg:definedIn": [
        {
          "@id": "estleg:surveseadme_ohutuse_seadus_Par_5"
        }
      ],
      "estleg:sourceAct": "Surveseadme ohutuse seadus",
      "rdfs:label": "V liik (surveseadme_ohutuse_seadus)"
    },
    {
      "@id": "estleg:Concept_surveseadme_ohutuse_seadus_Surveseadme_kitaja_peab_olema_vhemalt_18",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "Surveseadme käitaja peab olema vähemalt 18",
      "skos:definition": "aastane ja tal peavad olema tööks vajalikud teadmised ja oskused. 3 (3) Surveseadme käitaja peab olema sooritanud eksami vastaval erialal töötamiseks. Surveseadme käitaja erialaeksami komisjoni peab kuuluma käesoleva seaduse §-s 31 nimetatud isiku esindaja, kes annab allkirja surveseadme käitamisoskust tõendavale pädevustunnistusele. 4 (4) Loetelu surveseadmetest, mille käitajalt nõutakse pädevustunnistust, samuti käitajate hindamise ja tõendamise korra kehtestab majandus- ja kommunikatsiooniminister. ./dyn=748803&id=762476 RT I 2004 2 5 692098 2004-02-01+02:00",
      "estleg:definedIn": [
        {
          "@id": "estleg:surveseadme_ohutuse_seadus_Par_21"
        }
      ],
      "estleg:sourceAct": "Surveseadme ohutuse seadus",
      "rdfs:label": "Surveseadme käitaja peab olema vähemalt 18 (surveseadme_ohutuse_seadus)"
    },
