    {
      "@id": "estleg:Concept_eestit_okupeerinud_riikide_julgeolekuorganite_voi_relvajoudude_luure_voi_vastulu_Julgeoleku",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "Julgeoleku",
      "skos:definition": "ja luureorganid käesoleva seaduse mõistes on Saksa Riigi julgeolekuorganid ning relvajõudude luure- ja vastuluureorganid ning nendele alluvad struktuurid: 1 1) Saksa Riigi Julgeolekupolitsei - Sicherheitspolizei (SiPo) ja Saksa Riigi Julgeolekuteenistus - Sicherheitsdienst (SD), mis alates 1939. aastast tegutses SS-i Riigi Julgeoleku Peaameti - Reichs Sicherheits Hauptamt (RSHA) III ja VI osakonnana",
      "estleg:definedIn": [
        {
          "@id": "estleg:eestit_okupeerinud_riikide_julgeolekuorganite_voi_relvajoudude_luure_voi_vastulu_Par_2"
        }
      ],
      "estleg:sourceAct": "Eestit okupeerinud riikide julgeolekuorganite või relvajõudude luure- või vastuluureorganite teenistuses olnud või nendega koostööd teinud isikute arvelevõtmise ja avalikustamisekorra seadus",
      "rdfs:label": "Julgeoleku (eestit_okupeerinud_riikide_julgeolekuorganite_voi_relvajoudude_luure_voi_vastulu)"
    },
    {
      "@id": "estleg:Concept_eestit_okupeerinud_riikide_julgeolekuorganite_voi_relvajoudude_luure_voi_vastulu_Saksa_Riigi_Salapolitsei",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "Saksa Riigi Salapolitsei",
      "skos:definition": "Geheime Staatspolitzei (Gestapo), mis alates 1939. aastast tegutses SS-i Riigi Julgeoleku Peaameti (RSHA) IV osakonnana",
      "estleg:definedIn": [
        {
          "@id": "estleg:eestit_okupeerinud_riikide_julgeolekuorganite_voi_relvajoudude_luure_voi_vastulu_Par_2"
        }
      ],
      "estleg:sourceAct": "Eestit okupeerinud riikide julgeolekuorganite või relvajõudude luure- või vastuluureorganite teenistuses olnud või nendega koostööd teinud isikute arvelevõtmise ja avalikustamisekorra seadus",
      "rdfs:label": "Saksa Riigi Salapolitsei (eestit_okupeerinud_riikide_julgeolekuorganite_voi_relvajoudude_luure_voi_vastulu)"
    },
    {
      "@id": "estleg:Concept_eestit_okupeerinud_riikide_julgeolekuorganite_voi_relvajoudude_luure_voi_vastulu_Julgeoleku_2",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "Julgeoleku",
      "skos:definition": "ja luureorganid käesoleva seaduse mõistes on NSV Liidu julgeolekuorganid ning relvajõudude luure- ja vastuluureorganid ning nendele alluvad struktuurid: 1 1) NSV Liidu Siseasjade Rahvakomissariaadi (Narodnõi Komissariat Vnutrennihh Del) koosseisu kuulunud Riikliku Julgeoleku Peavalitsus - GUGB (Glavnoje Upravlenije Gossudarstvennoi Bezopasnosti), mis eksisteeris 1934. aasta 10. juulist kuni 1941. aasta 3. veebruarini ja 1941. aasta 20. juulist kuni 1943. aasta 14. aprillini",
      "estleg:definedIn": [
        {
          "@id": "estleg:eestit_okupeerinud_riikide_julgeolekuorganite_voi_relvajoudude_luure_voi_vastulu_Par_2"
        }
      ],
      "estleg:sourceAct": "Eestit okupeerinud riikide julgeolekuorganite või relvajõudude luure- või vastuluureorganite teenistuses olnud või nendega koostööd teinud isikute arvelevõtmise ja avalikustamisekorra seadus",
      "rdfs:label": "Julgeoleku (eestit_okupeerinud_riikide_julgeolekuorganite_voi_relvajoudude_luure_voi_vastulu)"
    },
    {
      "@id": "estleg:Concept_eestit_okupeerinud_riikide_julgeolekuorganite_voi_relvajoudude_luure_voi_vastulu_NSV_Liidu_Riikliku_Julgeoleku_Rahvakomissariaat",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalConcept"
      ],
      "skos:prefLabel": "NSV Liidu Riikliku Julgeoleku Rahvakomissariaat",
      "skos:definition": "NKGB (Narodnõi Komissariat Gossudarstvennoi Bezopasnosti), mis eksisteeris 1941. aasta 3. veebruarist kuni 20. juulini ja 1943. aasta 14. aprillist kuni 1946. aasta 15. märtsini",
      "estleg:definedIn": [
        {
          "@id": "estleg:eestit_okupeerinud_riikide_julgeolekuorganite_voi_relvajoudude_luure_voi_vastulu_Par_2"
        }
      ],
      "estleg:sourceAct": "Eestit okupeerinud riikide julgeolekuorganite või relvajõudude luure- või vastuluureorganite teenistuses olnud või nendega koostööd teinud isikute arvelevõtmise ja avalikustamisekorra seadus",
      "rdfs:label": "NSV Liidu Riikliku Julgeoleku Rahvakomissariaat (eestit_okupeerinud_riikide_julgeolekuorganite_voi_relvajoudude_luure_voi_vastulu)"
    },
    {
      "@id": "estleg:Concept_eestit_okupeerinud_riikide_julgeolekuorganite_voi_relvajoudude_luure_voi_vastulu_NSV_Liidu_Julgeoleku_Ministeerium",
      "@type": [
