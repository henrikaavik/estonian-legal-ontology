    },
    {
      "@id": "estleg:AOS_Par_80_asjaoigusseadus_osa5",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_AOS_osa5"
      ],
      "estleg:paragrahv": "§ 80",
      "rdfs:label": "Asja väljanõudmine ebaseaduslikust valdusest",
      "estleg:requestedCluster": "asjaoiguste_kaitse",
      "estleg:summary": "Omanikul on vindikatsiooninõue õigusliku aluseta valdaja vastu omandi tunnustamiseks ja asja tagastamiseks.",
      "estleg:sourceAct": "Asjaõigusseadus"
    },
    {
      "@id": "estleg:AOS_Par_82",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_AOS_osa5"
      ],
      "estleg:paragrahv": "§ 82",
      "rdfs:label": "Valduse tõendamine",
      "estleg:requestedCluster": "asjaoiguste_kaitse",
      "estleg:summary": "Norm käsitleb valduse olemasolu ja iseloomu tõendamist omandi kaitse nõuete lahendamisel.",
      "estleg:sourceAct": "Asjaõigusseadus"
    },
    {
      "@id": "estleg:AOS_Par_83_asjaoigusseadus_osa5",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_AOS_osa5"
      ],
      "estleg:paragrahv": "§ 83",
      "rdfs:label": "Valdaja vastuväited",
      "estleg:requestedCluster": "asjaoiguste_kaitse",
      "estleg:summary": "Valdaja võib keelduda asja väljaandmisest, kui tal või teatud juhtudel kaudsel valdajal on omaniku suhtes õigus asja vallata.",
      "estleg:sourceAct": "Asjaõigusseadus",
      "estleg:normativeType": [
        {
          "@id": "estleg:NormType_Right"
        }
      ]
    },
    {
      "@id": "estleg:AOS_Par_84_asjaoigusseadus_osa5",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_AOS_osa5"
      ],
      "estleg:paragrahv": "§ 84",
      "rdfs:label": "Valdaja vastutus asja ja päraldiste eest",
      "estleg:requestedCluster": "asjaoiguste_kaitse",
      "estleg:summary": "Pahauskne või omavoliline valdaja vastutab asja hävimise, väärtuse vähenemise ja päraldiste osas rangemalt kui heauskne valdaja.",
      "estleg:sourceAct": "Asjaõigusseadus"
    },
    {
      "@id": "estleg:AOS_Par_85",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_AOS_osa5"
      ],
      "estleg:paragrahv": "§ 85",
      "rdfs:label": "Kasu väljaandmine ja hüvitamine",
      "estleg:requestedCluster": "asjaoiguste_kaitse",
      "estleg:summary": "Paragrahv reguleerib valdaja saadud kasu väljaandmist ning kahju või kasu hüvitamise ulatust omaniku nõude korral.",
      "estleg:sourceAct": "Asjaõigusseadus"
    },
    {
      "@id": "estleg:AOS_Par_88_asjaoigusseadus_osa5",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_AOS_osa5"
      ],
      "estleg:paragrahv": "§ 88",
      "rdfs:label": "Kulutuste hüvitamine valdajale",
      "estleg:requestedCluster": "asjaoiguste_kaitse",
      "estleg:summary": "Valdajal on õigus nõuda vajalike kulutuste hüvitamist ning seaduses sätestatud tingimustel parendused asjalt eemaldada.",
      "estleg:sourceAct": "Asjaõigusseadus",
      "estleg:normativeType": [
        {
          "@id": "estleg:NormType_Right"
        }
      ]
    },
    {
      "@id": "estleg:AOS_Par_89_asjaoigusseadus_osa5",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_AOS_osa5"
      ],
      "estleg:paragrahv": "§ 89",
      "rdfs:label": "Omandi kaitse valduse kaotusega mitteseotud rikkumise korral",
      "estleg:requestedCluster": "asjaoiguste_kaitse",
      "estleg:summary": "Omanik võib nõuda omandiõiguse rikkumise kõrvaldamist ja rikkumisest hoidumist ka siis, kui valdus ei ole kaotatud.",
      "estleg:sourceAct": "Asjaõigusseadus",
      "estleg:normativeType": [
        {
          "@id": "estleg:NormType_Right"
        }
      ]
    },
    {
      "@id": "estleg:AOS_Par_90_asjaoigusseadus_osa5",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_AOS_osa5"
      ],
      "estleg:paragrahv": "§ 90",
      "rdfs:label": "Valdaja omandi eeldus",
      "estleg:requestedCluster": "asjaoiguste_kaitse",
      "estleg:summary": "Vallasasja valdajat eeldatakse omanikuks kuni vastupidise tõendamiseni, mis lihtsustab valdusel põhinevat õiguskaitset.",
      "estleg:sourceAct": "Asjaõigusseadus"
    },
    {
      "@id": "estleg:AOS_Par_92_asjaoigusseadus_osa5",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_AOS_osa5"
      ],
      "estleg:paragrahv": "§ 92",
      "rdfs:label": "Vallasomandi tekkimine üleandmisega",
      "estleg:requestedCluster": "voorandamine",
      "estleg:summary": "Vallasomand tekib valduse üleandmise ja omandi ülemineku kokkuleppega, kui seadus ei sätesta teisiti.",
      "estleg:sourceAct": "Asjaõigusseadus"
    },
    {
      "@id": "estleg:AOS_Par_93_asjaoigusseadus_osa5",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_AOS_osa5"
      ],
      "estleg:paragrahv": "§ 93",
      "rdfs:label": "Omandamine asja väljanõudeõiguse loovutamisega",
      "estleg:requestedCluster": "voorandamine",
      "estleg:summary": "Asja omand võib üle minna ka väljanõudeõiguse loovutamise teel, kui otsene valduse üleandmine ei toimu.",
      "estleg:sourceAct": "Asjaõigusseadus",
      "estleg:normativeType": [
        {
          "@id": "estleg:NormType_Right"
        }
      ]
    },
    {
      "@id": "estleg:AOS_Par_94",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_AOS_osa5"
      ],
      "estleg:paragrahv": "§ 94",
      "rdfs:label": "Omandamine asja jätmisega võõrandaja valdusse",
      "estleg:requestedCluster": "voorandamine",
      "estleg:summary": "Omand võib üle minna ka siis, kui asi jäetakse kokkuleppel võõrandaja valdusse, kui omandi üleminek on selgelt kokku lepitud.",
      "estleg:sourceAct": "Asjaõigusseadus",
      "estleg:normativeType": [
        {
          "@id": "estleg:NormType_Right"
        }
      ]
    },
    {
      "@id": "estleg:AOS_Par_95_asjaoigusseadus_osa5",
      "@type": [
        "owl:NamedIndividual",
        "estleg:LegalProvision_AOS_osa5"
      ],
      "estleg:paragrahv": "§ 95",
      "rdfs:label": "Heauskne omandamine",
      "estleg:requestedCluster": "voorandamine",
      "estleg:summary": "Heauskne omandamine võimaldab omandi üleminekut ka mitteõigustatud võõrandajalt, arvestades seaduses sätestatud omaniku kaitset.",
      "estleg:sourceAct": "Asjaõigusseadus"
    }
  ]
}
