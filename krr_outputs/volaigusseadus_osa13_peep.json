          "@id": "estleg:VOS_Par644"
        }
      ]
    },
    {
      "@id": "estleg:VOS_Par221",
      "@type": [
        "owl:NamedIndividual",
        "estleg:Section"
      ],
      "estleg:sectionNumber": "221",
      "rdfs:label": "§ 221. Asja lepingutingimustele mittevastavusele tuginemise erisused",
