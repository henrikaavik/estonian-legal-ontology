      "@id": "estleg:VOS_Par220",
      "@type": [
        "owl:NamedIndividual",
        "estleg:Section"
      ],
      "estleg:sectionNumber": "220",
      "rdfs:label": "§ 220. Asja lepingutingimustele mittevastavusest teatamine",
      "estleg:inPart": {
        "@id": "estleg:VOS_Part13"
      },
      "estleg:coversConcept": [
        {
          "@id": "estleg:ConformityAndRemedies"
        }
