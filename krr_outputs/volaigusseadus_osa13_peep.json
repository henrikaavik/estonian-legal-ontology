        "@id": "estleg:VOS_Part13"
      },
      "estleg:coversConcept": [
        {
          "@id": "estleg:ConformityAndRemedies"
        }
      ],
      "estleg:summary": "Annab müüjale regressivõimaluse tootja, varasema müüja või vahendaja vastu puudustega asja korral."
    },
    {
      "@id": "estleg:VOS_Par229",
      "@type": [
        "owl:NamedIndividual",
        "estleg:Section"
      ],
      "estleg:sectionNumber": "229",
      "rdfs:label": "§ 229. Ostja kohustus asi valdusse võtta ja säilitada",
