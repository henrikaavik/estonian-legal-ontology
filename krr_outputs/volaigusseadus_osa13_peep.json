          "@id": "estleg:VOS_Par642"
        }
      ]
    },
    {
      "@id": "estleg:VOS_Par219",
      "@type": [
        "owl:NamedIndividual",
        "estleg:Section"
      ],
      "estleg:sectionNumber": "219",
      "rdfs:label": "§ 219. Asja ülevaatamise kohustus",
      "estleg:inPart": {
        "@id": "estleg:VOS_Part13"
      },
      "estleg:coversConcept": [
        {
          "@id": "estleg:ConformityAndRemedies"
        }
      ],
      "estleg:summary": "Ostjal on kohustus asi mõistliku aja jooksul üle vaadata ning puudused tuvastada.",
