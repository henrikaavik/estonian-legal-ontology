    {
      "@id": "estleg:VOS_Par208",
      "@type": [
        "owl:NamedIndividual",
        "estleg:Section"
      ],
      "estleg:sectionNumber": "208",
      "rdfs:label": "§ 208. Müügilepingu mõiste",
      "estleg:inPart": {
        "@id": "estleg:VOS_Part13"
      },
      "estleg:coversConcept": [
        {
          "@id": "estleg:SaleContract"
        }
      ],
      "estleg:summary": "Määratleb müügilepingu: müüja kohustub asja üle andma ja omandi üle kandma, ostja kohustub tasuma ostuhinna.",
      "estleg:normativeType": [
        {
          "@id": "estleg:NormType_Obligation"
        }
      ],
      "estleg:semanticallySimilarTo": [
        {
          "@id": "estleg:Vlaigusseadus_Par_208"
        }
      ]
    },
    {
      "@id": "estleg:VOS_Par209",
      "@type": [
        "owl:NamedIndividual",
        "estleg:Section"
      ],
      "estleg:sectionNumber": "209",
      "rdfs:label": "§ 209. Asja üleandmise kohustus",
      "estleg:inPart": {
        "@id": "estleg:VOS_Part13"
      },
      "estleg:coversConcept": [
        {
          "@id": "estleg:SaleContract"
        },
        {
          "@id": "estleg:DeliveryOfGoods"
        }
      ],
      "estleg:summary": "Sätestab müüja põhilise kohustuse anda asi ostjale üle kokkulepitud ajal, kohas ja viisil."
    },
    {
      "@id": "estleg:VOS_Par210",
      "@type": [
        "owl:NamedIndividual",
        "estleg:Section"
      ],
      "estleg:sectionNumber": "210",
      "rdfs:label": "§ 210. Müüja täiendavad kohustused asja vedamise puhul",
      "estleg:inPart": {
        "@id": "estleg:VOS_Part13"
      },
      "estleg:coversConcept": [
        {
          "@id": "estleg:DeliveryOfGoods"
        }
      ],
      "estleg:summary": "Reguleerib müüja kohustusi, kui üleandmine toimub vedamisega, sh veole andmine ja vajalike toimingute tegemine."
    },
    {
      "@id": "estleg:VOS_Par211",
      "@type": [
        "owl:NamedIndividual",
        "estleg:Section"
      ],
      "estleg:sectionNumber": "211",
      "rdfs:label": "§ 211. Dokumentide üleandmine",
      "estleg:inPart": {
        "@id": "estleg:VOS_Part13"
      },
      "estleg:coversConcept": [
        {
          "@id": "estleg:DeliveryOfGoods"
        }
      ],
      "estleg:summary": "Müüja peab andma ostjale üle ka asja puudutavad dokumendid, mis on vajalikud asja kasutamiseks või käsutamiseks.",
      "estleg:normativeType": [
        {
          "@id": "estleg:NormType_Obligation"
        }
      ],
      "estleg:dutyHolder": "Müüja",
      "estleg:semanticallySimilarTo": [
        {
          "@id": "estleg:Vlaigusseadus_Par_211"
        }
      ]
    },
    {
      "@id": "estleg:VOS_Par212",
      "@type": [
        "owl:NamedIndividual",
        "estleg:Section"
      ],
      "estleg:sectionNumber": "212",
      "rdfs:label": "§ 212. Müüja teatamiskohustus",
      "estleg:inPart": {
        "@id": "estleg:VOS_Part13"
      },
      "estleg:coversConcept": [
        {
          "@id": "estleg:SaleContract"
        }
      ],
      "estleg:summary": "Müüjal lasub kohustus anda ostjale lepingu täitmiseks oluline teave, eeskätt täitmist mõjutavate asjaolude kohta."
    },
    {
      "@id": "estleg:VOS_Par213",
      "@type": [
        "owl:NamedIndividual",
        "estleg:Section"
      ],
      "estleg:sectionNumber": "213",
      "rdfs:label": "§ 213. Ostuhinna tasumise kohustus",
      "estleg:inPart": {
        "@id": "estleg:VOS_Part13"
      },
      "estleg:coversConcept": [
        {
          "@id": "estleg:SaleContract"
        }
      ],
      "estleg:summary": "Sätestab ostja kohustuse maksta ostuhind ning täpsustab maksmise aluspõhimõtted."
    },
    {
      "@id": "estleg:VOS_Par214",
      "@type": [
        "owl:NamedIndividual",
        "estleg:Section"
      ],
      "estleg:sectionNumber": "214",
      "rdfs:label": "§ 214. Ostuhinna tasumise kohustus asja juhusliku hävimise ja kahjustumise riisiko üleminekul ostjale",
      "estleg:inPart": {
        "@id": "estleg:VOS_Part13"
      },
      "estleg:coversConcept": [
        {
          "@id": "estleg:SaleContract"
        },
        {
          "@id": "estleg:DeliveryOfGoods"
        }
      ],
      "estleg:summary": "Kirjeldab hinna maksmise kohustuse püsimist olukorras, kus riisiko on ostjale üle läinud.",
      "estleg:semanticallySimilarTo": [
        {
          "@id": "estleg:Vlaigusseadus_Par_214"
        }
      ]
    },
    {
      "@id": "estleg:VOS_Par215",
      "@type": [
        "owl:NamedIndividual",
        "estleg:Section"
      ],
      "estleg:sectionNumber": "215",
      "rdfs:label": "§ 215. Lepingu sõlmimise ja täitmise kulud",
      "estleg:inPart": {
        "@id": "estleg:VOS_Part13"
      },
      "estleg:coversConcept": [
        {
          "@id": "estleg:SaleContract"
        }
      ],
      "estleg:summary": "Jaotab lepingu sõlmimise ja täitmisega seotud kulud poolte vahel, kui pooled ei ole teisiti kokku leppinud."
    },
    {
      "@id": "estleg:VOS_Par216",
      "@type": [
        "owl:NamedIndividual",
        "estleg:Section"
      ],
      "estleg:sectionNumber": "216",
      "rdfs:label": "§ 216. Asjaga seotud kasu, kulud ja koormised",
      "estleg:inPart": {
        "@id": "estleg:VOS_Part13"
      },
      "estleg:coversConcept": [
        {
          "@id": "estleg:DeliveryOfGoods"
        }
      ],
      "estleg:summary": "Määrab, millisest hetkest kuuluvad asjaga seotud kasu, kulud ja koormised ostjale."
    },
    {
      "@id": "estleg:VOS_Par217",
      "@type": [
        "owl:NamedIndividual",
        "estleg:Section"
      ],
      "estleg:sectionNumber": "217",
      "rdfs:label": "§ 217. Asja vastavus lepingutingimustele",
      "estleg:inPart": {
        "@id": "estleg:VOS_Part13"
      },
      "estleg:coversConcept": [
        {
          "@id": "estleg:ConformityAndRemedies"
        }
      ],
      "estleg:summary": "Sätestab, millal asi vastab lepingutingimustele, sh kvaliteedi, omaduste ja kasutuseesmärgi osas.",
      "estleg:semanticallySimilarTo": [
        {
          "@id": "estleg:VOS_Par641"
        }
      ]
    },
    {
      "@id": "estleg:VOS_Par218",
      "@type": [
        "owl:NamedIndividual",
        "estleg:Section"
      ],
      "estleg:sectionNumber": "218",
      "rdfs:label": "§ 218. Müüja vastutus asja lepingutingimustele mittevastavuse puhul",
      "estleg:inPart": {
        "@id": "estleg:VOS_Part13"
      },
      "estleg:coversConcept": [
        {
          "@id": "estleg:ConformityAndRemedies"
        }
      ],
      "estleg:summary": "Reguleerib müüja vastutust puuduste eest ning ostja õiguskaitsevahendite kasutamise eeldusi.",
