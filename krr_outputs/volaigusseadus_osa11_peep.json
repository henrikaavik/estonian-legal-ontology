    {
      "@id": "estleg:VOS_Par271",
      "@type": [
        "owl:NamedIndividual",
        "estleg:Section"
      ],
      "estleg:sectionNumber": "271",
      "rdfs:label": "§ 271. Üürilepingu mõiste",
      "estleg:inPart": {
        "@id": "estleg:VOS_Part11"
      },
      "estleg:coversConcept": [
        {
          "@id": "estleg:ResidentialLease"
        },
        {
          "@id": "estleg:CommercialLease"
        }
      ],
      "estleg:summary": "Määratleb üürilepingu kui kasutuslepingu liigi ja põhilise vastastikuse kohustuse: kasutusõigus asja suhtes ning üürimakse."
    },
    {
      "@id": "estleg:VOS_Par272",
      "@type": [
        "owl:NamedIndividual",
        "estleg:Section"
      ],
      "estleg:sectionNumber": "272",
      "rdfs:label": "§ 272. Sätete kohaldamine elu- ja äriruumide üürimisel",
      "estleg:inPart": {
        "@id": "estleg:VOS_Part11"
      },
      "estleg:coversConcept": [
        {
          "@id": "estleg:ResidentialLease"
        },
        {
          "@id": "estleg:CommercialLease"
        }
      ],
      "estleg:summary": "Piiritab, millised üürilepingu normid kohalduvad elu- ja äriruumide üürisuhetes."
    },
    {
      "@id": "estleg:VOS_Par273",
      "@type": [
        "owl:NamedIndividual",
        "estleg:Section"
      ],
      "estleg:sectionNumber": "273",
      "rdfs:label": "§ 273. Eluruumi üürilepinguga seotud kokkuleppe tühisus",
      "estleg:inPart": {
        "@id": "estleg:VOS_Part11"
      },
      "estleg:coversConcept": [
        {
          "@id": "estleg:ResidentialLease"
        }
      ],
      "estleg:summary": "Kaitseb eluruumi üürnikku, tunnistades teatud seadusega vastuolus olevad kokkulepped tühiseks."
    },
    {
      "@id": "estleg:VOS_Par274",
      "@type": [
        "owl:NamedIndividual",
        "estleg:Section"
      ],
      "estleg:sectionNumber": "274",
      "rdfs:label": "§ 274. Eluruumi üürilepingu vormi mõju lepingu tähtajale",
      "estleg:inPart": {
        "@id": "estleg:VOS_Part11"
      },
      "estleg:coversConcept": [
        {
          "@id": "estleg:ResidentialLease"
        }
      ],
      "estleg:summary": "Reguleerib, kuidas lepingu vorm mõjutab eluruumi üürilepingu tähtajalisust."
    },
    {
      "@id": "estleg:VOS_Par275",
      "@type": [
        "owl:NamedIndividual",
        "estleg:Section"
      ],
      "estleg:sectionNumber": "275",
      "rdfs:label": "§ 275. Sätete kohustuslikkus",
      "estleg:inPart": {
        "@id": "estleg:VOS_Part11"
      },
      "estleg:coversConcept": [
        {
          "@id": "estleg:ResidentialLease"
        }
      ],
      "estleg:summary": "Sätestab eluruumi üürilepingu kaitsenormide imperatiivsuse."
    },
    {
      "@id": "estleg:VOS_Par276_308",
      "@type": [
        "owl:NamedIndividual",
        "estleg:Section"
      ],
      "estleg:sectionNumber": "276-308",
      "rdfs:label": "§§ 276–308. Poolte õigused, kohustused, üür, kõrvalkulud ja tagatised",
      "estleg:inPart": {
        "@id": "estleg:VOS_Part11"
      },
      "estleg:coversConcept": [
        {
          "@id": "estleg:ResidentialLease"
        },
        {
          "@id": "estleg:CommercialLease"
        }
      ],
      "estleg:summary": "Koondab üürisuhte täitmist puudutavad normid (asja seisund, kasutamine, kõrvalkulud, üüri muutmine, pandiõigus, tagatisraha), sh eluruumi üürniku kaitse erisused."
    },
    {
      "@id": "estleg:VOS_Par309",
      "@type": [
        "owl:NamedIndividual",
        "estleg:Section"
      ],
      "estleg:sectionNumber": "309",
      "rdfs:label": "§ 309. Üürilepingu kestus",
      "estleg:inPart": {
        "@id": "estleg:VOS_Part11"
      },
      "estleg:coversConcept": [
        {
          "@id": "estleg:LeaseTermination"
        }
      ],
      "estleg:summary": "Määrab üürilepingu kestuse üldraamistiku."
    },
    {
      "@id": "estleg:VOS_Par310",
      "@type": [
        "owl:NamedIndividual",
        "estleg:Section"
      ],
      "estleg:sectionNumber": "310",
      "rdfs:label": "§ 310. Tähtajalise üürilepingu pikenemine",
      "estleg:inPart": {
        "@id": "estleg:VOS_Part11"
      },
      "estleg:coversConcept": [
        {
          "@id": "estleg:LeaseTermination"
        }
      ],
      "estleg:summary": "Reguleerib tähtajalise lepingu pikenemise eeldusi."
    },
    {
      "@id": "estleg:VOS_Par311",
      "@type": [
        "owl:NamedIndividual",
        "estleg:Section"
      ],
      "estleg:sectionNumber": "311",
      "rdfs:label": "§ 311. Tähtajatu üürilepingu korraline ülesütlemine",
      "estleg:inPart": {
        "@id": "estleg:VOS_Part11"
      },
      "estleg:coversConcept": [
        {
          "@id": "estleg:LeaseTermination"
        }
      ],
      "estleg:summary": "Sätestab tähtajatu üürilepingu korralise ülesütlemise aluse.",
      "estleg:semanticallySimilarTo": [
        {
          "@id": "estleg:VOS_Par686"
        }
      ]
    },
    {
      "@id": "estleg:VOS_Par312",
      "@type": [
        "owl:NamedIndividual",
        "estleg:Section"
      ],
      "estleg:sectionNumber": "312",
      "rdfs:label": "§ 312. Tähtajatu üürilepingu korralise ülesütlemise tähtajad",
      "estleg:inPart": {
        "@id": "estleg:VOS_Part11"
      },
      "estleg:coversConcept": [
        {
          "@id": "estleg:LeaseTermination"
        }
      ],
      "estleg:summary": "Määratleb korralise ülesütlemise etteteatamistähtajad."
    },
    {
      "@id": "estleg:VOS_Par313_333",
      "@type": [
        "owl:NamedIndividual",
        "estleg:Section"
      ],
      "estleg:sectionNumber": "313-333",
      "rdfs:label": "§§ 313–333. Erakorraline ülesütlemine ja eluruumi üürniku kaitse lõpetamisel",
      "estleg:inPart": {
        "@id": "estleg:VOS_Part11"
      },
      "estleg:coversConcept": [
        {
          "@id": "estleg:LeaseTermination"
        },
        {
          "@id": "estleg:ResidentialLease"
        },
        {
          "@id": "estleg:CommercialLease"
        }
      ],
      "estleg:summary": "Koondab erakorralise ülesütlemise alused ning eluruumi üürilepingu ülesütlemise vaidlustamise, pikendamise ja hea usu kaitse mehhanismid."
    },
    {
      "@id": "estleg:VOS_Par334_338",
      "@type": [
        "owl:NamedIndividual",
        "estleg:Section"
      ],
      "estleg:sectionNumber": "334-338",
      "rdfs:label": "§§ 334–338. Üüritud asja tagastamine ja lõppnõuded",
      "estleg:inPart": {
        "@id": "estleg:VOS_Part11"
      },
      "estleg:coversConcept": [
        {
          "@id": "estleg:LeaseTermination"
        }
      ],
      "estleg:summary": "Reguleerib lepingu lõppemise järel asja tagastamist, viivitusnõudeid, ülevaatust, ettemaksete tagastamist ja nõuete aegumist."
    }
