@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix estleg: <https://data.riik.ee/ontology/estleg#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# Shape for LegalProvision instances.
#
# The generators in scripts/ emit LegalProvision instances using Estonian-
# native vocabulary that mirrors how Estonian legal documents themselves
# refer to sections: `estleg:paragrahv` is the Estonian word for the
# section reference ("AdvS § 1", "TsÜS § 40 lg 1-2") and `estleg:summary`
# holds the LLM-generated topic-aware summary of what the provision does.
# Full legal text is optional via `estleg:legalText` (populated for a
# small subset — most provisions only need the summary for the topic map).
#
# This shape uses `sh:targetSubjectsOf estleg:paragrahv` instead of
# `sh:targetClass estleg:LegalProvision`. That is deliberate: the
# combined_ontology.jsonld graph contains ~50k per-law-typed instances
# like `estleg:LegalProvision_karistusseadustik` whose classes are NOT
# declared as `rdfs:subClassOf estleg:LegalProvision`, so targeting the
# base class would miss them entirely. Targeting "every node that has
# `estleg:paragrahv`" catches all provision-like nodes regardless of
# whether a new per-law type is added later, and is self-consistent
# with how consumers actually query the data.
estleg:LegalProvisionShape
    a sh:NodeShape ;
    sh:targetSubjectsOf estleg:paragrahv ;
    sh:property [
        sh:path estleg:paragrahv ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:name "paragrahv" ;
        sh:description "Every LegalProvision must have a section reference (e.g., 'AdvS § 1', 'TsÜS § 40 lg 1-2')" ;
    ] ;
    sh:property [
        sh:path estleg:summary ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:name "summary" ;
        sh:description "Every LegalProvision must have a topic-aware summary. Full legal text is optional via estleg:legalText." ;
    ] ;
    sh:property [
        sh:path estleg:legalText ;
        sh:datatype xsd:string ;
        sh:name "legalText" ;
        sh:description "Optional full legal text. Populated for provisions where the full paragraph was sourced verbatim; most provisions only carry the summary." ;
    ] ;
    sh:property [
        sh:path estleg:sourceAct ;
        sh:datatype xsd:string ;
        sh:name "sourceAct" ;
        sh:description "Human-readable name of the law this provision belongs to" ;
    ] ;
    sh:property [
        sh:path estleg:topicCluster ;
        sh:nodeKind sh:IRI ;
        sh:name "topicCluster" ;
        sh:description "Topic cluster reference must be an IRI" ;
    ] ;
    sh:property [
        sh:path estleg:references ;
        sh:nodeKind sh:IRI ;
        sh:name "references" ;
        sh:description "Cross-references must point to valid IRIs" ;
    ] .

# Shape for TopicCluster instances.
#
# The generators use `rdfs:label` as the display label for topic clusters
# (e.g., "§1–9 ÜLDSÄTTED"). The earlier shape additionally required
# `skos:prefLabel`, but no generator ever emits one, and the explorer
# reads cluster labels from `rdfs:label` anyway. If we ever want to layer
# SKOS labels on top, the shape can be tightened to require them again.
estleg:TopicClusterShape
    a sh:NodeShape ;
    sh:targetClass estleg:TopicCluster ;
    sh:property [
        sh:path rdfs:label ;
        sh:minCount 1 ;
        sh:name "label" ;
        sh:description "Every TopicCluster must have an rdfs:label used as its display name" ;
    ] ;
    sh:property [
        sh:path skos:prefLabel ;
        sh:name "prefLabel" ;
        sh:description "Optional SKOS preferred label (currently unused by the generators)" ;
    ] .

# Shape for LegalConcept instances
estleg:LegalConceptShape
    a sh:NodeShape ;
    sh:targetClass estleg:LegalConcept ;
    sh:property [
        sh:path rdfs:label ;
        sh:minCount 1 ;
        sh:name "label" ;
        sh:description "Every LegalConcept must have a label" ;
    ] .

# Shape enforcing @type is always a list (validated programmatically)
# Note: JSON-LD @type arrays cannot be validated via SHACL directly;
# use scripts/validate_all.py for this check.

# Shape for Section instances (from KarS generator)
estleg:SectionShape
    a sh:NodeShape ;
    sh:targetClass estleg:Section ;
    sh:property [
        sh:path estleg:sectionNumber ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:name "sectionNumber" ;
        sh:description "Section number must be a string" ;
    ] ;
    sh:property [
        sh:path rdfs:label ;
        sh:minCount 1 ;
        sh:name "label" ;
    ] .

# Shape for DraftLegislation instances
estleg:DraftLegislationShape
    a sh:NodeShape ;
    sh:targetClass estleg:DraftLegislation ;
    sh:property [
        sh:path rdfs:label ;
        sh:minCount 1 ;
        sh:name "label" ;
        sh:description "Every DraftLegislation must have a label (draft title)" ;
    ] ;
    sh:property [
        sh:path estleg:legislativePhase ;
        sh:minCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:name "legislativePhase" ;
        sh:description "Every draft must have a legislative phase" ;
    ] ;
    sh:property [
        sh:path estleg:draftType ;
        sh:minCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:name "draftType" ;
        sh:description "Every draft must have a type classification" ;
    ] ;
    sh:property [
        sh:path estleg:eisNumber ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:name "eisNumber" ;
        sh:description "EIS reference number (e.g., JDM/26-0268)" ;
    ] ;
    sh:property [
        sh:path estleg:eisLink ;
        sh:maxCount 1 ;
        sh:datatype xsd:anyURI ;
        sh:name "eisLink" ;
        sh:description "Direct link to the draft in EIS" ;
    ] ;
    sh:property [
        sh:path estleg:initiator ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:name "initiator" ;
        sh:description "Ministry or institution that initiated the draft" ;
    ] ;
    sh:property [
        sh:path estleg:publicationDate ;
        sh:maxCount 1 ;
        sh:datatype xsd:date ;
        sh:name "publicationDate" ;
        sh:description "Date when the draft was published in EIS" ;
    ] ;
    sh:property [
        sh:path estleg:amendsLaw ;
        sh:nodeKind sh:IRI ;
        sh:name "amendsLaw" ;
        sh:description "Reference to existing law being amended" ;
    ] .

# Shape for LegislativePhase instances
estleg:LegislativePhaseShape
    a sh:NodeShape ;
    sh:targetClass estleg:LegislativePhase ;
    sh:property [
        sh:path rdfs:label ;
        sh:minCount 1 ;
        sh:name "label" ;
        sh:description "Every LegislativePhase must have a label" ;
    ] .

# Shape for DraftType instances
estleg:DraftTypeShape
    a sh:NodeShape ;
    sh:targetClass estleg:DraftType ;
    sh:property [
        sh:path rdfs:label ;
        sh:minCount 1 ;
        sh:name "label" ;
        sh:description "Every DraftType must have a label" ;
    ] .

# Shape for CourtDecision instances
estleg:CourtDecisionShape
    a sh:NodeShape ;
    sh:targetClass estleg:CourtDecision ;
    sh:property [
        sh:path rdfs:label ;
        sh:minCount 1 ;
        sh:name "label" ;
        sh:description "Every CourtDecision must have a label" ;
    ] ;
    sh:property [
        sh:path estleg:caseNumber ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:name "caseNumber" ;
        sh:description "Court case number (e.g., 3-21-2176/52)" ;
    ] ;
    sh:property [
        sh:path estleg:caseType ;
        sh:minCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:name "caseType" ;
        sh:description "Type of court case (criminal, civil, administrative, etc.)" ;
    ] ;
    sh:property [
        sh:path estleg:decisionDate ;
        sh:maxCount 1 ;
        sh:datatype xsd:date ;
        sh:name "decisionDate" ;
        sh:description "Date of the court decision" ;
    ] ;
    sh:property [
        sh:path estleg:decisionLink ;
        sh:maxCount 1 ;
        sh:datatype xsd:anyURI ;
        sh:name "decisionLink" ;
        sh:description "Link to the full decision on riigikohus.ee" ;
    ] .

# Shape for CaseType instances
estleg:CaseTypeShape
    a sh:NodeShape ;
    sh:targetClass estleg:CaseType ;
    sh:property [
        sh:path rdfs:label ;
        sh:minCount 1 ;
        sh:name "label" ;
    ] .

