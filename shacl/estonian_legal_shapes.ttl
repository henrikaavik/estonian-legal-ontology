        sh:datatype xsd:string ;
        sh:name "caseNumber" ;
        sh:description "Court case number (e.g., 3-21-2176/52)" ;
    ] ;
    sh:property [
        sh:path estleg:caseType ;
        sh:minCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:name "caseType" ;
        sh:description "Type of court case (criminal, civil, administrative, etc.)" ;
    ] ;
    sh:property [
        sh:path estleg:decisionDate ;
        sh:maxCount 1 ;
        sh:datatype xsd:date ;
        sh:name "decisionDate" ;
        sh:description "Date of the court decision" ;
    ] ;
    sh:property [
        sh:path estleg:decisionLink ;
        sh:maxCount 1 ;
        sh:datatype xsd:anyURI ;
        sh:name "decisionLink" ;
        sh:description "Link to the full decision on riigikohus.ee" ;
    ] ;
    sh:property [
        sh:path estleg:interpretsLaw ;
