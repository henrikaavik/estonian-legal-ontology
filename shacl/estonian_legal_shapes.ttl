        sh:description "Every Institution must have a label" ;
    ] ;
    sh:property [
        sh:path estleg:competenceType ;
        sh:datatype xsd:string ;
        sh:name "competenceType" ;
        sh:description "Type of competence: supervision, licensing, enforcement, regulation" ;
    ] .

