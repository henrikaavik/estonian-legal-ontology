# ============================================================
# NEW INTEGRATION SHAPES (Issues #29-#43)
# ============================================================

# Shape for Sanction instances
estleg:SanctionShape
    a sh:NodeShape ;
    sh:targetClass estleg:Sanction ;
    sh:property [
        sh:path rdfs:label ;
        sh:minCount 1 ;
        sh:name "label" ;
        sh:description "Every Sanction must have a label" ;
    ] ;
    sh:property [
        sh:path estleg:sanctionType ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:name "sanctionType" ;
        sh:description "Type of sanction: imprisonment, fine, pecuniary_punishment, arrest" ;
    ] ;
    sh:property [
        sh:path estleg:maxPenalty ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:name "maxPenalty" ;
        sh:description "Maximum penalty (e.g., '5 years', '300 fine units')" ;
    ] ;
    sh:property [
        sh:path estleg:applicableProvision ;
        sh:minCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:name "applicableProvision" ;
        sh:description "Provision that defines this sanction" ;
    ] ;
    sh:property [
        sh:path estleg:minPenalty ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:name "minPenalty" ;
        sh:description "Minimum penalty if specified" ;
    ] .

