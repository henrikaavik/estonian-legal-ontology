        sh:name "interpretsLaw" ;
        sh:description "Specific legal provisions interpreted by this decision" ;
    ] ;
    sh:property [
        sh:path estleg:referencedLaw ;
        sh:datatype xsd:string ;
        sh:name "referencedLaw" ;
        sh:description "Name of the law referenced in this court decision" ;
    ] ;
    sh:property [
        sh:path estleg:rikObjectId ;
        sh:datatype xsd:string ;
        sh:name "rikObjectId" ;
        sh:description "Riigikohus object identifier" ;
    ] ;
    sh:property [
        sh:path estleg:decisionType ;
        sh:nodeKind sh:IRI ;
        sh:name "decisionType" ;
        sh:description "Type of court decision (e.g., judgment, ruling, order)" ;
    ] .

