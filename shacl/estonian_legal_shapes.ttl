    a sh:NodeShape ;
    sh:targetClass estleg:EULegislation ;
    sh:property [
        sh:path rdfs:label ;
        sh:minCount 1 ;
        sh:name "label" ;
        sh:description "Every EULegislation must have a label (Estonian title)" ;
    ] ;
    sh:property [
        sh:path estleg:celexNumber ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:name "celexNumber" ;
        sh:description "CELEX identifier (e.g., 32016R0679)" ;
    ] ;
    sh:property [
        sh:path estleg:euDocumentType ;
        sh:minCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:name "euDocumentType" ;
        sh:description "Type of EU legal act (Regulation, Directive, Decision)" ;
    ] ;
    sh:property [
        sh:path estleg:eurLexLink ;
        sh:maxCount 1 ;
        sh:datatype xsd:anyURI ;
        sh:name "eurLexLink" ;
        sh:description "Link to the act in EUR-Lex" ;
    ] ;
    sh:property [
        sh:path estleg:eliIdentifier ;
        sh:maxCount 1 ;
        sh:datatype xsd:anyURI ;
        sh:name "eliIdentifier" ;
        sh:description "European Legislation Identifier (ELI) URI" ;
    ] ;
    sh:property [
        sh:path estleg:documentDate ;
        sh:maxCount 1 ;
        sh:datatype xsd:date ;
        sh:name "documentDate" ;
        sh:description "Date of the legal act" ;
    ] ;
    sh:property [
        sh:path estleg:inForce ;
        sh:maxCount 1 ;
        sh:datatype xsd:boolean ;
        sh:name "inForce" ;
        sh:description "Whether the act is currently in force" ;
    ] ;
    sh:property [
        sh:path estleg:euInstitution ;
        sh:nodeKind sh:IRI ;
        sh:name "euInstitution" ;
        sh:description "EU institution that authored the act" ;
    ] .

